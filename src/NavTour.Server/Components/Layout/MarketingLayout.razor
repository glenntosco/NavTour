<script type="application/ld+json">
{
    "@@context": "https://schema.org",
    "@@type": "SoftwareApplication",
    "name": "NavTour",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Web",
    "description": "AI-powered interactive product demo platform with Chrome extension capture, AI tour generation, ElevenLabs voiceover, and lead capture forms.",
    "offers": {
