@if (Featured)
{
    <div class="mkt-testimonial-featured">
        <blockquote>"@Quote"</blockquote>
        <div class="mkt-testimonial-attribution" style="justify-content:center">
            <div>
                <div class="mkt-testimonial-name">@Name</div>
                <div class="mkt-testimonial-role">@Title, @Company</div>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Metric))
        {
            <div class="mkt-testimonial-metric" style="border-top:none;text-align:center">
                <div class="mkt-testimonial-metric-value">@Metric</div>
                <div class="mkt-testimonial-metric-label">@MetricLabel</div>
            </div>
        }
    </div>
}
else
{
    <div class="mkt-testimonial">
        <blockquote>"@Quote"</blockquote>
        <div class="mkt-testimonial-attribution">
            <div>
                <div class="mkt-testimonial-name">@Name</div>
                <div class="mkt-testimonial-role">@Title, @Company</div>
            </div>
        </div>
        @if (!string.IsNullOrEmpty(Metric))
        {
            <div class="mkt-testimonial-metric">
                <div class="mkt-testimonial-metric-value">@Metric</div>
                <div class="mkt-testimonial-metric-label">@MetricLabel</div>
            </div>
        }
    </div>
}

@code {
    [Parameter] public string Quote { get; set; } = "";
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Company { get; set; } = "";
    [Parameter] public string Metric { get; set; } = "";
    [Parameter] public string MetricLabel { get; set; } = "";
    [Parameter] public bool Featured { get; set; }
}
