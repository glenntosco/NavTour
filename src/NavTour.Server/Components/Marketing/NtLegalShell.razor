@* Shared legal-page shell: sticky TOC + prose content *@
<div class="nt-legal-wrap">
    <nav class="nt-legal-toc" aria-label="On this page">
        <h5>On this page</h5>
        <ul>
            @foreach (var (id, label) in Sections)
            {
                <li><a href="#@id">@label</a></li>
            }
        </ul>
    </nav>
    <div>
        <div class="nt-legal-meta">@Meta</div>
        <div class="nt-legal-prose">
            @ChildContent
        </div>
    </div>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Meta { get; set; } = "";
    [Parameter] public List<(string id, string label)> Sections { get; set; } = new();
}
