@if (Dark)
{
    <section class="mkt-section mkt-cta-section" style="background:var(--neutral-950);color:white">
        <div class="mkt-container text-center">
            <h2 style="color:white">@Title</h2>
            <p style="color:rgba(255,255,255,0.8)">@Subtitle</p>
            <div class="mkt-hero-actions" style="justify-content:center;margin-top:var(--space-8)">
                <a href="@CtaUrl" class="mkt-btn mkt-btn-lg" style="background:var(--nt-accent);color:white;border-color:var(--nt-accent)">@CtaText</a>
                @if (!string.IsNullOrEmpty(SecondaryCtaText))
                {
                    <a href="@SecondaryCtaUrl" class="mkt-btn mkt-btn-lg" style="background:transparent;color:white;border-color:rgba(255,255,255,0.3)">@SecondaryCtaText</a>
                }
            </div>
        </div>
    </section>
}
else
{
    <section class="mkt-section mkt-cta-section">
        <div class="mkt-container text-center">
            <h2>@Title</h2>
            <p>@Subtitle</p>
            <div class="mkt-hero-actions" style="justify-content:center;margin-top:var(--space-8)">
                <a href="@CtaUrl" class="mkt-btn mkt-btn-primary mkt-btn-lg">@CtaText</a>
                @if (!string.IsNullOrEmpty(SecondaryCtaText))
                {
                    <a href="@SecondaryCtaUrl" class="mkt-btn mkt-btn-secondary mkt-btn-lg">@SecondaryCtaText</a>
                }
            </div>
        </div>
    </section>
}

@code {
    [Parameter] public string Title { get; set; } = "Ready to transform your demos?";
    [Parameter] public string Subtitle { get; set; } = "Start building interactive demos in minutes. No credit card required.";
    [Parameter] public string CtaText { get; set; } = "Start Free";
    [Parameter] public string CtaUrl { get; set; } = "/register";
    [Parameter] public bool Dark { get; set; }
    [Parameter] public string? SecondaryCtaText { get; set; }
    [Parameter] public string SecondaryCtaUrl { get; set; } = "/contact";
}
