<div class="mkt-card mkt-feature-card">
    <div class="mkt-feature-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            @((MarkupString)GetIconPath())
        </svg>
    </div>
    <h3>@Title</h3>
    <p>@Description</p>
</div>

@code {
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string Description { get; set; } = "";

    private string GetIconPath() => Icon switch
    {
        "capture" or "📸" => "<rect x='3' y='3' width='18' height='18' rx='2' ry='2'/><circle cx='12' cy='13' r='4'/><path d='M12 3v2'/>",
        "annotate" or "✏️" => "<path d='M12 20h9'/><path d='M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z'/>",
        "personalize" or "🎯" => "<circle cx='12' cy='12' r='10'/><circle cx='12' cy='12' r='6'/><circle cx='12' cy='12' r='2'/>",
        "analyze" or "📈" => "<line x1='18' y1='20' x2='18' y2='10'/><line x1='12' y1='20' x2='12' y2='4'/><line x1='6' y1='20' x2='6' y2='14'/>",
        "extension" or "🧩" => "<rect x='3' y='3' width='18' height='18' rx='2' ry='2'/><path d='M9 3v18'/><path d='M3 9h18'/>",
        "builder" or "🔧" => "<rect x='3' y='3' width='7' height='7'/><rect x='14' y='3' width='7' height='7'/><rect x='3' y='14' width='7' height='7'/><rect x='14' y='14' width='7' height='7'/>",
        "lead" or "📋" => "<path d='M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2'/><circle cx='9' cy='7' r='4'/><line x1='19' y1='8' x2='19' y2='14'/><line x1='22' y1='11' x2='16' y2='11'/>",
        "api" or "🔌" => "<polyline points='16 18 22 12 16 6'/><polyline points='8 6 2 12 8 18'/>",
        "language" or "🌐" => "<circle cx='12' cy='12' r='10'/><line x1='2' y1='12' x2='22' y2='12'/><path d='M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z'/>",
        _ => "<circle cx='12' cy='12' r='10'/><path d='M12 6v6l4 2'/>"
    };
}
