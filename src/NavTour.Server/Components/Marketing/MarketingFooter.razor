@inject IStringLocalizer<NavTour.Server.SharedResources> L

<footer class="mkt-footer">
    <div class="mkt-container">
        <div class="mkt-footer-grid" style="grid-template-columns:1.4fr 1fr 1fr 1fr">
            <div class="mkt-footer-col">
                <div style="margin-bottom:var(--space-4)">
                    <a href="/" style="font-size:var(--text-xl);font-weight:var(--weight-bold);color:var(--text-primary);text-decoration:none">NavTour</a>
                    <p style="font-size:var(--text-sm);color:var(--text-tertiary);margin-top:var(--space-2)">@L["footer_tagline"]</p>
                </div>
                <div style="display:flex;gap:var(--space-4);margin-top:var(--space-4)">
                    <a href="#" aria-label="Twitter" style="color:var(--neutral-400)">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </a>
                    <a href="#" aria-label="LinkedIn" style="color:var(--neutral-400)">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </a>
                    <a href="#" aria-label="GitHub" style="color:var(--neutral-400)">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
                    </a>
                </div>
            </div>
            <div class="mkt-footer-col">
                <h4>@L["footer_product"]</h4>
                <a href="/product">@L["footer_features"]</a>
                <a href="/product/ai">@L["footer_ai_platform"]</a>
                <a href="/integrations">@L["footer_integrations"]</a>
                <a href="#">@L["footer_changelog"]</a>
                <a href="/docs">@L["footer_api_docs"]</a>
            </div>
            <div class="mkt-footer-col">
                <h4>@L["footer_resources"]</h4>
                <a href="/blog">@L["footer_blog"]</a>
                <a href="#">@L["footer_help_center"]</a>
                <a href="#">@L["footer_templates"]</a>
                <a href="#">@L["footer_webinars"]</a>
            </div>
            <div class="mkt-footer-col">
                <h4>@L["footer_company"]</h4>
                <a href="/about">@L["footer_about"]</a>
                <a href="#">@L["footer_careers"]</a>
                <a href="/contact">@L["footer_contact"]</a>
                <a href="/support">@L["footer_support"]</a>
                <a href="/security">@L["footer_security"]</a>
                <a href="#">@L["footer_legal"]</a>
            </div>
        </div>
        <div class="mkt-footer-bottom">
            <p>@L["footer_copyright"] &middot; <a href="#">@L["footer_privacy"]</a> &middot; <a href="#">@L["footer_terms"]</a> &middot; <a href="#">@L["footer_status"]</a></p>
        </div>
    </div>
</footer>
