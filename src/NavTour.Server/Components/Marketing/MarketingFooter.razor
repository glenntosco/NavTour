            <div class="parent">Part of the <b>P4 Software Cloud Suite</b> &middot; Grupo Barrdega</div>
        </div>
        <div>
            <h5>@L["footer_product"]</h5>
            <ul>
                <li><a href="/product">Demo Editor</a></li>
                <li><a href="/product">Demo Hubs</a></li>
                <li><a href="/product">Showcases</a></li>
                <li><a href="/product">Analytics</a></li>
                <li><a href="https://chromewebstore.google.com/detail/opgaokkionehglmipncajghhlmohanoi" target="_blank" rel="noopener noreferrer">Chrome Extension</a></li>
                <li><a href="/product/ai">AI Copilot <span style="color:var(--nt-orange);font-size:10px;margin-left:4px;letter-spacing:0.1em">&#9650; ANTHROPIC</span></a></li>
            </ul>
        </div>
        <div>
