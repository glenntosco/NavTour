@inject IStringLocalizer<NavTour.Server.SharedResources> L

<footer class="mkt-footer">
    <div class="mkt-container">
        <div class="mkt-footer-grid" style="grid-template-columns:1.4fr 1fr 1fr 1fr">
            <div class="mkt-footer-col">
                <div style="margin-bottom:var(--space-4)">
                    <a href="/" style="font-size:var(--text-xl);font-weight:var(--weight-bold);color:var(--text-primary);text-decoration:none">NavTour</a>
                    <p style="font-size:var(--text-sm);color:var(--text-tertiary);margin-top:var(--space-2)">@L["footer_tagline"]</p>
                </div>
                <div class="mkt-contact-detail-stack" style="margin-top:var(--space-5)">
                    <div>
                        <div class="mkt-stage-card-label">Email</div>
                        <a href="mailto:support@navtour.cloud">support@navtour.cloud</a>
                    </div>
                    <div>
                        <div class="mkt-stage-card-label">Phone</div>
                        <a href="tel:+5072096996">+507-209-6996</a>
                    </div>
                </div>
            </div>
            <div class="mkt-footer-col">
                <h4>@L["footer_product"]</h4>
                <a href="/product">@L["footer_features"]</a>
                <a href="/product/ai">@L["footer_ai_platform"]</a>
                <a href="/integrations">@L["footer_integrations"]</a>
                <a href="/pricing">Pricing</a>
                <a href="https://docs.navtour.cloud" target="_blank" rel="noopener noreferrer">@L["footer_api_docs"]</a>
            </div>
            <div class="mkt-footer-col">
                <h4>@L["footer_resources"]</h4>
                <a href="/blog">@L["footer_blog"]</a>
                <a href="/support">@L["footer_help_center"]</a>
                <a href="https://docs.navtour.cloud" target="_blank" rel="noopener noreferrer">@L["footer_api_docs"]</a>
                <a href="/contact">@L["footer_contact"]</a>
            </div>
            <div class="mkt-footer-col">
                <h4>@L["footer_company"]</h4>
                <a href="/about">@L["footer_about"]</a>
                <a href="/contact">@L["footer_contact"]</a>
                <a href="/support">@L["footer_support"]</a>
                <a href="/security">@L["footer_security"]</a>
                <a href="/legal">@L["footer_legal"]</a>
            </div>
        </div>
        <div class="mkt-footer-bottom">
            <p>@L["footer_copyright"] &middot; <a href="/privacy">@L["footer_privacy"]</a> &middot; <a href="/terms">@L["footer_terms"]</a> &middot; <a href="/cookies">Cookies</a> &middot; <a href="/legal">@L["footer_legal"]</a></p>
        </div>
    </div>
</footer>
