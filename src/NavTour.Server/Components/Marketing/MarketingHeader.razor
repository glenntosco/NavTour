@inject IStringLocalizer<NavTour.Server.SharedResources> L

<header class="mkt-header">
    <div class="mkt-container mkt-header-inner">
        <a href="/" class="mkt-logo" style="overflow:hidden;height:36px">
            <img src="favicon.svg" alt="NavTour" style="height:48px;width:auto;margin-top:-2px" />
        </a>

        <nav class="mkt-nav" id="mkt-nav">
            <div class="mkt-nav-group">
                <button class="mkt-nav-group-label" type="button">
                    @L["nav_product"]
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="mkt-nav-dropdown">
                    <a href="/product">@L["nav_features"]</a>
                    <a href="/product/ai">@L["nav_ai_platform"] <span style="background:var(--nt-accent-light);color:var(--nt-accent-dark);font-size:0.65rem;font-weight:700;padding:2px 6px;border-radius:3px;margin-left:6px">NEW</span></a>
                    <a href="/integrations">@L["nav_integrations"]</a>
                    <a href="/security">@L["nav_security"]</a>
                </div>
            </div>
            <div class="mkt-nav-group">
                <button class="mkt-nav-group-label" type="button">
                    @L["nav_solutions"]
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                </button>
                <div class="mkt-nav-dropdown">
                    <a href="/solutions/marketing">@L["nav_marketing"]</a>
                    <a href="/solutions/sales">@L["nav_sales"]</a>
                    <a href="/solutions/presales">@L["nav_presales"]</a>
                </div>
            </div>
            <a href="/customers">@L["nav_customers"]</a>
            <a href="/pricing">@L["nav_pricing"]</a>
            <a href="/login" class="mkt-nav-mobile-only">@L["nav_sign_in"]</a>
            <a href="/register" class="mkt-nav-mobile-only mkt-btn mkt-btn-primary" style="text-align:center">@L["nav_start_free"]</a>
        </nav>

        <div class="mkt-header-actions">
            <div class="mkt-lang-toggle">
                <a href="?culture=en&ui-culture=en" class="@(culture == "en" ? "active" : "")">EN</a>
                <span>|</span>
                <a href="?culture=es&ui-culture=es" class="@(culture == "es" ? "active" : "")">ES</a>
            </div>
            <a href="/login" class="mkt-btn mkt-btn-secondary">@L["nav_sign_in"]</a>
            <a href="/register" class="mkt-btn mkt-btn-primary">@L["nav_start_free"]</a>
        </div>

        <button class="mkt-hamburger" id="mkt-hamburger" aria-label="Toggle menu" aria-expanded="false" onclick="var n=document.getElementById('mkt-nav');n.classList.toggle('open');this.setAttribute('aria-expanded',n.classList.contains('open'))">
            <span></span><span></span><span></span>
        </button>
    </div>
</header>

@code {
    private string culture = "en";

    protected override void OnInitialized()
    {
        culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    }
}
