@inject IStringLocalizer<NavTour.Server.SharedResources> L

<div class="nt-nav-wrap">
    <div class="nt-nav-bar">
        <a href="/" class="nt-logo">
            <span class="brace">{</span>navt<span class="accent">o</span>ur<span class="brace">}</span>
        </a>

        <div class="nt-nav-links">
            <a href="/product">@L["nav_product"] <span class="caret">&#9662;</span></a>
            <a href="/solutions">@L["nav_solutions"]</a>
            <a href="/pricing">@L["nav_pricing"]</a>
            <a href="https://docs.navtour.cloud/" target="_blank" rel="noopener noreferrer">Docs</a>
        </div>

        <div class="nt-nav-cta">
            <span class="nt-lang">
                <a href="?culture=en&ui-culture=en" class="@(culture == "en" ? "active" : "")">EN</a>
                <span class="sep">&middot;</span>
                <a href="?culture=es&ui-culture=es" class="@(culture == "es" ? "active" : "")">ES</a>
            </span>
            <a href="/login" class="btn btn-ghost">@L["nav_sign_in"]</a>
            <a href="/register" class="btn btn-ink">@L["nav_start_free"]</a>
        </div>
    </div>
</div>

@code {
    private string culture = "en";

    protected override void OnInitialized()
    {
        culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    }
}
