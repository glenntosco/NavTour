@page "/about"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.Resources.SharedResources> L

<PageTitle>@L["about_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["about_meta_desc"]" />
</HeadContent>

<HeroSection Eyebrow="@L["about_eyebrow"]"
             Title="@L["about_title"]"
             Subtitle="@L["about_subtitle"]"
             PrimaryCtaUrl="/register"
             PrimaryCtaText="@L["about_hero_cta"]"
             SecondaryCtaUrl="/contact"
             SecondaryCtaText="@L["about_hero_cta_secondary"]" />

@* Mission *@
<section class="mkt-section">
    <div class="mkt-container" style="max-width:680px">
        <div class="reveal">
            <h2>@L["about_mission_heading"]</h2>
            <p style="margin-top:var(--space-4)">@L["about_mission_p1"]</p>
            <p style="margin-top:var(--space-3)">@L["about_mission_p2"]</p>
        </div>
    </div>
</section>

@* Values *@
<section class="mkt-section-alt">
    <div class="mkt-container">
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <div class="mkt-card">
                <h3>@L["about_value1_title"]</h3>
                <p>@L["about_value1_desc"]</p>
            </div>
            <div class="mkt-card">
                <h3>@L["about_value2_title"]</h3>
                <p>@L["about_value2_desc"]</p>
            </div>
            <div class="mkt-card">
                <h3>@L["about_value3_title"]</h3>
                <p>@L["about_value3_desc"]</p>
            </div>
        </div>
    </div>
</section>

@* By the Numbers *@
<section class="mkt-section">
    <div class="mkt-container text-center reveal">
        <div class="mkt-grid mkt-grid-4">
            <MetricCard Value="@L["about_metric1_value"]" Label="@L["about_metric1_label"]" />
            <MetricCard Value="@L["about_metric2_value"]" Label="@L["about_metric2_label"]" />
            <MetricCard Value="@L["about_metric3_value"]" Label="@L["about_metric3_label"]" />
            <MetricCard Value="@L["about_metric4_value"]" Label="@L["about_metric4_label"]" />
        </div>
    </div>
</section>

@* Team *@
<section class="mkt-section-alt">
    <div class="mkt-container" style="max-width:680px">
        <div class="reveal">
            <h2>@L["about_team_heading"]</h2>
            <p style="margin-top:var(--space-4)">@L["about_team_desc"]</p>
        </div>
    </div>
</section>

<CtaSection Title="@L["about_cta_title"]"
            Subtitle="@L["about_cta_subtitle"]"
            CtaText="@L["about_cta_button"]"
            CtaUrl="#" />
