@page "/features"
@layout MarketingLayout

<PageTitle>Features — NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="Capture, annotate, personalize, and analyze interactive product demos. Chrome extension, drag-and-drop builder, full API." />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-16)">
    <div class="mkt-container" style="max-width:680px">
        <h1 class="text-center">Everything you need to build interactive demos</h1>
        <p class="text-center" style="margin-top:var(--space-5)">From capture to analytics, NavTour gives your team the tools to create demos that convert — without writing a line of code.</p>
    </div>
</section>

@foreach (var (feature, index) in features.Select((f, i) => (f, i)))
{
    <section class="@(index % 2 == 0 ? "mkt-section" : "mkt-section-alt")">
        <div class="mkt-container reveal">
            <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
                @if (index % 2 == 1)
                {
                    <div class="mkt-placeholder mkt-placeholder-feature">@feature.PlaceholderLabel</div>
                    <div>
                        <p class="mkt-eyebrow">@feature.Label</p>
                        <h2 style="margin-top:var(--space-2)">@feature.Title</h2>
                        <p style="margin-top:var(--space-4)">@feature.Description</p>
                        <ul class="mkt-benefits">
                            @foreach (var bullet in feature.Bullets)
                            {
                                <li>@bullet</li>
                            }
                        </ul>
                    </div>
                }
                else
                {
                    <div>
                        <p class="mkt-eyebrow">@feature.Label</p>
                        <h2 style="margin-top:var(--space-2)">@feature.Title</h2>
                        <p style="margin-top:var(--space-4)">@feature.Description</p>
                        <ul class="mkt-benefits">
                            @foreach (var bullet in feature.Bullets)
                            {
                                <li>@bullet</li>
                            }
                        </ul>
                    </div>
                    <div class="mkt-placeholder mkt-placeholder-feature">@feature.PlaceholderLabel</div>
                }
            </div>
        </div>
    </section>
}

<CtaSection Title="Ready to build your first demo?" Subtitle="Get started in minutes. No credit card required." />

