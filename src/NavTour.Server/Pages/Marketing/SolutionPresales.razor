@page "/solutions/presales"
@layout MarketingLayout

<PageTitle>NavTour for Presales — Scale Your SE Team with AI Demos</PageTitle>
<HeadContent>
    <meta name="description" content="Let NavTour handle the first demo. AI-generated self-serve experiences qualify prospects before your SEs invest a minute." />
</HeadContent>

<HeroSection Eyebrow="For Presales &amp; Solution Engineering"
             Title="Your SEs spend 80% of their time on repetitive discovery demos"
             Subtitle="Let NavTour handle the first demo. AI-generated self-serve experiences qualify prospects before your SEs invest a minute."
             PrimaryCtaText="Start Building Free"
             SecondaryCtaText="See Presales Demos"
             SecondaryCtaUrl="/contact" />

@* Pain Points *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <div class="mkt-card">
                <h3>SEs are the bottleneck</h3>
                <p>Every deal requires SE involvement for the first demo. Your team is stretched thin, and sales cycles slow down as the pipeline grows.</p>
            </div>
            <div class="mkt-card">
                <h3>Repetitive demos burn out your best people</h3>
                <p>80% of discovery demos cover the same features. Your senior SEs are doing work that could be automated.</p>
            </div>
            <div class="mkt-card">
                <h3>No scalable demo infrastructure</h3>
                <p>Each SE builds demos differently. No version control, no consistency, no way to measure what works.</p>
            </div>
        </div>
    </div>
</section>

@* Solution Feature 1 *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <p class="mkt-eyebrow">Self-Serve</p>
                <h2 style="margin-top:var(--space-2)">Self-Serve Discovery Demos</h2>
                <p style="margin-top:var(--space-4)">Let prospects explore your product through AI-generated interactive demos before the sales call. Qualify interest, identify their use case, and give SEs context before they ever pick up the phone.</p>
            </div>
            <div class="mkt-placeholder mkt-placeholder-feature">Prospect exploring a self-serve demo</div>
        </div>
    </div>
</section>

@* Solution Feature 2 *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div class="mkt-placeholder mkt-placeholder-feature">Demo template library with version history</div>
            <div>
                <p class="mkt-eyebrow">Templates</p>
                <h2 style="margin-top:var(--space-2)">Template Library With Version Control</h2>
                <p style="margin-top:var(--space-4)">Build reusable demo templates for every vertical, use case, and persona. Version control ensures everyone uses the latest. AI brand voice keeps messaging consistent across the team.</p>
            </div>
        </div>
    </div>
</section>

@* Solution Feature 3 *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <p class="mkt-eyebrow">Analytics</p>
                <h2 style="margin-top:var(--space-2)">Team Analytics & Optimization</h2>
                <p style="margin-top:var(--space-4)">See which demos perform best, which SEs drive the most engagement, and which templates convert. AI suggests optimizations based on aggregate data across your entire team.</p>
            </div>
            <div class="mkt-placeholder mkt-placeholder-feature">Team analytics and optimization dashboard</div>
        </div>
    </div>
</section>

@* Metrics *@
<section class="mkt-section">
    <div class="mkt-container text-center reveal">
        <h2>Presales teams using NavTour see results</h2>
        <div class="mkt-grid mkt-grid-3" style="margin-top:var(--space-10)">
            <MetricCard Value="5x" Label="more demos delivered per SE" />
            <MetricCard Value="60%" Label="reduction in repetitive demo work" />
            <MetricCard Value="12 hrs/wk" Label="saved per SE on average" />
        </div>
    </div>
</section>

<CtaSection Dark="true"
            Title="Scale your presales team without hiring"
            Subtitle="AI handles the repetitive work. Your SEs handle the deals that matter." />
