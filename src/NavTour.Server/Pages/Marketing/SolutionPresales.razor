@page "/solutions/presales"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.Resources.SharedResources> L

<PageTitle>@L["sol_presales_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["sol_presales_meta_desc"].Value" />
</HeadContent>

<HeroSection Eyebrow="@L["sol_presales_eyebrow"].Value"
             Title="@L["sol_presales_hero_title"].Value"
             Subtitle="@L["sol_presales_hero_subtitle"].Value"
             PrimaryCtaText="@L["sol_presales_cta_primary"].Value"
             SecondaryCtaText="@L["sol_presales_cta_secondary"].Value"
             SecondaryCtaUrl="/contact" />

@* Pain Points *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <div class="mkt-card">
                <h3>@L["sol_presales_pain1_title"]</h3>
                <p>@L["sol_presales_pain1_desc"]</p>
            </div>
            <div class="mkt-card">
                <h3>@L["sol_presales_pain2_title"]</h3>
                <p>@L["sol_presales_pain2_desc"]</p>
            </div>
            <div class="mkt-card">
                <h3>@L["sol_presales_pain3_title"]</h3>
                <p>@L["sol_presales_pain3_desc"]</p>
            </div>
        </div>
    </div>
</section>

@* Solution Feature 1 *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <p class="mkt-eyebrow">@L["sol_presales_feat1_eyebrow"]</p>
                <h2 style="margin-top:var(--space-2)">@L["sol_presales_feat1_title"]</h2>
                <p style="margin-top:var(--space-4)">@L["sol_presales_feat1_desc"]</p>
            </div>
            <div class="mkt-placeholder mkt-placeholder-feature">@L["sol_presales_feat1_placeholder"]</div>
        </div>
    </div>
</section>

@* Solution Feature 2 *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div class="mkt-placeholder mkt-placeholder-feature">@L["sol_presales_feat2_placeholder"]</div>
            <div>
                <p class="mkt-eyebrow">@L["sol_presales_feat2_eyebrow"]</p>
                <h2 style="margin-top:var(--space-2)">@L["sol_presales_feat2_title"]</h2>
                <p style="margin-top:var(--space-4)">@L["sol_presales_feat2_desc"]</p>
            </div>
        </div>
    </div>
</section>

@* Solution Feature 3 *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <p class="mkt-eyebrow">@L["sol_presales_feat3_eyebrow"]</p>
                <h2 style="margin-top:var(--space-2)">@L["sol_presales_feat3_title"]</h2>
                <p style="margin-top:var(--space-4)">@L["sol_presales_feat3_desc"]</p>
            </div>
            <div class="mkt-placeholder mkt-placeholder-feature">@L["sol_presales_feat3_placeholder"]</div>
        </div>
    </div>
</section>

@* Metrics *@
<section class="mkt-section">
    <div class="mkt-container text-center reveal">
        <h2>@L["sol_presales_metrics_title"]</h2>
        <div class="mkt-grid mkt-grid-3" style="margin-top:var(--space-10)">
            <MetricCard Value="5x" Label="@L["sol_presales_metric1_label"].Value" />
            <MetricCard Value="60%" Label="@L["sol_presales_metric2_label"].Value" />
            <MetricCard Value="12 hrs/wk" Label="@L["sol_presales_metric3_label"].Value" />
        </div>
    </div>
</section>

<CtaSection Dark="true"
            Title="@L["sol_presales_cta_title"].Value"
            Subtitle="@L["sol_presales_cta_subtitle"].Value" />
