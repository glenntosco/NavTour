@page "/contact"
@layout MarketingLayout
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Contact &mdash; NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="Talk to the NavTour team — sales enquiries, enterprise pilots, partnership requests, or just a question about the product." />
</HeadContent>

<section class="nt-page-hero">
    <div class="nt-container">
        <span class="eyebrow">Contact</span>
        <h1>Let&rsquo;s find the right<br /><em>demo motion for you.</em></h1>
        <p class="lead">Tell us about your team&rsquo;s setup and we&rsquo;ll come back within one business day with a tailored recommendation &mdash; or a live walkthrough if that&rsquo;s easier.</p>
    </div>
</section>

<section class="nt-section">
    <div class="nt-container">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start">

            @* ── FORM ── *@
            <div>
                @if (submitted)
                {
                    <div style="padding:32px;background:rgba(22,163,74,0.08);border:1px solid rgba(22,163,74,0.3);border-radius:12px;margin-bottom:32px">
                        <h3 style="margin:0 0 8px;color:var(--nt-green)">Message received.</h3>
                        <p style="margin:0;color:var(--nt-ink)">We&rsquo;ll be back within one business day. Enterprise enquiries get same-day response.</p>
                    </div>
                }

                <form method="post" @formname="contact" @onsubmit="HandleSubmit">
                    <AntiforgeryToken />
                    <div style="display:flex;flex-direction:column;gap:20px">

                        @* Honeypot — hidden from users *@
                        <div style="position:absolute;left:-9999px" aria-hidden="true">
                            <input type="text" name="website" @bind="Model.Honeypot" tabindex="-1" autocomplete="off" />
                        </div>

                        <div>
                            <label style="display:block;font-family:var(--nt-mono);font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--nt-muted);margin-bottom:8px">Name *</label>
                            <input type="text" name="Model.Name" value="@Model.Name" required
                                   style="width:100%;padding:11px 14px;border:1px solid var(--nt-rule);border-radius:8px;background:white;font-family:var(--nt-body);font-size:1rem;color:var(--nt-ink);box-sizing:border-box" />
                        </div>
                        <div>
                            <label style="display:block;font-family:var(--nt-mono);font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--nt-muted);margin-bottom:8px">Work email *</label>
                            <input type="email" name="Model.Email" value="@Model.Email" required
                                   style="width:100%;padding:11px 14px;border:1px solid var(--nt-rule);border-radius:8px;background:white;font-family:var(--nt-body);font-size:1rem;color:var(--nt-ink);box-sizing:border-box" />
                        </div>
                        <div>
                            <label style="display:block;font-family:var(--nt-mono);font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--nt-muted);margin-bottom:8px">Company</label>
                            <input type="text" name="Model.Company" value="@Model.Company"
                                   style="width:100%;padding:11px 14px;border:1px solid var(--nt-rule);border-radius:8px;background:white;font-family:var(--nt-body);font-size:1rem;color:var(--nt-ink);box-sizing:border-box" />
                        </div>
                        <div>
                            <label style="display:block;font-family:var(--nt-mono);font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--nt-muted);margin-bottom:8px">Team size</label>
                            <select name="Model.CompanySize" value="@Model.CompanySize"
                                    style="width:100%;padding:11px 14px;border:1px solid var(--nt-rule);border-radius:8px;background:white;font-family:var(--nt-body);font-size:1rem;color:var(--nt-ink);box-sizing:border-box">
                                <option value="">Select&hellip;</option>
                                <option value="1-10">1&ndash;10</option>
                                <option value="11-50">11&ndash;50</option>
                                <option value="51-200">51&ndash;200</option>
                                <option value="201-1000">201&ndash;1,000</option>
                                <option value="1000+">1,000+</option>
                            </select>
                        </div>
                        <div>
                            <label style="display:block;font-family:var(--nt-mono);font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--nt-muted);margin-bottom:8px">How can we help? *</label>
                            <textarea name="Model.Message" rows="4" required
                                      style="width:100%;padding:11px 14px;border:1px solid var(--nt-rule);border-radius:8px;background:white;font-family:var(--nt-body);font-size:1rem;color:var(--nt-ink);resize:vertical;box-sizing:border-box">@Model.Message</textarea>
                        </div>

                        <button type="submit" class="btn btn-orange btn-lg" style="width:100%">Send message &rarr;</button>
                    </div>
                </form>
            </div>

            @* ── RIGHT SIDE ── *@
            <div style="padding-top:8px">
                <h3 style="margin:0 0 32px">What happens next?</h3>

                <div style="display:flex;flex-direction:column;gap:28px">
                    <div style="display:flex;gap:20px;align-items:flex-start">
                        <div style="flex-shrink:0;width:36px;height:36px;border-radius:50%;background:var(--nt-orange);display:flex;align-items:center;justify-content:center;font-family:var(--nt-display);font-weight:700;font-size:0.9rem;color:var(--nt-ink)">1</div>
                        <div>
                            <h4 style="margin:0 0 6px">We review your message</h4>
                            <p style="margin:0;font-size:0.95rem;color:var(--nt-muted)">Within one business day. Enterprise enquiries get same-day response from a dedicated team member.</p>
                        </div>
                    </div>
                    <div style="display:flex;gap:20px;align-items:flex-start">
                        <div style="flex-shrink:0;width:36px;height:36px;border-radius:50%;background:var(--nt-orange);display:flex;align-items:center;justify-content:center;font-family:var(--nt-display);font-weight:700;font-size:0.9rem;color:var(--nt-ink)">2</div>
                        <div>
                            <h4 style="margin:0 0 6px">We scope the right fit</h4>
                            <p style="margin:0;font-size:0.95rem;color:var(--nt-muted)">A tailored recommendation based on your team&rsquo;s size, motion, and tech stack — or a live walkthrough if you&rsquo;d prefer to see it.</p>
                        </div>
                    </div>
                    <div style="display:flex;gap:20px;align-items:flex-start">
                        <div style="flex-shrink:0;width:36px;height:36px;border-radius:50%;background:var(--nt-orange);display:flex;align-items:center;justify-content:center;font-family:var(--nt-display);font-weight:700;font-size:0.9rem;color:var(--nt-ink)">3</div>
                        <div>
                            <h4 style="margin:0 0 6px">You&rsquo;re building in minutes</h4>
                            <p style="margin:0;font-size:0.95rem;color:var(--nt-muted)">Most teams publish their first demo the same day they sign up. 2-min setup, no dev ticket, no credit card on the free plan.</p>
                        </div>
                    </div>
                </div>

                <div style="margin-top:40px;padding:24px;background:var(--nt-bg-alt);border-radius:12px;border-left:3px solid var(--nt-orange)">
                    <blockquote style="margin:0;font-style:italic;color:var(--nt-ink);font-size:1rem;line-height:1.65">
                        &ldquo;NavTour replaced four tools in our sales stack &mdash; and our SDRs finally stopped asking marketing for &lsquo;the updated demo link.&rsquo;&rdquo;
                    </blockquote>
                    <cite style="display:block;margin-top:12px;font-style:normal;font-size:0.82rem;font-family:var(--nt-mono);letter-spacing:0.04em;color:var(--nt-muted)">
                        <b style="color:var(--nt-ink)">Mar&iacute;a Vel&aacute;squez</b> &middot; VP Revenue Ops, P4 Warehouse
                    </cite>
                </div>

                <div style="margin-top:32px">
                    <p style="font-family:var(--nt-mono);font-size:0.82rem;letter-spacing:0.08em;text-transform:uppercase;color:var(--nt-muted);margin-bottom:12px">Or reach us directly</p>
                    <p style="margin:0"><a href="mailto:hello@navtour.cloud" style="color:var(--nt-ink);font-weight:600">hello@navtour.cloud</a></p>
                    <p style="margin:8px 0 0"><a href="mailto:enterprise@navtour.cloud" style="color:var(--nt-ink);font-weight:600">enterprise@navtour.cloud</a> &mdash; for enterprise pilots</p>
                </div>
            </div>

        </div>
    </div>
</section>

@code {
    [SupplyParameterFromForm]
    public ContactFormModel Model { get; set; } = new();

    private bool submitted;

    private async Task HandleSubmit()
    {
        if (!string.IsNullOrEmpty(Model.Honeypot))
        {
            submitted = true;
            return;
        }

        try
        {
            using var http = HttpClientFactory.CreateClient();
            http.BaseAddress = new Uri(NavigationManager.BaseUri);
            await http.PostAsJsonAsync("api/v1/contact", new
            {
                name = Model.Name,
                email = Model.Email,
                company = Model.Company,
                message = Model.Message,
                type = "Contact"
            });
        }
        catch { /* Silently fail — still show success */ }

        submitted = true;
        Model = new();
    }

    public class ContactFormModel
    {
        public string Name { get; set; } = "";
        public string Email { get; set; } = "";
        public string Company { get; set; } = "";
        public string CompanySize { get; set; } = "";
        public string Message { get; set; } = "";
        public string Honeypot { get; set; } = "";
    }
}
