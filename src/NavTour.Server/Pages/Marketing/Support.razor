@page "/support"
@layout MarketingLayout

<PageTitle>Support &mdash; NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="NavTour support: email, docs, and a dedicated enterprise team. SOC 2 Type II, bilingual EN/ES, response time under 4 hours for paid plans." />
</HeadContent>

<section class="nt-page-hero">
    <div class="nt-container">
        <span class="eyebrow">Support</span>
        <h1>We&rsquo;re here when the<br /><em>demo matters most.</em></h1>
        <p class="lead">Email support, comprehensive docs, and an enterprise team for complex deployments. Bilingual EN/ES. SOC&nbsp;2 Type&nbsp;II.</p>
    </div>
</section>

<section class="nt-section">
    <div class="nt-container">
        <div class="nt-card-grid">
            <div class="nt-card" style="display:flex;flex-direction:column;gap:16px">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--nt-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                <h3 style="margin:0">Email support</h3>
                <p style="margin:0;flex:1">Response under 4 hours for paid plans, next business day for Free. All support bilingual EN/ES.</p>
                <a href="mailto:support@navtour.cloud" class="btn btn-outline" style="align-self:flex-start">support@navtour.cloud</a>
            </div>
            <div class="nt-card" style="display:flex;flex-direction:column;gap:16px">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--nt-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                <h3 style="margin:0">Documentation</h3>
                <p style="margin:0;flex:1">Full user manual covering capture, the editor, AI Copilot, analytics, integrations, and the REST API.</p>
                <a href="/docs" class="btn btn-outline" style="align-self:flex-start">Browse docs &rarr;</a>
            </div>
            <div class="nt-card" style="display:flex;flex-direction:column;gap:16px">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--nt-orange)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
                <h3 style="margin:0">FAQ</h3>
                <p style="margin:0;flex:1">Answers to the most common questions about billing, limits, integrations, and security compliance.</p>
                <a href="/pricing#faq" class="btn btn-outline" style="align-self:flex-start">Read the FAQ &rarr;</a>
            </div>
        </div>
    </div>
</section>

<NtCTABand Headline="Enterprise support, dedicated CSM, custom onboarding."
           SubText="Our enterprise team handles SSO setup, data residency, custom MSAs, and bilingual onboarding workshops."
           PrimaryLabel="Talk to the enterprise team &rarr;"
           PrimaryHref="/contact"
           SecondaryLabel="Back to pricing"
           SecondaryHref="/pricing" />
