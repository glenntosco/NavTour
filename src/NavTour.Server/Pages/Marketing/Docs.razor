<script>
(function() {
    // ⌘K search
    var input = document.getElementById('docs-search');
    document.addEventListener('keydown', function(e) {
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); input.focus(); }
        if (e.key === 'Escape' && document.activeElement === input) { input.value = ''; filterTOC(''); input.blur(); }
    });
    input.addEventListener('input', function() { filterTOC(this.value); });
    function filterTOC(q) {
        var groups = document.querySelectorAll('.nt-docs-nav-group');
        groups.forEach(function(g) {
            var links = g.querySelectorAll('a');
            var any = false;
            links.forEach(function(a) {
                var match = !q || a.textContent.toLowerCase().includes(q.toLowerCase());
                a.classList.toggle('hidden', !match);
                if (match) any = true;
            });
            g.classList.toggle('hidden', !any);
        });
    }
    // Scrollspy
    var headings = document.querySelectorAll('.nt-docs-content h2, .nt-docs-content h3');
    var rightLinks = document.querySelectorAll('#docs-right-list a');
    var leftLinks = document.querySelectorAll('.nt-docs-nav-group a');
    var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
            if (e.isIntersecting) {
                var id = e.target.id;
                rightLinks.forEach(function(a) { a.classList.toggle('active', a.getAttribute('href') === '#' + id); });
                leftLinks.forEach(function(a) { a.classList.toggle('active', a.getAttribute('href') === '#' + id); });
            }
        });
    }, { rootMargin: '-20% 0px -70% 0px' });
    headings.forEach(function(h) { if (h.id) io.observe(h); });
}());
</script>
