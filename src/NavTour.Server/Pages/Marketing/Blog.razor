@page "/blog"
@layout MarketingLayout

<PageTitle>Blog &mdash; NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="Product updates, sales and marketing insights, and engineering notes from the NavTour team." />
</HeadContent>

<section class="nt-page-hero">
    <div class="nt-container">
        <div class="nt-issue-mark">VOL &middot; XII &middot; BLOG &middot; 2026</div>
        <h1>From the <em>NavTour</em> desk.</h1>
        <p class="lead">Product updates, sales and marketing insights, and engineering notes from the team building interactive demos for the Americas.</p>
    </div>
</section>

