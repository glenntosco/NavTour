            <span style="font-family:var(--nt-mono);font-size:0.82rem;letter-spacing:0.1em;text-transform:uppercase;padding:6px 16px;border:1px solid var(--nt-rule);border-radius:999px;cursor:pointer;color:var(--nt-muted)">Product</span>
