@page "/blog"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>@L["blog_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["blog_meta_desc"].Value" />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-10)">
    <div class="mkt-container" style="max-width:680px">
        <h1 class="text-center">@L["blog_title"]</h1>
        <p class="text-center" style="margin-top:var(--space-5)">@L["blog_subtitle"]</p>
    </div>
</section>

<section style="padding:0 var(--space-6) var(--space-32)">
    <div class="mkt-container">
        @* Category filter bar *@
        <div class="mkt-blog-categories reveal">
            <a href="/blog" class="active">@L["blog_cat_all"]</a>
            <a href="/blog">@L["blog_cat_product"]</a>
            <a href="/blog">@L["blog_cat_sales"]</a>
            <a href="/blog">@L["blog_cat_marketing"]</a>
            <a href="/blog">@L["blog_cat_engineering"]</a>
            <a href="/blog">@L["blog_cat_customers"]</a>
        </div>

        @* Blog post grid *@
        <div class="mkt-grid mkt-grid-2 reveal-stagger" style="gap:var(--space-8)">
            @* Post 1 *@
            <div class="mkt-blog-card">
                <div class="mkt-blog-card-image">@L["blog_cat_product"]</div>
                <div class="mkt-blog-card-body">
                    <span class="mkt-blog-card-tag">@L["blog_cat_product"]</span>
                    <h3 class="mkt-blog-card-title">@L["blog_post1_title"]</h3>
                    <p class="mkt-blog-card-excerpt">@L["blog_post1_excerpt"]</p>
                    <div class="mkt-blog-card-meta">
                        <span>NavTour Team</span> &middot; <span>Mar 12, 2026</span> &middot; <a href="/blog" style="color:var(--nt-primary);font-weight:var(--weight-semibold)">@L["blog_read"] &rarr;</a>
                    </div>
                </div>
            </div>

            @* Post 2 *@
            <div class="mkt-blog-card">
                <div class="mkt-blog-card-image">@L["blog_cat_sales"]</div>
                <div class="mkt-blog-card-body">
                    <span class="mkt-blog-card-tag">@L["blog_cat_sales"]</span>
                    <h3 class="mkt-blog-card-title">@L["blog_post2_title"]</h3>
                    <p class="mkt-blog-card-excerpt">@L["blog_post2_excerpt"]</p>
                    <div class="mkt-blog-card-meta">
                        <span>Sarah Chen</span> &middot; <span>Mar 8, 2026</span> &middot; <a href="/blog" style="color:var(--nt-primary);font-weight:var(--weight-semibold)">@L["blog_read"] &rarr;</a>
                    </div>
                </div>
            </div>

            @* Post 3 *@
            <div class="mkt-blog-card">
                <div class="mkt-blog-card-image">@L["blog_cat_marketing"]</div>
                <div class="mkt-blog-card-body">
                    <span class="mkt-blog-card-tag">@L["blog_cat_marketing"]</span>
                    <h3 class="mkt-blog-card-title">@L["blog_post3_title"]</h3>
                    <p class="mkt-blog-card-excerpt">@L["blog_post3_excerpt"]</p>
                    <div class="mkt-blog-card-meta">
                        <span>NavTour Team</span> &middot; <span>Mar 1, 2026</span> &middot; <a href="/blog" style="color:var(--nt-primary);font-weight:var(--weight-semibold)">@L["blog_read"] &rarr;</a>
                    </div>
                </div>
            </div>

            @* Post 4 *@
            <div class="mkt-blog-card">
                <div class="mkt-blog-card-image">@L["blog_cat_customers"]</div>
                <div class="mkt-blog-card-body">
                    <span class="mkt-blog-card-tag">@L["blog_cat_customers"]</span>
                    <h3 class="mkt-blog-card-title">@L["blog_post4_title"]</h3>
                    <p class="mkt-blog-card-excerpt">@L["blog_post4_excerpt"]</p>
                    <div class="mkt-blog-card-meta">
                        <span>Alex Rivera</span> &middot; <span>Feb 25, 2026</span> &middot; <a href="/blog" style="color:var(--nt-primary);font-weight:var(--weight-semibold)">@L["blog_read"] &rarr;</a>
                    </div>
                </div>
            </div>

            @* Post 5 *@
            <div class="mkt-blog-card">
                <div class="mkt-blog-card-image">@L["blog_cat_engineering"]</div>
                <div class="mkt-blog-card-body">
                    <span class="mkt-blog-card-tag">@L["blog_cat_engineering"]</span>
                    <h3 class="mkt-blog-card-title">@L["blog_post5_title"]</h3>
                    <p class="mkt-blog-card-excerpt">@L["blog_post5_excerpt"]</p>
                    <div class="mkt-blog-card-meta">
                        <span>NavTour Engineering</span> &middot; <span>Feb 18, 2026</span> &middot; <a href="/blog" style="color:var(--nt-primary);font-weight:var(--weight-semibold)">@L["blog_read"] &rarr;</a>
                    </div>
                </div>
            </div>

            @* Post 6 *@
            <div class="mkt-blog-card">
                <div class="mkt-blog-card-image">@L["blog_cat_sales"]</div>
                <div class="mkt-blog-card-body">
                    <span class="mkt-blog-card-tag">@L["blog_cat_sales"]</span>
                    <h3 class="mkt-blog-card-title">@L["blog_post6_title"]</h3>
                    <p class="mkt-blog-card-excerpt">@L["blog_post6_excerpt"]</p>
                    <div class="mkt-blog-card-meta">
                        <span>NavTour Team</span> &middot; <span>Feb 10, 2026</span> &middot; <a href="/blog" style="color:var(--nt-primary);font-weight:var(--weight-semibold)">@L["blog_read"] &rarr;</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
