@page "/solutions/customer-success"
@layout MarketingLayout

<PageTitle>NavTour for Customer Success — Onboard Faster with Interactive Tours</PageTitle>
<HeadContent>
    <meta name="description" content="Self-serve product tours that reduce onboarding time by 60%. Scale customer success without scaling headcount." />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-16)">
    <div class="mkt-container" style="max-width:680px">
        <p class="mkt-eyebrow text-center">For Customer Success</p>
        <h1 class="text-center" style="margin-top:var(--space-2)">Onboard faster with self-serve product tours</h1>
        <p class="text-center" style="margin-top:var(--space-5)">Create step-by-step product tours that guide new users through setup and feature adoption — without scheduling a single call. Scale onboarding without scaling headcount.</p>
        <div class="mkt-hero-actions" style="justify-content:center;margin-top:var(--space-8)">
            <a href="/register" class="mkt-btn mkt-btn-primary mkt-btn-lg">Start Free</a>
            <a href="/contact" class="mkt-btn mkt-btn-secondary mkt-btn-lg">Talk to Us</a>
        </div>
    </div>
</section>

@* Onboarding Tours *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <p class="mkt-eyebrow">Onboarding</p>
                <h2 style="margin-top:var(--space-2)">Self-serve onboarding that actually works</h2>
                <p style="margin-top:var(--space-4)">New customers shouldn't wait days for an onboarding call. Create interactive product tours that walk users through setup, configuration, and first-value moments. Customers get started immediately, and your CS team can focus on strategic accounts.</p>
                <ul class="mkt-benefits">
                    <li>Step-by-step setup guides with tooltips and hotspots</li>
                    <li>Assign tours by customer segment or plan tier</li>
                    <li>Track completion to identify users who need help</li>
                </ul>
            </div>
            <div class="mkt-placeholder mkt-placeholder-feature">Self-serve onboarding tour with progress bar</div>
        </div>
    </div>
</section>

@* Feature Adoption *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div class="mkt-placeholder mkt-placeholder-feature">Feature adoption tour for advanced settings</div>
            <div>
                <p class="mkt-eyebrow">Feature Adoption</p>
                <h2 style="margin-top:var(--space-2)">Drive adoption of features customers are paying for</h2>
                <p style="margin-top:var(--space-4)">Customers churn when they don't use what they're paying for. Build feature-specific tours that guide users through advanced capabilities. Send targeted tours when usage data shows a customer hasn't activated a key feature.</p>
                <ul class="mkt-benefits">
                    <li>Feature-specific tours for advanced capabilities</li>
                    <li>Trigger tours based on usage signals or lifecycle stage</li>
                    <li>A/B test tour variants to optimize adoption rates</li>
                </ul>
            </div>
        </div>
    </div>
</section>

@* Renewal Enablement *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <p class="mkt-eyebrow">Renewal</p>
                <h2 style="margin-top:var(--space-2)">Demonstrate value at renewal time</h2>
                <p style="margin-top:var(--space-4)">When renewal conversations start, give decision-makers an interactive tour of new features and improvements since they signed. Show ROI through personalized impact summaries that make the renewal decision obvious.</p>
                <ul class="mkt-benefits">
                    <li>New feature showcase tours for renewals</li>
                    <li>Personalized with customer usage data</li>
                    <li>Shareable with procurement and budget owners</li>
                </ul>
            </div>
            <div class="mkt-placeholder mkt-placeholder-feature">Renewal demo showing new features since signup</div>
        </div>
    </div>
</section>

@* Scale CS *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div class="mkt-placeholder mkt-placeholder-feature">CS dashboard with tour completion analytics</div>
            <div>
                <p class="mkt-eyebrow">Scale</p>
                <h2 style="margin-top:var(--space-2)">Scale CS without scaling headcount</h2>
                <p style="margin-top:var(--space-4)">Your CS team can't do 1:1 onboarding calls for every customer forever. NavTour tours handle the repeatable parts — setup, training, feature discovery — so your team can focus on strategic conversations that drive expansion and retention.</p>
                <ul class="mkt-benefits">
                    <li>Automate repeatable onboarding workflows</li>
                    <li>Free up CS time for strategic account management</li>
                    <li>Consistent experience regardless of which CSM is assigned</li>
                </ul>
            </div>
        </div>
    </div>
</section>

@* Metrics *@
<section class="mkt-section">
    <div class="mkt-container text-center reveal">
        <h2>CS teams using NavTour see results</h2>
        <div class="mkt-grid mkt-grid-3" style="margin-top:var(--space-10)">
            <MetricCard Value="60%" Label="less onboarding time" Source="vs. live-call-only onboarding" />
            <MetricCard Value="45%" Label="fewer support tickets" Source="in the first 30 days" />
            <MetricCard Value="+15" Label="NPS improvement" Source="after launching self-serve tours" />
        </div>
    </div>
</section>

@* Testimonial *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <TestimonialCard Featured="true"
            Quote="We reduced onboarding calls by 60% after launching NavTour product tours. Customers complete setup 3x faster and our NPS went up 15 points."
            Name="David Park"
            Title="VP of Customer Success"
            Company="Horizon Ops"
            Metric="+15"
            MetricLabel="NPS improvement" />
    </div>
</section>

<CtaSection Title="Ready to scale customer success?" Subtitle="Start building self-serve product tours today. Free to start." />
