@page "/security"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>@L["security_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["security_meta_desc"].Value" />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-16)">
    <div class="mkt-container" style="max-width:680px">
        <p class="mkt-eyebrow text-center" style="text-transform:uppercase;letter-spacing:0.1em;color:var(--nt-accent)">@L["security_eyebrow"]</p>
        <h1 class="text-center">@L["security_title"]</h1>
        <p class="text-center" style="margin-top:var(--space-5)">@L["security_subtitle"]</p>
    </div>
</section>

@* Trust Badges *@
<section class="mkt-social-proof">
    <div class="mkt-container">
        <div class="mkt-trust-badges">
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                @L["security_badge_soc2"]
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                @L["security_badge_uptime"]
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                @L["security_badge_encryption"]
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                @L["security_badge_gdpr"]
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                @L["security_badge_azure"]
            </div>
        </div>
    </div>
</section>

@* Data Security *@
<section class="mkt-section">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_data_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_data_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_data_p2"]</p>
    </div>
</section>

@* Infrastructure *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_infra_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_infra_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_infra_p2"]</p>
    </div>
</section>

@* Compliance *@
<section class="mkt-section">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_compliance_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_compliance_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_compliance_p2"]</p>
    </div>
</section>

@* Privacy *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_privacy_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_privacy_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_privacy_p2"]</p>
    </div>
</section>

@* Responsible Disclosure *@
<section class="mkt-section">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_disclosure_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_disclosure_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_disclosure_p2"]</p>
    </div>
</section>

<CtaSection Title="@L["security_cta_title"].Value" Subtitle="@L["security_cta_subtitle"].Value" CtaText="@L["security_cta_button"].Value" CtaUrl="/contact" />
