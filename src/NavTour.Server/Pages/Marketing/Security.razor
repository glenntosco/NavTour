@page "/security"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>@L["security_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["security_meta_desc"].Value" />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-16)">
    <div class="mkt-container" style="max-width:680px">
        <p class="mkt-eyebrow text-center" style="text-transform:uppercase;letter-spacing:0.1em;color:var(--nt-accent)">@L["security_eyebrow"]</p>
        <h1 class="text-center">@L["security_title"]</h1>
        <p class="text-center" style="margin-top:var(--space-5)">@L["security_subtitle"]</p>
        <div class="mkt-hero-proof" style="justify-content:center;margin-top:var(--space-8)">
            <div class="mkt-hero-proof-item">@L["security_badge_soc2"]</div>
            <div class="mkt-hero-proof-item">@L["security_badge_encryption"]</div>
            <div class="mkt-hero-proof-item">@L["security_badge_azure"]</div>
        </div>
    </div>
</section>

@* Trust Badges *@
<section class="mkt-social-proof">
    <div class="mkt-container">
        <div class="mkt-trust-badges">
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                @L["security_badge_soc2"]
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                @L["security_badge_uptime"]
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                @L["security_badge_encryption"]
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                @L["security_badge_gdpr"]
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                @L["security_badge_azure"]
            </div>
        </div>
    </div>
</section>

@* Security Principles *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <p class="mkt-eyebrow">@L["security_principles_eyebrow"]</p>
            <h2>@L["security_principles_title"]</h2>
            <p>@L["security_principles_subtitle"]</p>
        </div>
        <div class="mkt-grid mkt-grid-4 reveal-stagger">
            <div class="mkt-card">
                <div class="mkt-integration-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </div>
                <h3>@L["security_principle1_title"]</h3>
                <p>@L["security_principle1_desc"]</p>
            </div>
            <div class="mkt-card">
                <div class="mkt-integration-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                </div>
                <h3>@L["security_principle2_title"]</h3>
                <p>@L["security_principle2_desc"]</p>
            </div>
            <div class="mkt-card">
                <div class="mkt-integration-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                </div>
                <h3>@L["security_principle3_title"]</h3>
                <p>@L["security_principle3_desc"]</p>
            </div>
            <div class="mkt-card">
                <div class="mkt-integration-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <h3>@L["security_principle4_title"]</h3>
                <p>@L["security_principle4_desc"]</p>
            </div>
        </div>
    </div>
</section>

@* Data Security *@
<section class="mkt-section">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_data_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_data_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_data_p2"]</p>
    </div>
</section>

@* Security Checklist *@
<section class="mkt-section-alt">
    <div class="mkt-container">
        <div class="mkt-grid mkt-grid-2 reveal-stagger" style="align-items:start;gap:var(--space-12)">
            <div>
                <p class="mkt-eyebrow">@L["security_checklist_eyebrow"]</p>
                <h2>@L["security_checklist_title"]</h2>
                <p style="margin-top:var(--space-4)">@L["security_checklist_subtitle"]</p>
                <ul class="mkt-benefits">
                    <li>@L["security_check1"]</li>
                    <li>@L["security_check2"]</li>
                    <li>@L["security_check3"]</li>
                    <li>@L["security_check4"]</li>
                    <li>@L["security_check5"]</li>
                </ul>
            </div>
            <div class="mkt-stage-card">
                <div class="mkt-stage-card-header">
                    <div>
                        <div class="mkt-stage-card-label">@L["security_ops_label"]</div>
                        <div class="mkt-stage-card-title">@L["security_ops_title"]</div>
                    </div>
                    <div class="mkt-stage-pill">@L["security_ops_pill"]</div>
                </div>
                <div class="mkt-stack-flow">
                    <div class="mkt-stack-node">
                        <div class="mkt-stack-node-step">01</div>
                        <div>
                            <h3>@L["security_ops_step1_title"]</h3>
                            <p>@L["security_ops_step1_desc"]</p>
                        </div>
                    </div>
                    <div class="mkt-stack-flow-line"></div>
                    <div class="mkt-stack-node">
                        <div class="mkt-stack-node-step">02</div>
                        <div>
                            <h3>@L["security_ops_step2_title"]</h3>
                            <p>@L["security_ops_step2_desc"]</p>
                        </div>
                    </div>
                    <div class="mkt-stack-flow-line"></div>
                    <div class="mkt-stack-node">
                        <div class="mkt-stack-node-step">03</div>
                        <div>
                            <h3>@L["security_ops_step3_title"]</h3>
                            <p>@L["security_ops_step3_desc"]</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* Infrastructure *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_infra_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_infra_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_infra_p2"]</p>
    </div>
</section>

@* Compliance *@
<section class="mkt-section">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_compliance_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_compliance_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_compliance_p2"]</p>
    </div>
</section>

@* Privacy *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal" style="max-width:720px">
        <h2>@L["security_privacy_title"]</h2>
        <p style="margin-top:var(--space-5)">@L["security_privacy_p1"]</p>
        <p style="margin-top:var(--space-4)">@L["security_privacy_p2"]</p>
    </div>
</section>

@* Responsible Disclosure *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:start;gap:var(--space-12)">
            <div>
                <h2>@L["security_disclosure_title"]</h2>
                <p style="margin-top:var(--space-5)">@L["security_disclosure_p1"]</p>
                <p style="margin-top:var(--space-4)">@L["security_disclosure_p2"]</p>
            </div>
            <div class="mkt-card">
                <p class="mkt-eyebrow">@L["security_contact_eyebrow"]</p>
                <h3>@L["security_contact_title"]</h3>
                <p style="margin-top:var(--space-3)">@L["security_contact_desc"]</p>
                <div class="mkt-badge-row" style="margin-top:var(--space-6)">
                    <span>@L["security_contact_badge1"]</span>
                    <span>@L["security_contact_badge2"]</span>
                    <span>@L["security_contact_badge3"]</span>
                </div>
                <a href="/contact" class="mkt-btn mkt-btn-primary" style="margin-top:var(--space-6)">@L["security_cta_button"]</a>
            </div>
        </div>
    </div>
</section>

<CtaSection Title="@L["security_cta_title"].Value" Subtitle="@L["security_cta_subtitle"].Value" CtaText="@L["security_cta_button"].Value" CtaUrl="/contact" />
