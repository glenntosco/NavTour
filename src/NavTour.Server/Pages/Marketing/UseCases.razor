@page "/use-cases"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>@L["usecases_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["usecases_meta_desc"]" />
</HeadContent>

<HeroSection Eyebrow="@L["usecases_eyebrow"]"
             Title="@L["usecases_title"]"
             Subtitle="@L["usecases_subtitle"]"
             PrimaryCtaUrl="/register"
             PrimaryCtaText="@L["usecases_hero_cta"]"
             SecondaryCtaUrl="/contact"
             SecondaryCtaText="@L["usecases_hero_cta_secondary"]" />

@* Use Case Cards *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <a href="/solutions/marketing" class="mkt-card" style="text-decoration:none;color:inherit">
                <h3>@L["usecases_card1_title"]</h3>
                <p>@L["usecases_card1_desc"]</p>
            </a>
            <a href="/solutions/sales" class="mkt-card" style="text-decoration:none;color:inherit">
                <h3>@L["usecases_card2_title"]</h3>
                <p>@L["usecases_card2_desc"]</p>
            </a>
            <a href="/solutions/presales" class="mkt-card" style="text-decoration:none;color:inherit">
                <h3>@L["usecases_card3_title"]</h3>
                <p>@L["usecases_card3_desc"]</p>
            </a>
            <a href="/solutions/customer-success" class="mkt-card" style="text-decoration:none;color:inherit">
                <h3>@L["usecases_card4_title"]</h3>
                <p>@L["usecases_card4_desc"]</p>
            </a>
            <a href="/product" class="mkt-card" style="text-decoration:none;color:inherit">
                <h3>@L["usecases_card5_title"]</h3>
                <p>@L["usecases_card5_desc"]</p>
            </a>
            <a href="/product/ai" class="mkt-card" style="text-decoration:none;color:inherit">
                <h3>@L["usecases_card6_title"]</h3>
                <p>@L["usecases_card6_desc"]</p>
            </a>
        </div>
    </div>
</section>

@* How Teams Use NavTour *@
<section class="mkt-section-alt">
    <div class="mkt-container" style="max-width:780px">
        <div class="mkt-section-heading reveal">
            <h2>@L["usecases_how_heading"]</h2>
        </div>

        <div class="reveal" style="margin-top:var(--space-12)">
            <h3>@L["usecases_how1_title"]</h3>
            <p style="margin-top:var(--space-3)">@L["usecases_how1_desc"]</p>
        </div>

        <div class="reveal" style="margin-top:var(--space-12)">
            <h3>@L["usecases_how2_title"]</h3>
            <p style="margin-top:var(--space-3)">@L["usecases_how2_desc"]</p>
        </div>

        <div class="reveal" style="margin-top:var(--space-12)">
            <h3>@L["usecases_how3_title"]</h3>
            <p style="margin-top:var(--space-3)">@L["usecases_how3_desc"]</p>
        </div>
    </div>
</section>

<CtaSection Dark="true"
            Title="@L["usecases_cta_title"]"
            Subtitle="@L["usecases_cta_subtitle"]"
            CtaText="@L["usecases_cta_text"]"
            SecondaryCtaText="@L["usecases_cta_secondary"]"
            SecondaryCtaUrl="/contact" />
