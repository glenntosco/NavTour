@page "/form/{Slug}"
@layout MarketingLayout
@using NavTour.Server.Services
@using NavTour.Shared.DTOs.Forms
@using NavTour.Shared.Enums
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Antiforgery
@attribute [AllowAnonymous]
@attribute [RequireAntiforgeryToken(required: false)]
@inject IFormService FormService

<PageTitle>@(form?.Settings?.Title ?? form?.Name ?? "Form") — NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="@(form?.Description ?? "Submit this form powered by NavTour")" />
    <meta name="robots" content="noindex" />
</HeadContent>

<section style="min-height:70vh;display:flex;align-items:center">
    <div class="nt-container" style="display:flex;justify-content:center">

        @if (notFound)
        {
            <div style="text-align:center;max-width:480px">
                <div style="font-size:3rem;margin-bottom:1rem">&#128269;</div>
                <h1 style="font-size:1.5rem;margin-bottom:0.75rem">Form not found</h1>
                <p style="color:#64748b;margin-bottom:2rem">This form may have been removed or the link is incorrect.</p>
                <a href="/" class="btn btn-ink">Back to home</a>
            </div>
        }
        else if (submitted)
        {
            <div style="text-align:center;max-width:480px;padding:3rem 0">
                <div style="font-size:3rem;margin-bottom:1rem">&#10003;</div>
                <h1 style="font-size:1.5rem;margin-bottom:0.75rem">Thank you!</h1>
                <p style="color:#64748b">Your submission has been received.</p>
            </div>
        }
        else if (form is not null)
        {
            <div style="width:100%;max-width:500px">
                <div style="background:#fff;border-radius:8px;box-shadow:0 4px 24px rgba(0,0,0,0.08);padding:2.5rem;border:1px solid #e2e8f0">
                    <div style="text-align:center;margin-bottom:2rem">
                        @if (!string.IsNullOrEmpty(form.Settings?.Title))
                        {
                            <h1 style="font-size:1.5rem;margin-bottom:0.5rem">@form.Settings.Title</h1>
                        }
                        else
                        {
                            <h1 style="font-size:1.5rem;margin-bottom:0.5rem">@form.Name</h1>
                        }
                        @if (!string.IsNullOrEmpty(form.Settings?.Subtitle))
                        {
                            <p style="color:#64748b">@form.Settings.Subtitle</p>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div style="background:#fef2f2;color:#991b1b;padding:0.75rem 1rem;border-radius:6px;font-size:0.875rem;margin-bottom:1rem">@errorMessage</div>
                    }

                    <form method="post" @formname="standalone-form" @onsubmit="HandleSubmit">
                        <AntiforgeryToken />
                        <div style="display:flex;flex-direction:column;gap:1.25rem">
                            @foreach (var field in form.Fields.OrderBy(f => f.SortOrder))
                            {
                                <div>
                                    <label style="display:block;font-size:0.875rem;font-weight:600;color:#0b1929;margin-bottom:0.375rem">
                                        @field.Label
                                        @if (field.IsRequired) { <span style="color:#c62828"> *</span> }
                                    </label>
                                    @if (!string.IsNullOrEmpty(field.Description))
                                    {
                                        <p style="font-size:0.75rem;color:#94a3b8;margin-bottom:0.375rem">@field.Description</p>
                                    }

                                    @switch (field.FieldType)
                                    {
                                        case FormFieldType.Text:
                                        case FormFieldType.Phone:
                                        case FormFieldType.Url:
                                            <input type="@GetInputType(field.FieldType)" name="@field.Key"
                                                   value="@GetValue(field.Key)" placeholder="@field.Placeholder"
                                                   @(field.IsRequired ? "required" : "")
                                                   style="width:100%;padding:0.625rem 0.875rem;border:1px solid #cbd5e1;border-radius:6px;font-size:0.875rem;box-sizing:border-box" />
                                            break;

                                        case FormFieldType.Email:
                                            <input type="email" name="@field.Key"
                                                   value="@GetValue(field.Key)" placeholder="@(field.Placeholder ?? "email@example.com")"
                                                   @(field.IsRequired ? "required" : "")
                                                   style="width:100%;padding:0.625rem 0.875rem;border:1px solid #cbd5e1;border-radius:6px;font-size:0.875rem;box-sizing:border-box" />
                                            break;

                                        case FormFieldType.TextArea:
                                            <textarea name="@field.Key" rows="3" placeholder="@field.Placeholder"
                                                      @(field.IsRequired ? "required" : "")
                                                      style="width:100%;padding:0.625rem 0.875rem;border:1px solid #cbd5e1;border-radius:6px;font-size:0.875rem;resize:vertical;box-sizing:border-box">@GetValue(field.Key)</textarea>
                                            break;

                                        case FormFieldType.Select:
                                            <select name="@field.Key" @(field.IsRequired ? "required" : "")
                                                    style="width:100%;padding:0.625rem 0.875rem;border:1px solid #cbd5e1;border-radius:6px;font-size:0.875rem;box-sizing:border-box">
                                                <option value="">@(field.Placeholder ?? "Select...")</option>
                                                @if (field.Options is not null)
                                                {
                                                    @foreach (var opt in field.Options)
                                                    {
                                                        <option value="@opt" selected="@(GetValue(field.Key) == opt)">@opt</option>
                                                    }
                                                }
                                            </select>
                                            break;

                                        case FormFieldType.Multiselect:
                                            @if (field.Options is not null)
                                            {
                                                <div style="display:flex;flex-direction:column;gap:0.5rem">
                                                    @foreach (var opt in field.Options)
                                                    {
                                                        <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.875rem;cursor:pointer">
                                                            <input type="checkbox" name="@(field.Key + "_" + opt)" value="true" />
                                                            @opt
                                                        </label>
                                                    }
                                                </div>
                                            }
                                            break;

                                        case FormFieldType.Checkbox:
                                            <label style="display:flex;align-items:center;gap:0.5rem;font-size:0.875rem;cursor:pointer">
                                                <input type="checkbox" name="@field.Key" value="true" />
                                                @(field.Placeholder ?? field.Label)
                                            </label>
                                            break;
                                    }
                                </div>
                            }

                            <button type="submit" style="width:100%;padding:0.75rem;background:#4361ee;color:#fff;border:none;border-radius:6px;font-size:0.875rem;font-weight:600;cursor:pointer;margin-top:0.5rem">
                                @(form.Settings?.SubmitButtonText ?? "Submit")
                            </button>
                        </div>
                    </form>
                </div>

                <div style="margin-top:1.5rem;text-align:center">
                    <a href="/" style="font-size:0.75rem;color:#94a3b8;text-decoration:none">
                        Powered by <strong style="color:#64748b">NavTour</strong>
                    </a>
                </div>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string Slug { get; set; } = "";

    [CascadingParameter] public HttpContext? HttpContext { get; set; }

    private FormResponse? form;
    private bool notFound;
    private bool submitted;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Slug))
        {
            notFound = true;
            return;
        }

        form = await FormService.GetBySlugPublicAsync(Slug);
        if (form is null)
        {
            notFound = true;
            return;
        }

        // Only count view on GET, not POST
        if (HttpContext?.Request.Method == "GET")
        {
            await FormService.IncrementViewCountAsync(form.Id);
        }
    }

    private async Task HandleSubmit()
    {
        if (form == null || HttpContext == null) return;

        var formData = HttpContext.Request.Form;

        // Collect form values from the posted form data
        var values = new Dictionary<string, string>();

        foreach (var field in form.Fields)
        {
            if (field.FieldType == FormFieldType.Multiselect && field.Options != null)
            {
                var selected = field.Options
                    .Where(opt => formData.ContainsKey(field.Key + "_" + opt))
                    .ToList();
                values[field.Key] = string.Join(", ", selected);
            }
            else
            {
                values[field.Key] = formData[field.Key].ToString();
            }
        }

        // Validate required fields
        foreach (var field in form.Fields.Where(f => f.IsRequired))
        {
            if (string.IsNullOrWhiteSpace(values.GetValueOrDefault(field.Key)))
            {
                errorMessage = $"{field.Label} is required.";
                return;
            }
        }

        var result = await FormService.SubmitStandaloneFormAsync(Slug, new FormSubmissionRequest(values));
        if (result != null)
        {
            submitted = true;
        }
        else
        {
            errorMessage = "Failed to submit. Please try again.";
        }
    }

    private string GetValue(string key)
    {
        if (HttpContext?.Request.Method != "POST" || !HttpContext.Request.HasFormContentType)
            return "";
        return HttpContext.Request.Form[key].ToString();
    }

    private static string GetInputType(FormFieldType fieldType) => fieldType switch
    {
        FormFieldType.Email => "email",
        FormFieldType.Phone => "tel",
        FormFieldType.Url => "url",
        _ => "text"
    };
}
