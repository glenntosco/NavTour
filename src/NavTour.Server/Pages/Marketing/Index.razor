@page "/"
@layout MarketingLayout
@rendermode InteractiveServer

<PageTitle>NavTour — Interactive Product Demos That Sell</PageTitle>
<HeadContent>
    <meta name="description" content="Create no-code interactive walkthroughs of your software. Embed on your website, share in sales emails, or use in ad campaigns — and watch engagement soar." />
    <meta property="og:title" content="NavTour — Let your product sell itself." />
    <meta property="og:description" content="Create no-code interactive walkthroughs of your software. Embed, share, and convert." />
    <meta property="og:url" content="https://navtour.cloud/" />
    <meta property="og:image" content="https://navtour.cloud/images/product-form-builder.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NavTour" />
    <link rel="canonical" href="https://navtour.cloud/" />
    <link rel="alternate" hreflang="en" href="https://navtour.cloud/" />
    <link rel="alternate" hreflang="es" href="https://navtour.cloud/?culture=es&amp;ui-culture=es" />
    <link rel="alternate" hreflang="x-default" href="https://navtour.cloud/" />
</HeadContent>

@* ── 1. Hero — Centered CTA Block ── *@
<RadzenRow Class="rz-mx-auto" Style="max-width: 1200px">
    <RadzenColumn Size="12" Class="rz-p-6 rz-p-sm-12">
        <RadzenStack AlignItems="AlignItems.Center" Gap="0" Class="rz-my-12">
            <RadzenText Text="Interactive Product Demos" TextStyle="TextStyle.Overline" TextAlign="TextAlign.Center" Class="rz-color-primary" Style="font-size: 1rem" />
            <RadzenText Text="Let your product sell itself." TextStyle="TextStyle.DisplayH1" TextAlign="TextAlign.Center" Style="max-width: 800px" />
            <RadzenText TextStyle="TextStyle.H5" TextAlign="TextAlign.Center" TagName="TagName.P" Style="max-width: 700px; line-height: 1.6" Class="rz-text-secondary-color">
                Create no-code interactive walkthroughs of your software. Embed them on your website, share in sales emails, or use in ad campaigns.
            </RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" JustifyContent="JustifyContent.Center" Wrap="FlexWrap.Wrap" Class="rz-mt-8">
                <RadzenLink Text="Start Free Trial" Path="/register" Class="rz-button rz-button-lg rz-variant-flat rz-success rz-shade-default" Style="--rz-link-hover-text-decoration: none" />
                <RadzenLink Text="Book a Demo" Path="/contact" Class="rz-button rz-button-lg rz-variant-outlined rz-base rz-shade-default" Style="--rz-link-hover-text-decoration: none" />
            </RadzenStack>
        </RadzenStack>
        <RadzenImage Path="/images/product-form-builder.png" Style="width: 100%; max-width: 960px; margin: 0 auto; display: block; border-radius: 12px; box-shadow: 0 20px 48px rgba(0,0,0,0.08)" AlternateText="NavTour Product" />
    </RadzenColumn>
</RadzenRow>

@* ── 2. Logo Bar ── *@
<div style="padding: 3rem 0; background: var(--rz-base-100, #f5f5f5); border-bottom: 1px solid var(--rz-base-200, #e0e0e0)">
    <RadzenStack AlignItems="AlignItems.Center" Gap="1.5rem" Class="rz-mx-auto" Style="max-width: 1200px">
        <RadzenText Text="TRUSTED BY INNOVATIVE TEAMS" TextStyle="TextStyle.Overline" TextAlign="TextAlign.Center" Class="rz-text-secondary-color" />
        <RadzenStack Orientation="Orientation.Horizontal" Gap="2.5rem" JustifyContent="JustifyContent.Center" Wrap="FlexWrap.Wrap">
            <RadzenText Text="Acme Corp" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" Style="font-weight: 600" />
            <RadzenText Text="Beacon AI" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" Style="font-weight: 600" />
            <RadzenText Text="CloudStack" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" Style="font-weight: 600" />
            <RadzenText Text="DataPulse" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" Style="font-weight: 600" />
            <RadzenText Text="Elevate" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" Style="font-weight: 600" />
            <RadzenText Text="FinOps.io" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" Style="font-weight: 600" />
        </RadzenStack>
    </RadzenStack>
</div>

@* ── 3. Product Features — RadzenTabs ── *@
<div class="home-section">
    <RadzenStack AlignItems="AlignItems.Center" Gap="0" Class="rz-mb-8" Style="max-width: 1200px; margin: 0 auto">
        <RadzenText Text="One platform, three superpowers." TextStyle="TextStyle.H2" TextAlign="TextAlign.Center" />
    </RadzenStack>
    <RadzenTabs TabPosition="TabPosition.Top" Style="max-width: 1200px; margin: 0 auto">
        <Tabs>
            <RadzenTabsItem Text="Interactive Demos">
                <RadzenRow Gap="2rem" Class="rz-mt-6 rz-align-items-center">
                    <RadzenColumn Size="12" SizeMD="6" Class="rz-p-6">
                        <RadzenText Text="Build walkthroughs your buyers actually finish." TextStyle="TextStyle.H4" Class="rz-mb-4" />
                        <RadzenText TextStyle="TextStyle.Body1" TagName="TagName.P" Class="rz-text-secondary-color" Style="max-width: 480px; line-height: 1.7">
                            Build step-by-step product walkthroughs from screenshots or live captures. Add hotspots, tooltips, guided flows, and branching logic. No coding required.
                        </RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="width: 100%; aspect-ratio: 16/10; background: var(--rz-base-100, #f5f5f5); border: 1px solid var(--rz-base-200, #e0e0e0); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: var(--rz-text-secondary-color)">
                            <RadzenText Text="Interactive Demos Preview" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" />
                        </div>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenTabsItem>
            <RadzenTabsItem Text="Demo Hub">
                <RadzenRow Gap="2rem" Class="rz-mt-6 rz-align-items-center">
                    <RadzenColumn Size="12" SizeMD="6" Class="rz-p-6">
                        <RadzenText Text="Let prospects self-serve the right demo." TextStyle="TextStyle.H4" Class="rz-mb-4" />
                        <RadzenText TextStyle="TextStyle.Body1" TagName="TagName.P" Class="rz-text-secondary-color" Style="max-width: 480px; line-height: 1.7">
                            A centralized library where prospects self-serve demos by persona, use case, or product line. Reduces sales friction and lets buyers explore on their own terms.
                        </RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="width: 100%; aspect-ratio: 16/10; background: var(--rz-base-100, #f5f5f5); border: 1px solid var(--rz-base-200, #e0e0e0); border-radius: 12px; display: flex; align-items: center; justify-content: center">
                            <RadzenText Text="Demo Hub Preview" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" />
                        </div>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenTabsItem>
            <RadzenTabsItem Text="Analytics Dashboard">
                <RadzenRow Gap="2rem" Class="rz-mt-6 rz-align-items-center">
                    <RadzenColumn Size="12" SizeMD="6" Class="rz-p-6">
                        <RadzenText Text="Know exactly what resonates." TextStyle="TextStyle.H4" Class="rz-mb-4" />
                        <RadzenText TextStyle="TextStyle.Body1" TagName="TagName.P" Class="rz-text-secondary-color" Style="max-width: 480px; line-height: 1.7">
                            Track who viewed your demos, how far they got, where they dropped off, and which features generated the most interest. Feed intent data directly into your CRM.
                        </RadzenText>
                    </RadzenColumn>
                    <RadzenColumn Size="12" SizeMD="6">
                        <div style="width: 100%; aspect-ratio: 16/10; background: var(--rz-base-100, #f5f5f5); border: 1px solid var(--rz-base-200, #e0e0e0); border-radius: 12px; display: flex; align-items: center; justify-content: center">
                            <RadzenText Text="Analytics Dashboard Preview" TextStyle="TextStyle.Body2" Class="rz-text-secondary-color" />
                        </div>
                    </RadzenColumn>
                </RadzenRow>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
</div>

@* ── 4. Buyer Journey — 6 Cards ── *@
<div class="home-section" style="background: var(--rz-base-100, #f5f5f5)">
    <RadzenStack AlignItems="AlignItems.Center" Gap="0" Class="rz-mb-10" Style="max-width: 1200px; margin: 0 auto">
        <RadzenText Text="Demos for every stage of the buyer journey." TextStyle="TextStyle.H2" TextAlign="TextAlign.Center" />
    </RadzenStack>
    <RadzenRow Gap="1.5rem" Class="rz-mx-auto" Style="max-width: 1200px">
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Outlined" Class="rz-p-6" Style="height: 100%">
                <RadzenText Text="Paid Ads" TextStyle="TextStyle.H5" Class="rz-mb-2" />
                <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.P" Class="rz-text-secondary-color" Style="line-height: 1.6">
                    Replace static landing pages with interactive demos that convert ad clicks into qualified pipeline.
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Outlined" Class="rz-p-6" Style="height: 100%">
                <RadzenText Text="Website Embeds" TextStyle="TextStyle.H5" Class="rz-mb-2" />
                <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.P" Class="rz-text-secondary-color" Style="line-height: 1.6">
                    Let visitors explore your product on your homepage before they ever talk to sales.
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Outlined" Class="rz-p-6" Style="height: 100%">
                <RadzenText Text="Pre-Call Discovery" TextStyle="TextStyle.H5" Class="rz-mb-2" />
                <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.P" Class="rz-text-secondary-color" Style="line-height: 1.6">
                    Send personalized demos before meetings so prospects arrive educated and ready to buy.
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Outlined" Class="rz-p-6" Style="height: 100%">
                <RadzenText Text="Post-Call Follow-Up" TextStyle="TextStyle.H5" Class="rz-mb-2" />
                <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.P" Class="rz-text-secondary-color" Style="line-height: 1.6">
                    Reinforce your pitch with a shareable walkthrough champions can forward to decision makers.
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Outlined" Class="rz-p-6" Style="height: 100%">
                <RadzenText Text="Onboarding" TextStyle="TextStyle.H5" Class="rz-mb-2" />
                <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.P" Class="rz-text-secondary-color" Style="line-height: 1.6">
                    Guide new users through your product with interactive walkthroughs that reduce time-to-value.
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="4">
            <RadzenCard Variant="Variant.Outlined" Class="rz-p-6" Style="height: 100%">
                <RadzenText Text="Upsell Campaigns" TextStyle="TextStyle.H5" Class="rz-mb-2" />
                <RadzenText TextStyle="TextStyle.Body2" TagName="TagName.P" Class="rz-text-secondary-color" Style="line-height: 1.6">
                    Show existing customers the features they haven't discovered yet to drive expansion revenue.
                </RadzenText>
            </RadzenCard>
        </RadzenColumn>
    </RadzenRow>
</div>

@* ── 5. Metrics ── *@
<div class="home-section">
    <RadzenStack AlignItems="AlignItems.Center" Gap="0" Class="rz-mb-10" Style="max-width: 1200px; margin: 0 auto">
        <RadzenText Text="The numbers speak for themselves." TextStyle="TextStyle.H2" TextAlign="TextAlign.Center" />
    </RadzenStack>
    <RadzenRow Gap="2rem" Class="rz-mx-auto" Style="max-width: 1200px">
        <RadzenColumn Size="6" SizeMD="3">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenText Text="3x" TextStyle="TextStyle.DisplayH1" TextAlign="TextAlign.Center" Class="rz-color-primary" />
                <RadzenText Text="higher engagement vs. static screenshots" TextStyle="TextStyle.Body2" TextAlign="TextAlign.Center" Class="rz-text-secondary-color" Style="max-width: 200px" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenText Text="47%" TextStyle="TextStyle.DisplayH1" TextAlign="TextAlign.Center" Class="rz-color-primary" />
                <RadzenText Text="faster deal velocity" TextStyle="TextStyle.Body2" TextAlign="TextAlign.Center" Class="rz-text-secondary-color" Style="max-width: 200px" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenText Text="2x" TextStyle="TextStyle.DisplayH1" TextAlign="TextAlign.Center" Class="rz-color-primary" />
                <RadzenText Text="more qualified pipeline" TextStyle="TextStyle.Body2" TextAlign="TextAlign.Center" Class="rz-text-secondary-color" Style="max-width: 200px" />
            </RadzenStack>
        </RadzenColumn>
        <RadzenColumn Size="6" SizeMD="3">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenText Text="60%" TextStyle="TextStyle.DisplayH1" TextAlign="TextAlign.Center" Class="rz-color-primary" />
                <RadzenText Text="reduction in first-call no-shows" TextStyle="TextStyle.Body2" TextAlign="TextAlign.Center" Class="rz-text-secondary-color" Style="max-width: 200px" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
</div>

@* ── 6. Testimonial ── *@
<div class="home-section" style="background: var(--rz-base-100, #f5f5f5)">
    <RadzenStack AlignItems="AlignItems.Center" Style="max-width: 1200px; margin: 0 auto">
        <RadzenCard Variant="Variant.Text" Style="max-width: 700px; text-align: center">
            <RadzenText TextStyle="TextStyle.H4" TagName="TagName.P" Style="font-style: italic; line-height: 1.7" Class="rz-mb-6">
                "NavTour transformed how we share product demos with prospects. Our sales cycle shortened by 40% and engagement went through the roof."
            </RadzenText>
            <RadzenText Text="VP of Sales" TextStyle="TextStyle.Subtitle1" TextAlign="TextAlign.Center" />
            <RadzenText Text="Enterprise SaaS Company" TextStyle="TextStyle.Body2" TextAlign="TextAlign.Center" Class="rz-text-secondary-color" />
        </RadzenCard>
    </RadzenStack>
</div>

@* ── 7. Trust Badges ── *@
<div style="padding: 3rem 0; background: #fff; border-top: 1px solid var(--rz-base-200, #e0e0e0); border-bottom: 1px solid var(--rz-base-200, #e0e0e0)">
    <RadzenStack Orientation="Orientation.Horizontal" Gap="3rem" JustifyContent="JustifyContent.Center" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap">
        <RadzenText Text="SOC 2 Type II" TextStyle="TextStyle.Body2" Style="font-weight: 600" Class="rz-text-secondary-color" />
        <RadzenText Text="Microsoft Azure" TextStyle="TextStyle.Body2" Style="font-weight: 600" Class="rz-text-secondary-color" />
        <RadzenText Text="99.9% Uptime" TextStyle="TextStyle.Body2" Style="font-weight: 600" Class="rz-text-secondary-color" />
        <RadzenText Text="GDPR Compliant" TextStyle="TextStyle.Body2" Style="font-weight: 600" Class="rz-text-secondary-color" />
    </RadzenStack>
</div>

@* ── 8. Final CTA ── *@
<div class="home-section" style="background: var(--rz-base-100, #f5f5f5)">
    <RadzenRow Class="rz-mx-auto" Style="max-width: 1200px">
        <RadzenColumn Size="12">
            <RadzenStack AlignItems="AlignItems.Center" Gap="0">
                <RadzenText Text="Turn demos into deals." TextStyle="TextStyle.H2" TextAlign="TextAlign.Center" />
                <RadzenText TextStyle="TextStyle.Body1" TextAlign="TextAlign.Center" TagName="TagName.P" Class="rz-text-secondary-color rz-mt-4" Style="max-width: 480px; line-height: 1.6">
                    Join hundreds of teams using NavTour to accelerate their sales pipeline.
                </RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" JustifyContent="JustifyContent.Center" Class="rz-mt-8">
                    <RadzenLink Text="Start Free Trial" Path="/register" Class="rz-button rz-button-lg rz-variant-flat rz-success rz-shade-default" Style="--rz-link-hover-text-decoration: none" />
                </RadzenStack>
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>
</div>

<style>
    /* Section spacing only — no color definitions */
    .home-section {
        padding: 5rem 1.5rem;
    }
</style>
