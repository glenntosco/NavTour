@page "/"
@layout MarketingLayout

<PageTitle>NavTour — Upload Screenshots. AI Builds Your Tour.</PageTitle>
<HeadContent>
    <meta name="description" content="Upload screenshots and AI generates a complete interactive product tour in 60 seconds. AI-powered voiceover, smart annotations, and lead capture built in." />
    <meta property="og:title" content="NavTour — Upload Screenshots. AI Builds Your Tour." />
    <meta property="og:description" content="The AI demo platform that turns screenshots into interactive product tours in under 60 seconds." />
</HeadContent>

@* ═══════════════════════════════════════════════════════════════
   1. HERO
   ═══════════════════════════════════════════════════════════════ *@
<HeroSection
    Eyebrow="Introducing AI Tour Generator"
    Title="Upload Screenshots. AI Builds Your Tour."
    Subtitle="NavTour uses Claude AI to analyze your product screens, generate guided annotations, and write natural voiceover scripts — all in under 60 seconds."
    PrimaryCtaText="Start Building Free →"
    PrimaryCtaUrl="/register"
    SecondaryCtaText="See It In Action"
    SecondaryCtaUrl="/contact"
    ImageUrl="/images/product-form-builder.png" />

@* ═══════════════════════════════════════════════════════════════
   2. SOCIAL PROOF
   ═══════════════════════════════════════════════════════════════ *@
<section class="mkt-social-proof">
    <div class="mkt-container text-center">
        <div style="display:flex;align-items:center;justify-content:center;gap:var(--space-8);margin-bottom:var(--space-8)">
            <div style="display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--text-secondary)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nt-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <strong>4.9/5</strong> on G2
            </div>
            <div style="width:1px;height:20px;background:var(--neutral-300)"></div>
            <div style="font-size:var(--text-sm);color:var(--text-secondary)">
                Trusted by <strong>500+</strong> product-led teams
            </div>
        </div>
        <LogoGrid Companies='new() { "Apex Financial", "Meridian Health", "CloudScale", "TerraLogic", "Pinnacle SaaS", "Vantage CRM", "Horizon Ops", "NovaBridge" }' Columns="8" />
    </div>
</section>

@* ═══════════════════════════════════════════════════════════════
   3. AI DEEP DIVE — Tour Generator
   ═══════════════════════════════════════════════════════════════ *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <div class="mkt-eyebrow" style="color:var(--nt-accent);font-size:var(--text-sm);font-weight:600;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:var(--space-3)">Powered by Claude AI</div>
            <h2>One Click. Complete Tour.</h2>
            <p style="max-width:600px;margin:var(--space-4) auto 0;color:var(--text-secondary);font-size:var(--text-lg)">
                Click "AI Generate" in the editor and Claude Opus analyzes every frame of your demo — identifying UI elements, generating step-by-step annotations, and writing voiceover scripts.
            </p>
        </div>

        <div class="mkt-grid mkt-grid-3 reveal-stagger" style="margin-top:var(--space-12)">
            <div class="mkt-feature-card">
                <div class="mkt-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--nt-accent)" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </div>
                <h3>Screenshot Analysis</h3>
                <p>AI reads your HTML frames and understands the UI layout, navigation patterns, and key elements — no manual tagging needed.</p>
            </div>
            <div class="mkt-feature-card">
                <div class="mkt-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--nt-accent)" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <h3>Smart Annotations</h3>
                <p>Generates titled tooltips with contextual descriptions, positioned precisely where they matter most on each screen.</p>
            </div>
            <div class="mkt-feature-card">
                <div class="mkt-feature-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--nt-accent)" stroke-width="2" stroke-linecap="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/></svg>
                </div>
                <h3>Voiceover Scripts</h3>
                <p>Natural, conversational voiceover text for every step — ready for AI voice generation with 24+ ElevenLabs voices.</p>
            </div>
        </div>
    </div>
</section>

