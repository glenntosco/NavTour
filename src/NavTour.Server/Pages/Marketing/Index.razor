    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>@L["home_features_title"]</h2>
        </div>
        <div class="reveal-stagger" style="display:flex;flex-direction:column;gap:var(--space-16)">
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_feat1_label"]</div>
                    <h3>@L["home_feat1_title"]</h3>
                    <p>@L["home_feat1_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">AI Copilot Interface</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_feat2_label"]</div>
                    <h3>@L["home_feat2_title"]</h3>
                    <p>@L["home_feat2_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Smart Editor Interface</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_feat3_label"]</div>
                    <h3>@L["home_feat3_title"]</h3>
                    <p>@L["home_feat3_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Personalization Engine</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_feat4_label"]</div>
                    <h3>@L["home_feat4_title"]</h3>
                    <p>@L["home_feat4_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Intent Scoring Dashboard</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_feat5_label"]</div>
                    <h3>@L["home_feat5_title"]</h3>
                    <p>@L["home_feat5_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Visual Demo Builder</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_feat6_label"]</div>
                    <h3>@L["home_feat6_title"]</h3>
                    <p>@L["home_feat6_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Integration Hub</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_feat7_label"]</div>
                    <h3>@L["home_feat7_title"]</h3>
                    <p>@L["home_feat7_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Team Workspace</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* 6. Metrics *@
<section class="mkt-section-alt" style="background:var(--nt-primary-light)">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>@L["home_metrics_title"]</h2>
        </div>
        <div class="mkt-grid mkt-grid-4 reveal-stagger">
            <MetricCard Value="@L["home_metric1_value"].Value" Label="@L["home_metric1_label"].Value" />
            <MetricCard Value="@L["home_metric2_value"].Value" Label="@L["home_metric2_label"].Value" />
            <MetricCard Value="@L["home_metric3_value"].Value" Label="@L["home_metric3_label"].Value" />
            <MetricCard Value="@L["home_metric4_value"].Value" Label="@L["home_metric4_label"].Value" />
        </div>
    </div>
</section>

@* 7. Testimonial *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <TestimonialCard Featured="true"
            Quote="@L["home_testimonial_quote"].Value"
            Name="@L["home_testimonial_name"].Value"
            Title="@L["home_testimonial_title"].Value"
            Company="@L["home_testimonial_company"].Value"
            Metric="@L["home_testimonial_metric"].Value"
            MetricLabel="@L["home_testimonial_metric_label"].Value" />
    </div>
</section>

@* 8. Bottom CTA *@
<CtaSection Dark="true"
    Title="@L["home_cta_title"].Value"
    Subtitle="@L["home_cta_subtitle"].Value"
    CtaText="@L["home_cta_text"].Value"
    CtaUrl="/register"
    SecondaryCtaText="@L["home_cta_secondary_text"].Value"
    SecondaryCtaUrl="/contact" />
