@page "/"
@layout MarketingLayout
@rendermode InteractiveServer

<PageTitle>NavTour — Interactive Product Demos That Sell</PageTitle>
<HeadContent>
    <meta name="description" content="Create no-code interactive walkthroughs of your software. Embed on your website, share in sales emails, or use in ad campaigns — and watch engagement soar." />
    <meta property="og:title" content="NavTour — Let your product sell itself." />
    <meta property="og:description" content="Create no-code interactive walkthroughs of your software. Embed, share, and convert." />
    <meta property="og:url" content="https://navtour.cloud/" />
    <meta property="og:image" content="https://navtour.cloud/images/product-form-builder.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NavTour" />
    <link rel="canonical" href="https://navtour.cloud/" />
    <link rel="alternate" hreflang="en" href="https://navtour.cloud/" />
    <link rel="alternate" hreflang="es" href="https://navtour.cloud/?culture=es&amp;ui-culture=es" />
    <link rel="alternate" hreflang="x-default" href="https://navtour.cloud/" />
</HeadContent>

@* ── 1. Hero — Centered, editorial, confident ── *@
<section class="home-hero">
    <div class="home-container">
        <RadzenStack AlignItems="AlignItems.Center" Gap="0">
            <span class="home-overline">Interactive Product Demos</span>
            <h1 class="home-headline">Accelerate the buyer<br />journey with demos</h1>
            <p class="home-subtitle">
                From first touch on the website, to pre-call discovery and post-call follow up,
                speed up every step of the buyer journey with NavTour's demo automation platform.
            </p>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="1rem" JustifyContent="JustifyContent.Center" Wrap="FlexWrap.Wrap" Class="rz-mt-10">
                <a href="/product" class="home-btn home-btn-dark">Explore product <span class="home-arrow-down">&#8595;</span></a>
                <a href="/contact" class="home-btn home-btn-outlined">Book a Demo</a>
            </RadzenStack>

            @* Product selector pills *@
            <div class="home-product-pills">
                <button class="home-pill @(_activeProduct == 0 ? "active" : "")" @onclick="() => _activeProduct = 0">
                    <span class="home-dot home-dot-blue"></span> Interactive Demos
                </button>
                <button class="home-pill @(_activeProduct == 1 ? "active" : "")" @onclick="() => _activeProduct = 1">
                    <span class="home-dot home-dot-teal"></span> Demo Hub
                </button>
                <button class="home-pill @(_activeProduct == 2 ? "active" : "")" @onclick="() => _activeProduct = 2">
                    <span class="home-dot home-dot-orange"></span> Analytics
                </button>
            </div>

            @* Live interactive demo embed *@
            <div class="home-hero-screenshot" style="position: relative; width: 100%; max-width: 1000px; margin: 0 auto;">
                <div style="position: relative; padding-bottom: 62.5%; height: 0; overflow: hidden;">
                    <iframe
                        src="https://navtour.cloud/demo/navtour"
                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; border-radius: 8px;"
                        loading="lazy"
                        title="NavTour Interactive Demo"
                        allowfullscreen></iframe>
                </div>
            </div>
        </RadzenStack>
    </div>
</section>

@* ── 2. Trusted By (light gray bg) ── *@
<section class="home-section home-section-gray">
    <div class="home-container">
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Wrap="FlexWrap.Wrap" Gap="1rem" Class="rz-mb-8">
            <span class="home-section-label">Trusted by innovative teams</span>
            <a href="/customers" class="home-link">Meet our customers <span>&rarr;</span></a>
        </RadzenStack>
        <div class="home-logos">
            <span class="home-logo-placeholder">Acme Corp</span>
            <span class="home-logo-placeholder">Beacon AI</span>
            <span class="home-logo-placeholder">CloudStack</span>
            <span class="home-logo-placeholder">DataPulse</span>
            <span class="home-logo-placeholder">Elevate</span>
            <span class="home-logo-placeholder">FinOps.io</span>
        </div>
    </div>
</section>

@* ── 3. Product Features — 3 vertical cards (white bg) ── *@
<section class="home-section">
    <div class="home-container">
        @* Card 1: Interactive Demos *@
        <div class="home-feature-card">
            <RadzenRow Gap="2rem" Class="rz-align-items-center">
                <RadzenColumn Size="12" SizeMD="5">
                    <div class="home-feature-label"><span class="home-dot home-dot-blue"></span> Interactive Demos</div>
                    <h2 class="home-feature-headline">Build interactive demos faster with AI Copilot</h2>
                    <p class="home-feature-desc">
                        Capture your product with our Chrome extension, then let AI generate guided tours
                        with tooltips, hotspots, and branching logic. No coding required.
                    </p>
                    <a href="/product" class="home-link">Explore Interactive Demos <span>&rarr;</span></a>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="7">
                    <div class="home-feature-image-placeholder">
                        <span>Interactive Demos Preview</span>
                    </div>
                </RadzenColumn>
            </RadzenRow>
        </div>

        @* Card 2: Demo Hub *@
        <div class="home-feature-card">
            <RadzenRow Gap="2rem" Class="rz-align-items-center">
                <RadzenColumn Size="12" SizeMD="5">
                    <div class="home-feature-label"><span class="home-dot home-dot-teal"></span> Demo Hub</div>
                    <h2 class="home-feature-headline">Demo automation for live demos and pre &amp; post-call discovery</h2>
                    <p class="home-feature-desc">
                        A centralized library where prospects self-serve demos by persona, use case, or product line.
                        Reduces sales friction and lets buyers explore on their own terms.
                    </p>
                    <a href="/product" class="home-link">Explore Demo Hub <span>&rarr;</span></a>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="7">
                    <div class="home-feature-image-placeholder">
                        <span>Demo Hub Preview</span>
                    </div>
                </RadzenColumn>
            </RadzenRow>
        </div>

        @* Card 3: Analytics *@
        <div class="home-feature-card">
            <RadzenRow Gap="2rem" Class="rz-align-items-center">
                <RadzenColumn Size="12" SizeMD="5">
                    <div class="home-feature-label"><span class="home-dot home-dot-orange"></span> Analytics</div>
                    <h2 class="home-feature-headline">Track engagement and feed intent data to your CRM</h2>
                    <p class="home-feature-desc">
                        Know who viewed your demos, how far they got, where they dropped off,
                        and which features generated the most interest. Feed data directly into your CRM.
                    </p>
                    <a href="/product" class="home-link">Explore Analytics <span>&rarr;</span></a>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="7">
                    <div class="home-feature-image-placeholder">
                        <span>Analytics Preview</span>
                    </div>
                </RadzenColumn>
            </RadzenRow>
        </div>
    </div>
</section>

@* ── 4. Buyer Journey (light gray bg) ── *@
<section class="home-section home-section-gray">
    <div class="home-container">
        <h2 class="home-section-headline">Use demos at any point in the buyer journey.</h2>
        <RadzenRow Gap="3rem" Class="rz-mt-10">
            <RadzenColumn Size="12" SizeMD="5">
                <div class="home-journey-image-placeholder">
                    <span>Buyer Journey Visual</span>
                </div>
            </RadzenColumn>
            <RadzenColumn Size="12" SizeMD="7">
                <div class="home-journey-list">
                    <div class="home-journey-item">
                        <div class="home-journey-item-header">
                            <span class="home-dot home-dot-blue"></span>
                            <span class="home-journey-label">Retargeting campaigns</span>
                        </div>
                        <h3 class="home-journey-title">LinkedIn, Google, Reddit Ads</h3>
                        <p class="home-journey-desc">Replace static landing pages with interactive demos that convert ad clicks into qualified pipeline.</p>
                    </div>
                    <div class="home-journey-item">
                        <div class="home-journey-item-header">
                            <span class="home-dot home-dot-teal"></span>
                            <span class="home-journey-label">Website embed</span>
                        </div>
                        <h3 class="home-journey-title">Persona or use-case website embeds</h3>
                        <p class="home-journey-desc">Let visitors explore your product on your homepage before they ever talk to sales.</p>
                    </div>
                    <div class="home-journey-item">
                        <div class="home-journey-item-header">
                            <span class="home-dot home-dot-orange"></span>
                            <span class="home-journey-label">Pre-call discovery</span>
                        </div>
                        <h3 class="home-journey-title">Pre-live demo asset</h3>
                        <p class="home-journey-desc">Send personalized demos before meetings so prospects arrive educated and ready to buy.</p>
                    </div>
                    <div class="home-journey-item">
                        <div class="home-journey-item-header">
                            <span class="home-dot home-dot-blue"></span>
                            <span class="home-journey-label">Champion enablement</span>
                        </div>
                        <h3 class="home-journey-title">Post-call follow-up</h3>
                        <p class="home-journey-desc">Reinforce your pitch with a shareable walkthrough champions can forward to decision makers.</p>
                    </div>
                    <div class="home-journey-item">
                        <div class="home-journey-item-header">
                            <span class="home-dot home-dot-teal"></span>
                            <span class="home-journey-label">Upsell campaigns</span>
                        </div>
                        <h3 class="home-journey-title">Feature launches</h3>
                        <p class="home-journey-desc">Show existing customers the features they haven't discovered yet to drive expansion revenue.</p>
                    </div>
                    <div class="home-journey-item">
                        <div class="home-journey-item-header">
                            <span class="home-dot home-dot-orange"></span>
                            <span class="home-journey-label">Booth enablement</span>
                        </div>
                        <h3 class="home-journey-title">Conference demos</h3>
                        <p class="home-journey-desc">Run polished, self-guided demos at trade shows without needing a live environment.</p>
                    </div>
                </div>
            </RadzenColumn>
        </RadzenRow>
    </div>
</section>

@* ── 5. Social Proof / G2 (white bg) ── *@
<section class="home-section">
    <div class="home-container" style="text-align: center">
        <div class="home-g2-stars">&#9733; &#9733; &#9733; &#9733; &#9733;</div>
        <p class="home-g2-rating">4.8 stars &middot; 700+ reviews</p>
        <h2 class="home-section-headline">Top-rated platform and customer service</h2>
    </div>
</section>

@* ── 6. Impact Metrics (white bg) ── *@
<section class="home-section" style="padding-bottom: 3rem">
    <div class="home-container">
        <h2 class="home-section-headline" style="margin-bottom: 3rem">Impact that's impossible to ignore.</h2>
        <div class="home-metrics-row">
            <div class="home-metric-card">
                <span class="home-metric-value">$10M</span>
                <span class="home-metric-label">ARR influenced</span>
            </div>
            <div class="home-metric-card">
                <span class="home-metric-value">450%</span>
                <span class="home-metric-label">increase in trial signups</span>
            </div>
            <div class="home-metric-card">
                <span class="home-metric-value">1,000s</span>
                <span class="home-metric-label">of high-intent leads</span>
            </div>
            <div class="home-metric-card">
                <span class="home-metric-value">15%</span>
                <span class="home-metric-label">of website leads</span>
            </div>
        </div>
    </div>
</section>

@* ── 7. Customer Logos + Testimonial (light gray bg) ── *@
<section class="home-section home-section-gray">
    <div class="home-container">
        <div class="home-logos rz-mb-10">
            <span class="home-logo-placeholder">Acme Corp</span>
            <span class="home-logo-placeholder">Beacon AI</span>
            <span class="home-logo-placeholder">CloudStack</span>
            <span class="home-logo-placeholder">DataPulse</span>
            <span class="home-logo-placeholder">Elevate</span>
        </div>
        <blockquote class="home-testimonial">
            <p>&ldquo;Since launching NavTour, it's been responsible for 15% of the leads on our website.&rdquo;</p>
            <footer>
                <strong>VP of Marketing</strong>
                <span class="home-testimonial-company">Enterprise SaaS Company</span>
            </footer>
        </blockquote>
    </div>
</section>

@* ── 8. Final CTA (white bg) ── *@
<section class="home-section home-cta-section">
    <div class="home-container" style="text-align: center">
        <h2 class="home-headline" style="font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 1rem">Turn demos into deals.</h2>
        <p class="home-subtitle" style="margin-bottom: 2.5rem">
            Join hundreds of teams using NavTour to accelerate their sales pipeline.
        </p>
        <form class="home-cta-form" @onsubmit:preventDefault>
            <input type="email" placeholder="Enter your work email" class="home-cta-input" @bind="_ctaEmail" />
            <a href="/contact" class="home-btn home-btn-dark">Book a demo</a>
        </form>
    </div>
</section>

@code {
    private int _activeProduct = 0;
    private string _ctaEmail = "";
}

<style>
    /* ── Typography ── */
    .home-headline,
    .home-feature-headline,
    .home-section-headline,
    .home-metric-value {
        font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
        color: #0F172A;
    }

    /* ── Container ── */
    .home-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
    }

    /* ── Section Spacing ── */
    .home-section {
        padding: 6rem 0;
    }

    .home-section-gray {
        background: #F8FAFC;
    }

    /* ── Hero ── */
    .home-hero {
        padding: 6rem 0 4rem;
        background: #fff;
    }

    .home-overline {
        display: inline-block;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: #64748B;
        margin-bottom: 1.5rem;
    }

    .home-headline {
        font-size: clamp(2.5rem, 5.5vw, 4.5rem);
        font-weight: 800;
        line-height: 1.08;
        letter-spacing: -0.025em;
        text-align: center;
        margin: 0 0 1.5rem;
        color: #0F172A;
    }

    .home-subtitle {
        font-family: 'Inter', sans-serif;
        font-size: 1.125rem;
        line-height: 1.7;
        color: #64748B;
        text-align: center;
        max-width: 640px;
        margin: 0 auto;
    }

    /* ── Buttons ── */
    .home-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 600;
        padding: 0.875rem 2rem;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.15s ease;
        cursor: pointer;
        border: none;
    }

    a.home-btn-dark,
    .home-btn-dark {
        background: #1E293B;
        color: #fff !important;
    }

    a.home-btn-dark:hover,
    .home-btn-dark:hover {
        background: #0F172A;
        color: #fff !important;
        text-decoration: none;
    }

    .home-btn-outlined {
        background: transparent;
        color: #0F172A;
        border: 1.5px solid #CBD5E1;
    }

    .home-btn-outlined:hover {
        border-color: #94A3B8;
        color: #0F172A;
        text-decoration: none;
    }

    .home-arrow-down {
        font-size: 1.1em;
    }

    /* ── Product Selector Pills ── */
    .home-product-pills {
        display: flex;
        gap: 0.75rem;
        margin-top: 3rem;
        margin-bottom: 3rem;
        flex-wrap: wrap;
        justify-content: center;
    }

    .home-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.9375rem;
        font-weight: 600;
        padding: 0.625rem 1.25rem;
        border-radius: 999px;
        border: 1.5px solid #E2E8F0;
        background: #fff;
        color: #475569;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .home-pill:hover {
        border-color: #94A3B8;
    }

    .home-pill.active {
        border-color: #1E293B;
        color: #0F172A;
        background: #F8FAFC;
    }

    /* ── Colored Dots ── */
    .home-dot {
        display: inline-block;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .home-dot-blue {
        background: #3B82F6;
    }

    .home-dot-teal {
        background: #14B8A6;
    }

    .home-dot-orange {
        background: #F59E0B;
    }

    /* ── Hero Screenshot ── */
    .home-hero-screenshot {
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        border-radius: 12px;
        box-shadow: 0 25px 60px rgba(15, 23, 42, 0.08), 0 4px 16px rgba(15, 23, 42, 0.04);
        overflow: hidden;
        border: 1px solid #E2E8F0;
    }

    /* ── Trusted By ── */
    .home-section-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.9375rem;
        font-weight: 600;
        color: #64748B;
    }

    .home-link {
        font-family: 'Inter', sans-serif;
        font-size: 0.9375rem;
        font-weight: 600;
        color: #3B82F6;
        text-decoration: none;
    }

    .home-link:hover {
        text-decoration: underline;
    }

    .home-logos {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 3rem;
        flex-wrap: wrap;
    }

    .home-logo-placeholder {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: #94A3B8;
        letter-spacing: 0.02em;
        user-select: none;
    }

    /* ── Feature Cards ── */
    .home-feature-card {
        padding: 3rem 0;
        border-bottom: 1px solid #F1F5F9;
    }

    .home-feature-card:last-child {
        border-bottom: none;
    }

    .home-feature-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #64748B;
        margin-bottom: 1rem;
    }

    .home-feature-headline {
        font-size: clamp(1.5rem, 2.5vw, 2rem);
        font-weight: 700;
        line-height: 1.2;
        letter-spacing: -0.015em;
        margin: 0 0 1rem;
    }

    .home-feature-desc {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        line-height: 1.7;
        color: #64748B;
        margin: 0 0 1.5rem;
        max-width: 440px;
    }

    .home-feature-image-placeholder {
        width: 100%;
        aspect-ratio: 16 / 10;
        background: #F8FAFC;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94A3B8;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
    }

    /* ── Section Headlines ── */
    .home-section-headline {
        font-size: clamp(1.75rem, 3.5vw, 2.75rem);
        font-weight: 700;
        line-height: 1.15;
        letter-spacing: -0.02em;
        text-align: center;
        margin: 0;
        color: #0F172A;
    }

    /* ── Buyer Journey ── */
    .home-journey-image-placeholder {
        width: 100%;
        aspect-ratio: 4 / 5;
        background: #F1F5F9;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94A3B8;
        font-family: 'Inter', sans-serif;
        font-size: 0.875rem;
        position: sticky;
        top: 2rem;
    }

    .home-journey-list {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .home-journey-item {
        padding: 1.5rem;
        border-radius: 10px;
        transition: background 0.15s ease;
    }

    .home-journey-item:hover {
        background: #F1F5F9;
    }

    .home-journey-item-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .home-journey-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.8125rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748B;
    }

    .home-journey-title {
        font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: #0F172A;
        margin: 0 0 0.5rem;
    }

    .home-journey-desc {
        font-family: 'Inter', sans-serif;
        font-size: 0.9375rem;
        line-height: 1.6;
        color: #64748B;
        margin: 0;
    }

    /* ── G2 / Social Proof ── */
    .home-g2-stars {
        font-size: 2rem;
        color: #F59E0B;
        letter-spacing: 0.1em;
        margin-bottom: 0.5rem;
    }

    .home-g2-rating {
        font-family: 'Inter', sans-serif;
        font-size: 1rem;
        font-weight: 600;
        color: #64748B;
        margin: 0 0 1.5rem;
    }

    /* ── Impact Metrics ── */
    .home-metrics-row {
        display: flex;
        gap: 1.5rem;
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        padding-bottom: 1rem;
    }

    .home-metric-card {
        flex: 1;
        min-width: 220px;
        background: #F8FAFC;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        padding: 2.5rem 2rem;
        text-align: center;
        scroll-snap-align: start;
    }

    .home-metric-value {
        display: block;
        font-size: clamp(2rem, 3.5vw, 3rem);
        font-weight: 800;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
    }

    .home-metric-label {
        font-family: 'Inter', sans-serif;
        font-size: 0.9375rem;
        color: #64748B;
        line-height: 1.5;
    }

    /* ── Testimonial ── */
    .home-testimonial {
        max-width: 700px;
        margin: 0 auto;
        text-align: center;
        border: none;
        padding: 0;
    }

    .home-testimonial p {
        font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
        font-size: clamp(1.25rem, 2vw, 1.5rem);
        font-weight: 600;
        line-height: 1.6;
        color: #0F172A;
        margin: 0 0 1.5rem;
    }

    .home-testimonial footer {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        align-items: center;
    }

    .home-testimonial footer strong {
        font-family: 'Inter', sans-serif;
        font-size: 0.9375rem;
