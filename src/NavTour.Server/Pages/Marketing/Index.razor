@page "/"
@layout MarketingLayout

<PageTitle>NavTour — Interactive Product Demos That Sell</PageTitle>
<HeadContent>
    <meta name="description" content="Create no-code interactive walkthroughs of your software. Embed on your website, share in sales emails, or use in ad campaigns — and watch engagement soar." />
    <meta property="og:title" content="NavTour — Let your product sell itself." />
    <meta property="og:description" content="Create no-code interactive walkthroughs of your software. Embed, share, and convert." />
    <meta property="og:url" content="https://navtour.cloud/" />
    <meta property="og:image" content="https://navtour.cloud/images/screenshots/dark-editor.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NavTour" />
    <link rel="canonical" href="https://navtour.cloud/" />
    <link rel="alternate" hreflang="en" href="https://navtour.cloud/" />
    <link rel="alternate" hreflang="es" href="https://navtour.cloud/?culture=es&amp;ui-culture=es" />
    <link rel="alternate" hreflang="x-default" href="https://navtour.cloud/" />
</HeadContent>

@* ── 1. Hero ── *@
<section class="mkt-section mkt-hero">
    <div class="mkt-container">
        <div class="mkt-hero-content">
            <p class="mkt-eyebrow" style="text-transform:uppercase;letter-spacing:0.1em;color:var(--nt-accent)">Interactive Demo Platform</p>
            <h1>Exceptional product demos<br />in minutes, not days</h1>
            <p class="mkt-hero-sub">
                Capture your product, build guided walkthroughs, and share interactive demos
                that accelerate every stage of the buyer journey.
            </p>
            <div class="mkt-hero-actions">
                <a href="/contact" class="mkt-btn mkt-btn-secondary mkt-btn-lg">Request a demo</a>
                <a href="/register" class="mkt-btn mkt-btn-primary mkt-btn-lg">Start for free &rarr;</a>
            </div>
        </div>
        <div class="mkt-hero-demo">
            <iframe
                src="/demo/navtour"
                loading="lazy"
                title="NavTour Interactive Demo"
                allowfullscreen></iframe>
        </div>
    </div>
</section>

@* ── 2. Trust Bar ── *@
<div class="mkt-trust">
    <p class="mkt-trust-label">Trusted by teams at</p>
    <div class="mkt-trust-logos">
        <span>P4 Software</span>
        <span>Barrdega</span>
        <span>OpenDocs</span>
        <span>CifraHQ</span>
        <span>Nerv Corp</span>
        <span>Certifyd</span>
    </div>
</div>

@* ── 3. Feature Tabs ── *@
<section class="mkt-section reveal" id="features">
    <div class="mkt-container">
        <div class="mkt-section-heading">
            <h2>Creating elegant product demos<br />doesn't have to be painful</h2>
        </div>
        <div class="mkt-tabs" role="tablist">
            <button class="mkt-tab active" role="tab" aria-selected="true" data-tab="0">Screenshot &amp; Video</button>
            <button class="mkt-tab" role="tab" aria-selected="false" data-tab="1">Guided HTML</button>
            <button class="mkt-tab" role="tab" aria-selected="false" data-tab="2">Demo Hub</button>
            <button class="mkt-tab" role="tab" aria-selected="false" data-tab="3">Analytics</button>
        </div>
        <div class="mkt-tab-panels">
            <div class="mkt-tab-panel active" data-panel="0">
                <div class="mkt-step-row">
                    <div class="mkt-step-row-content">
                        <h3>Pixel-perfect captures in one click</h3>
                        <p>Our Chrome extension captures any web application as a high-fidelity screenshot or video clip. No staging environments, no dev resources.</p>
                        <ul class="mkt-benefits">
                            <li>Full-page and element-level captures</li>
                            <li>Automatic asset optimization</li>
                            <li>Video recording with annotations</li>
                        </ul>
                    </div>
                    <div class="mkt-step-row-visual">
                        <img src="/images/screenshots/tab-screenshot-video.png" alt="Screenshot and video capture" class="mkt-screenshot-img mkt-lightbox" />
                    </div>
                </div>
            </div>
            <div class="mkt-tab-panel" data-panel="1">
                <div class="mkt-step-row">
                    <div class="mkt-step-row-content">
                        <h3>Interactive HTML walkthroughs</h3>
                        <p>Capture your product as real HTML and CSS, then overlay guided tooltips, hotspots, and branching logic. Visitors click through your actual UI.</p>
                        <ul class="mkt-benefits">
                            <li>Tooltips, modals, and hotspot annotations</li>
                            <li>Branching paths based on user choice</li>
                            <li>Personalization tokens like &#123;&#123;company&#125;&#125;</li>
                        </ul>
                    </div>
                    <div class="mkt-step-row-visual">
                        <img src="/images/screenshots/tab-guided-html.png" alt="Guided HTML demo editor" class="mkt-screenshot-img mkt-lightbox" />
                    </div>
                </div>
            </div>
            <div class="mkt-tab-panel" data-panel="2">
                <div class="mkt-step-row">
                    <div class="mkt-step-row-content">
                        <h3>A centralized demo library</h3>
                        <p>Organize demos by persona, use case, or product line. Let prospects self-serve the right demo at the right time without waiting for sales.</p>
                        <ul class="mkt-benefits">
                            <li>Filterable demo collections</li>
                            <li>Embeddable on your website</li>
                            <li>Lead capture gates per demo</li>
                        </ul>
                    </div>
                    <div class="mkt-step-row-visual">
                        <img src="/images/screenshots/tab-demo-hub.png" alt="Demo Hub editor" class="mkt-screenshot-img mkt-lightbox" />
                    </div>
                </div>
            </div>
            <div class="mkt-tab-panel" data-panel="3">
                <div class="mkt-step-row">
                    <div class="mkt-step-row-content">
                        <h3>Know what moves the needle</h3>
                        <p>Track who viewed your demos, how far they got, and which features generated the most interest. Feed intent data straight into your CRM.</p>
                        <ul class="mkt-benefits">
                            <li>Viewer-level engagement analytics</li>
                            <li>Drop-off and completion rates</li>
                            <li>CRM and Slack integrations</li>
                        </ul>
                    </div>
                    <div class="mkt-step-row-visual">
                        <img src="/images/screenshots/tab-analytics.png" alt="Analytics dashboard" class="mkt-screenshot-img mkt-lightbox" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── 4. How It Works ── *@
<section class="mkt-section mkt-section-alt reveal">
    <div class="mkt-container">
        <div class="mkt-section-heading">
            <p class="mkt-eyebrow">How it works</p>
            <h2>From capture to conversion in three steps</h2>
        </div>
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">01. Capture</div>
                <h3>Browser capture that preserves the real product</h3>
                <p>Our Chrome extension captures any web app as interactive HTML and CSS — not just a flat screenshot. No dev resources, no staging environment required.</p>
                <ul class="mkt-benefits">
                    <li>Click-to-capture with our Chrome extension</li>
                    <li>HTML/CSS snapshots with full fidelity fixes</li>
                    <li>Support for complex dashboards and SPAs</li>
                </ul>
            </div>
            <div class="mkt-step-row-visual">
                <img src="/images/screenshots/step-capture.png" alt="NavTour capture workflow" class="mkt-screenshot-img mkt-lightbox" />
            </div>
        </div>
    </div>
</section>

<section class="mkt-section reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">02. Build</div>
                <h3>Editor workflow for real guided demos</h3>
                <p>Add tooltips, hotspots, navigation cards, and branching logic with a point-and-click editor. Publish when ready, keep drafts private until then.</p>
                <ul class="mkt-benefits">
                    <li>Annotations, hotspots, and step triggers</li>
                    <li>Drawer-based editing for steps and annotations</li>
                    <li>Navigation cards with back, next, and finish states</li>
                </ul>
            </div>
            <div class="mkt-step-row-visual">
                <img src="/images/screenshots/step-build.png" alt="NavTour demo editor" class="mkt-screenshot-img mkt-lightbox" />
            </div>
        </div>
    </div>
</section>

<section class="mkt-section mkt-section-alt reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">03. Measure</div>
                <h3>Analytics that show how people actually engage</h3>
                <p>Track who viewed your demos, how far they got, and which steps drove the most interest. Feed engagement data directly into your CRM.</p>
                <ul class="mkt-benefits">
                    <li>Per-demo and global analytics pages</li>
                    <li>Step-level completion and engagement data</li>
                    <li>Lead capture visibility tied to demo activity</li>
                </ul>
            </div>
            <div class="mkt-step-row-visual">
                <img src="/images/screenshots/step-analytics.png" alt="NavTour analytics dashboard" class="mkt-screenshot-img mkt-lightbox" />
            </div>
        </div>
    </div>
</section>

@* ── 5. Dark Feature Section ── *@
<section class="mkt-section reveal" style="background:var(--neutral-950)">
    <div class="mkt-container">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <h2 style="color:white;font-size:var(--text-3xl);font-weight:var(--weight-bold)">Built for speed and simplicity</h2>
                <div style="display:flex;flex-direction:column;gap:var(--space-8);margin-top:var(--space-8)">
                    <div>
                        <h4 style="color:white;font-weight:var(--weight-semibold);margin-bottom:var(--space-2)">No-code builder</h4>
                        <p style="color:var(--neutral-400);margin:0">Point-and-click editor that anyone on your team can use. No engineering tickets, no staging environments.</p>
                    </div>
                    <div>
                        <h4 style="color:white;font-weight:var(--weight-semibold);margin-bottom:var(--space-2)">AI-powered editing</h4>
                        <p style="color:var(--neutral-400);margin:0">Let AI generate step descriptions, suggest annotations, and optimize your demo flow for maximum engagement.</p>
                    </div>
                    <div>
                        <h4 style="color:white;font-weight:var(--weight-semibold);margin-bottom:var(--space-2)">Instant personalization</h4>
                        <p style="color:var(--neutral-400);margin:0">Dynamic tokens replace company names, logos, and data so every prospect sees a demo built for them.</p>
                    </div>
                    <div>
                        <h4 style="color:white;font-weight:var(--weight-semibold);margin-bottom:var(--space-2)">Embed anywhere</h4>
                        <p style="color:var(--neutral-400);margin:0">Drop demos into your website, knowledge base, sales emails, or ad landing pages with a single embed code.</p>
                    </div>
                </div>
            </div>
            <div>
                <img src="/images/screenshots/dark-editor.png" alt="NavTour demo editor" class="mkt-screenshot-img-dark" />
            </div>
        </div>
    </div>
</section>

@* ── 6. CTA ── *@
<CtaSection Dark="true"
            Title="Start building interactive demos today"
            Subtitle="Create a free account. No credit card required."
            CtaText="Start for free"
            SecondaryCtaText="Request a demo"
            SecondaryCtaUrl="/contact" />

<script>
(function () {
    var tabs = document.querySelectorAll('.mkt-tab[data-tab]');
    var panels = document.querySelectorAll('.mkt-tab-panel[data-panel]');
    tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
            var idx = this.getAttribute('data-tab');
            tabs.forEach(function (t) { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
            panels.forEach(function (p) { p.classList.remove('active'); });
            this.classList.add('active');
            this.setAttribute('aria-selected', 'true');
            var target = document.querySelector('.mkt-tab-panel[data-panel="' + idx + '"]');
            if (target) target.classList.add('active');
        });
    });
}());
</script>
