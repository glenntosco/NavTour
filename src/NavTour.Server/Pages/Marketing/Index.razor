@page "/"
@layout MarketingLayout

<PageTitle>NavTour — AI-Powered Interactive Demo Platform</PageTitle>
<HeadContent>
    <meta name="description" content="AI builds your demos, personalizes them for every prospect, and tells you who's ready to buy. Capture your product and launch interactive demos in minutes." />
    <meta property="og:title" content="NavTour — AI-Powered Interactive Demo Platform" />
    <meta property="og:description" content="AI builds your demos, personalizes them for every prospect, and tells you who's ready to buy." />
</HeadContent>

@* 1. Hero *@
<HeroSection
    Eyebrow="AI-Powered Demo Platform"
    Title="AI builds your demos.<br/>AI personalizes your demos.<br/>AI closes your deals."
    Subtitle="Capture your product. AI creates interactive demos, personalizes them for every prospect, and tells you who's ready to buy."
    PrimaryCtaText="Start Building Free"
    PrimaryCtaUrl="/register"
    SecondaryCtaText="See It In Action"
    SecondaryCtaUrl="/contact" />

@* 2. Social Proof / Logo Bar *@
<section class="mkt-social-proof">
    <div class="mkt-container text-center">
        <p>Trusted by product-led teams</p>
        <LogoGrid Companies='new() { "Apex Financial", "Meridian Health", "CloudScale", "TerraLogic", "Pinnacle SaaS", "Vantage CRM", "Horizon Ops", "NovaBridge" }' Columns="8" />
        <p style="margin-top:var(--space-4);font-size:var(--text-xs);color:var(--neutral-400)">Rated 4.9/5 by users</p>
    </div>
</section>

@* 3. Use Cases — Buyer Journey *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>Demos for every stage of the buyer journey</h2>
        </div>
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <BuyerJourneyCard Icon="website" Title="Website Embeds" Description="Let visitors experience your product before talking to sales. Replace static screenshots with interactive, persona-specific tours." />
            <BuyerJourneyCard Icon="discovery" Title="Outbound Sales" Description="Send personalized demo links within minutes of a discovery call. Each prospect sees their own version." />
            <BuyerJourneyCard Icon="email" Title="Ad Campaigns" Description="Replace 'Request a Demo' with 'Take a Tour'. Convert ad traffic with instant interactive experiences." />
            <BuyerJourneyCard Icon="champion" Title="Pre-Call Discovery" Description="Let prospects explore your product before the sales call. Qualify interest and identify their use case automatically." />
            <BuyerJourneyCard Icon="tradeshow" Title="Post-Call Follow-Up" Description="Give champions a demo they can share internally. Help them sell your product inside their organization." />
            <BuyerJourneyCard Icon="onboarding" Title="Help Docs &amp; Onboarding" Description="Self-serve product tours for new customers. Reduce time-to-value and eliminate scheduling bottlenecks." />
        </div>
    </div>
</section>

@* 4. How It Works *@
<section class="mkt-section-alt">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>From capture to conversion in minutes</h2>
        </div>
        <div class="reveal-stagger" style="display:flex;flex-direction:column;gap:var(--space-16)">
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">Step 1</div>
                    <h3>Capture</h3>
                    <p>Install the Chrome extension. Click through your product. NavTour records every screen automatically as an interactive HTML snapshot.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Chrome Extension Capture</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">Step 2</div>
                    <h3>AI Builds Your Demo</h3>
                    <p>AI Copilot writes your guide copy, anchors tooltips to the right elements, creates branching paths, and personalizes content — all while you grab coffee.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">AI Copilot Building Demo</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">Step 3</div>
                    <h3>Launch &amp; Measure</h3>
                    <p>Embed anywhere. AI analytics tell you who's engaged, score buying intent, and feed signals directly to your CRM.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Analytics Dashboard + CRM Sync</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* 5. Features Deep Dive *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>Everything you need to demo at scale</h2>
        </div>
        <div class="reveal-stagger" style="display:flex;flex-direction:column;gap:var(--space-16)">
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">AI Copilot</div>
                    <h3>Click through your product. AI does the rest.</h3>
                    <p>AI auto-generates a complete demo draft — guide copy, tooltip anchors, story flow, and branching logic. Trained on best practices from thousands of high-performing demos.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">AI Copilot Interface</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">Smart Editor</div>
                    <h3>Edit demos in plain English.</h3>
                    <p>Tell AI what to change: "Replace all company names with fintech brands." It handles text, dates, pricing — across all your demos, instantly.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Smart Editor Interface</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">AI Personalization Engine</div>
                    <h3>Every prospect sees THEIR version.</h3>
                    <p>Dynamic variables swap company name, logo, and data fields automatically. Bulk-generate 50 custom demos from one template. AI suggests what to personalize.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Personalization Engine</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">AI Analytics &amp; Intent</div>
                    <h3>AI tells you who's ready to buy.</h3>
                    <p>AI scores viewer engagement and predicts buying intent. Identifies companies viewing demos without form fills. Signals feed directly to CRM.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Intent Scoring Dashboard</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">No-Code Editor</div>
                    <h3>Drag, drop, publish.</h3>
                    <p>Hotspots, tooltips, modals, multi-step flows, conditional branching — all without writing a single line of code.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Visual Demo Builder</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">Integrations</div>
                    <h3>Connects to your stack.</h3>
                    <p>HubSpot, Salesforce, Marketo, Slack, Zapier, REST API. Demo data flows wherever you need it.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Integration Hub</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">Team Workspace</div>
                    <h3>Scale your demo operation.</h3>
                    <p>Shared demo library, templates, version control, role-based permissions, and AI brand voice memory across all team members.</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Team Workspace</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* 6. Metrics *@
<section class="mkt-section-alt" style="background:var(--nt-primary-light)">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>Results that speak for themselves</h2>
        </div>
        <div class="mkt-grid mkt-grid-4 reveal-stagger">
            <MetricCard Value="10x" Label="Faster demo creation with AI" />
            <MetricCard Value="47%" Label="Increase in qualified leads" />
            <MetricCard Value="< 5 min" Label="First AI demo, no training" />
            <MetricCard Value="2.4x" Label="Faster sales cycle" />
        </div>
    </div>
</section>

@* 7. Testimonial *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <TestimonialCard Featured="true"
            Quote="NavTour replaced our entire demo environment. Our sales team creates custom demos in minutes instead of days. The AI copilot alone saved us 20 hours a week."
            Name="Sarah Chen"
            Title="VP of Sales Engineering"
            Company="CloudScale"
            Metric="20 hrs/wk"
            MetricLabel="saved with AI copilot" />
    </div>
</section>

@* 8. Bottom CTA *@
<CtaSection Dark="true"
    Title="Let AI build, personalize, and optimize your demos — starting now"
    Subtitle="Free forever — 1 demo, 10 frames. No credit card. Build your first interactive demo in under 10 minutes."
    CtaText="Start Building Free"
    CtaUrl="/register"
    SecondaryCtaText="Book a Demo"
    SecondaryCtaUrl="/contact" />
