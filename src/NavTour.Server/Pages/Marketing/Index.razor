@page "/"
@layout MarketingLayout

<PageTitle>NavTour — Interactive Product Demos That Sell</PageTitle>
<HeadContent>
    <meta name="description" content="Create no-code interactive walkthroughs of your software. Embed on your website, share in sales emails, or use in ad campaigns — and watch engagement soar." />
    <meta property="og:title" content="NavTour — Let your product sell itself." />
    <meta property="og:description" content="Create no-code interactive walkthroughs of your software. Embed, share, and convert." />
    <meta property="og:url" content="https://navtour.cloud/" />
    <meta property="og:image" content="https://navtour.cloud/images/product-form-builder.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="NavTour" />
    <link rel="canonical" href="https://navtour.cloud/" />
    <link rel="alternate" hreflang="en" href="https://navtour.cloud/" />
    <link rel="alternate" hreflang="es" href="https://navtour.cloud/?culture=es&amp;ui-culture=es" />
    <link rel="alternate" hreflang="x-default" href="https://navtour.cloud/" />
</HeadContent>

@* ── 1. Hero ── *@
<HeroSection
    Eyebrow="Interactive Product Demos"
    Title="Let your product sell itself."
    Subtitle="Create no-code interactive walkthroughs of your software. Embed them on your website, share in sales emails, or use in ad campaigns — and watch engagement soar."
    PrimaryCtaText="Start Free Trial"
    PrimaryCtaUrl="/register"
    SecondaryCtaText="Book a Demo"
    SecondaryCtaUrl="/contact"
    ImageUrl="/images/product-form-builder.png" />

@* ── 2. Logo Bar ── *@
<section class="mkt-logos">
    <div class="mkt-container">
        <p class="mkt-logos-label reveal">Trusted by innovative teams</p>
        <div class="mkt-logos-row reveal">
            <div class="mkt-logo-slot">Acme Corp</div>
            <div class="mkt-logo-slot">Beacon AI</div>
            <div class="mkt-logo-slot">CloudStack</div>
            <div class="mkt-logo-slot">DataPulse</div>
            <div class="mkt-logo-slot">Elevate</div>
            <div class="mkt-logo-slot">FinOps.io</div>
        </div>
    </div>
</section>

@* ── 3. Product Tabs ── *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>One platform, three superpowers.</h2>
        </div>

        <div class="mkt-tabs reveal" role="tablist">
            <input type="radio" name="product-tab" id="tab-demos" class="mkt-tab-radio" checked />
            <input type="radio" name="product-tab" id="tab-hub" class="mkt-tab-radio" />
            <input type="radio" name="product-tab" id="tab-analytics" class="mkt-tab-radio" />

            <div class="mkt-tab-labels">
                <label for="tab-demos" class="mkt-tab-label" role="tab">Interactive Demos</label>
                <label for="tab-hub" class="mkt-tab-label" role="tab">Demo Hub</label>
                <label for="tab-analytics" class="mkt-tab-label" role="tab">Analytics Dashboard</label>
            </div>

            <div class="mkt-tab-panels">
                <div class="mkt-tab-panel mkt-tab-panel-1">
                    <div class="mkt-tab-panel-body">
                        <h3>Build walkthroughs your buyers actually finish.</h3>
                        <p>Build step-by-step product walkthroughs from screenshots or live captures. Add hotspots, tooltips, guided flows, and branching logic. No coding required.</p>
                    </div>
                    <div class="mkt-tab-panel-visual">
                        <div class="mkt-tab-screen">Interactive Demos Preview</div>
                    </div>
                </div>
                <div class="mkt-tab-panel mkt-tab-panel-2">
                    <div class="mkt-tab-panel-body">
                        <h3>Let prospects self-serve the right demo.</h3>
                        <p>A centralized library where prospects self-serve demos by persona, use case, or product line. Reduces sales friction and lets buyers explore on their own terms.</p>
                    </div>
                    <div class="mkt-tab-panel-visual">
                        <div class="mkt-tab-screen">Demo Hub Preview</div>
                    </div>
                </div>
                <div class="mkt-tab-panel mkt-tab-panel-3">
                    <div class="mkt-tab-panel-body">
                        <h3>Know exactly what resonates.</h3>
                        <p>Track who viewed your demos, how far they got, where they dropped off, and which features generated the most interest. Feed intent data directly into your CRM.</p>
                    </div>
                    <div class="mkt-tab-panel-visual">
                        <div class="mkt-tab-screen">Analytics Dashboard Preview</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── 4. Buyer Journey ── *@
<section class="mkt-section-alt">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <div class="mkt-eyebrow" style="color:var(--nt-accent)">Use Cases</div>
            <h2>Demos for every stage of the buyer journey.</h2>
        </div>
        <div class="mkt-grid mkt-journey-grid reveal-stagger">
            <div class="mkt-card mkt-journey-card">
                <h3>Paid Ads</h3>
                <p>Replace static landing pages with interactive demos that convert ad clicks into qualified pipeline.</p>
            </div>
            <div class="mkt-card mkt-journey-card">
                <h3>Website Embeds</h3>
                <p>Let visitors explore your product on your homepage before they ever talk to sales.</p>
            </div>
            <div class="mkt-card mkt-journey-card">
                <h3>Pre-Call Discovery</h3>
                <p>Send personalized demos before meetings so prospects arrive educated and ready to buy.</p>
            </div>
            <div class="mkt-card mkt-journey-card">
                <h3>Post-Call Follow-Up</h3>
                <p>Reinforce your pitch with a shareable walkthrough champions can forward to decision makers.</p>
            </div>
            <div class="mkt-card mkt-journey-card">
                <h3>Onboarding</h3>
                <p>Guide new users through your product with interactive walkthroughs that reduce time-to-value.</p>
            </div>
            <div class="mkt-card mkt-journey-card">
                <h3>Upsell Campaigns</h3>
                <p>Show existing customers the features they haven't discovered yet to drive expansion revenue.</p>
            </div>
        </div>
    </div>
</section>

@* ── 5. Metrics ── *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>The numbers speak for themselves.</h2>
        </div>
        <div class="mkt-metrics-row reveal-stagger">
            <div class="mkt-metric">
                <div class="mkt-metric-value">3x</div>
                <div class="mkt-metric-label">higher engagement vs. static screenshots</div>
            </div>
            <div class="mkt-metric">
                <div class="mkt-metric-value">47%</div>
                <div class="mkt-metric-label">faster deal velocity</div>
            </div>
            <div class="mkt-metric">
                <div class="mkt-metric-value">2x</div>
                <div class="mkt-metric-label">more qualified pipeline</div>
            </div>
            <div class="mkt-metric">
                <div class="mkt-metric-value">60%</div>
                <div class="mkt-metric-label">reduction in first-call no-shows</div>
            </div>
        </div>
    </div>
</section>

@* ── 6. Testimonial ── *@
<section class="mkt-section-alt">
    <div class="mkt-container">
        <div class="mkt-testimonial-featured reveal">
            <blockquote>"NavTour transformed how we share product demos with prospects. Our sales cycle shortened by 40% and engagement went through the roof."</blockquote>
            <div class="mkt-testimonial-attribution" style="justify-content:center">
                <div>
                    <div class="mkt-testimonial-name">VP of Sales</div>
                    <div class="mkt-testimonial-role">Enterprise SaaS Company</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── 7. Trust Badges ── *@
<section class="mkt-trust">
    <div class="mkt-container">
        <div class="mkt-trust-row reveal">
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nt-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                <span>SOC 2</span>
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nt-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                <span>Azure Hosted</span>
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nt-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                <span>99.9% Uptime</span>
            </div>
            <div class="mkt-trust-badge">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nt-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                <span>GDPR Compliant</span>
            </div>
        </div>
    </div>
</section>

@* ── 8. Final CTA ── *@
<CtaSection Dark="true"
    Title="Turn demos into deals."
    Subtitle="Join hundreds of teams using NavTour to accelerate their sales pipeline."
    CtaText="Start Free Trial"
    CtaUrl="/register" />

@* ── Scoped Styles ── *@
<style>
    /* ── Logo Bar ── */
    .mkt-logos {
        padding: var(--space-16) var(--space-6);
        border-bottom: 1px solid var(--neutral-200);
    }
    .mkt-logos-label {
        text-align: center;
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        color: var(--text-tertiary);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: var(--space-8);
    }
    .mkt-logos-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-10);
        flex-wrap: wrap;
    }
    .mkt-logo-slot {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 140px;
        height: 48px;
        border: 1px dashed var(--neutral-300);
        border-radius: var(--radius);
        color: var(--text-tertiary);
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
    }

    /* ── Product Tabs ── */
    .mkt-tab-radio {
        position: absolute;
        opacity: 0;
        pointer-events: none;
    }
    .mkt-tabs {
        margin-top: var(--space-12);
    }
    .mkt-tab-labels {
        display: flex;
        justify-content: center;
        gap: var(--space-2);
        border-bottom: 1px solid var(--neutral-200);
        margin-bottom: var(--space-12);
    }
    .mkt-tab-label {
        padding: var(--space-4) var(--space-6);
        font-size: var(--text-base);
        font-weight: var(--weight-medium);
        color: var(--text-tertiary);
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -1px;
        transition: color 200ms ease, border-color 200ms ease;
    }
    .mkt-tab-label:hover {
        color: var(--text-primary);
    }

    /* Tab selection — pure CSS */
    .mkt-tab-panel { display: none; }
    #tab-demos:checked ~ .mkt-tab-labels label[for="tab-demos"],
    #tab-hub:checked ~ .mkt-tab-labels label[for="tab-hub"],
    #tab-analytics:checked ~ .mkt-tab-labels label[for="tab-analytics"] {
        color: var(--nt-primary);
        border-bottom-color: var(--nt-primary);
    }
    #tab-demos:checked ~ .mkt-tab-panels .mkt-tab-panel-1,
    #tab-hub:checked ~ .mkt-tab-panels .mkt-tab-panel-2,
    #tab-analytics:checked ~ .mkt-tab-panels .mkt-tab-panel-3 {
        display: grid;
    }

    .mkt-tab-panel {
        grid-template-columns: 1fr 1fr;
        gap: var(--space-12);
        align-items: center;
    }
    .mkt-tab-panel-body h3 {
        margin-bottom: var(--space-4);
    }
    .mkt-tab-panel-body p {
        max-width: 480px;
        font-size: var(--text-lg);
        color: var(--text-secondary);
        line-height: var(--leading-normal);
    }
    .mkt-tab-screen {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        aspect-ratio: 16 / 10;
        background: var(--neutral-100);
        border: 1px solid var(--neutral-200);
        border-radius: var(--radius-lg);
        color: var(--text-tertiary);
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
    }

    /* ── Buyer Journey Grid ── */
    .mkt-journey-grid {
        grid-template-columns: repeat(3, 1fr);
    }
    .mkt-journey-card {
        padding: var(--space-8);
    }
    .mkt-journey-card h3 {
        margin-bottom: var(--space-3);
    }
    .mkt-journey-card p {
        font-size: var(--text-base);
        color: var(--text-secondary);
        line-height: var(--leading-normal);
    }

    /* ── Metrics ── */
    .mkt-metrics-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: var(--space-8);
        margin-top: var(--space-12);
    }
    .mkt-metric {
        text-align: center;
        padding: var(--space-10) var(--space-6);
        background: var(--surface-primary);
        border: 1px solid var(--neutral-200);
        border-radius: var(--radius-lg);
    }
    .mkt-metric-value {
        font-family: var(--font-display);
        font-size: var(--text-5xl);
        font-weight: var(--weight-bold);
        color: var(--nt-primary);
        letter-spacing: -0.03em;
        line-height: 1;
        margin-bottom: var(--space-3);
    }
    .mkt-metric-label {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: var(--leading-normal);
        max-width: 200px;
        margin: 0 auto;
    }

    /* ── Trust Badges ── */
    .mkt-trust {
        padding: var(--space-16) var(--space-6);
        border-top: 1px solid var(--neutral-200);
        border-bottom: 1px solid var(--neutral-200);
    }
    .mkt-trust-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-12);
        flex-wrap: wrap;
    }
    .mkt-trust-badge {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        font-size: var(--text-sm);
        font-weight: var(--weight-medium);
        color: var(--text-secondary);
    }

    /* ── Responsive ── */
    @@media (max-width: 1024px) {
        .mkt-journey-grid {
            grid-template-columns: repeat(2, 1fr);
        }
        .mkt-metrics-row {
            grid-template-columns: repeat(2, 1fr);
        }
        .mkt-tab-panel {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 640px) {
        .mkt-journey-grid {
            grid-template-columns: 1fr;
        }
        .mkt-metrics-row {
            grid-template-columns: 1fr 1fr;
        }
        .mkt-tab-labels {
            flex-direction: column;
            align-items: stretch;
            border-bottom: none;
            gap: 0;
        }
        .mkt-tab-label {
            border-bottom: 1px solid var(--neutral-200);
            text-align: center;
            padding: var(--space-3) var(--space-4);
        }
        .mkt-logos-row {
            gap: var(--space-6);
        }
        .mkt-logo-slot {
            width: 120px;
            height: 40px;
        }
        .mkt-trust-row {
            gap: var(--space-6);
        }
        .mkt-metric-value {
            font-size: var(--text-4xl);
        }
    }
</style>
