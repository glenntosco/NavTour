@page "/"
@layout MarketingLayout

<PageTitle>NavTour — Interactive Demo Platform</PageTitle>
<HeadContent>
    <meta name="description" content="Turn your product into your best salesperson. Interactive demos that drive 3x engagement and close deals 40% faster. Free to start." />
    <meta property="og:title" content="NavTour — Interactive Demo Platform" />
    <meta property="og:description" content="Interactive product demos that close deals faster. Free to start." />
</HeadContent>

@* 1. Hero *@
<HeroSection
    Title="Turn your product into your best salesperson"
    Subtitle="Companies using interactive demos see 3x more engagement and close 40% faster. NavTour makes it free to start."
    PrimaryCtaText="Start Free"
    PrimaryCtaUrl="/register"
    SecondaryCtaText="See a Demo"
    SecondaryCtaUrl="/contact" />

@* 2. Social Proof Bar *@
<section class="mkt-social-proof">
    <div class="mkt-container text-center">
        <p>Trusted by go-to-market teams worldwide</p>
        <LogoGrid Companies='new() { "Apex Financial", "Meridian Health", "CloudScale", "TerraLogic", "Pinnacle SaaS", "Vantage CRM", "Horizon Ops", "NovaBridge" }' Columns="8" />
        <p style="margin-top:var(--space-4);font-size:var(--text-xs);color:var(--neutral-400)">Rated 4.9/5 by users</p>
    </div>
</section>

@* 3. Product Pillars *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>One platform. Three superpowers.</h2>
            <p>Everything your team needs to build, personalize, and measure interactive product demos.</p>
        </div>
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <div class="mkt-card" style="padding:var(--space-10)">
                <div class="mkt-placeholder" style="height:200px;margin-bottom:var(--space-6)">Interactive Demo Builder</div>
                <h3>Interactive Demos</h3>
                <ul class="mkt-benefits" style="margin-top:var(--space-4)">
                    <li>Capture any web app with the Chrome extension</li>
                    <li>Build guided walkthroughs with drag-and-drop</li>
                    <li>Add tooltips, modals, and hotspot overlays</li>
                    <li>Share via link or embed on any website</li>
                    <li>Works on SPA, MPA, and static sites</li>
                </ul>
            </div>
            <div class="mkt-card" style="padding:var(--space-10)">
                <div class="mkt-placeholder" style="height:200px;margin-bottom:var(--space-6)">Analytics Dashboard</div>
                <h3>Lead Capture &amp; Analytics</h3>
                <ul class="mkt-benefits" style="margin-top:var(--space-4)">
                    <li>Gate demos with customizable lead forms</li>
                    <li>Track every click and scroll interaction</li>
                    <li>Step completion heatmaps and drop-off analysis</li>
                    <li>Lead scoring based on engagement depth</li>
                    <li>Export data or push to your CRM via API</li>
                </ul>
            </div>
            <div class="mkt-card" style="padding:var(--space-10)">
                <div class="mkt-placeholder" style="height:200px;margin-bottom:var(--space-6)">Personalization Engine</div>
                <h3>Personalization at Scale</h3>
                <ul class="mkt-benefits" style="margin-top:var(--space-4)">
                    <li>Dynamic &#123;&#123;tokens&#125;&#125; for company, name, and more</li>
                    <li>URL parameter resolution for instant personalization</li>
                    <li>One template serves unlimited variations</li>
                    <li>Works with any CRM or marketing tool</li>
                    <li>Personalized thumbnails and preview text</li>
                </ul>
            </div>
        </div>
    </div>
</section>

@* 4. Feature Highlights *@
<section class="mkt-section-alt">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>Everything you need to build demos</h2>
        </div>
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <FeatureCard Icon="capture" Title="Chrome Capture" Description="One-click extension captures your product as interactive HTML snapshots. Works on any web app." />
            <FeatureCard Icon="annotate" Title="Annotations" Description="Add tooltips, modals, hotspots, and blur overlays to guide viewers step-by-step." />
            <FeatureCard Icon="personalize" Title="Personalization" Description="Dynamic tokens tailor every demo to every prospect. Resolve via URL parameters." />
            <FeatureCard Icon="analyze" Title="Analytics" Description="Session tracking, step completion rates, and drop-off analysis in real time." />
            <FeatureCard Icon="lead" Title="Lead Capture" Description="Gate demos with customizable forms. Capture contact info and push leads to your CRM." />
            <FeatureCard Icon="api" Title="API Access" Description="Automate demo creation, trigger events, and integrate with your stack via REST API." />
        </div>
    </div>
</section>

@* 5. How It Works *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>Build a demo in 3 steps</h2>
            <p>No engineering required. Go from product to published demo in minutes.</p>
        </div>
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <div style="text-align:center">
                <div class="mkt-step-number">1</div>
                <h3>Capture</h3>
                <p style="margin-top:var(--space-3)">Install the Chrome extension and click to capture. Each click saves a full DOM snapshot — HTML, CSS, and layout — as an interactive frame. Works on Salesforce, HubSpot, your own product, or any web app.</p>
            </div>
            <div style="text-align:center">
                <div class="mkt-step-number">2</div>
                <h3>Customize</h3>
                <p style="margin-top:var(--space-3)">Add annotations — tooltips, modals, hotspots, blur overlays — with drag-and-drop. Insert personalization tokens, configure the step flow, and preview the experience in real time.</p>
            </div>
            <div style="text-align:center">
                <div class="mkt-step-number">3</div>
                <h3>Share</h3>
                <p style="margin-top:var(--space-3)">Publish and share a unique link. Embed on your website with a script tag. Add lead capture gates. Track every session, click, and drop-off from your analytics dashboard.</p>
            </div>
        </div>
    </div>
</section>

@* 6. Buyer Journey Grid *@
<section class="mkt-section-alt">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>Interactive demos for every stage</h2>
            <p>From first touch to renewal, NavTour meets your buyers wherever they are.</p>
        </div>
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <BuyerJourneyCard Icon="website" Title="Website Embed" Description="Let visitors experience your product before talking to sales. Replace static screenshots with interactive walkthroughs." />
            <BuyerJourneyCard Icon="discovery" Title="Post-Discovery" Description="Send a personalized demo within 2 minutes of a discovery call. Keep momentum while the conversation is fresh." />
            <BuyerJourneyCard Icon="champion" Title="Champion Enablement" Description="Give champions a demo they can share internally. Help them sell your product inside their organization." />
            <BuyerJourneyCard Icon="email" Title="Email Campaigns" Description="Embed interactive demos in nurture sequences. Drive 3x more click-through than static images or video." />
            <BuyerJourneyCard Icon="onboarding" Title="Onboarding" Description="Self-serve product tours for new customers. Reduce time-to-value and eliminate scheduling bottlenecks." />
            <BuyerJourneyCard Icon="tradeshow" Title="Trade Shows" Description="Interactive booth demos that capture leads automatically. No more clipboard sign-up sheets." />
        </div>
    </div>
</section>

@* 7. Customer Impact Metrics *@
<section class="mkt-section">
    <div class="mkt-container text-center reveal">
        <div class="mkt-eyebrow">Impact</div>
        <h2>The numbers speak for themselves</h2>
        <p class="text-constrain-sm" style="margin:var(--space-4) auto var(--space-12)">Teams using interactive demos consistently outperform those relying on static content and live walkthroughs.</p>
        <div class="mkt-grid mkt-grid-3">
            <MetricCard Value="40%" Label="faster deal cycles" Source="vs. teams without interactive demos" />
            <MetricCard Value="3x" Label="website engagement" Source="vs. static screenshots and video" />
            <MetricCard Value="67%" Label="fewer no-shows" Source="when prospects interact before a call" />
        </div>
    </div>
</section>

