@page "/"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>NavTour — AI-Powered Interactive Demo Platform</PageTitle>
<HeadContent>
    <meta name="description" content="AI builds your demos, personalizes them for every prospect, and tells you who's ready to buy. Capture your product and launch interactive demos in minutes." />
    <meta property="og:title" content="NavTour — AI-Powered Interactive Demo Platform" />
    <meta property="og:description" content="AI builds your demos, personalizes them for every prospect, and tells you who's ready to buy." />
</HeadContent>

@* 1. Hero *@
<HeroSection
    Eyebrow="@L["home_eyebrow"].Value"
    Title="@L["home_title"].Value"
    Subtitle="@L["home_subtitle"].Value"
    PrimaryCtaText="@L["home_cta_primary"].Value"
    PrimaryCtaUrl="/register"
    SecondaryCtaText="@L["home_cta_secondary"].Value"
    SecondaryCtaUrl="/contact" />

@* 2. Social Proof / Logo Bar *@
<section class="mkt-social-proof">
    <div class="mkt-container text-center">
        <div style="display:flex;align-items:center;justify-content:center;gap:var(--space-8);margin-bottom:var(--space-8)">
            <div style="display:flex;align-items:center;gap:var(--space-2);font-size:var(--text-sm);color:var(--text-secondary)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--nt-accent)" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <strong>4.9/5</strong> on G2
            </div>
            <div style="width:1px;height:20px;background:var(--neutral-300)"></div>
            <div style="font-size:var(--text-sm);color:var(--text-secondary)">
                Trusted by <strong>500+</strong> product-led teams
            </div>
        </div>
        <LogoGrid Companies='new() { "Apex Financial", "Meridian Health", "CloudScale", "TerraLogic", "Pinnacle SaaS", "Vantage CRM", "Horizon Ops", "NovaBridge" }' Columns="8" />
    </div>
</section>

@* 3. Use Cases — Buyer Journey *@
<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>@L["home_use_cases_title"]</h2>
        </div>
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <BuyerJourneyCard Icon="website" Title="@L["home_uc1_title"].Value" Description="@L["home_uc1_desc"].Value" />
            <BuyerJourneyCard Icon="discovery" Title="@L["home_uc2_title"].Value" Description="@L["home_uc2_desc"].Value" />
            <BuyerJourneyCard Icon="email" Title="@L["home_uc3_title"].Value" Description="@L["home_uc3_desc"].Value" />
            <BuyerJourneyCard Icon="champion" Title="@L["home_uc4_title"].Value" Description="@L["home_uc4_desc"].Value" />
            <BuyerJourneyCard Icon="tradeshow" Title="@L["home_uc5_title"].Value" Description="@L["home_uc5_desc"].Value" />
            <BuyerJourneyCard Icon="onboarding" Title="@L["home_uc6_title"].Value" Description="@L["home_uc6_desc"].Value" />
        </div>
    </div>
</section>

@* 4. How It Works *@
<section class="mkt-section-alt">
    <div class="mkt-container">
        <div class="mkt-section-heading reveal">
            <h2>@L["home_how_title"]</h2>
        </div>
        <div class="reveal-stagger" style="display:flex;flex-direction:column;gap:var(--space-16)">
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_step1_label"]</div>
                    <h3>@L["home_step1_title"]</h3>
                    <p>@L["home_step1_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Chrome Extension Capture</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_step2_label"]</div>
                    <h3>@L["home_step2_title"]</h3>
                    <p>@L["home_step2_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">AI Copilot Building Demo</div>
                </div>
            </div>
            <div class="mkt-step-row">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L["home_step3_label"]</div>
                    <h3>@L["home_step3_title"]</h3>
                    <p>@L["home_step3_desc"]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">Analytics Dashboard + CRM Sync</div>
                </div>
            </div>
        </div>
    </div>
</section>

@* 5. Features Deep Dive *@
