@page "/product/ai"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.Resources.SharedResources> L

<PageTitle>AI Features — NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="NavTour AI builds, edits, and optimizes your interactive demos. Auto-generation, smart editing, personalization at scale, intent scoring, and more." />
</HeadContent>

<HeroSection
    Eyebrow="@L["ai_eyebrow"].Value"
    Title="@L["ai_title"].Value"
    Subtitle="@L["ai_subtitle"].Value"
    PrimaryCtaText="@L["ai_cta_primary"].Value"
    SecondaryCtaText="@L["ai_cta_secondary"].Value"
    SecondaryCtaUrl="/contact" />

@* Capability 01 — AI Copilot *@
<section class="mkt-section reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">@L["ai_cap1_label"]</div>
                <h3>@L["ai_cap1_title"]</h3>
                <p>@L["ai_cap1_desc"]</p>
            </div>
            <div class="mkt-step-row-visual">
                <div class="mkt-placeholder mkt-placeholder-feature">AI Copilot — Capture to Demo Flow</div>
            </div>
        </div>
    </div>
</section>

@* Capability 02 — AI Smart Editor *@
<section class="mkt-section-alt reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">@L["ai_cap2_label"]</div>
                <h3>@L["ai_cap2_title"]</h3>
                <p>@L["ai_cap2_desc"]</p>
            </div>
            <div class="mkt-step-row-visual">
                <div class="mkt-placeholder mkt-placeholder-feature">Before/After Natural Language Edit</div>
            </div>
        </div>
    </div>
</section>

@* Capability 03 — AI Personalization *@
<section class="mkt-section reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">@L["ai_cap3_label"]</div>
                <h3>@L["ai_cap3_title"]</h3>
                <p>@L["ai_cap3_desc"]</p>
            </div>
            <div class="mkt-step-row-visual">
                <div class="mkt-placeholder mkt-placeholder-feature">Bulk Demo Generation Interface</div>
            </div>
        </div>
    </div>
</section>

@* Capability 04 — AI Analytics & Intent *@
<section class="mkt-section-alt reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">@L["ai_cap4_label"]</div>
                <h3>@L["ai_cap4_title"]</h3>
                <p>@L["ai_cap4_desc"]</p>
            </div>
            <div class="mkt-step-row-visual">
                <div class="mkt-placeholder mkt-placeholder-feature">Intent Score Dashboard + CRM Sync</div>
            </div>
        </div>
    </div>
</section>

@* Capability 05 — AI Demo Review *@
<section class="mkt-section reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">@L["ai_cap5_label"]</div>
                <h3>@L["ai_cap5_title"]</h3>
                <p>@L["ai_cap5_desc"]</p>
            </div>
            <div class="mkt-step-row-visual">
                <div class="mkt-placeholder mkt-placeholder-feature">Demo Optimization Scorecard</div>
            </div>
        </div>
    </div>
</section>

@* Capability 06 — AI Branching Logic *@
<section class="mkt-section-alt reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">@L["ai_cap6_label"]</div>
                <h3>@L["ai_cap6_title"]</h3>
                <p>@L["ai_cap6_desc"]</p>
            </div>
            <div class="mkt-step-row-visual">
                <div class="mkt-placeholder mkt-placeholder-feature">Auto-Generated Branching Flow</div>
            </div>
        </div>
    </div>
</section>

@* Capability 07 — AI Brand Voice *@
<section class="mkt-section reveal">
    <div class="mkt-container">
        <div class="mkt-step-row">
            <div class="mkt-step-row-content">
                <div class="mkt-step-label">@L["ai_cap7_label"]</div>
                <h3>@L["ai_cap7_title"]</h3>
                <p>@L["ai_cap7_desc"]</p>
            </div>
            <div class="mkt-step-row-visual">
                <div class="mkt-placeholder mkt-placeholder-feature">Brand Voice Settings Panel</div>
            </div>
        </div>
    </div>
</section>

@* Competitor Comparison Table *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-section-heading">
            <h2>@L["ai_compare_title"]</h2>
            <p>@L["ai_compare_subtitle"]</p>
        </div>
        <div style="overflow-x:auto">
            <table class="mkt-table">
                <thead>
                    <tr>
                        <th>@L["ai_compare_feature"]</th>
                        <th class="highlighted">NavTour</th>
                        <th>Navattic</th>
                        <th>Storylane</th>
                        <th>Walnut</th>
                        <th>Supademo</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr>
                            <td>@L[row.FeatureKey]</td>
                            <td class="highlighted">@((MarkupString)Check(row.NavTour))</td>
                            <td>@((MarkupString)Check(row.Navattic))</td>
                            <td>@((MarkupString)Check(row.Storylane))</td>
                            <td>@((MarkupString)Check(row.Walnut))</td>
                            <td>@((MarkupString)Check(row.Supademo))</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<CtaSection Dark="true"
    Title="@L["ai_bottom_cta_title"].Value"
    Subtitle="@L["ai_bottom_cta_subtitle"].Value"
    CtaText="@L["ai_bottom_cta_text"].Value"
    SecondaryCtaText="@L["ai_bottom_cta_secondary"].Value"
    SecondaryCtaUrl="/contact" />

@code {
    private record CompRow(string FeatureKey, string NavTour, string Navattic, string Storylane, string Walnut, string Supademo);

    private string Check(string val) => val == "yes"
        ? "<span class='mkt-check'>&#10003;</span>"
        : "<span class='mkt-dash'>&mdash;</span>";

    private readonly List<CompRow> rows = new()
    {
        new("ai_row_generation",       "yes", "yes", "yes", "no",  "yes"),
        new("ai_row_copy_editing",     "yes", "yes", "no",  "no",  "no"),
        new("ai_row_smart_editing",    "yes", "no",  "no",  "no",  "no"),
        new("ai_row_personalization",  "yes", "no",  "yes", "yes", "no"),
        new("ai_row_intent",          "yes", "no",  "no",  "no",  "no"),
        new("ai_row_review",          "yes", "no",  "no",  "no",  "no"),
        new("ai_row_branching",       "yes", "no",  "no",  "no",  "no"),
        new("ai_row_brand_voice",     "yes", "no",  "no",  "no",  "no"),
        new("ai_row_nl_editing",      "yes", "no",  "no",  "no",  "no"),
        new("ai_row_bulk",            "yes", "no",  "no",  "no",  "no"),
    };
}
