@page "/showcase-view/{Slug}"
@layout NavTour.Server.Components.Layout.BlankLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject NavTour.Server.Services.ShowcaseService ShowcaseService
@using NavTour.Shared.DTOs.Showcases

<HeadContent>
    <title>@(showcase?.Name ?? "Showcase")</title>
    <meta name="description" content="@(showcase?.Description ?? "Explore interactive product demos")" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <style>
        body { margin: 0; padding: 0; font-family: 'Segoe UI', system-ui, -apple-system, sans-serif; }
    </style>
</HeadContent>

@if (showcase == null)
{
    <div class="scv-loading">
        <div class="scv-spinner"></div>
    </div>
}
else if (showcase.LayoutTheme == "Sidebar")
{
    @* ── Sidebar Layout ── *@
    <div class="scv-sidebar-layout">
        <aside class="scv-sidebar">
            <div class="scv-sidebar-header">
                <h1 class="scv-sidebar-title">@showcase.Name</h1>
                @if (!string.IsNullOrEmpty(showcase.Description))
                {
                    <p class="scv-sidebar-desc">@showcase.Description</p>
                }
            </div>
            <nav class="scv-sidebar-nav">
                @foreach (var sec in showcase.Sections)
                {
                    <div class="scv-nav-section">
                        <h3 class="scv-nav-section-title">@sec.Name</h3>
                        @foreach (var item in sec.Items)
                        {
                            var demoId = item.DemoId;
                            var slug = item.DemoSlug;
                            <button class="scv-nav-item @(activeDemoId == demoId ? "active" : "")"
                                    @onclick="() => SelectDemo(demoId, slug)">
                                <span class="scv-nav-indicator @(activeDemoId == demoId ? "active" : "")"></span>
                                <span class="scv-nav-item-title">@(item.TitleOverride ?? item.DemoName ?? "Untitled")</span>
                                @if (item.DemoStepCount > 0)
                                {
                                    <span class="scv-nav-item-meta">@item.DemoStepCount steps</span>
                                }
                            </button>
                        }
                    </div>
                }
            </nav>
        </aside>
        <main class="scv-main">
            @if (activeDemoSlug != null)
            {
                <iframe src="/demo/@activeDemoSlug" class="scv-player-frame"></iframe>
            }
            else
            {
                <div class="scv-no-demo">
                    <p>Select a demo from the sidebar to get started.</p>
                </div>
            }
        </main>
    </div>
    <div class="scv-footer-bar">
        <a href="https://navtour.cloud" target="_blank" rel="noopener" class="scv-powered">Powered by NavTour.cloud</a>
    </div>
}
else
{
    @* ── Checklist Layout ── *@
    <div class="scv-checklist-layout">
        <div class="scv-checklist-header">
            <h1 class="scv-checklist-title">@showcase.Name</h1>
            @if (!string.IsNullOrEmpty(showcase.Description))
            {
                <p class="scv-checklist-desc">@showcase.Description</p>
            }
        </div>

        <div class="scv-checklist-body">
            @foreach (var sec in showcase.Sections)
            {
                <div class="scv-cl-section">
                    <h3 class="scv-cl-section-title">@sec.Name</h3>
                    <div class="scv-cl-items">
                        @foreach (var item in sec.Items)
                        {
                            var slug = item.DemoSlug;
                            var demoId = item.DemoId;
                            <div class="scv-cl-item">
                                <div class="scv-cl-item-check @(completedDemos.Contains(demoId) ? "checked" : "")">
                                    @if (completedDemos.Contains(demoId))
                                    {
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
                                    }
                                </div>
                                <div class="scv-cl-item-info">
                                    <span class="scv-cl-item-title">@(item.TitleOverride ?? item.DemoName ?? "Untitled")</span>
                                    @if (item.DemoStepCount > 0)
                                    {
                                        <span class="scv-cl-item-meta">@item.DemoStepCount steps &middot; ~@(Math.Max(1, (int)Math.Round(item.DemoStepCount * 0.5))) min</span>
                                    }
                                </div>
                                <button class="scv-cl-play-btn" @onclick="() => LaunchDemo(demoId, slug)">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                                    Play
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="scv-checklist-footer">
            <a href="https://navtour.cloud" target="_blank" rel="noopener" class="scv-powered">Powered by NavTour.cloud</a>
        </div>
    </div>

    @* ── Demo Player Modal ── *@
    @if (activeDemoSlug != null)
    {
        <div class="scv-player-overlay" @onclick="ClosePlayer">
            <div class="scv-player-modal" @onclick:stopPropagation="true">
                <div class="scv-player-bar">
                    <button class="scv-player-back" @onclick="ClosePlayer">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                        Back to showcase
                    </button>
                </div>
                <iframe src="/demo/@activeDemoSlug" class="scv-player-iframe"></iframe>
            </div>
        </div>
    }
}

<style>
    /* ── Loading ── */
    .scv-loading {
        display: flex; align-items: center; justify-content: center;
        min-height: 100vh;
    }
    .scv-spinner {
        width: 32px; height: 32px; border: 3px solid #E5E5E5;
        border-top-color: #4361ee; border-radius: 50%;
        animation: scv-spin 600ms linear infinite;
    }
    @@keyframes scv-spin { to { transform: rotate(360deg); } }

    /* ── Powered By ── */
    .scv-powered {
        font-size: 0.75rem; color: #A3A3A3; text-decoration: none;
        transition: color 150ms;
    }
    .scv-powered:hover { color: #737373; }

    /* ══════════════════════════════════════════
       Sidebar Layout
       ══════════════════════════════════════════ */
    .scv-sidebar-layout {
        display: flex; min-height: calc(100vh - 40px);
    }

    .scv-sidebar {
        width: 300px; flex-shrink: 0; background: #FAFAFA;
        border-right: 1px solid #E5E5E5; display: flex; flex-direction: column;
        overflow-y: auto;
    }
    .scv-sidebar-header {
        padding: 32px 24px 24px; border-bottom: 1px solid #E5E5E5;
    }
    .scv-sidebar-title {
        font-size: 1.25rem; font-weight: 700; color: #0A0A0A;
        margin: 0 0 8px; line-height: 1.3; letter-spacing: -0.01em;
    }
    .scv-sidebar-desc {
        font-size: 0.8125rem; color: #737373; margin: 0; line-height: 1.5;
    }

    .scv-sidebar-nav { flex: 1; padding: 16px 0; }
    .scv-nav-section { margin-bottom: 8px; }
    .scv-nav-section-title {
        font-size: 0.6875rem; font-weight: 700; color: #A3A3A3;
        text-transform: uppercase; letter-spacing: 0.06em;
        padding: 12px 24px 6px;
    }
    .scv-nav-item {
        display: flex; align-items: center; gap: 10px; width: 100%;
        padding: 10px 24px; background: none; border: none; cursor: pointer;
        font-family: inherit; font-size: 0.875rem; color: #525252;
        min-height: 44px; transition: background 150ms, color 150ms;
    }
    .scv-nav-item:hover { background: #F0F0F0; color: #0A0A0A; }
    .scv-nav-item.active { background: #EEF1FF; color: #4361ee; font-weight: 600; }

    .scv-nav-indicator {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
        border: 2px solid #D4D4D4; transition: all 150ms;
    }
    .scv-nav-indicator.active { background: #4361ee; border-color: #4361ee; }

    .scv-nav-item-title { flex: 1; text-align: left; }
    .scv-nav-item-meta {
        font-size: 0.6875rem; color: #A3A3A3; flex-shrink: 0;
    }

    .scv-main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .scv-player-frame { flex: 1; border: none; width: 100%; min-height: 0; }

    .scv-no-demo {
        flex: 1; display: flex; align-items: center; justify-content: center;
        color: #A3A3A3; font-size: 1rem;
    }

    .scv-footer-bar {
        height: 40px; border-top: 1px solid #E5E5E5;
        display: flex; align-items: center; justify-content: center;
    }

    /* ══════════════════════════════════════════
       Checklist Layout
       ══════════════════════════════════════════ */
    .scv-checklist-layout {
        max-width: 720px; margin: 0 auto;
        min-height: 100vh; display: flex; flex-direction: column;
    }

    .scv-checklist-header {
        padding: 64px 24px 40px; text-align: center;
    }
    .scv-checklist-title {
        font-size: 2rem; font-weight: 700; color: #0A0A0A;
        margin: 0 0 12px; line-height: 1.2; letter-spacing: -0.02em;
    }
    .scv-checklist-desc {
        font-size: 1rem; color: #737373; margin: 0; line-height: 1.5;
        max-width: 560px; margin: 0 auto;
    }

    .scv-checklist-body { flex: 1; padding: 0 24px 64px; }

    .scv-cl-section { margin-bottom: 32px; }
    .scv-cl-section-title {
        font-size: 0.8125rem; font-weight: 700; color: #A3A3A3;
        text-transform: uppercase; letter-spacing: 0.06em;
        margin: 0 0 12px; padding-bottom: 8px;
        border-bottom: 1px solid #E5E5E5;
    }

    .scv-cl-items { display: flex; flex-direction: column; gap: 8px; }

    .scv-cl-item {
        display: flex; align-items: center; gap: 16px;
        padding: 16px 20px; background: #FFFFFF;
        border: 1px solid #E5E5E5; border-radius: 10px;
        transition: border-color 200ms, box-shadow 200ms;
    }
    .scv-cl-item:hover {
        border-color: #D4D4D4;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    }

    .scv-cl-item-check {
        width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0;
        border: 2px solid #D4D4D4; display: flex;
        align-items: center; justify-content: center;
        transition: all 200ms;
    }
    .scv-cl-item-check.checked {
        background: #10B981; border-color: #10B981; color: #FFFFFF;
    }

    .scv-cl-item-info { flex: 1; min-width: 0; }
    .scv-cl-item-title {
        display: block; font-size: 0.9375rem; font-weight: 600;
        color: #0A0A0A; line-height: 1.3;
    }
    .scv-cl-item-meta {
        display: block; font-size: 0.75rem; color: #A3A3A3; margin-top: 2px;
    }

    .scv-cl-play-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 20px; background: #4361ee; color: #FFFFFF;
        border: none; border-radius: 8px; cursor: pointer;
        font-size: 0.8125rem; font-weight: 600; font-family: inherit;
        min-height: 44px; white-space: nowrap;
        transition: background 150ms;
    }
    .scv-cl-play-btn:hover { background: #3451d1; }

    .scv-checklist-footer {
        padding: 24px; text-align: center;
        border-top: 1px solid #E5E5E5;
    }

    /* ── Player Modal (Checklist) ── */
    .scv-player-overlay {
        position: fixed; inset: 0; z-index: 1000;
        background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px);
        display: flex; align-items: center; justify-content: center;
        padding: 32px;
    }
    .scv-player-modal {
        width: 100%; max-width: 1200px; height: 90vh;
        background: #FFFFFF; border-radius: 12px;
        overflow: hidden; display: flex; flex-direction: column;
        box-shadow: 0 24px 64px rgba(0, 0, 0, 0.2);
    }
    .scv-player-bar {
        padding: 12px 16px; border-bottom: 1px solid #E5E5E5;
        flex-shrink: 0;
    }
    .scv-player-back {
        display: inline-flex; align-items: center; gap: 8px;
        background: none; border: none; cursor: pointer;
        font-size: 0.875rem; font-weight: 500; color: #0A0A0A;
        font-family: inherit; min-height: 44px;
    }
    .scv-player-back:hover { color: #4361ee; }
    .scv-player-iframe {
        flex: 1; border: none; width: 100%;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .scv-sidebar-layout { flex-direction: column; }
        .scv-sidebar {
            width: 100%; border-right: none; border-bottom: 1px solid #E5E5E5;
            max-height: none; overflow-y: visible;
        }
        .scv-sidebar-header { padding: 24px 16px 16px; }
        .scv-sidebar-nav {
            display: flex; overflow-x: auto; padding: 0 16px 12px;
            gap: 4px; flex-wrap: nowrap;
        }
        .scv-nav-section { display: flex; gap: 4px; margin-bottom: 0; flex-shrink: 0; }
        .scv-nav-section-title { display: none; }
        .scv-nav-item {
            white-space: nowrap; padding: 8px 16px;
            border: 1px solid #E5E5E5; border-radius: 24px;
            font-size: 0.8125rem; min-height: 40px;
        }
        .scv-nav-item.active { border-color: #4361ee; }
        .scv-nav-indicator { display: none; }
        .scv-nav-item-meta { display: none; }

        .scv-main { min-height: 60vh; }

        .scv-checklist-header { padding: 40px 16px 24px; }
        .scv-checklist-title { font-size: 1.5rem; }
        .scv-checklist-body { padding: 0 16px 48px; }

        .scv-cl-item { padding: 12px 16px; gap: 12px; }
        .scv-cl-play-btn { padding: 8px 14px; }

        .scv-player-overlay { padding: 0; }
        .scv-player-modal { max-width: 100%; height: 100vh; border-radius: 0; }
    }

    @@media (max-width: 375px) {
        .scv-cl-item { flex-wrap: wrap; }
        .scv-cl-play-btn { width: 100%; justify-content: center; }
    }

    @@media (prefers-reduced-motion: reduce) {
        .scv-spinner { animation: none; }
        .scv-cl-item { transition: none; }
    }
</style>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private ShowcaseResponse? showcase;
    private Guid? activeDemoId;
    private string? activeDemoSlug;
    private HashSet<Guid> completedDemos = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            showcase = await ShowcaseService.GetBySlugAsync(Slug);
            if (showcase != null && showcase.Status != "Published") showcase = null;
        }
        catch { }

        // Auto-select first demo for sidebar layout
        if (showcase?.LayoutTheme == "Sidebar")
        {
            // Only auto-select first demo for sidebar layout (not checklist)
            if (showcase.LayoutTheme?.Equals("Sidebar", StringComparison.OrdinalIgnoreCase) == true)
            {
                var firstItem = showcase.Sections.FirstOrDefault()?.Items.FirstOrDefault();
                if (firstItem != null)
                {
                    activeDemoId = firstItem.DemoId;
                    activeDemoSlug = firstItem.DemoSlug;
                }
            }
        }
    }

    private void SelectDemo(Guid demoId, string? slug)
    {
        activeDemoId = demoId;
        activeDemoSlug = slug;
    }

    private void LaunchDemo(Guid demoId, string? slug)
    {
        activeDemoId = demoId;
        activeDemoSlug = slug;
        completedDemos.Add(demoId);
    }

    private void ClosePlayer()
    {
        activeDemoSlug = null;
        activeDemoId = null;
    }
}
