@page "/legal"
@layout MarketingLayout

<PageTitle>Legal &mdash; NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="Legal information for NavTour, including privacy, terms, cookies, security, and company contact details." />
</HeadContent>

<section class="nt-page-hero" style="padding-bottom:40px">
    <div class="nt-container">
        <span class="eyebrow">Legal</span>
        <h1>Policies &amp; company information</h1>
    </div>
</section>

<section class="nt-section" style="padding-top:0">
    <div class="nt-container">
        <NtLegalShell Meta="Last updated: March 24, 2026"
                      Sections='new() { ("overview","Overview"), ("privacy","Privacy policy"), ("terms","Terms of use"), ("cookies","Cookie policy"), ("security","Security"), ("company","Company") }'>
            <section id="overview">
                <h2>Overview</h2>
                <p>This page collects the public legal and privacy information for NavTour. It is intended to give customers, prospects, and procurement teams one place to review our baseline policies and contact details.</p>
            </section>

            <section id="privacy">
                <h2>Privacy policy</h2>
                <p>Our privacy policy describes what data we collect, how we use it, how long we keep it, and your rights as a data subject. NavTour does not sell personal data to third parties.</p>
                <p><a href="/privacy">Read the full privacy policy &rarr;</a></p>
            </section>

            <section id="terms">
                <h2>Terms of use</h2>
                <p>Our terms of use govern access to and use of the NavTour website, hosted application, browser extension, APIs, and related services.</p>
                <p><a href="/terms">Read the full terms of use &rarr;</a></p>
            </section>

            <section id="cookies">
                <h2>Cookie policy</h2>
                <p>Our cookie policy describes the cookies and similar browser technologies we use across the website and application — what they do and how to control them.</p>
                <p><a href="/cookies">Read the full cookie policy &rarr;</a></p>
            </section>

            <section id="security">
                <h2>Security</h2>
                <p>NavTour is SOC 2 Type II certified, hosted on Microsoft Azure, and uses TLS 1.2+ in transit and AES-256 at rest. For our full security posture, responsible disclosure policy, and compliance information, see the security page.</p>
                <p><a href="/security">Read the security overview &rarr;</a></p>
            </section>

            <section id="company">
                <h2>Company information</h2>
                <p>NavTour is a product of Grupo Barrdega, S.A., a company incorporated under the laws of the Republic of Panama.</p>
                <ul>
                    <li><strong>Legal name:</strong> Grupo Barrdega, S.A.</li>
                    <li><strong>Jurisdiction:</strong> Republic of Panama</li>
                    <li><strong>Registered address:</strong> Avenida de los Periodistas, PH Leaf Tower, Panama City, Panama</li>
                    <li><strong>General contact:</strong> <a href="mailto:hello@navtour.cloud">hello@navtour.cloud</a></li>
                    <li><strong>Legal and privacy contact:</strong> <a href="mailto:support@navtour.cloud">support@navtour.cloud</a></li>
                    <li><strong>Phone:</strong> <a href="tel:+5072096996">+507-209-6996</a></li>
                </ul>
            </section>
        </NtLegalShell>
    </div>
</section>
