@page "/legal"
@layout MarketingLayout

<PageTitle>Legal - NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="Legal information for NavTour, including privacy, terms, cookies, security, and company contact details." />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-16)">
    <div class="mkt-container mkt-legal-shell">
        <p class="mkt-eyebrow">Legal</p>
        <h1>Policies and company information</h1>
        <p class="mkt-legal-meta">Last updated: March 24, 2026</p>
        <p style="margin-top:var(--space-5)">
            This page collects the public legal and privacy information for NavTour. It is intended to give customers,
            prospects, and procurement teams one place to review our baseline policies and contact details.
        </p>
    </div>
</section>

<section class="mkt-social-proof">
    <div class="mkt-container">
        <div class="mkt-grid mkt-grid-3 reveal-stagger">
            <a class="mkt-card mkt-link-card" href="/privacy">
                <p class="mkt-eyebrow">Privacy</p>
                <h3>Privacy Policy</h3>
                <p>How we collect, use, store, and handle personal data across the website, application, and extension.</p>
            </a>
            <a class="mkt-card mkt-link-card" href="/terms">
                <p class="mkt-eyebrow">Terms</p>
                <h3>Terms of Service</h3>
                <p>The conditions that govern access to the NavTour website, product, accounts, and acceptable use.</p>
            </a>
            <a class="mkt-card mkt-link-card" href="/cookies">
                <p class="mkt-eyebrow">Cookies</p>
                <h3>Cookie Policy</h3>
                <p>What cookies and similar technologies we use, why we use them, and how visitors can manage them.</p>
            </a>
        </div>
    </div>
</section>

<section class="mkt-section">
    <div class="mkt-container">
        <div class="mkt-grid mkt-grid-2 reveal-stagger" style="align-items:start;gap:var(--space-12)">
            <div class="mkt-card">
                <p class="mkt-eyebrow">Company</p>
                <h2 style="margin-top:var(--space-2)">NavTour contact details</h2>
                <div class="mkt-contact-detail-stack" style="margin-top:var(--space-6)">
                    <div>
                        <div class="mkt-stage-card-label">Address</div>
                        <p>Avenida de los Periodistas, PH Leaf Tower<br />Panama City, Panama</p>
                    </div>
                    <div>
                        <div class="mkt-stage-card-label">Phone</div>
                        <p><a href="tel:+5072096996">+507-209-6996</a></p>
                    </div>
                    <div>
                        <div class="mkt-stage-card-label">Email</div>
                        <p><a href="mailto:support@navtour.cloud">support@navtour.cloud</a></p>
                    </div>
                </div>
            </div>

            <div class="mkt-card">
                <p class="mkt-eyebrow">Related</p>
                <h2 style="margin-top:var(--space-2)">Trust and support</h2>
                <ul class="mkt-legal-list" style="margin-top:var(--space-6)">
                    <li><a href="/security">Security overview</a></li>
                    <li><a href="/support">Support center</a></li>
                    <li><a href="/contact">General contact</a></li>
                    <li><a href="https://docs.navtour.cloud" target="_blank" rel="noopener noreferrer">Documentation</a></li>
                </ul>
            </div>
        </div>
    </div>
</section>
