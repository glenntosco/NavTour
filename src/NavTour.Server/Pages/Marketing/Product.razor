@page "/product"
@page "/features"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.Resources.SharedResources> L

<PageTitle>Product — NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="The complete AI-powered interactive demo platform. Capture, build, personalize, and measure product demos at scale with NavTour." />
</HeadContent>

<HeroSection Eyebrow="@L["product_eyebrow"].Value"
             Title="@L["product_title"].Value"
             Subtitle="@L["product_subtitle"].Value" />

@foreach (var (feature, index) in _features.Select((f, i) => (f, i)))
{
    <section class="@(index % 2 == 0 ? "mkt-section reveal" : "mkt-section-alt reveal")">
        <div class="mkt-container">
            <div class="mkt-step-row" style="@(index % 2 == 1 ? "flex-direction:row-reverse" : "")">
                <div class="mkt-step-row-content">
                    <div class="mkt-step-label">@L[feature.LabelKey]</div>
                    <h2>@L[feature.TitleKey]</h2>
                    <p>@L[feature.DescKey]</p>
                </div>
                <div class="mkt-step-row-visual">
                    <div class="mkt-placeholder mkt-placeholder-feature">@feature.Placeholder</div>
                </div>
            </div>
        </div>
    </section>
}

<CtaSection Dark="true"
            Title="@L["product_cta_title"].Value"
            Subtitle="@L["product_cta_subtitle"].Value"
            CtaText="@L["product_cta_text"].Value"
            SecondaryCtaText="@L["product_cta_secondary"].Value"
            SecondaryCtaUrl="/contact" />

@code {
    private record FeatureItem(string LabelKey, string TitleKey, string DescKey, string Placeholder);

    private readonly List<FeatureItem> _features = new()
    {
        new("product_feat1_label", "product_feat1_title", "product_feat1_desc", "AI Copilot Demo Generation"),
        new("product_feat2_label", "product_feat2_title", "product_feat2_desc", "Natural Language Editing"),
        new("product_feat3_label", "product_feat3_title", "product_feat3_desc", "Bulk Personalization Interface"),
        new("product_feat4_label", "product_feat4_title", "product_feat4_desc", "Intent Scoring Dashboard"),
        new("product_feat5_label", "product_feat5_title", "product_feat5_desc", "Chrome Extension Recording"),
        new("product_feat6_label", "product_feat6_title", "product_feat6_desc", "Drag-and-Drop Editor"),
        new("product_feat7_label", "product_feat7_title", "product_feat7_desc", "Multi-Channel Embed"),
        new("product_feat8_label", "product_feat8_title", "product_feat8_desc", "Demo Score Card"),
        new("product_feat9_label", "product_feat9_title", "product_feat9_desc", "Branching Flow Builder"),
        new("product_feat10_label", "product_feat10_title", "product_feat10_desc", "Team Dashboard"),
        new("product_feat11_label", "product_feat11_title", "product_feat11_desc", "Integration Marketplace"),
        new("product_feat12_label", "product_feat12_title", "product_feat12_desc", "Language Selection"),
    };
}
