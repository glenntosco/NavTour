@page "/privacy"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>@L["privacy_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["privacy_meta_desc"].Value" />
</HeadContent>

<section class="mkt-section">
    <div class="mkt-container mkt-legal-shell">
        <div class="reveal">
            <p class="mkt-eyebrow">Privacy</p>
            <h1>@L["privacy_heading"]</h1>
            <p class="mkt-legal-meta">@L["privacy_last_updated"]</p>
        </div>

        <div class="mkt-legal-prose reveal" style="margin-top:var(--space-12)">

            <section>
                <h2>@L["privacy_s1_title"]</h2>
                <p>@L["privacy_s1_body"]</p>
            </section>

            <section>
                <h2>@L["privacy_s2_title"]</h2>
                <p>@L["privacy_s2_intro"]</p>
                <ul class="mkt-legal-list">
                    <li>@L["privacy_s2_item1"]</li>
                    <li>@L["privacy_s2_item2"]</li>
                    <li>@L["privacy_s2_item3"]</li>
                    <li>@L["privacy_s2_item4"]</li>
                </ul>
            </section>

            <section>
                <h2>@L["privacy_s3_title"]</h2>
                <p>@L["privacy_s3_intro"]</p>
                <ul class="mkt-legal-list">
                    <li>@L["privacy_s3_item1"]</li>
                    <li>@L["privacy_s3_item2"]</li>
                    <li>@L["privacy_s3_item3"]</li>
                </ul>
            </section>

            <section>
                <h2>@L["privacy_s4_title"]</h2>
                <p>@L["privacy_s4_body"]</p>
            </section>

            <section>
                <h2>@L["privacy_s5_title"]</h2>
                <p>@L["privacy_s5_body"]</p>
            </section>

            <section>
                <h2>@L["privacy_s6_title"]</h2>
                <p>@L["privacy_s6_body"]</p>
            </section>

            <section>
                <h2>@L["privacy_s7_title"]</h2>
                <p>@L["privacy_s7_intro"]</p>
                <ul class="mkt-legal-list">
                    <li>@L["privacy_s7_item1"]</li>
                    <li>@L["privacy_s7_item2"]</li>
                    <li>@L["privacy_s7_item3"]</li>
                    <li>@L["privacy_s7_item4"]</li>
                </ul>
            </section>

            <section>
                <h2>@L["privacy_s8_title"]</h2>
                <p>@L["privacy_s8_body"]</p>
            </section>

            <section>
                <h2>@L["privacy_s9_title"]</h2>
                <p>@L["privacy_s9_body"]</p>
            </section>

            <section class="mkt-card">
                <p class="mkt-eyebrow">Contact</p>
                <h3>@L["privacy_contact_title"]</h3>
                <p>@L["privacy_contact_body"]</p>
                <div class="mkt-contact-detail-stack" style="margin-top:var(--space-5)">
                    <div>
                        <div class="mkt-stage-card-label">Email</div>
                        <a href="mailto:support@navtour.cloud">support@navtour.cloud</a>
                    </div>
                    <div>
                        <div class="mkt-stage-card-label">Phone</div>
                        <a href="tel:+5072096996">+507-209-6996</a>
                    </div>
                    <div>
                        <div class="mkt-stage-card-label">Mailing address</div>
                        <p>Avenida de los Periodistas, PH Leaf Tower<br />Panama City, Panama</p>
                    </div>
                </div>
            </section>
        </div>
    </div>
</section>
