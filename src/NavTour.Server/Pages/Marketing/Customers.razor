@page "/customers"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>@L["customers_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["customers_meta_desc"].Value" />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-16)">
    <div class="mkt-container" style="max-width:680px">
        <p class="mkt-eyebrow text-center" style="text-transform:uppercase;letter-spacing:0.1em;color:var(--nt-accent)">@L["customers_eyebrow"]</p>
        <h1 class="text-center">@L["customers_title"]</h1>
        <p class="text-center" style="margin-top:var(--space-5)">@L["customers_subtitle"]</p>
    </div>
</section>

@* Logo Wall *@
<section class="mkt-social-proof">
    <div class="mkt-container text-center">
        <div class="mkt-eyebrow" style="margin-bottom:var(--space-6)">@L["customers_logo_saas"]</div>
        <LogoGrid Companies='new() { "Apex Financial", "Meridian Health", "CloudScale", "TerraLogic", "Pinnacle SaaS", "Vantage CRM", "Horizon Ops", "NovaBridge" }' Columns="8" />

        <div class="mkt-eyebrow" style="margin-top:var(--space-12);margin-bottom:var(--space-6)">@L["customers_logo_finhealth"]</div>
        <LogoGrid Companies='new() { "FinVault", "CareConnect", "LendFlow", "MedTrack", "PaySync", "HealthGrid", "WealthPilot", "InsureLink" }' Columns="8" />
    </div>
</section>

@* Case Study 1 — CloudScale *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-card" style="padding:var(--space-10)">
            <div style="display:flex;align-items:center;gap:var(--space-4);margin-bottom:var(--space-6)">
                <h2 style="margin:0">CloudScale</h2>
                <span class="mkt-blog-card-tag">@L["customers_cs1_tag"]</span>
            </div>
            <div class="mkt-grid mkt-grid-2" style="gap:var(--space-10);align-items:start">
                <div>
                    <h4 style="margin-bottom:var(--space-2)">@L["customers_challenge"]</h4>
                    <p style="font-size:var(--text-base)">@L["customers_cs1_challenge"]</p>
                    <h4 style="margin-top:var(--space-6);margin-bottom:var(--space-2)">@L["customers_solution"]</h4>
                    <p style="font-size:var(--text-base)">@L["customers_cs1_solution"]</p>
                    <h4 style="margin-top:var(--space-6);margin-bottom:var(--space-2)">@L["customers_result"]</h4>
                    <p style="font-size:var(--text-base)">@L["customers_cs1_result"]</p>
                </div>
                <div style="display:flex;align-items:center;justify-content:center">
                    <div style="text-align:center">
                        <div class="mkt-metric-card-value" style="font-size:var(--text-6xl)">40%</div>
                        <div class="mkt-metric-card-label" style="margin-top:var(--space-3)">@L["customers_cs1_metric"]</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* Testimonial 1 *@
<section class="mkt-section-alt" style="padding:var(--space-16) var(--space-6)">
    <div class="mkt-container reveal" style="max-width:720px">
        <TestimonialCard
            Quote="@L["customers_testimonial1_quote"].Value"
            Name="Alex Rivera"
            Title="@L["customers_testimonial1_title"].Value"
            Company="TerraLogic"
            Featured="true" />
    </div>
</section>

@* Case Study 2 — Meridian Health *@
