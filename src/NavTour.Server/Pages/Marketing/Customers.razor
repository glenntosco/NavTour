                        <div class="mkt-metric-card-label" style="margin-top:var(--space-3)">@L["customers_cs2_metric"]</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* Testimonial 2 *@
<section class="mkt-section-alt" style="padding:var(--space-16) var(--space-6)">
    <div class="mkt-container reveal" style="max-width:720px">
        <TestimonialCard
