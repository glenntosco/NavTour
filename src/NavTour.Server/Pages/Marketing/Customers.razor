@page "/customers"
@layout MarketingLayout

<PageTitle>Customers — NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="See how teams at leading companies use NavTour interactive demos to close deals faster, convert more visitors, and onboard customers at scale." />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-16)">
    <div class="mkt-container" style="max-width:680px">
        <p class="mkt-eyebrow text-center" style="text-transform:uppercase;letter-spacing:0.1em;color:var(--nt-accent)">Customers</p>
        <h1 class="text-center">See how teams use NavTour to close more deals</h1>
        <p class="text-center" style="margin-top:var(--space-5)">From startups to enterprise, product-led teams trust NavTour for interactive demos.</p>
    </div>
</section>

@* Logo Wall *@
<section class="mkt-social-proof">
    <div class="mkt-container text-center">
        <div class="mkt-eyebrow" style="margin-bottom:var(--space-6)">SaaS Leaders</div>
        <LogoGrid Companies='new() { "Apex Financial", "Meridian Health", "CloudScale", "TerraLogic", "Pinnacle SaaS", "Vantage CRM", "Horizon Ops", "NovaBridge" }' Columns="8" />

        <div class="mkt-eyebrow" style="margin-top:var(--space-12);margin-bottom:var(--space-6)">Financial &amp; Healthcare</div>
        <LogoGrid Companies='new() { "FinVault", "CareConnect", "LendFlow", "MedTrack", "PaySync", "HealthGrid", "WealthPilot", "InsureLink" }' Columns="8" />
    </div>
</section>

@* Case Study 1 — CloudScale *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-card" style="padding:var(--space-10)">
            <div style="display:flex;align-items:center;gap:var(--space-4);margin-bottom:var(--space-6)">
                <h2 style="margin:0">CloudScale</h2>
                <span class="mkt-blog-card-tag">SaaS Platform</span>
            </div>
            <div class="mkt-grid mkt-grid-2" style="gap:var(--space-10);align-items:start">
                <div>
                    <h4 style="margin-bottom:var(--space-2)">Challenge</h4>
                    <p style="font-size:var(--text-base)">Sales team spent 3 hours per custom demo. Pipeline was growing faster than the team could support.</p>
                    <h4 style="margin-top:var(--space-6);margin-bottom:var(--space-2)">Solution</h4>
                    <p style="font-size:var(--text-base)">NavTour's AI Copilot generates personalized demos in under 2 minutes. SEs shifted from demo building to strategic selling.</p>
                    <h4 style="margin-top:var(--space-6);margin-bottom:var(--space-2)">Result</h4>
                    <p style="font-size:var(--text-base)">40% increase in close rate. Demo creation time dropped from 3 hours to 2 minutes.</p>
                </div>
                <div style="display:flex;align-items:center;justify-content:center">
                    <div style="text-align:center">
                        <div class="mkt-metric-card-value" style="font-size:var(--text-6xl)">40%</div>
                        <div class="mkt-metric-card-label" style="margin-top:var(--space-3)">increase in close rate</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* Testimonial 1 *@
<section class="mkt-section-alt" style="padding:var(--space-16) var(--space-6)">
    <div class="mkt-container reveal" style="max-width:720px">
        <TestimonialCard
            Quote="NavTour is the highest-ROI tool we've added this year. Our reps send personalized demos before the discovery call even ends."
            Name="Alex Rivera"
            Title="Head of Sales"
            Company="TerraLogic"
            Featured="true" />
    </div>
</section>

@* Case Study 2 — Meridian Health *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-card" style="padding:var(--space-10)">
            <div style="display:flex;align-items:center;gap:var(--space-4);margin-bottom:var(--space-6)">
                <h2 style="margin:0">Meridian Health</h2>
                <span class="mkt-blog-card-tag">Healthcare Tech</span>
            </div>
            <div class="mkt-grid mkt-grid-2" style="gap:var(--space-10);align-items:start">
                <div>
                    <h4 style="margin-bottom:var(--space-2)">Challenge</h4>
                    <p style="font-size:var(--text-base)">Compliance requirements made live product demos risky. Prospects needed to see the product but couldn't access PHI.</p>
                    <h4 style="margin-top:var(--space-6);margin-bottom:var(--space-2)">Solution</h4>
                    <p style="font-size:var(--text-base)">Interactive demos with synthetic data. Prospects explore the full workflow without compliance concerns.</p>
                    <h4 style="margin-top:var(--space-6);margin-bottom:var(--space-2)">Result</h4>
                    <p style="font-size:var(--text-base)">Sales cycle shortened by 3 weeks. 100% compliant demo environment.</p>
                </div>
                <div style="display:flex;align-items:center;justify-content:center">
                    <div style="text-align:center">
                        <div class="mkt-metric-card-value" style="font-size:var(--text-6xl)">3 weeks</div>
                        <div class="mkt-metric-card-label" style="margin-top:var(--space-3)">shorter sales cycle</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@* Testimonial 2 *@
<section class="mkt-section-alt" style="padding:var(--space-16) var(--space-6)">
    <div class="mkt-container reveal" style="max-width:720px">
        <TestimonialCard
            Quote="We embedded NavTour demos on every product page. Engagement tripled overnight. It's like having a sales rep on every page."
            Name="Priya Sharma"
            Title="VP of Marketing"
            Company="Pinnacle SaaS"
            Featured="true" />
    </div>
</section>

@* Case Study 3 — FinVault *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-card" style="padding:var(--space-10)">
            <div style="display:flex;align-items:center;gap:var(--space-4);margin-bottom:var(--space-6)">
                <h2 style="margin:0">FinVault</h2>
                <span class="mkt-blog-card-tag">Financial Services</span>
            </div>
            <div class="mkt-grid mkt-grid-2" style="gap:var(--space-10);align-items:start">
                <div>
                    <h4 style="margin-bottom:var(--space-2)">Challenge</h4>
                    <p style="font-size:var(--text-base)">Marketing had no way to show the product on the website. Every prospect required a scheduled demo call.</p>
                    <h4 style="margin-top:var(--space-6);margin-bottom:var(--space-2)">Solution</h4>
                    <p style="font-size:var(--text-base)">Embedded interactive demos on landing pages. AI personalization shows relevant features based on visitor segment.</p>
                    <h4 style="margin-top:var(--space-6);margin-bottom:var(--space-2)">Result</h4>
                    <p style="font-size:var(--text-base)">67% of website visitors interact with demos. Marketing-sourced pipeline up 52%.</p>
                </div>
                <div style="display:flex;align-items:center;justify-content:center">
                    <div style="text-align:center">
                        <div class="mkt-metric-card-value" style="font-size:var(--text-6xl)">52%</div>
                        <div class="mkt-metric-card-label" style="margin-top:var(--space-3)">increase in pipeline</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<CtaSection Title="Join the teams already winning with NavTour" Subtitle="Start free. See results in your first week." />
