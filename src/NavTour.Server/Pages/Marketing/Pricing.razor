    private List<string> StarterFeatures => new() { L["pricing_starter_feat1"].Value, L["pricing_starter_feat2"].Value, L["pricing_starter_feat3"].Value, L["pricing_starter_feat4"].Value, L["pricing_starter_feat5"].Value, L["pricing_starter_feat6"].Value, L["pricing_starter_feat7"].Value, L["pricing_starter_feat8"].Value, L["pricing_starter_feat9"].Value };
    private List<string> GrowthFeatures => new() { L["pricing_growth_feat1"].Value, L["pricing_growth_feat2"].Value, L["pricing_growth_feat3"].Value, L["pricing_growth_feat4"].Value, L["pricing_growth_feat5"].Value, L["pricing_growth_feat6"].Value, L["pricing_growth_feat7"].Value, L["pricing_growth_feat8"].Value };
