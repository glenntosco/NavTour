@page "/pricing"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>Pricing — NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="NavTour pricing starts at $0. Pro plans from $99/mo. Simple pricing, powerful demos. No credit card required." />
</HeadContent>

@* Hero *@
<section class="mkt-section" style="padding-bottom:var(--space-8)">
    <div class="mkt-container" style="max-width:620px">
        <h1 class="text-center reveal">@L["pricing_title"]</h1>
        <p class="text-center reveal" style="margin-top:var(--space-5)">@L["pricing_subtitle"]</p>
        <p class="text-center reveal mkt-pricing-annual-note" style="margin-top:var(--space-3)">@L["pricing_annual_note"]</p>
    </div>
</section>

@* Pricing Cards *@
<section class="mkt-section" style="padding-top:0">
    <div class="mkt-container">
        <div class="mkt-grid mkt-grid-4 reveal-stagger">
            <PricingCard Name="@L["pricing_free_name"].Value" Price="@L["pricing_free_price"].Value" Description="@L["pricing_free_desc"].Value"
                Features="@FreeFeatures"
                CtaText="@L["pricing_free_cta"].Value" />
            <PricingCard Name="@L["pricing_starter_name"].Value" Price="@L["pricing_starter_price"].Value" Description="@L["pricing_starter_desc"].Value"
                Features="@StarterFeatures"
                CtaText="@L["pricing_starter_cta"].Value" />
            <PricingCard Name="@L["pricing_growth_name"].Value" Price="@L["pricing_growth_price"].Value" Description="@L["pricing_growth_desc"].Value" Highlighted="true"
                Features="@GrowthFeatures"
                CtaText="@L["pricing_growth_cta"].Value" />
            <PricingCard Name="@L["pricing_enterprise_name"].Value" Price="@L["pricing_enterprise_price"].Value" Description="@L["pricing_enterprise_desc"].Value"
                Features="@EnterpriseFeatures"
                CtaText="@L["pricing_enterprise_cta"].Value" CtaUrl="/contact" />
        </div>
    </div>
</section>

@* Feature Comparison Table *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-section-heading">
            <h2>@L["pricing_compare_title"]</h2>
        </div>
        <div style="overflow-x:auto">
            <table class="mkt-table">
                <thead>
                    <tr>
                        <th>@L["pricing_table_feature"]</th>
                        <th>@L["pricing_free_name"]</th>
                        <th>@L["pricing_starter_name"]</th>
                        <th class="highlighted">@L["pricing_growth_name"]</th>
                        <th>@L["pricing_enterprise_name"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in comparisonRows)
                    {
                        if (row.IsCategory)
                        {
                            <tr class="mkt-table-category">
                                <td colspan="5">@L[row.Feature]</td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td>@L[row.Feature]</td>
                                <td>@((MarkupString)FormatCheck(row.Free))</td>
                                <td>@((MarkupString)FormatCheck(row.Starter))</td>
                                <td class="highlighted">@((MarkupString)FormatCheck(row.Growth))</td>
                                <td>@((MarkupString)FormatCheck(row.Enterprise))</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

@* FAQ *@
<section class="mkt-section" id="faq">
    <div class="mkt-container" style="max-width:720px">
        <div class="mkt-section-heading reveal">
            <h2>@L["pricing_faq_title"]</h2>
        </div>
        <div class="reveal">
            @foreach (var faq in faqKeys)
            {
                <details class="mkt-faq">
                    <summary>@L[faq.QKey]</summary>
                    <p>@L[faq.AKey]</p>
                </details>
            }
        </div>
    </div>
</section>

<CtaSection Dark="true" Title="@L["pricing_cta_title"].Value" Subtitle="@L["pricing_cta_subtitle"].Value" CtaText="@L["pricing_cta_text"].Value" />

@code {
