@page "/integrations"
@layout MarketingLayout

<PageTitle>Integrations — NavTour</PageTitle>
<HeadContent>
    <meta name="description" content="Connect NavTour to Salesforce, HubSpot, Marketo, Google Analytics, Segment, and more. REST API, webhooks, and embed scripts." />
</HeadContent>

<section class="mkt-section" style="padding-bottom:var(--space-16)">
    <div class="mkt-container" style="max-width:680px">
        <h1 class="text-center">Connect NavTour to your existing stack</h1>
        <p class="text-center" style="margin-top:var(--space-5)">Push leads to your CRM, track engagement in your analytics tools, and embed demos anywhere. NavTour integrates with the tools you already use.</p>
    </div>
</section>

@foreach (var (category, index) in categories.Select((c, i) => (c, i)))
{
    <section class="@(index % 2 == 0 ? "mkt-section" : "mkt-section-alt")">
        <div class="mkt-container">
            <div class="mkt-section-heading reveal">
                <p class="mkt-eyebrow">@category.Label</p>
                <h2>@category.Title</h2>
                <p>@category.Description</p>
            </div>
            <div class="mkt-grid mkt-grid-3 reveal-stagger">
                @foreach (var integration in category.Items)
                {
                    <div class="mkt-integration-card">
                        <div class="mkt-integration-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                @((MarkupString)integration.IconPath)
                            </svg>
                        </div>
                        <h3>@integration.Name</h3>
                        <p>@integration.Desc</p>
                        <p style="margin-top:var(--space-3);font-size:var(--text-xs);color:var(--neutral-400)">@integration.HowItConnects</p>
                    </div>
                }
            </div>
        </div>
    </section>
}

@* API Section *@
<section class="mkt-section">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <p class="mkt-eyebrow">Developer Platform</p>
                <h2 style="margin-top:var(--space-2)">Build anything with the NavTour API</h2>
                <p style="margin-top:var(--space-4)">Every feature in NavTour is accessible via our REST API. Create demos programmatically, manage leads, pull analytics data, and trigger webhooks for real-time event processing.</p>
                <ul class="mkt-benefits">
                    <li>Full REST API with OpenAPI specification</li>
                    <li>Webhook notifications for demo events</li>
                    <li>API key management with scoped permissions</li>
                    <li>Rate limits designed for production workloads</li>
                    <li>Comprehensive API documentation</li>
                </ul>
                <a href="/docs" class="mkt-btn mkt-btn-secondary" style="margin-top:var(--space-6)">View API Docs</a>
            </div>
            <div class="mkt-placeholder mkt-placeholder-feature">API documentation with code examples</div>
        </div>
    </div>
</section>

<CtaSection Title="Don't see your tool?" Subtitle="Our API connects NavTour to any tool in your stack. Talk to us about custom integrations." CtaText="Contact Us" CtaUrl="/contact" />

