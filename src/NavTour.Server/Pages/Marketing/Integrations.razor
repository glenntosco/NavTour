@page "/integrations"
@layout MarketingLayout
@inject IStringLocalizer<NavTour.Server.SharedResources> L

<PageTitle>@L["integ_page_title"]</PageTitle>
<HeadContent>
    <meta name="description" content="@L["integ_meta_desc"].Value" />
</HeadContent>

<HeroSection Eyebrow="@L["integ_eyebrow"].Value"
             Title="@L["integ_hero_title"].Value"
             Subtitle="@L["integ_hero_subtitle"].Value"
             PrimaryCtaText="@L["integ_cta_primary"].Value"
             SecondaryCtaText="@L["integ_cta_secondary"].Value"
             SecondaryCtaUrl="/contact" />

@foreach (var (category, index) in categories.Select((c, i) => (c, i)))
{
    <section class="@(index % 2 == 0 ? "mkt-section" : "mkt-section-alt")">
        <div class="mkt-container">
            <div class="mkt-section-heading reveal">
                <p class="mkt-eyebrow">@L[category.LabelKey]</p>
                <h2>@L[category.TitleKey]</h2>
            </div>
            <div class="mkt-grid mkt-grid-3 reveal-stagger">
                @foreach (var integration in category.Items)
                {
                    <div class="mkt-card">
                        <div class="mkt-integration-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                @((MarkupString)integration.IconPath)
                            </svg>
                        </div>
                        <h3>@L[integration.NameKey]</h3>
                        <p>@L[integration.DescKey]</p>
                    </div>
                }
            </div>
        </div>
    </section>
}

@* API Section *@
<section class="mkt-section-alt">
    <div class="mkt-container reveal">
        <div class="mkt-grid mkt-grid-2" style="align-items:center;gap:var(--space-16)">
            <div>
                <p class="mkt-eyebrow">@L["integ_api_eyebrow"]</p>
                <h2 style="margin-top:var(--space-2)">@L["integ_api_title"]</h2>
                <p style="margin-top:var(--space-4)">@L["integ_api_desc"]</p>
                <a href="/docs" class="mkt-btn mkt-btn-secondary" style="margin-top:var(--space-6)">@L["integ_api_link"] &rarr;</a>
            </div>
            <div class="mkt-placeholder mkt-placeholder-feature">REST API documentation</div>
        </div>
    </div>
</section>

<CtaSection Title="@L["integ_bottom_cta_title"].Value"
            Subtitle="@L["integ_bottom_cta_subtitle"].Value"
            CtaText="@L["integ_bottom_cta_text"].Value"
            CtaUrl="/contact" />

