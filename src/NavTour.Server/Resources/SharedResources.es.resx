  <data name="home_uc6_desc" xml:space="preserve"><value>Tours de producto autoservicio para nuevos clientes. Reduce el tiempo de activación y elimina cuellos de botella.</value></data>

  <!-- Homepage How It Works -->
  <data name="home_how_title" xml:space="preserve"><value>De la captura a la conversión en minutos</value></data>
  <data name="home_how_subtitle" xml:space="preserve"><value></value></data>
  <data name="home_step1_label" xml:space="preserve"><value>Paso 1</value></data>
  <data name="home_step1_title" xml:space="preserve"><value>Captura</value></data>
  <data name="home_step1_desc" xml:space="preserve"><value>Instala la extensión de Chrome. Navega por tu producto. NavTour graba cada pantalla automáticamente como un snapshot HTML interactivo.</value></data>
  <data name="home_step2_label" xml:space="preserve"><value>Paso 2</value></data>
  <data name="home_step2_title" xml:space="preserve"><value>La IA Construye tu Demo</value></data>
  <data name="home_step2_desc" xml:space="preserve"><value>El Copiloto IA escribe el texto guía, ancla tooltips a los elementos correctos, crea rutas ramificadas y personaliza el contenido — todo mientras tomas un café.</value></data>
  <data name="home_step3_label" xml:space="preserve"><value>Paso 3</value></data>
