@using NavTour.Shared.DTOs.Frames
@inject DemoApiService DemoApi

<div class="fs-container">
    <div class="fs-header">
        <span class="fs-header-title">Frames</span>
        <span class="fs-header-count">@Frames.Count</span>
    </div>

    <div class="fs-list">
        @for (int i = 0; i < Frames.Count; i++)
        {
            var frame = Frames[i];
            var index = i;
            var isSelected = frame.Id == SelectedFrameId;

            <div class="fs-frame @(isSelected ? "fs-selected" : "") @(dragOverIndex == index ? "fs-drag-over" : "") @(dragIndex == index ? "fs-dragging" : "")"
                 draggable="true"
                 @ondragstart="() => OnDragStart(index)"
                 @ondragenter="() => OnDragEnter(index)"
                 @ondragover:preventDefault
                 @ondragend="OnDragEnd"
                 @onclick="() => OnFrameSelected.InvokeAsync(frame.Id)">

                @* Thumbnail preview *@
                <div class="fs-thumbnail" title="Click to select. Double-click name to rename.">
                    @if (frameHtmlCache.TryGetValue(frame.Id, out var html))
                    {
                        <iframe class="fs-thumbnail-iframe" srcdoc="@html" sandbox="" scrolling="no" tabindex="-1"></iframe>
                    }
                    else
                    {
                        <div class="fs-thumbnail-placeholder">
                            <RadzenIcon Icon="web" Style="font-size:24px;color:var(--rz-text-secondary-color);opacity:0.5" />
                        </div>
                    }
                    <div class="fs-actions" @onclick:stopPropagation="true">
                        <button class="fs-action-btn" @onclick="() => StartRename(frame)" title="Rename frame">
                            <RadzenIcon Icon="edit" Style="font-size:13px" />
                        </button>
                        <button class="fs-action-btn fs-action-danger" @onclick="() => ConfirmDelete(frame.Id)" title="Delete frame">
                            <RadzenIcon Icon="close" Style="font-size:13px" />
                        </button>
                    </div>
                </div>

                @* Frame label *@
                <div class="fs-label">
                    <div class="fs-drag-dots" title="Drag to reorder">
                        <svg width="6" height="10" viewBox="0 0 6 10" fill="currentColor" opacity="0.3">
                            <circle cx="1.5" cy="1.5" r="1"/><circle cx="4.5" cy="1.5" r="1"/>
                            <circle cx="1.5" cy="5" r="1"/><circle cx="4.5" cy="5" r="1"/>
                            <circle cx="1.5" cy="8.5" r="1"/><circle cx="4.5" cy="8.5" r="1"/>
                        </svg>
                    </div>
                    @if (renamingFrameId == frame.Id)
                    {
                        <input class="fs-rename-input" type="text" @bind="renameValue" @bind:event="oninput"
                            @onkeydown="HandleRenameKey" @onblur="CommitRename" />
                    }
                    else
                    {
                        <span class="fs-frame-name" @ondblclick="() => StartRename(frame)" @ondblclick:stopPropagation="true">
                            @(frame.Name ?? $"Frame {frame.SequenceOrder}")
                        </span>
                    }
                </div>
            </div>
        }
    </div>

    <RadzenButton Text="+ Add Frame" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
        Style="width:100%;margin-top:4px" Click="OnAddFrame" title="Upload an HTML snapshot from the Chrome extension" />
</div>

@if (confirmDeleteId != null)
{
    <div class="fs-confirm-overlay" @onclick="() => confirmDeleteId = null">
        <div class="fs-confirm-dialog" @onclick:stopPropagation="true">
            <RadzenText TextStyle="TextStyle.Body2"><strong>Delete this frame?</strong></RadzenText>
            <RadzenText TextStyle="TextStyle.Caption" Style="color:var(--rz-text-secondary-color)">This cannot be undone.</RadzenText>
            <RadzenStack Orientation="Orientation.Horizontal" Gap="6px" Style="margin-top:8px">
                <RadzenButton Text="Delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.ExtraSmall"
                    Click="ExecuteDelete" />
                <RadzenButton Text="Cancel" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall"
                    Click="() => confirmDeleteId = null" />
            </RadzenStack>
        </div>
    </div>
}

<style>
    .fs-container {
        width: 220px;
        min-height: 100%;
        display: flex;
        flex-direction: column;
        border-right: 1px solid var(--rz-border-color);
        padding: 8px;
        overflow-y: auto;
    }

    .fs-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 4px 4px 8px;
    }

    .fs-header-title {
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--rz-text-secondary-color);
    }

    .fs-header-count {
        font-size: 0.6875rem;
        background: var(--rz-base-200);
        border-radius: 10px;
        padding: 1px 8px;
        color: var(--rz-text-secondary-color);
    }

    .fs-list {
        display: flex;
        flex-direction: column;
        gap: 4px;
        flex: 1;
    }

    .fs-frame {
        position: relative;
        cursor: pointer;
        border-radius: 8px;
        border: 2px solid transparent;
        background: var(--rz-base-background-color);
        transition: border-color 0.15s, background 0.15s, opacity 0.2s;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .fs-frame:hover {
        border-color: var(--rz-border-color);
    }

    .fs-selected {
        border-color: var(--rz-primary) !important;
    }

    .fs-dragging {
        opacity: 0.35;
    }

    .fs-drag-over {
        border-top: 3px solid var(--rz-primary) !important;
    }

    /* Thumbnail area */
    .fs-thumbnail {
        position: relative;
        width: 100%;
        height: 110px;
        overflow: hidden;
        background: #f8fafc;
        border-bottom: 1px solid var(--rz-border-color);
    }

    .fs-thumbnail-iframe {
        width: 1280px;
        height: 800px;
        transform: scale(0.158);
        transform-origin: top left;
        border: none;
        pointer-events: none;
        position: absolute;
        top: 0;
        left: 0;
    }

    .fs-thumbnail-placeholder {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Action buttons overlay on thumbnail */
    .fs-actions {
        position: absolute;
        top: 4px;
        right: 4px;
        display: none;
        flex-direction: row;
        gap: 2px;
        z-index: 2;
    }

    .fs-frame:hover .fs-actions {
        display: flex;
    }

    .fs-action-btn {
        background: rgba(255,255,255,0.9);
        border: 1px solid var(--rz-border-color);
        border-radius: 4px;
        cursor: pointer;
        padding: 2px;
        display: flex;
        align-items: center;
        color: var(--rz-text-secondary-color);
        transition: background 0.1s, color 0.1s;
        backdrop-filter: blur(4px);
    }

    .fs-action-btn:hover {
        background: #fff;
        color: var(--rz-text-color);
    }

    .fs-action-danger:hover {
        color: var(--rz-danger);
    }

    /* Label area */
    .fs-label {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 6px 8px;
        min-height: 28px;
    }

    .fs-drag-dots {
        cursor: grab;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        padding: 2px 0;
        color: var(--rz-text-secondary-color);
        opacity: 0;
        transition: opacity 0.15s;
    }

    .fs-frame:hover .fs-drag-dots {
        opacity: 1;
    }

    .fs-drag-dots:active {
        cursor: grabbing;
    }

    .fs-frame-name {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--rz-text-color);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        cursor: default;
        flex: 1;
        min-width: 0;
    }

    .fs-rename-input {
        font-size: 0.75rem;
        font-weight: 500;
        padding: 2px 4px;
        border: 1px solid var(--rz-primary);
        border-radius: 4px;
        outline: none;
        width: 100%;
        background: var(--rz-base-background-color);
        color: var(--rz-text-color);
        font-family: inherit;
    }

    .fs-confirm-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0,0,0,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10000;
    }

    .fs-confirm-dialog {
        background: var(--rz-base-background-color);
        border-radius: 10px;
        padding: 16px;
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
        min-width: 200px;
    }
</style>

@code {
    [Parameter] public List<FrameResponse> Frames { get; set; } = [];
    [Parameter] public Guid? SelectedFrameId { get; set; }
    [Parameter] public EventCallback<Guid> OnFrameSelected { get; set; }
    [Parameter] public EventCallback OnAddFrame { get; set; }
    [Parameter] public EventCallback<Guid> OnDeleteFrame { get; set; }
    [Parameter] public EventCallback<int> OnInsertFrame { get; set; }
    [Parameter] public EventCallback<(int OldIndex, int NewIndex)> OnReorderFrame { get; set; }
    [Parameter] public EventCallback<(Guid FrameId, string Name)> OnRenameFrame { get; set; }

    private Guid? confirmDeleteId;
    private Guid? renamingFrameId;
    private string renameValue = "";

    // Drag state
    private int? dragIndex;
    private int? dragOverIndex;

    // Frame HTML cache for thumbnails
    private Dictionary<Guid, string> frameHtmlCache = new();
    private HashSet<Guid> loadedFrameIds = new();

    protected override async Task OnParametersSetAsync()
    {
        // Load frame HTML for thumbnails (lazy, only new ones)
        foreach (var frame in Frames)
        {
            if (!loadedFrameIds.Contains(frame.Id))
            {
                loadedFrameIds.Add(frame.Id);
                _ = LoadFrameHtml(frame.Id);
            }
        }
    }

    private async Task LoadFrameHtml(Guid frameId)
    {
        try
        {
            var detail = await DemoApi.GetFrameDetailAsync(frameId);
            if (detail != null)
            {
                frameHtmlCache[frameId] = detail.HtmlContent;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { }
    }

    private void OnDragStart(int index)
    {
        dragIndex = index;
    }

    private void OnDragEnter(int index)
    {
        if (dragIndex == null || dragIndex == index) return;
        dragOverIndex = index;
    }

    private async Task OnDragEnd()
    {
        if (dragIndex != null && dragOverIndex != null && dragIndex != dragOverIndex)
        {
            await OnReorderFrame.InvokeAsync((dragIndex.Value, dragOverIndex.Value));
        }
        dragIndex = null;
        dragOverIndex = null;
    }

    private void ConfirmDelete(Guid frameId)
    {
        confirmDeleteId = frameId;
    }

    private async Task ExecuteDelete()
    {
        if (confirmDeleteId != null)
        {
            var id = confirmDeleteId.Value;
            confirmDeleteId = null;
            await OnDeleteFrame.InvokeAsync(id);
        }
    }

    private void StartRename(FrameResponse frame)
    {
        renamingFrameId = frame.Id;
        renameValue = frame.Name ?? $"Frame {frame.SequenceOrder}";
    }

    private async Task CommitRename()
    {
        if (renamingFrameId != null && !string.IsNullOrWhiteSpace(renameValue))
        {
            await OnRenameFrame.InvokeAsync((renamingFrameId.Value, renameValue.Trim()));
        }
        renamingFrameId = null;
    }

    private async Task HandleRenameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await CommitRename();
        else if (e.Key == "Escape")
            renamingFrameId = null;
    }
}
