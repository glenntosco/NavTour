@inject NavigationManager Nav
@inject IJSRuntime JS

@if (IsOpen)
{
    <div class="cmd-overlay" @onclick="Close">
        <div class="cmd-modal" @onclick:stopPropagation="true">
            <div class="cmd-search">
                <svg class="cmd-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input @ref="searchInput" type="text" class="cmd-input" placeholder="Type a command or search..."
                    value="@searchText" @oninput="OnSearchInput" @onkeydown="HandleKeyDown" />
                <kbd class="cmd-kbd">ESC</kbd>
            </div>
            @if (filteredItems.Count > 0)
            {
                <div class="cmd-results">
                    @for (int i = 0; i < filteredItems.Count; i++)
                    {
                        var item = filteredItems[i];
                        var idx = i;
                        <a href="@item.Path" class="cmd-item @(idx == selectedIndex ? "cmd-item-active" : "")"
                            @onclick="Close" @onmouseenter="() => selectedIndex = idx">
                            <span class="cmd-item-icon">@item.Icon</span>
                            <span class="cmd-item-label">@item.Label</span>
                            <span class="cmd-item-hint">@item.Hint</span>
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="cmd-empty">No results found</div>
            }
        </div>
    </div>
}

<style>
    .cmd-overlay {
        position: fixed; inset: 0; z-index: 1000;
        background: rgba(0,0,0,0.4); backdrop-filter: blur(4px);
        display: flex; align-items: flex-start; justify-content: center;
        padding-top: 20vh;
        animation: cmd-fade-in 150ms ease;
    }

    .cmd-modal {
        width: 100%; max-width: 560px;
        background: var(--nt-surface); border: 1px solid var(--nt-border);
        border-radius: var(--nt-radius-lg); box-shadow: var(--nt-shadow-xl);
        overflow: hidden;
        animation: cmd-slide-in 200ms cubic-bezier(0.1, 0.9, 0.2, 1);
    }

    .cmd-search {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 16px; border-bottom: 1px solid var(--nt-border);
    }

    .cmd-search-icon { color: var(--nt-text-muted); flex-shrink: 0; }

    .cmd-input {
        flex: 1; border: none; outline: none; background: none;
        font-size: var(--nt-text-lg); font-family: var(--nt-font);
        color: var(--nt-text-primary);
    }
    .cmd-input::placeholder { color: var(--nt-text-muted); }

    .cmd-kbd {
        font-size: 0.6875rem; font-family: var(--nt-font);
        padding: 2px 6px; border-radius: 4px;
        background: var(--nt-surface-subtle); color: var(--nt-text-muted);
        border: 1px solid var(--nt-border);
    }

    .cmd-results { max-height: 320px; overflow-y: auto; padding: 8px; }

    .cmd-item {
        display: flex; align-items: center; gap: 12px;
        padding: 10px 12px; border-radius: var(--nt-radius);
        text-decoration: none; color: var(--nt-text-primary);
        cursor: pointer; transition: background 100ms;
    }
    .cmd-item:hover, .cmd-item-active {
        background: var(--nt-surface-subtle);
    }

    .cmd-item-icon { font-size: 1rem; width: 24px; text-align: center; }
    .cmd-item-label { font-size: var(--nt-text-base); font-weight: 500; flex: 1; }
    .cmd-item-hint { font-size: var(--nt-text-sm); color: var(--nt-text-muted); }

    .cmd-empty {
        padding: 32px 16px; text-align: center;
        color: var(--nt-text-muted); font-size: var(--nt-text-base);
    }

    @@keyframes cmd-fade-in { from { opacity: 0; } to { opacity: 1; } }
    @@keyframes cmd-slide-in {
        from { opacity: 0; transform: translateY(-8px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @@media (prefers-reduced-motion: reduce) {
        .cmd-overlay, .cmd-modal { animation: none; }
    }
</style>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private record CommandItem(string Icon, string Label, string Hint, string Path);

    private static readonly List<CommandItem> allItems = [
        new("📦", "Dashboard", "View all demos", "/dashboard"),
        new("📊", "Analytics", "Performance metrics", "/analytics"),
        new("👤", "Leads", "Captured leads", "/leads"),
        new("📝", "Forms", "Form builder", "/forms"),
        new("👥", "Team", "Team management", "/team"),
        new("⚙️", "Settings", "Workspace settings", "/settings"),
        new("🎨", "Themes", "Theme editor", "/themes"),
        new("🚀", "Get Started", "Onboarding guide", "/get-started"),
    ];

    private ElementReference searchInput;
    private string searchText = "";
    private int selectedIndex;
    private List<CommandItem> filteredItems = [];

    protected override void OnParametersSet()
    {
        if (IsOpen)
        {
            searchText = "";
            selectedIndex = 0;
            filteredItems = allItems;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (IsOpen)
        {
            try { await searchInput.FocusAsync(); } catch { }
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";
        selectedIndex = 0;
        filteredItems = string.IsNullOrWhiteSpace(searchText)
            ? allItems
            : allItems.Where(i => i.Label.Contains(searchText, StringComparison.OrdinalIgnoreCase)
                || i.Hint.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") { Close(); return; }
        if (e.Key == "ArrowDown") { selectedIndex = Math.Min(selectedIndex + 1, filteredItems.Count - 1); return; }
        if (e.Key == "ArrowUp") { selectedIndex = Math.Max(selectedIndex - 1, 0); return; }
        if (e.Key == "Enter" && filteredItems.Count > 0)
        {
            Nav.NavigateTo(filteredItems[selectedIndex].Path);
            Close();
        }
    }

    private void Close() => OnClose.InvokeAsync();
}
