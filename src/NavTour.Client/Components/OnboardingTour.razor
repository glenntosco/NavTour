@inject IJSRuntime JS
@implements IDisposable

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    private bool isActive;
    private int currentIndex;
    private DotNetObjectReference<OnboardingTour>? objRef;

    private static readonly TourStep[] tourSteps =
    [
        new("Frame Strip", "These are your captured pages. Click to select and edit, drag to reorder.", ".frame-strip"),
        new("Frame Editor", "Click any element to edit text, replace images, blur, or hide it.", ".frame-editor"),
        new("Steps Panel", "Steps define your demo's guided flow. Set triggers and navigation actions for each step.", ".step-panel"),
        new("Annotations", "Add tooltips, modals, hotspots, and beacons to guide viewers through each step.", ".annotation-editor"),
        new("Toolbar", "Save your work, preview the demo, toggle publication status, and share.", ".editor-toolbar"),
        new("Preview", "Click Preview to see your demo exactly as viewers will experience it.", ".preview-btn"),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("tourInterop._registerDotNet", objRef);

            try
            {
                var completed = await JS.InvokeAsync<bool>("tourInterop.isCompleted");
                if (!completed)
                {
                    await Task.Delay(2500);
                    await StartTour();
                }
            }
            catch { }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && !isActive)
        {
            await StartTour();
        }
    }

    private async Task StartTour()
    {
        currentIndex = 0;
        isActive = true;
        await ShowCurrentStep();
    }

    private async Task ShowCurrentStep()
    {
        var step = tourSteps[currentIndex];
        await JS.InvokeVoidAsync("tourInterop.show",
            step.Selector, step.Title, step.Description,
            tourSteps.Length, currentIndex, currentIndex > 0);
    }

    [JSInvokable]
    public async Task OnTourNext()
    {
        if (currentIndex < tourSteps.Length - 1)
        {
            currentIndex++;
            await ShowCurrentStep();
        }
        else
        {
            await MarkCompleted();
        }
    }

    [JSInvokable]
    public async Task OnTourBack()
    {
        if (currentIndex > 0)
        {
            currentIndex--;
            await ShowCurrentStep();
        }
    }

    [JSInvokable]
    public async Task OnTourSkip()
    {
        await MarkCompleted();
    }

    private async Task MarkCompleted()
    {
        isActive = false;
        await JS.InvokeVoidAsync("tourInterop.hide");
        try { await JS.InvokeVoidAsync("tourInterop.markCompleted"); } catch { }
        await VisibleChanged.InvokeAsync(false);
    }

    public void Dispose()
    {
        objRef?.Dispose();
    }

    private record TourStep(string Title, string Description, string Selector);
}
