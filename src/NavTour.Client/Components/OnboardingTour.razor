@inject IJSRuntime JS

@if (isActive)
{
    <div class="tour-overlay" @onclick="HandleOverlayClick">
        @if (spotlightRect != null)
        {
            <div class="tour-spotlight" style="left:@(spotlightRect.Left - 4)px;top:@(spotlightRect.Top - 4)px;width:@(spotlightRect.Width + 8)px;height:@(spotlightRect.Height + 8)px"></div>
        }

        <div class="tour-card" style="@GetCardPosition()" @onclick:stopPropagation="true">
            <h3>@tourSteps[currentIndex].Title</h3>
            <p>@tourSteps[currentIndex].Description</p>

            <div class="tour-dots">
                @for (int i = 0; i < tourSteps.Length; i++)
                {
                    <div class="tour-dot @(i == currentIndex ? "active" : "")"></div>
                }
            </div>

            <div class="tour-actions">
                <button class="tour-btn tour-btn-skip" @onclick="Skip">Skip tour</button>
                <div style="display:flex;gap:8px">
                    @if (currentIndex > 0)
                    {
                        <button class="tour-btn tour-btn-secondary" @onclick="Previous">Back</button>
                    }
                    @if (currentIndex < tourSteps.Length - 1)
                    {
                        <button class="tour-btn tour-btn-primary" @onclick="Next">Next</button>
                    }
                    else
                    {
                        <button class="tour-btn tour-btn-primary" @onclick="Complete">Finish</button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback<bool> VisibleChanged { get; set; }

    private bool isActive;
    private int currentIndex;
    private ElementRect? spotlightRect;

    private static readonly TourStep[] tourSteps =
    [
        new("Frame Strip", "These are your captured pages. Click to select and edit, drag to reorder.", ".frame-strip", "right"),
        new("Frame Editor", "Click any element to edit text, replace images, blur, or hide it.", ".frame-editor", "left"),
        new("Steps Panel", "Steps define your demo's guided flow. Set triggers and navigation actions for each step.", ".step-panel", "left"),
        new("Annotations", "Add tooltips, modals, hotspots, and beacons to guide viewers through each step.", ".annotation-editor", "left"),
        new("Toolbar", "Save your work, preview the demo, toggle publication status, and share.", ".editor-toolbar", "bottom"),
        new("Preview", "Click Preview to see your demo exactly as viewers will experience it.", ".preview-btn", "bottom"),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var completed = await JS.InvokeAsync<bool>("tourInterop.isCompleted");
                if (!completed)
                {
                    // Auto-start tour after a short delay to let the editor render
                    await Task.Delay(1500);
                    await StartTour();
                }
            }
            catch { }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Visible && !isActive)
        {
            await StartTour();
        }
    }

    private async Task StartTour()
    {
        currentIndex = 0;
        isActive = true;
        await UpdateSpotlight();
        StateHasChanged();
    }

    private async Task UpdateSpotlight()
    {
        try
        {
            spotlightRect = await JS.InvokeAsync<ElementRect?>("tourInterop.getElementRect", tourSteps[currentIndex].Selector);
        }
        catch
        {
            spotlightRect = null;
        }
    }

    private async Task Next()
    {
        if (currentIndex < tourSteps.Length - 1)
        {
            currentIndex++;
            await UpdateSpotlight();
        }
    }

    private async Task Previous()
    {
        if (currentIndex > 0)
        {
            currentIndex--;
            await UpdateSpotlight();
        }
    }

    private async Task Skip()
    {
        await MarkCompleted();
    }

    private async Task Complete()
    {
        await MarkCompleted();
    }

    private async Task MarkCompleted()
    {
        isActive = false;
        try { await JS.InvokeVoidAsync("tourInterop.markCompleted"); } catch { }
        await VisibleChanged.InvokeAsync(false);
    }

    private void HandleOverlayClick()
    {
        // Don't dismiss on overlay click — user must use buttons
    }

    private string GetCardPosition()
    {
        if (spotlightRect == null)
            return "top:50%;left:50%;transform:translate(-50%,-50%)";

        var step = tourSteps[currentIndex];
        return step.Position switch
        {
            "right" => $"top:{spotlightRect.Top}px;left:{spotlightRect.Left + spotlightRect.Width + 16}px",
            "left" => $"top:{spotlightRect.Top}px;right:{GetRightOffset(spotlightRect)}px",
            "bottom" => $"top:{spotlightRect.Top + spotlightRect.Height + 12}px;left:{spotlightRect.Left}px",
            "top" => $"bottom:{GetBottomOffset(spotlightRect)}px;left:{spotlightRect.Left}px",
            _ => $"top:{spotlightRect.Top}px;left:{spotlightRect.Left + spotlightRect.Width + 16}px"
        };
    }

    private static double GetRightOffset(ElementRect rect) => 16; // from right edge of spotlight
    private static double GetBottomOffset(ElementRect rect) => 16;

    private record TourStep(string Title, string Description, string Selector, string Position);

    private class ElementRect
    {
        public double Left { get; set; }
        public double Top { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }
}
