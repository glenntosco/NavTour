@using NavTour.Shared.DTOs.Screenshots

<div class="sc-slide-strip">
    @for (int i = 0; i < Slides.Count; i++)
    {
        var slide = Slides[i];
        var index = i;
        <div class="sc-slide-thumb @(SelectedSlideId == slide.Id ? "selected" : "")"
             @onclick="() => OnSelectSlide.InvokeAsync(slide.Id)">
            <div class="sc-slide-num">@(index + 1)</div>
            @if (slide.ThumbnailUrl != null && slide.ThumbnailUrl.StartsWith("data:"))
            {
                <img src="@slide.ThumbnailUrl" alt="Slide @(index+1)" class="sc-slide-img" />
            }
            else if (slide.ImageData.StartsWith("data:"))
            {
                <img src="@slide.ImageData" alt="Slide @(index+1)" class="sc-slide-img" />
            }
            else
            {
                <div class="sc-slide-placeholder">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </div>
            }
        </div>
    }
    <button class="sc-add-slide" @onclick="() => OnAddSlide.InvokeAsync()">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Slide
    </button>
</div>

<style>
.sc-slide-strip { display: flex; flex-direction: column; gap: 8px; padding: 12px 8px; height: 100%; overflow-y: auto; background: #f8f9fa; border-right: 1px solid var(--rz-base-border-color); min-width: 100px; }
.sc-slide-thumb { position: relative; border: 2px solid transparent; border-radius: 6px; overflow: hidden; cursor: pointer; background: white; aspect-ratio: 16/9; }
.sc-slide-thumb.selected { border-color: var(--rz-primary); box-shadow: 0 0 0 2px rgba(67,97,238,0.2); }
.sc-slide-thumb:hover:not(.selected) { border-color: var(--rz-base-border-color); }
.sc-slide-num { position: absolute; top: 4px; left: 4px; background: rgba(0,0,0,0.5); color: white; font-size: 10px; font-weight: 700; border-radius: 3px; padding: 1px 4px; z-index: 1; }
.sc-slide-img { width: 100%; height: 100%; object-fit: cover; display: block; }
.sc-slide-placeholder { display: flex; align-items: center; justify-content: center; height: 100%; color: var(--rz-text-secondary-color); min-height: 56px; }
.sc-add-slide { display: flex; align-items: center; gap: 6px; padding: 8px; border: 1px dashed var(--rz-base-border-color); background: transparent; border-radius: 6px; cursor: pointer; font-size: 0.75rem; color: var(--rz-text-secondary-color); transition: all 0.15s; justify-content: center; }
.sc-add-slide:hover { border-color: var(--rz-primary); color: var(--rz-primary); background: rgba(67,97,238,0.04); }
</style>

@code {
    [Parameter, EditorRequired] public List<ScreenshotSlideResponse> Slides { get; set; } = [];
    [Parameter] public Guid? SelectedSlideId { get; set; }
    [Parameter] public EventCallback<Guid> OnSelectSlide { get; set; }
    [Parameter] public EventCallback OnAddSlide { get; set; }
}
