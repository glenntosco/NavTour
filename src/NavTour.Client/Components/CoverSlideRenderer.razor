@using NavTour.Shared.DTOs

<div class="cover-slide cover-slide-@(Settings.Theme)">
    @if (Settings.BackgroundType == "frame" && BackgroundImageUrl != null)
    {
        <div class="cover-bg" style="background-image:url('@BackgroundImageUrl');opacity:@(Settings.BackdropOpacity / 100.0)"></div>
    }
    else if (Settings.BackgroundType == "custom" && Settings.BackgroundUrl != null)
    {
        <div class="cover-bg" style="background-image:url('@Settings.BackgroundUrl');opacity:@(Settings.BackdropOpacity / 100.0)"></div>
    }

    <div class="cover-overlay"></div>

    <div class="cover-content cover-layout-@(Settings.Layout)">
        <div class="cover-card">
            @if (Settings.ShowLogo)
            {
                <img src="@(Settings.LogoUrl ?? LogoUrl)" alt="Logo" class="cover-logo" />
            }
            <h2 class="cover-title">@Settings.Title</h2>
            @if (!string.IsNullOrEmpty(Settings.Description))
            {
                <p class="cover-desc">@Settings.Description</p>
            }
            <div class="cover-meta">
                <span class="cover-badge">@TotalSteps steps · Interactive demo</span>
            </div>
            <button class="cover-cta" @onclick="OnCtaClick">@Settings.CtaText</button>
        </div>
    </div>
</div>

<style>
    .cover-slide {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        font-family: var(--nt-font);
    }

    .cover-slide-dark { background: var(--nt-neutral-950); color: #fff; }
    .cover-slide-dark .cover-overlay { background: rgba(0,0,0,0.4); }
    .cover-slide-dark .cover-card { background: rgba(0,0,0,0.6); backdrop-filter: blur(12px); border: 1px solid rgba(255,255,255,0.1); }
    .cover-slide-dark .cover-title { color: #fff; }
    .cover-slide-dark .cover-desc { color: rgba(255,255,255,0.7); }
    .cover-slide-dark .cover-badge { background: rgba(255,255,255,0.1); color: rgba(255,255,255,0.6); }
    .cover-slide-dark .cover-cta { background: var(--nt-accent); color: #fff; }
    .cover-slide-dark .cover-cta:hover { background: var(--nt-accent-hover); }

    .cover-slide-light { background: var(--nt-neutral-50); color: var(--nt-text-primary); }
    .cover-slide-light .cover-overlay { background: rgba(255,255,255,0.5); }
    .cover-slide-light .cover-card { background: rgba(255,255,255,0.9); backdrop-filter: blur(12px); border: 1px solid var(--nt-border); box-shadow: var(--nt-shadow-xl); }
    .cover-slide-light .cover-title { color: var(--nt-text-primary); }
    .cover-slide-light .cover-desc { color: var(--nt-text-secondary); }
    .cover-slide-light .cover-badge { background: var(--nt-surface-subtle); color: var(--nt-text-secondary); }
    .cover-slide-light .cover-cta { background: var(--nt-primary); color: #fff; }
    .cover-slide-light .cover-cta:hover { background: var(--nt-primary-hover); }

    .cover-bg {
        position: absolute; inset: 0;
        background-size: cover; background-position: center;
        z-index: 0;
    }

    .cover-overlay {
        position: absolute; inset: 0; z-index: 1;
    }

    .cover-content {
        position: relative; z-index: 2;
        width: 100%; height: 100%;
        display: flex; align-items: center;
        padding: 48px;
    }

    .cover-layout-center { justify-content: center; }
    .cover-layout-left { justify-content: flex-start; }
    .cover-layout-right { justify-content: flex-end; }

    .cover-card {
        max-width: 480px; padding: 40px;
        border-radius: var(--nt-radius-lg);
        text-align: center;
        animation: cover-enter 600ms cubic-bezier(0.1, 0.9, 0.2, 1) both;
    }

    .cover-layout-left .cover-card,
    .cover-layout-right .cover-card { text-align: left; }

    .cover-logo {
        height: 40px; width: auto; margin-bottom: 24px;
        object-fit: contain;
    }

    .cover-layout-center .cover-logo { display: block; margin-left: auto; margin-right: auto; margin-bottom: 24px; }

    .cover-title {
        font-size: 1.75rem; font-weight: 700;
        margin: 0 0 12px; line-height: 1.2;
        letter-spacing: -0.02em;
    }

    .cover-desc {
        font-size: 0.9375rem; line-height: 1.6;
        margin: 0 0 24px;
    }

    .cover-meta { margin-bottom: 28px; }

    .cover-badge {
        display: inline-block;
        padding: 6px 14px; border-radius: 20px;
        font-size: 0.75rem; font-weight: 500;
    }

    .cover-cta {
        display: inline-flex; align-items: center;
        padding: 12px 32px; border: none;
        border-radius: var(--nt-radius); font-size: 0.9375rem;
        font-weight: 600; cursor: pointer;
        font-family: var(--nt-font);
        transition: background 150ms, transform 100ms;
    }

    .cover-cta:active { transform: scale(0.98); }

    @@keyframes cover-enter {
        from { opacity: 0; transform: translateY(20px) scale(0.97); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @@media (prefers-reduced-motion: reduce) {
        .cover-card { animation: none; }
    }

    @@media (max-width: 768px) {
        .cover-content { padding: 24px; }
        .cover-card { max-width: 100%; padding: 28px; }
        .cover-title { font-size: 1.375rem; }
    }
</style>

@code {
    [Parameter] public ChapterSettings Settings { get; set; } = new();
    [Parameter] public string? BackgroundImageUrl { get; set; }
    [Parameter] public string LogoUrl { get; set; } = "favicon.svg";
    [Parameter] public int TotalSteps { get; set; }
    [Parameter] public EventCallback OnCtaClick { get; set; }
    [Parameter] public bool IsClosing { get; set; }
}
