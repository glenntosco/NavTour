@inject IJSRuntime JS

<div style="flex:1;position:relative;overflow:hidden;background:var(--rz-base-200)">
    @if (HtmlContent != null)
    {
        <iframe @ref="iframeRef" id="@_previewIframeId" sandbox="allow-same-origin" style="width:100%;height:100%;border:none"></iframe>

        @* Annotation overlays rendered on top *@
        @if (Annotations != null)
        {
            foreach (var annotation in Annotations)
            {
                <AnnotationOverlay Annotation="annotation" Mode="AnnotationOverlay.AnnotationOverlayMode.Edit" />
            }
        }
    }
    else
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="height:100%">
            <RadzenIcon Icon="image" Style="font-size:64px;color:var(--rz-text-tertiary-color)" />
            <RadzenText Style="color:var(--rz-text-secondary-color)">Select a frame to preview</RadzenText>
        </RadzenStack>
    }
</div>

@code {
    [Parameter] public string? HtmlContent { get; set; }
    [Parameter] public Guid? FrameId { get; set; }
    [Parameter] public List<AnnotationResponse>? Annotations { get; set; }

    private ElementReference iframeRef;
    private string _previewIframeId = "navtour-preview-" + Guid.NewGuid().ToString("N")[..8];
    private string? _lastHtml;
    private Guid? _lastFrameId;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Prefer server URL when FrameId is available (resources load from same origin)
        if (FrameId.HasValue && FrameId != _lastFrameId)
        {
            _lastFrameId = FrameId;
            _lastHtml = HtmlContent;
            await JS.InvokeVoidAsync("navtourSetFrameSrc", _previewIframeId, $"/api/v1/player/frames/{FrameId}/html");
        }
        else if (HtmlContent != null && HtmlContent != _lastHtml)
        {
            _lastHtml = HtmlContent;
            await JS.InvokeVoidAsync("navtourSetFrameContent", _previewIframeId, HtmlContent);
        }
    }
}
