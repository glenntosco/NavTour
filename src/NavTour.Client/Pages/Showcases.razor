@page "/showcases"
@page "/showcases/{ShowcaseId:guid}"
@rendermode InteractiveServer
@inject ShowcaseApiService ShowcaseApi
@inject DemoApiService DemoApi
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS
@using NavTour.Shared.DTOs.Showcases

<PageTitle>Showcases — NavTour</PageTitle>

@if (loading)
{
    <div class="sc-loading">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </div>
}
else if (ShowcaseId == null)
{
    @* ── List View ── *@
    <div class="sc-list">
        @if (showWelcome)
        {
            <div class="sc-welcome">
                <div class="sc-welcome-content">
                    <svg class="sc-welcome-icon" viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12zM10 9h8v2h-8zm0 3h4v2h-4zm0-6h8v2h-8z"/></svg>
                    <div>
                        <h3 class="sc-welcome-title">Welcome to Showcases!</h3>
                        <p class="sc-welcome-text">Group multiple demos into a single, shareable URL. Perfect for onboarding flows, feature tours, and sales presentations.</p>
                    </div>
                </div>
                <button class="sc-welcome-dismiss" @onclick="DismissWelcome" title="Dismiss">
                    <svg width="16" height="16" viewBox="0 0 24 24"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/></svg>
                </button>
            </div>
        }

        <div class="sc-list-header">
            <h2 class="sc-list-title">Showcases</h2>
            <button class="sc-btn-primary" @onclick="CreateShowcase">+ Create Showcase</button>
        </div>

        @if (showcases.Count > 0)
        {
            <div class="sc-table">
                <div class="sc-table-head">
                    <span class="sc-th sc-th-name">Name</span>
                    <span class="sc-th sc-th-status">Status</span>
                    <span class="sc-th sc-th-date">Date</span>
                    <span class="sc-th sc-th-actions"></span>
                </div>
                @foreach (var sc in showcases)
                {
                    <div class="sc-table-row" @onclick="() => OpenEditor(sc.Id)">
                        <span class="sc-td sc-td-name">
                            <svg class="sc-row-icon" viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12zM10 9h8v2h-8zm0 3h4v2h-4zm0-6h8v2h-8z"/></svg>
                            <div>
                                <span class="sc-row-name">@sc.Name</span>
                                <span class="sc-row-sub">@sc.Sections.Sum(s => s.Items.Count) demos &middot; @sc.ViewCount views</span>
                            </div>
                        </span>
                        <span class="sc-td sc-td-status">
                            <span class="sc-badge @(sc.Status == "Published" ? "sc-badge-pub" : "")">@sc.Status</span>
                        </span>
                        <span class="sc-td sc-td-date">@sc.CreatedAt.ToString("MMM d, yyyy")</span>
                        <span class="sc-td sc-td-actions" @onclick:stopPropagation="true">
                            <button class="sc-icon-btn" @onclick="() => CopyShowcaseLink(sc)" title="Copy link">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                            </button>
                            <div class="sc-ctx-wrapper">
                                <button class="sc-icon-btn" @onclick="() => ToggleContextMenu(sc.Id)" title="More actions">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                                </button>
                                @if (contextMenuId == sc.Id)
                                {
                                    <div class="sc-ctx-menu">
                                        <button class="sc-ctx-item" @onclick="() => CopyShowcaseLink(sc)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                                            Copy link
                                        </button>
                                        <button class="sc-ctx-item" @onclick="() => OpenEditor(sc.Id)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                            Edit
                                        </button>
                                        <button class="sc-ctx-item" @onclick="() => { OpenEditor(sc.Id); showShareMenu = true; }">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                                            Share
                                        </button>
                                        <button class="sc-ctx-item" @onclick="() => DuplicateShowcase(sc)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                            Duplicate
                                        </button>
                                        <div class="sc-ctx-divider"></div>
                                        <button class="sc-ctx-item sc-ctx-danger" @onclick="() => DeleteShowcase(sc.Id)">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                            Delete
                                        </button>
                                    </div>
                                }
                            </div>
                        </span>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="sc-empty">
                <svg class="sc-empty-icon" viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H8V4h12v12zM10 9h8v2h-8zm0 3h4v2h-4zm0-6h8v2h-8z"/></svg>
                <h3 class="sc-empty-title">No showcases yet</h3>
                <p class="sc-empty-text">Create a showcase to group multiple demos into a single shareable link.</p>
                <button class="sc-btn-primary" @onclick="CreateShowcase">+ Create Showcase</button>
            </div>
        }
    </div>
}
else if (showcase != null)
{
    @* ── Editor View ── *@
    <div class="sc-editor" @onclick="CloseMenus">
        <div class="sc-editor-bar">
            <div class="sc-editor-bar-left">
                <button class="sc-btn-back" @onclick="BackToList">
                    <svg viewBox="0 0 24 24" width="16" height="16"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="currentColor"/></svg>
                    Back
                </button>
                <input class="sc-name-input" type="text" @bind="editName" @bind:event="oninput" placeholder="Showcase name" />
            </div>
            <div class="sc-editor-bar-right">
                <label class="sc-publish-toggle">
                    <RadzenSwitch @bind-Value="isPublished" Change="@OnPublishToggle" />
                    <span class="sc-publish-label">@(isPublished ? "Published" : "Draft")</span>
                </label>
                <button class="sc-btn-save" @onclick="SaveShowcase" disabled="@saving">@(saving ? "Saving..." : "Save")</button>
                <div class="sc-share-wrapper" @onclick:stopPropagation="true">
                    <button class="sc-btn-share" @onclick="() => showShareMenu = !showShareMenu">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                        Share
                    </button>
                    @if (showShareMenu)
                    {
                        <div class="sc-share-menu">
                            <div class="sc-share-url">
                                <input type="text" readonly value="@GetShowcaseUrl()" class="sc-share-url-input" />
                                <button class="sc-share-copy" @onclick="CopyShowcaseUrl">@(linkCopied ? "Copied!" : "Copy")</button>
                            </div>
                            <div class="sc-share-divider"></div>
                            <div class="sc-share-buttons">
                                <a href="@GetFacebookShareUrl()" target="_blank" rel="noopener" class="sc-share-btn" title="Share on Facebook">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                                </a>
                                <a href="@GetTwitterShareUrl()" target="_blank" rel="noopener" class="sc-share-btn" title="Share on X">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                                </a>
                                <a href="@GetWhatsAppShareUrl()" target="_blank" rel="noopener" class="sc-share-btn" title="Share on WhatsApp">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                                </a>
                                <a href="@GetLinkedInShareUrl()" target="_blank" rel="noopener" class="sc-share-btn" title="Share on LinkedIn">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                </a>
                                <a href="@GetEmailShareUrl()" class="sc-share-btn" title="Share via Email">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="sc-editor-body">
            @* ── Settings Panel ── *@
            <div class="sc-settings">
                <h3 class="sc-section-title">Settings</h3>

                <div class="sc-field">
                    <label class="sc-label">Layout Theme</label>
                    <div class="sc-segmented">
                        <button class="sc-seg-btn @(editLayoutTheme == "Checklist" ? "active" : "")" @onclick='() => editLayoutTheme = "Checklist"'>Checklist</button>
                        <button class="sc-seg-btn @(editLayoutTheme == "Sidebar" ? "active" : "")" @onclick='() => editLayoutTheme = "Sidebar"'>Sidebar</button>
                    </div>
                </div>

                <div class="sc-field">
                    <label class="sc-label">Autoplay</label>
                    <RadzenSwitch @bind-Value="editAutoplay" />
                </div>

                <div class="sc-field">
                    <label class="sc-label">SEO Title</label>
                    <input class="sc-input" type="text" @bind="editSeoTitle" @bind:event="oninput" placeholder="Page title for search engines" />
                </div>

                <div class="sc-field">
                    <label class="sc-label">SEO Description</label>
                    <textarea class="sc-textarea" @bind="editDescription" @bind:event="oninput" placeholder="Brief description for search engines" rows="3"></textarea>
                </div>
            </div>

            @* ── Sections Manager ── *@
            <div class="sc-sections">
                <h3 class="sc-section-title">Sections &amp; Demos</h3>

                @for (int si = 0; si < editSections.Count; si++)
                {
                    var sIdx = si;
                    var sec = editSections[si];
                    <div class="sc-section-card">
                        <div class="sc-section-header" @onclick="() => ToggleSectionCollapse(sec.Id)">
                            <svg class="sc-chevron @(collapsedSections.Contains(sec.Id) ? "" : "expanded")" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z"/></svg>
                            @if (renamingSectionId == sec.Id)
                            {
                                <input class="sc-section-name-input" type="text" @bind="renamingSectionName" @bind:event="oninput"
                                    @onkeydown="HandleSectionRenameKey"
                                    @onclick:stopPropagation="true" />
                                <button class="sc-icon-btn-sm" @onclick="FinishRenameSection" @onclick:stopPropagation="true" title="Save name">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                </button>
                            }
                            else
                            {
                                <span class="sc-section-name">@sec.Name</span>
                                <span class="sc-section-count">@sec.Items.Count demos</span>
                            }
                            <div class="sc-section-actions" @onclick:stopPropagation="true">
                                <button class="sc-icon-btn-sm" @onclick="() => StartRenameSection(sec)" title="Rename">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </button>
                                <button class="sc-icon-btn-sm sc-danger" @onclick="() => DeleteSection(sec.Id)" title="Delete section">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                                </button>
                            </div>
                        </div>

                        @if (!collapsedSections.Contains(sec.Id))
                        {
                            <div class="sc-section-items">
                                @for (int ii = 0; ii < sec.Items.Count; ii++)
                                {
                                    var iIdx = ii;
                                    var item = sec.Items[ii];
                                    <div class="sc-item">
                                        <div class="sc-item-drag" title="Reorder">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
                                        </div>
                                        <div class="sc-item-info">
                                            <span class="sc-item-title">@(item.TitleOverride ?? item.DemoName ?? "Untitled")</span>
                                            <span class="sc-item-meta">@item.DemoStepCount steps</span>
                                        </div>
                                        <div class="sc-item-actions">
                                            @if (iIdx > 0)
                                            {
                                                <button class="sc-icon-btn-sm" @onclick="() => MoveItem(sec, iIdx, -1)" title="Move up">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7 14l5-5 5 5z"/></svg>
                                                </button>
                                            }
                                            @if (iIdx < sec.Items.Count - 1)
                                            {
                                                <button class="sc-icon-btn-sm" @onclick="() => MoveItem(sec, iIdx, 1)" title="Move down">
                                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M7 10l5 5 5-5z"/></svg>
                                                </button>
                                            }
                                            <button class="sc-icon-btn-sm sc-danger" @onclick="() => DeleteItem(sec, item.Id)" title="Remove demo">
                                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                            </button>
                                        </div>
                                    </div>
                                }
                                @if (sec.Items.Count == 0)
                                {
                                    <div class="sc-items-empty">No demos in this section yet.</div>
                                }
                                <div class="sc-add-demo-wrap">
                                    @if (addingDemoSectionId == sec.Id)
                                    {
                                        <div class="sc-demo-picker" @onclick:stopPropagation="true">
                                            <input class="sc-demo-search" type="text" placeholder="Search demos..." @bind="demoSearchText" @bind:event="oninput" />
                                            <div class="sc-demo-picker-list">
                                                @foreach (var demo in GetFilteredDemos())
                                                {
                                                    <button class="sc-demo-picker-item" @onclick="() => AddDemoToSection(sec.Id, demo)">
                                                        <span class="sc-demo-picker-name">@demo.Name</span>
                                                        <span class="sc-demo-picker-meta">@demo.StepCount steps</span>
                                                    </button>
                                                }
                                                @if (!GetFilteredDemos().Any())
                                                {
                                                    <div class="sc-demo-picker-empty">No published demos found</div>
                                                }
                                            </div>
                                            <button class="sc-demo-picker-close" @onclick="() => addingDemoSectionId = null">Cancel</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <button class="sc-btn-add-demo" @onclick="() => OpenDemoPicker(sec.Id)" @onclick:stopPropagation="true">
                                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                            Add Demo
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <button class="sc-btn-add-section" @onclick="AddSection">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add Section
                </button>
            </div>
        </div>
    </div>
}

<style>
    /* ── Loading ── */
    .sc-loading { display:flex; align-items:center; justify-content:center; min-height:60vh; }

    /* ── Welcome Card ── */
    .sc-welcome {
        display:flex; align-items:flex-start; justify-content:space-between; gap:var(--nt-space-4);
        padding:var(--nt-space-6); margin-bottom:var(--nt-space-6);
        background:var(--nt-accent-light); border:1px solid var(--nt-accent);
        border-radius:var(--nt-radius-lg);
    }
    .sc-welcome-content { display:flex; align-items:flex-start; gap:var(--nt-space-4); }
    .sc-welcome-icon { width:32px; height:32px; flex-shrink:0; fill:var(--nt-accent); margin-top:2px; }
    .sc-welcome-title { font-size:var(--nt-text-lg); font-weight:var(--nt-weight-semibold); color:var(--nt-text-primary); margin:0 0 var(--nt-space-1); }
