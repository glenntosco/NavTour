@code {
    [Parameter] public Guid? ShowcaseId { get; set; }

    private bool loading = true;
    private bool saving;
    private bool showWelcome = true;
    private bool showShareMenu;
    private bool linkCopied;
    private Guid? contextMenuId;

    // List view
    private List<ShowcaseResponse> showcases = [];

    // Editor view
    private ShowcaseResponse? showcase;
    private string editName = "";
    private string editDescription = "";
    private string editSeoTitle = "";
    private string editLayoutTheme = "Checklist";
    private bool editAutoplay;
    private bool isPublished;
    private List<ShowcaseSectionResponse> editSections = [];
    private HashSet<Guid> collapsedSections = [];

    // Section rename
    private Guid? renamingSectionId;
    private string renamingSectionName = "";

    // Add demo
    private Guid? addingDemoSectionId;
    private string demoSearchText = "";
    private List<DemoListItemResponse> allDemos = [];

    protected override async Task OnParametersSetAsync()
    {
        loading = true;
        contextMenuId = null;
        showShareMenu = false;

        try
        {
            if (ShowcaseId.HasValue)
            {
                showcase = await ShowcaseApi.GetByIdAsync(ShowcaseId.Value);
                if (showcase != null)
                {
                    editName = showcase.Name;
                    editDescription = showcase.Description ?? "";
                    editSeoTitle = "";
                    editLayoutTheme = showcase.LayoutTheme;
                    editAutoplay = showcase.Autoplay;
                    isPublished = showcase.Status == "Published";
                    editSections = showcase.Sections.Select(s =>
                        new ShowcaseSectionResponse(s.Id, s.Name, s.SortOrder, s.Items.ToList())).ToList();
                }
                allDemos = await DemoApi.GetDemosAsync();
            }
            else
            {
                showcase = null;
                showcases = await ShowcaseApi.GetAllAsync();
            }
        }
        catch { }

        try
        {
            var dismissed = await JS.InvokeAsync<string>("localStorage.getItem", "navtour_showcase_welcome_dismissed");
            showWelcome = dismissed != "true";
        }
        catch { }

        loading = false;
    }

    // ── List Actions ──

    private async Task CreateShowcase()
    {
        var created = await ShowcaseApi.CreateAsync(new CreateShowcaseRequest(null));
        if (created != null) Nav.NavigateTo($"/showcases/{created.Id}");
    }

    private void OpenEditor(Guid id) => Nav.NavigateTo($"/showcases/{id}");
    private void BackToList() => Nav.NavigateTo("/showcases");

    private async Task CopyShowcaseLink(ShowcaseResponse sc)
    {
        var url = $"{Nav.BaseUri.TrimEnd('/')}/showcase-view/{sc.Slug}";
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", url); } catch { }
        contextMenuId = null;
    }

    private async Task DuplicateShowcase(ShowcaseResponse sc)
    {
        contextMenuId = null;
        var dup = await ShowcaseApi.CreateAsync(new CreateShowcaseRequest($"{sc.Name} (copy)"));
        if (dup != null)
        {
            // Copy sections and items
            foreach (var section in sc.Sections)
            {
                var newSection = await ShowcaseApi.AddSectionAsync(new CreateSectionRequest(dup.Id, section.Name));
                if (newSection != null)
                {
                    foreach (var item in section.Items)
                    {
                        await ShowcaseApi.AddItemAsync(new AddShowcaseItemRequest(newSection.Id, item.DemoId, item.TitleOverride));
                    }
                }
            }
            showcases = await ShowcaseApi.GetAllAsync();
        }
    }

    private async Task DeleteShowcase(Guid id)
    {
        contextMenuId = null;
        await ShowcaseApi.DeleteAsync(id);
        showcases = await ShowcaseApi.GetAllAsync();
    }

    private void ToggleContextMenu(Guid id)
    {
        contextMenuId = contextMenuId == id ? null : id;
    }

    private async Task DismissWelcome()
    {
        showWelcome = false;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "navtour_showcase_welcome_dismissed", "true"); } catch { }
    }

    // ── Editor Actions ──

    private async Task SaveShowcase()
    {
        if (showcase == null) return;
        saving = true;
        try
        {
            await ShowcaseApi.UpdateAsync(showcase.Id, new UpdateShowcaseRequest(
                editName, editDescription,
                isPublished ? "Published" : "Draft",
                editLayoutTheme, editAutoplay));

            // Sync section order
            for (int i = 0; i < editSections.Count; i++)
            {
                await ShowcaseApi.UpdateSectionAsync(editSections[i].Id, new UpdateSectionRequest(null, i));
            }
        }
        catch { }
        saving = false;
    }

    private async Task OnPublishToggle()
    {
        if (showcase == null) return;
        await ShowcaseApi.UpdateAsync(showcase.Id, new UpdateShowcaseRequest(
            null, null, isPublished ? "Published" : "Draft", null, null));
    }

    // ── Section Actions ──

    private async Task AddSection()
    {
        if (showcase == null) return;
        var section = await ShowcaseApi.AddSectionAsync(new CreateSectionRequest(showcase.Id, $"Section {editSections.Count + 1}"));
        if (section != null) editSections.Add(section);
    }

    private void StartRenameSection(ShowcaseSectionResponse section)
    {
        renamingSectionId = section.Id;
        renamingSectionName = section.Name;
    }

    private async Task FinishRenameSection()
    {
        if (renamingSectionId == null) return;
        var updated = await ShowcaseApi.UpdateSectionAsync(renamingSectionId.Value, new UpdateSectionRequest(renamingSectionName, null));
        if (updated != null)
        {
            var idx = editSections.FindIndex(s => s.Id == renamingSectionId.Value);
            if (idx >= 0) editSections[idx] = updated;
        }
        renamingSectionId = null;
    }

    private async Task DeleteSection(Guid sectionId)
    {
        await ShowcaseApi.DeleteSectionAsync(sectionId);
        editSections.RemoveAll(s => s.Id == sectionId);
    }

    private void ToggleSectionCollapse(Guid sectionId)
    {
        if (!collapsedSections.Remove(sectionId)) collapsedSections.Add(sectionId);
    }

    // ── Item Actions ──

    private async Task AddDemoToSection(Guid sectionId, DemoListItemResponse demo)
    {
        var item = await ShowcaseApi.AddItemAsync(new AddShowcaseItemRequest(sectionId, demo.Id, null));
        if (item != null)
        {
            var section = editSections.FirstOrDefault(s => s.Id == sectionId);
            if (section != null)
            {
                section.Items.Add(item);
            }
        }
        addingDemoSectionId = null;
    }

    private async Task DeleteItem(ShowcaseSectionResponse section, Guid itemId)
    {
        await ShowcaseApi.DeleteItemAsync(itemId);
        section.Items.RemoveAll(i => i.Id == itemId);
    }

    private async Task MoveItem(ShowcaseSectionResponse section, int index, int direction)
    {
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= section.Items.Count) return;
        var item = section.Items[index];
        section.Items.RemoveAt(index);
        section.Items.Insert(newIndex, item);

        // Update sort orders
        for (int i = 0; i < section.Items.Count; i++)
        {
            await ShowcaseApi.UpdateItemAsync(section.Items[i].Id, new UpdateShowcaseItemRequest(null, i));
        }
    }

    private IEnumerable<DemoListItemResponse> GetFilteredDemos()
    {
        var demos = allDemos.Where(d => d.Status == DemoStatus.Published);
        if (!string.IsNullOrWhiteSpace(demoSearchText))
            demos = demos.Where(d => d.Name.Contains(demoSearchText, StringComparison.OrdinalIgnoreCase));
        return demos;
    }

    // ── Share Helpers ──

    private string GetShowcaseUrl() => showcase?.Slug != null ? $"{Nav.BaseUri.TrimEnd('/')}/showcase-view/{showcase.Slug}" : "";
    private string GetFacebookShareUrl() => $"https://www.facebook.com/sharer/sharer.php?u={Uri.EscapeDataString(GetShowcaseUrl())}";
    private string GetTwitterShareUrl() => $"https://twitter.com/intent/tweet?url={Uri.EscapeDataString(GetShowcaseUrl())}&text={Uri.EscapeDataString($"Check out this showcase: {showcase?.Name ?? "Showcase"}")}";
    private string GetWhatsAppShareUrl() => $"https://wa.me/?text={Uri.EscapeDataString($"{showcase?.Name ?? "Showcase"} — {GetShowcaseUrl()}")}";
    private string GetLinkedInShareUrl() => $"https://www.linkedin.com/sharing/share-offsite/?url={Uri.EscapeDataString(GetShowcaseUrl())}";
    private string GetEmailShareUrl() => $"mailto:?subject={Uri.EscapeDataString(showcase?.Name ?? "Showcase")}&body={Uri.EscapeDataString($"Check out this showcase: {GetShowcaseUrl()}")}";

    private async Task CopyShowcaseUrl()
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", GetShowcaseUrl()); linkCopied = true; StateHasChanged(); await Task.Delay(2000); linkCopied = false; StateHasChanged(); } catch { }
    }

    private void CloseMenus()
    {
        contextMenuId = null;
        showShareMenu = false;
        addingDemoSectionId = null;
    }

    private async Task HandleSectionRenameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await FinishRenameSection();
    }

    private void OpenDemoPicker(Guid sectionId)
    {
        addingDemoSectionId = sectionId;
        demoSearchText = "";
    }
}
