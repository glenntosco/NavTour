@page "/demos/{DemoId:guid}/settings"
@rendermode InteractiveServer
@inject DemoApiService DemoApi
@inject NavigationManager Nav
@inject NotificationService Notification
@inject AuthService Auth
@inject DialogService DialogService
@inject FormApiService FormApi
@inject IJSRuntime JS

<RadzenStack Gap="16px" Style="max-width:600px">
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
        <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
            Click='() => Nav.NavigateTo($"/demos/{DemoId}/edit")' />
        <RadzenText TextStyle="TextStyle.H5">Demo Settings</RadzenText>
    </RadzenStack>

    @if (demo != null)
    {
        <RadzenCard>
            <RadzenStack Gap="12px">
                <RadzenFormField Text="Name">
                    <RadzenTextBox @bind-Value="name" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Description">
                    <RadzenTextArea @bind-Value="description" Style="width:100%" Rows="3" />
                </RadzenFormField>
                <RadzenFormField Text="Slug (URL path)">
                    <RadzenTextBox Value="@demo.Slug" Disabled="true" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Language">
                    <RadzenDropDown @bind-Value="locale" Data="@locales" Style="width:100%" />
                </RadzenFormField>
                <RadzenButton Text="Save Changes" ButtonStyle="ButtonStyle.Primary" Click="Save" IsBusy="saving" />
            </RadzenStack>
        </RadzenCard>

        <RadzenCard>
            <RadzenStack Gap="12px">
                <RadzenText TextStyle="TextStyle.H6">Welcome Screen</RadzenText>
                <RadzenText Style="font-size:13px;color:var(--rz-text-secondary-color)">Customize the overlay shown before the demo starts.</RadzenText>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px">
                    <RadzenSwitch @bind-Value="showWelcomeScreen" Change="@(_ => StateHasChanged())" />
                    <RadzenText Style="font-size:13px">Show Welcome Screen</RadzenText>
                </RadzenStack>
                @if (showWelcomeScreen)
                {
                    <RadzenFormField Text="Welcome Title" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="welcomeTitle" Placeholder="Leave empty to use demo name" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                    <RadzenFormField Text="Welcome Subtitle" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="welcomeSubtitle" Placeholder="Leave empty for default" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                    <RadzenFormField Text="Button Text" Style="width:100%">
                        <ChildContent>
                            <RadzenTextBox @bind-Value="welcomeButtonText" Placeholder="Start Demo" Style="width:100%" />
                        </ChildContent>
                    </RadzenFormField>
                }
                <RadzenButton Text="Save Welcome Settings" ButtonStyle="ButtonStyle.Secondary" Click="SaveWelcomeSettings" IsBusy="savingWelcome" />
            </RadzenStack>
        </RadzenCard>

        <VariableEditor DemoId="DemoId" />

        <RadzenCard>
            <RadzenStack Gap="12px">
                <RadzenText TextStyle="TextStyle.H6">Lead Capture Form</RadzenText>
                <RadzenText Style="font-size:13px;color:var(--rz-text-secondary-color)">Choose which form to show when a viewer completes the demo.</RadzenText>
                <RadzenDropDown @bind-Value="selectedFormId" Data="@formOptions" TextProperty="Name" ValueProperty="Id"
                    Placeholder="Default (Email, Name, Company)" AllowClear="true" Style="width:100%"
                    Change="@OnFormSelectionChanged" />
                <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
                    <RadzenLink Path="/forms/new" Text="Create New Form" Style="font-size:13px" />
                    @if (selectedFormId.HasValue)
                    {
                        <RadzenLink Path="@($"/forms/{selectedFormId}/edit")" Text="Edit Form" Style="font-size:13px" />
                    }
                </RadzenStack>
            </RadzenStack>
        </RadzenCard>

        <RadzenCard>
            <RadzenStack Gap="8px">
                <RadzenText TextStyle="TextStyle.H6" Style="color:var(--rz-danger)">Danger Zone</RadzenText>
                <RadzenText Style="font-size:13px;color:var(--rz-text-secondary-color)">This will permanently delete the demo, all frames, steps, and annotations. This action cannot be undone.</RadzenText>
                <RadzenButton Text="Delete Demo" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined" Click="ConfirmDelete" />
            </RadzenStack>
        </RadzenCard>
    }
</RadzenStack>

@code {
    [Parameter] public Guid DemoId { get; set; }

    private DemoResponse? demo;
    private string name = "";
    private string? description;
    private string locale = "en";
    private bool saving;
    private bool savingWelcome;
    private List<string> locales = ["en", "es"];

    // Welcome screen settings
    private bool showWelcomeScreen = true;
    private string? welcomeTitle;
    private string? welcomeSubtitle;
    private string? welcomeButtonText;

    // Lead capture form
    private Guid? selectedFormId;
    private List<FormOptionItem> formOptions = [];

    private record FormOptionItem(Guid Id, string Name);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.TryRestoreAsync();
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        demo = await DemoApi.GetDemoAsync(DemoId);
        if (demo != null)
        {
            name = demo.Name;
            description = demo.Description;
            locale = demo.Locale;
            selectedFormId = demo.FormId;
            LoadWelcomeSettings(demo.Settings);
        }
        var forms = await FormApi.GetFormsAsync();
        formOptions = forms.Select(f => new FormOptionItem(f.Id, f.Name)).ToList();
        StateHasChanged();
    }

    private void LoadWelcomeSettings(string? settingsJson)
    {
        if (string.IsNullOrEmpty(settingsJson)) return;
        try
        {
            var dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(settingsJson);
            if (dict == null) return;
            if (dict.TryGetValue("welcomeTitle", out var t)) welcomeTitle = t;
            if (dict.TryGetValue("welcomeSubtitle", out var s)) welcomeSubtitle = s;
            if (dict.TryGetValue("welcomeButtonText", out var b)) welcomeButtonText = b;
            if (dict.TryGetValue("showWelcomeScreen", out var sw)) showWelcomeScreen = sw != "false";
        }
        catch { }
    }

    private Dictionary<string, string> GetCurrentSettings()
    {
        Dictionary<string, string> dict = new();
        if (!string.IsNullOrEmpty(demo?.Settings))
        {
            try { dict = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(demo.Settings) ?? new(); }
            catch { }
        }
        return dict;
    }

    private async Task Save()
    {
        saving = true;
        await DemoApi.UpdateDemoAsync(DemoId, new UpdateDemoRequest(name, description, locale, null));
        Notification.Notify(NotificationSeverity.Success, "Saved");
        saving = false;
    }

    private async Task SaveWelcomeSettings()
    {
        savingWelcome = true;
        var dict = GetCurrentSettings();
        dict["showWelcomeScreen"] = showWelcomeScreen ? "true" : "false";
        dict["welcomeTitle"] = welcomeTitle ?? "";
        dict["welcomeSubtitle"] = welcomeSubtitle ?? "";
        dict["welcomeButtonText"] = welcomeButtonText ?? "";
        var json = System.Text.Json.JsonSerializer.Serialize(dict);
        await DemoApi.UpdateDemoAsync(DemoId, new UpdateDemoRequest(null, null, null, json));
        if (demo != null) demo = demo with { Settings = json };
        Notification.Notify(NotificationSeverity.Success, "Welcome settings saved");
        savingWelcome = false;
    }

    private async Task OnFormSelectionChanged()
    {
        await FormApi.AssignFormToDemoAsync(DemoId, new AssignFormRequest(selectedFormId));
        Notification.Notify(NotificationSeverity.Success, selectedFormId.HasValue ? "Form assigned" : "Form removed");
    }

    private async Task ConfirmDelete()
    {
        var confirmed = await DialogService.Confirm(
            "This will permanently delete the demo, all frames, steps, and annotations. This action cannot be undone.",
            "Delete Demo?",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

        if (confirmed == true)
        {
            await DemoApi.DeleteDemoAsync(DemoId);
            Notification.Notify(NotificationSeverity.Success, "Demo deleted");
            Nav.NavigateTo("/dashboard");
        }
    }
}
