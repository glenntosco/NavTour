@page "/hub"
@page "/hub/{HubId:guid}"
@rendermode InteractiveServer
@inject HubApiService HubApi
@inject DemoApiService DemoApi
@inject AuthService Auth
@inject NavigationManager Nav
@inject HttpClient Http
@inject IJSRuntime JS
@using NavTour.Shared.DTOs.Hub

<PageTitle>Demo Hub — NavTour</PageTitle>

@if (loading)
{
    <div class="he-loading">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </div>
}
else if (hub == null)
{
    @* ── Hub List / Selection ── *@
    <div class="he-hub-list">
        <div class="he-hub-list-header">
            <h2 class="he-hub-list-title">Demo Hubs</h2>
            <button class="he-btn-primary" @onclick="CreateHub">+ Create Hub</button>
        </div>
        <div class="he-hub-cards">
            @foreach (var h in hubs)
            {
                <div class="he-hub-card" @onclick="() => SelectHub(h)">
                    <div class="he-hub-card-info">
                        <span class="he-hub-card-name">@h.Name</span>
                        <span class="he-hub-card-meta">@h.Categories.Sum(c => c.Items.Count) demos &middot; @h.CreatedAt.ToString("MMM d, yyyy")</span>
                    </div>
                    <span class="he-hub-card-status @(h.IsPublished ? "published" : "")">@(h.IsPublished ? "Published" : "Draft")</span>
                </div>
            }
            @if (hubs.Count == 0)
            {
                <div class="he-empty">
                    <p>No hubs yet. Create one to get started.</p>
                </div>
            }
        </div>
    </div>
}
else
{
    @* ── Editor Shell ── *@
    <div class="he-shell">
        @* ── Left Panel: Tabs + Settings ── *@
        <div class="he-left">
            <div class="he-top-bar">
                <button class="he-btn-back" @onclick="BackToList" title="Back to hub list">
                    <svg viewBox="0 0 24 24" width="16" height="16"><path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z" fill="currentColor"/></svg>
                    <span>@hub.Name</span>
                </button>
                <div class="he-top-actions">
                    <label class="he-publish-toggle">
                        <RadzenSwitch @bind-Value="isPublished" Change="@OnPublishToggle" />
                        <span class="he-publish-label">@(isPublished ? "Published" : "Draft")</span>
                    </label>
                    <button class="he-btn-share" @onclick="() => showShareMenu = !showShareMenu" title="Share this hub">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                        Share
                    </button>
                    <button class="he-btn-primary" @onclick="SaveHub" disabled="@saving">@(saving ? "Saving..." : "Save")</button>
                </div>
                @if (showShareMenu)
                {
                    <div class="he-share-menu" @onclick:stopPropagation="true">
                        <div class="he-share-url">
                            <input type="text" readonly value="@GetHubUrl()" class="he-share-url-input" />
                            <button class="he-share-copy" @onclick="CopyHubUrl">@(linkCopied ? "Copied!" : "Copy")</button>
                        </div>
                        <div class="he-share-divider"></div>
                        <div class="he-share-buttons">
                            <a href="@GetFacebookShareUrl()" target="_blank" rel="noopener" class="he-share-btn" title="Share on Facebook">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                            </a>
                            <a href="@GetTwitterShareUrl()" target="_blank" rel="noopener" class="he-share-btn" title="Share on X">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                            </a>
                            <a href="@GetWhatsAppShareUrl()" target="_blank" rel="noopener" class="he-share-btn" title="Share on WhatsApp">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
                            </a>
                            <a href="@GetLinkedInShareUrl()" target="_blank" rel="noopener" class="he-share-btn" title="Share on LinkedIn">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                            </a>
                            <a href="@GetEmailShareUrl()" class="he-share-btn" title="Share via Email">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            </a>
                        </div>
                    </div>
                }
            </div>

            @* ── Tab Bar ── *@
            <div class="he-tabs">
                <button class="he-tab @(activeTab == "appearance" ? "active" : "")" @onclick='() => activeTab = "appearance"'>Appearance</button>
                <button class="he-tab @(activeTab == "content" ? "active" : "")" @onclick='() => activeTab = "content"'>Content</button>
                <button class="he-tab @(activeTab == "behavior" ? "active" : "")" @onclick='() => activeTab = "behavior"'>Behavior</button>
                <button class="he-tab @(activeTab == "install" ? "active" : "")" @onclick='() => activeTab = "install"'>Install</button>
                <button class="he-tab @(activeTab == "analytics" ? "active" : "")" @onclick="SelectAnalyticsTab">Analytics</button>
            </div>

            @* ── Tab Content ── *@
            <div class="he-panel">
                @switch (activeTab)
                {
                    case "appearance":
                        @AppearanceTab();
                        break;
                    case "content":
                        @ContentTab();
                        break;
                    case "behavior":
                        @BehaviorTab();
                        break;
                    case "install":
                        @InstallTab();
                        break;
                    case "analytics":
                        @AnalyticsTab();
                        break;
                }
            </div>
        </div>

        @* ── Right Panel: Live Preview ── *@
        <aside class="he-preview-pane">
            <h3 class="he-preview-title">Live Preview</h3>
            <div class="he-preview-stage">
                <div class="hub-preview" style="
                    --hub-bg1: @appearance.BackgroundColor1;
                    --hub-bg2: @(appearance.BackgroundColor2 ?? appearance.BackgroundColor1);
                    --hub-text: @appearance.TextColor;
                    --hub-accent: @(appearance.AccentColor ?? "#4361ee");
                    --hub-radius: @(appearance.BorderRadius)px;
                ">
                    <div class="hub-preview-header" style="background: @GetHeaderBackground()">
                        @if (appearance.ShowCloseButton) { <span class="preview-close">&times;</span> }
                        @if (appearance.DisplayType == "logo" && !string.IsNullOrEmpty(appearance.LogoUrl))
                        {
                            <img src="@appearance.LogoUrl" class="preview-logo" alt="Logo" />
                        }
                        else
                        {
                            <h3 class="preview-header-title" style="color:@appearance.TextColor;text-align:@appearance.Alignment">@(appearance.Title ?? "Help Center")</h3>
                        }
                        @if (!string.IsNullOrEmpty(appearance.Subtitle))
                        {
                            <p class="preview-header-sub" style="color:@appearance.TextColor;opacity:0.7;text-align:@appearance.Alignment">@appearance.Subtitle</p>
                        }
                    </div>
                    @if (behavior.SearchEnabled)
                    {
                        <div class="hub-preview-search">
                            <svg viewBox="0 0 24 24" width="14" height="14" style="opacity:0.5"><path d="M15.5 14h-.79l-.28-.27A6.47 6.47 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/></svg>
                            <span>@(behavior.SearchPlaceholder ?? "Search demos...")</span>
                        </div>
                    }
                    <div class="hub-preview-tabs">
                        <span class="preview-tab active">All</span>
                        @foreach (var cat in categories.Take(3))
                        {
                            <span class="preview-tab">@cat.Name</span>
                        }
                    </div>
                    <div class="hub-preview-cards @(appearance.CardStyle == "list" ? "list-view" : "")">
                        @{ var totalItems = categories.Sum(c => c.Items.Count); }
                        @for (int i = 0; i < Math.Max(Math.Min(4, totalItems), 2); i++)
                        {
                            <div class="preview-card">
                                @if (appearance.ShowThumbnails) { <div class="preview-thumb"></div> }
                                <div class="preview-card-body">
                                    <span class="preview-card-title">Demo @(i + 1)</span>
                                    @if (appearance.ShowDescriptions) { <span class="preview-card-desc">Interactive product walkthrough</span> }
                                    <div class="preview-card-meta">
                                        @if (appearance.ShowStepCount) { <span>5 steps</span> }
                                        @if (appearance.ShowDuration) { <span>2 min</span> }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="hub-preview-footer">
                        <span>@appearance.FooterMenuLabel</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>
}

@* ── Render Fragments ── *@

@{
    RenderFragment AppearanceTab() => @<div class="he-form">
        <label class="he-label">Display Type</label>
        <div class="he-seg">
            <button class="he-seg-btn @(appearance.DisplayType == "title" ? "active" : "")" @onclick='() => appearance.DisplayType = "title"'>Title</button>
            <button class="he-seg-btn @(appearance.DisplayType == "logo" ? "active" : "")" @onclick='() => appearance.DisplayType = "logo"'>Logo</button>
        </div>

        @if (appearance.DisplayType == "title")
        {
            <label class="he-label">Header Title</label>
            <RadzenTextBox @bind-Value="appearance.Title" Style="width:100%" />
        }
        else
        {
            <label class="he-label">Logo</label>
            @if (!string.IsNullOrEmpty(appearance.LogoUrl))
            {
                <div class="he-logo-preview">
                    <img src="@appearance.LogoUrl" alt="Logo" style="max-height:40px;max-width:200px" />
                    <button class="he-logo-remove" @onclick='() => appearance.LogoUrl = null'>Remove</button>
                </div>
            }
            <label class="he-upload-btn">
                <InputFile OnChange="HandleLogoUpload" accept=".png,.jpg,.jpeg,.svg,.webp,.gif" />
                <span>@(string.IsNullOrEmpty(appearance.LogoUrl) ? "Upload Logo" : "Replace")</span>
            </label>
            @if (logoUploading) { <span class="he-upload-status">Uploading...</span> }
        }

        <label class="he-label">Subtitle</label>
        <RadzenTextBox @bind-Value="appearance.Subtitle" Placeholder="Optional subtitle" Style="width:100%" />

        <label class="he-label">Alignment</label>
        <div class="he-seg">
            <button class="he-seg-btn @(appearance.Alignment == "left" ? "active" : "")" @onclick='() => appearance.Alignment = "left"'>Left</button>
            <button class="he-seg-btn @(appearance.Alignment == "center" ? "active" : "")" @onclick='() => appearance.Alignment = "center"'>Center</button>
            <button class="he-seg-btn @(appearance.Alignment == "right" ? "active" : "")" @onclick='() => appearance.Alignment = "right"'>Right</button>
        </div>

        <label class="he-label">Background Type</label>
        <div class="he-seg">
            <button class="he-seg-btn @(appearance.BackgroundType == "solid" ? "active" : "")" @onclick='() => appearance.BackgroundType = "solid"'>Solid</button>
            <button class="he-seg-btn @(appearance.BackgroundType == "gradient" ? "active" : "")" @onclick='() => appearance.BackgroundType = "gradient"'>Gradient</button>
            <button class="he-seg-btn @(appearance.BackgroundType == "image" ? "active" : "")" @onclick='() => appearance.BackgroundType = "image"'>Image</button>
        </div>

        <label class="he-label">Background Color</label>
        <div class="he-color-row">
            <input type="color" class="he-color-picker" @bind="appearance.BackgroundColor1" />
            <input type="text" class="he-color-hex" @bind="appearance.BackgroundColor1" @bind:event="oninput" />
        </div>

        @if (appearance.BackgroundType == "gradient")
        {
            <label class="he-label">Background Color 2</label>
            <div class="he-color-row">
                <input type="color" class="he-color-picker" value="@(appearance.BackgroundColor2 ?? "#4361ee")" @onchange="e => appearance.BackgroundColor2 = e.Value?.ToString()" />
                <input type="text" class="he-color-hex" value="@(appearance.BackgroundColor2 ?? "#4361ee")" @onchange="e => appearance.BackgroundColor2 = e.Value?.ToString()" />
            </div>
        }

        <label class="he-label">Text Color</label>
        <div class="he-color-row">
            <input type="color" class="he-color-picker" @bind="appearance.TextColor" />
            <input type="text" class="he-color-hex" @bind="appearance.TextColor" @bind:event="oninput" />
        </div>

        <label class="he-label">Accent Color</label>
        <div class="he-color-row">
            <input type="color" class="he-color-picker" value="@(appearance.AccentColor ?? "#4361ee")" @onchange="e => appearance.AccentColor = e.Value?.ToString()" />
            <input type="text" class="he-color-hex" value="@(appearance.AccentColor ?? "#4361ee")" @onchange="e => appearance.AccentColor = e.Value?.ToString()" />
        </div>

        <label class="he-label">Close Button</label>
        <RadzenSwitch @bind-Value="appearance.ShowCloseButton" />

        <label class="he-label">Content Theme</label>
        <div class="he-seg">
            <button class="he-seg-btn @(appearance.ContentTheme == "light" ? "active" : "")" @onclick='() => appearance.ContentTheme = "light"'>Light</button>
            <button class="he-seg-btn @(appearance.ContentTheme == "dark" ? "active" : "")" @onclick='() => appearance.ContentTheme = "dark"'>Dark</button>
            <button class="he-seg-btn @(appearance.ContentTheme == "auto" ? "active" : "")" @onclick='() => appearance.ContentTheme = "auto"'>Auto</button>
        </div>

        <label class="he-label">Card Style</label>
        <div class="he-seg">
            <button class="he-seg-btn @(appearance.CardStyle == "grid" ? "active" : "")" @onclick='() => appearance.CardStyle = "grid"'>Grid</button>
            <button class="he-seg-btn @(appearance.CardStyle == "list" ? "active" : "")" @onclick='() => appearance.CardStyle = "list"'>List</button>
        </div>

        <label class="he-label">Border Radius &mdash; @(appearance.BorderRadius)px</label>
        <input type="range" class="he-range" min="0" max="24" @bind="appearance.BorderRadius" @bind:event="oninput" />

        <div class="he-switch-group">
            <label class="he-switch-row"><RadzenSwitch @bind-Value="appearance.ShowThumbnails" /><span>Show Thumbnails</span></label>
            <label class="he-switch-row"><RadzenSwitch @bind-Value="appearance.ShowDescriptions" /><span>Show Descriptions</span></label>
            <label class="he-switch-row"><RadzenSwitch @bind-Value="appearance.ShowDuration" /><span>Show Duration</span></label>
            <label class="he-switch-row"><RadzenSwitch @bind-Value="appearance.ShowStepCount" /><span>Show Step Count</span></label>
        </div>

        <label class="he-label">Footer Menu Label</label>
        <RadzenTextBox @bind-Value="appearance.FooterMenuLabel" Style="width:100%" />

        <label class="he-label">Footer Links</label>
        @for (int i = 0; i < appearance.FooterLinks.Count; i++)
        {
            var idx = i;
            <div class="he-footer-link-row">
                <RadzenTextBox @bind-Value="appearance.FooterLinks[idx].Text" Placeholder="Label" Style="flex:1" />
                <RadzenTextBox @bind-Value="appearance.FooterLinks[idx].Url" Placeholder="https://..." Style="flex:2" />
                <button class="he-btn-icon-danger" @onclick="() => appearance.FooterLinks.RemoveAt(idx)">
                    <svg viewBox="0 0 24 24" width="14" height="14"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/></svg>
                </button>
            </div>
        }
        <button class="he-btn-text" @onclick="() => appearance.FooterLinks.Add(new FooterLink())">+ Add Link</button>
    </div>;

    RenderFragment ContentTab() => @<div class="he-form">
        @foreach (var cat in categories)
        {
            var catRef = cat;
            <div class="he-category">
                <div class="he-category-header" @onclick="() => ToggleCategory(catRef.Id)">
                    <svg viewBox="0 0 24 24" width="16" height="16" class="he-chevron @(expandedCategories.Contains(catRef.Id) ? "expanded" : "")">
                        <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z" fill="currentColor"/>
                    </svg>
                    <input type="text" class="he-inline-edit" value="@catRef.Name" @onchange="e => RenameCategoryLocal(catRef, e.Value?.ToString())" @onclick:stopPropagation="true" />
                    <span class="he-category-count">@catRef.Items.Count</span>
                    <button class="he-btn-icon-danger" @onclick="() => DeleteCategory(catRef)" @onclick:stopPropagation="true" title="Delete category">
                        <svg viewBox="0 0 24 24" width="14" height="14"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z" fill="currentColor"/></svg>
                    </button>
                </div>
                @if (expandedCategories.Contains(catRef.Id))
                {
                    <div class="he-category-body">
                        @foreach (var item in catRef.Items.OrderBy(i => i.SortOrder))
                        {
                            <div class="he-item-row">
                                <svg viewBox="0 0 24 24" width="14" height="14" class="he-drag-handle"><path d="M11 18c0 1.1-.9 2-2 2s-2-.9-2-2 .9-2 2-2 2 .9 2 2zm-2-8c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0-6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm6 4c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z" fill="currentColor"/></svg>
                                <span class="he-item-name">@(item.TitleOverride ?? item.DemoName ?? "Untitled")</span>
                                <span class="he-item-type">@item.ItemType</span>
                                <button class="he-btn-icon-danger" @onclick="() => DeleteItem(catRef, item)" title="Remove">
                                    <svg viewBox="0 0 24 24" width="14" height="14"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/></svg>
                                </button>
                            </div>
                        }
                        <div class="he-add-item-row">
                            <RadzenDropDown TValue="Guid?" @bind-Value="selectedDemoId" Data="availableDemos"
                                TextProperty="Name" ValueProperty="Id" Placeholder="Select a demo..." Style="flex:1" AllowClear="true" />
                            <button class="he-btn-secondary" @onclick="() => AddItemToCategory(catRef)" disabled="@(selectedDemoId == null)">Add</button>
                        </div>
                    </div>
                }
            </div>
        }
        <button class="he-btn-secondary he-btn-add-cat" @onclick="AddCategory">+ Add Category</button>
    </div>;

    RenderFragment BehaviorTab() => @<div class="he-form">
        <label class="he-label">Open Trigger</label>
        <RadzenDropDown TValue="string" @bind-Value="behavior.OpenTrigger"
            Data='new[] { "launcher", "custom", "hash", "api" }' Style="width:100%" />

        <label class="he-label">Auto Open</label>
        <div class="he-seg">
            <button class="he-seg-btn @(behavior.AutoOpen == "off" ? "active" : "")" @onclick='() => behavior.AutoOpen = "off"'>Off</button>
            <button class="he-seg-btn @(behavior.AutoOpen == "firstVisit" ? "active" : "")" @onclick='() => behavior.AutoOpen = "firstVisit"'>First Visit</button>
            <button class="he-seg-btn @(behavior.AutoOpen == "always" ? "active" : "")" @onclick='() => behavior.AutoOpen = "always"'>Always</button>
        </div>

        @if (behavior.AutoOpen != "off")
        {
            <label class="he-label">Auto Open Delay (ms)</label>
            <RadzenNumeric TValue="int" @bind-Value="behavior.AutoOpenDelay" Min="0" Max="30000" Step="500" Style="width:100%" />
        }

        <label class="he-label">Remember State</label>
        <RadzenSwitch @bind-Value="behavior.RememberState" />

        <label class="he-label">Search</label>
        <RadzenSwitch @bind-Value="behavior.SearchEnabled" />

        @if (behavior.SearchEnabled)
        {
            <label class="he-label">Search Placeholder</label>
            <RadzenTextBox @bind-Value="behavior.SearchPlaceholder" Style="width:100%" />
        }

        <label class="he-label">Keyboard Shortcut</label>
        <RadzenTextBox @bind-Value="behavior.KeyboardShortcut" Placeholder="e.g. Ctrl+K" Style="width:100%" />

        <label class="he-label">Mobile Behavior</label>
        <RadzenDropDown TValue="string" @bind-Value="behavior.MobileBehavior"
            Data='new[] { "drawer", "fullscreen", "redirect" }' Style="width:100%" />

        <label class="he-label">Notification Badge</label>
        <div class="he-seg">
            <button class="he-seg-btn @(behavior.NotificationBadge == "off" ? "active" : "")" @onclick='() => behavior.NotificationBadge = "off"'>Off</button>
            <button class="he-seg-btn @(behavior.NotificationBadge == "count" ? "active" : "")" @onclick='() => behavior.NotificationBadge = "count"'>Count</button>
            <button class="he-seg-btn @(behavior.NotificationBadge == "dot" ? "active" : "")" @onclick='() => behavior.NotificationBadge = "dot"'>Dot</button>
        </div>

        <label class="he-label">New Content Indicator</label>
        <RadzenSwitch @bind-Value="behavior.NewContentIndicator" />

        <label class="he-label">Completion Tracking</label>
        <RadzenSwitch @bind-Value="behavior.CompletionTracking" />
    </div>;

    RenderFragment InstallTab() => @<div class="he-form">
        <label class="he-label">Display Mode</label>
        <div class="he-seg">
            <button class="he-seg-btn @(install.DisplayMode == "launcher" ? "active" : "")" @onclick='() => install.DisplayMode = "launcher"'>Launcher</button>
            <button class="he-seg-btn @(install.DisplayMode == "customTrigger" ? "active" : "")" @onclick='() => install.DisplayMode = "customTrigger"'>Custom Trigger</button>
        </div>

        @if (install.DisplayMode == "launcher")
        {
            <label class="he-label">Launcher Style</label>
            <div class="he-seg">
                <button class="he-seg-btn @(install.LauncherStyle == "icon" ? "active" : "")" @onclick='() => install.LauncherStyle = "icon"'>Icon</button>
                <button class="he-seg-btn @(install.LauncherStyle == "iconText" ? "active" : "")" @onclick='() => install.LauncherStyle = "iconText"'>Icon + Text</button>
                <button class="he-seg-btn @(install.LauncherStyle == "text" ? "active" : "")" @onclick='() => install.LauncherStyle = "text"'>Text</button>
            </div>

            <label class="he-label">Launcher Text</label>
            <RadzenTextBox @bind-Value="install.LauncherText" Style="width:100%" />

            <label class="he-label">Launcher Color</label>
            <div class="he-color-row">
                <input type="color" class="he-color-picker" @bind="install.LauncherColor" />
                <input type="text" class="he-color-hex" @bind="install.LauncherColor" @bind:event="oninput" />
            </div>

            <label class="he-label">Position</label>
            <RadzenDropDown TValue="string" @bind-Value="install.Position"
                Data='new[] { "bottomRight", "bottomLeft", "topRight", "topLeft" }' Style="width:100%" />

            <div class="he-offset-row">
                <div class="he-offset-field">
                    <label class="he-label">Offset X (px)</label>
                    <RadzenNumeric TValue="int" @bind-Value="install.OffsetX" Min="0" Max="200" Style="width:100%" />
                </div>
                <div class="he-offset-field">
                    <label class="he-label">Offset Y (px)</label>
                    <RadzenNumeric TValue="int" @bind-Value="install.OffsetY" Min="0" Max="200" Style="width:100%" />
                </div>
            </div>
        }

        <label class="he-label" style="margin-top:24px">Installation Code</label>
        <div class="he-code-block">
            <div class="he-code-header">
                <span>Add to your website</span>
                <button class="he-btn-copy" @onclick="CopyScript">Copy</button>
            </div>
            <pre class="he-code"><code>&lt;script src="https://cdn.navtour.cloud/hub.js"&gt;&lt;/script&gt;
&lt;script&gt;
  NavTour.hub.init("@hub.Slug", @("{")
    position: "@install.Position",
    theme: "@appearance.ContentTheme"
  @("}"));
&lt;/script&gt;</code></pre>
        </div>

        <label class="he-label">Allowed Domains</label>
        <div class="he-domain-input">
            <RadzenTextBox @bind-Value="newDomain" Placeholder="example.com" Style="flex:1" />
            <button class="he-btn-secondary" @onclick="AddDomain" disabled="@string.IsNullOrWhiteSpace(newDomain)">Add</button>
        </div>
        <div class="he-domain-list">
            @foreach (var domain in install.AllowedDomains)
            {
                var d = domain;
                <span class="he-domain-tag">
                    @d
                    <button class="he-domain-remove" @onclick="() => install.AllowedDomains.Remove(d)">&times;</button>
                </span>
            }
        </div>
    </div>;

    RenderFragment AnalyticsTab() => @<div class="he-form">
        <div class="he-analytics-header">
            <h3 class="he-analytics-title">Hub Analytics</h3>
            <span class="he-analytics-range">Last 30 days</span>
        </div>
        @if (analyticsLoading)
        {
            <div class="he-analytics-loading">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Small" />
                <span>Loading analytics...</span>
            </div>
        }
        else if (hubAnalytics == null)
        {
            <div class="he-analytics-placeholder">
                <svg viewBox="0 0 24 24" width="48" height="48" fill="var(--nt-text-muted)"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"/></svg>
                <h3>No data yet</h3>
                <p>Analytics will appear once the hub is published and the widget SDK is installed on your site.</p>
            </div>
        }
        else
        {
            @* KPI Cards *@
            <div class="he-analytics-kpis">
                <div class="analytics-stat-card">
                    <span class="analytics-stat-icon" style="background:var(--nt-accent-light);color:var(--nt-accent)">
                        <RadzenIcon Icon="open_in_new" />
                    </span>
                    <span class="analytics-stat-value">@hubAnalytics.HubOpens.ToString("N0")</span>
                    <span class="analytics-stat-label">Hub Opens</span>
                </div>
                <div class="analytics-stat-card">
                    <span class="analytics-stat-icon" style="background:rgba(16,185,129,0.1);color:#059669">
                        <RadzenIcon Icon="people" />
                    </span>
                    <span class="analytics-stat-value">@hubAnalytics.UniqueVisitors.ToString("N0")</span>
                    <span class="analytics-stat-label">Unique Visitors</span>
                </div>
                <div class="analytics-stat-card">
                    <span class="analytics-stat-icon" style="background:rgba(245,158,11,0.1);color:#D97706">
                        <RadzenIcon Icon="play_circle" />
                    </span>
                    <span class="analytics-stat-value">@hubAnalytics.DemoStarts.ToString("N0")</span>
                    <span class="analytics-stat-label">Demo Starts</span>
                </div>
                <div class="analytics-stat-card">
                    <span class="analytics-stat-icon" style="background:rgba(239,68,68,0.1);color:#DC2626">
                        <RadzenIcon Icon="exit_to_app" />
                    </span>
                    <span class="analytics-stat-value">@hubAnalytics.BounceRate.ToString("F1")%</span>
                    <span class="analytics-stat-label">Bounce Rate</span>
                </div>
            </div>

            @* Top Searches *@
            <div class="he-analytics-section">
                <h4 class="he-analytics-section-title">Top Searches</h4>
                @if (hubAnalytics.TopSearches.Count == 0)
                {
                    <p class="he-analytics-empty">No search data yet.</p>
                }
                else
                {
                    <div class="he-analytics-list">
                        @foreach (var s in hubAnalytics.TopSearches)
                        {
                            <div class="he-analytics-row">
                                <span class="he-analytics-row-label">@s.Query</span>
                                <span class="he-analytics-row-count">@s.Count</span>
                            </div>
                        }
                    </div>
                }
            </div>

            @* Top Demos *@
            <div class="he-analytics-section">
                <h4 class="he-analytics-section-title">Top Demos</h4>
                @if (hubAnalytics.TopDemos.Count == 0)
                {
                    <p class="he-analytics-empty">No demo start data yet.</p>
                }
                else
                {
                    <div class="he-analytics-list">
                        @foreach (var d in hubAnalytics.TopDemos)
                        {
                            <div class="he-analytics-row">
                                <span class="he-analytics-row-label">@d.DemoName</span>
                                <span class="he-analytics-row-count">@d.Count starts</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>;
}

<style>
    /* ── Loading ── */
    .he-loading {
        display: flex; align-items: center; justify-content: center;
        height: 100%; min-height: 400px;
    }

    /* ── Hub List View ── */
    .he-hub-list {
        max-width: 720px; margin: 0 auto; padding: 32px 24px;
    }
    .he-hub-list-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 24px;
    }
    .he-hub-list-title {
        font-size: var(--nt-text-xl); font-weight: var(--nt-weight-bold);
        color: var(--nt-text-primary); margin: 0;
    }
    .he-hub-cards {
        display: flex; flex-direction: column; gap: 8px;
    }
    .he-hub-card {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px; border-radius: var(--nt-radius-md);
        border: 1px solid var(--nt-border); background: var(--nt-surface);
        cursor: pointer; transition: border-color var(--nt-duration-fast) var(--nt-ease), box-shadow var(--nt-duration-fast) var(--nt-ease);
    }
    .he-hub-card:hover {
        border-color: var(--nt-accent); box-shadow: 0 2px 8px rgba(67, 97, 238, 0.08);
    }
    .he-hub-card-info { display: flex; flex-direction: column; gap: 4px; }
    .he-hub-card-name {
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-primary);
    }
    .he-hub-card-meta {
        font-size: var(--nt-text-xs); color: var(--nt-text-muted);
    }
    .he-hub-card-status {
        font-size: var(--nt-text-xs); font-weight: var(--nt-weight-semibold);
        padding: 4px 10px; border-radius: 99px;
        background: var(--nt-neutral-100); color: var(--nt-text-muted);
    }
    .he-hub-card-status.published {
        background: rgba(16, 185, 129, 0.1); color: #059669;
    }
    .he-empty {
        padding: 48px 24px; text-align: center;
        font-size: var(--nt-text-sm); color: var(--nt-text-muted);
    }
    .he-empty p { margin: 0; }

    /* ── Editor Shell ── */
    .he-shell {
        display: flex; height: 100%; min-height: 0;
    }
    .he-left {
        flex: 1; display: flex; flex-direction: column; min-width: 0;
        border-right: 1px solid var(--nt-border);
    }

    /* ── Top Bar ── */
    .he-top-bar {
        display: flex; align-items: center; justify-content: space-between;
        padding: 12px 20px; border-bottom: 1px solid var(--nt-border);
        background: var(--nt-surface);
    }
    .he-btn-back {
        display: flex; align-items: center; gap: 8px;
        border: none; background: none; cursor: pointer;
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-primary); padding: 4px 0;
    }
    .he-btn-back:hover { color: var(--nt-accent); }
    .he-top-actions {
        display: flex; align-items: center; gap: 16px;
    }
    .he-publish-toggle {
        display: flex; align-items: center; gap: 8px; cursor: pointer;
    }
    .he-publish-label {
        font-size: var(--nt-text-xs); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-secondary);
    }

    /* ── Tabs ── */
    .he-tabs {
        display: flex; border-bottom: 1px solid var(--nt-border);
        padding: 0 20px; background: var(--nt-surface);
    }
    .he-tab {
        padding: 10px 16px; border: none; background: none; cursor: pointer;
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-medium);
        color: var(--nt-text-muted); position: relative;
        transition: color var(--nt-duration-fast) var(--nt-ease);
    }
    .he-tab:hover { color: var(--nt-text-primary); }
    .he-tab.active {
        color: var(--nt-accent); font-weight: var(--nt-weight-semibold);
    }
    .he-tab.active::after {
        content: ''; position: absolute; bottom: -1px; left: 0; right: 0;
        height: 2px; background: var(--nt-accent); border-radius: 2px 2px 0 0;
    }

    /* ── Settings Panel ── */
    .he-panel {
        flex: 1; overflow-y: auto; padding: 20px;
    }
    .he-form {
        display: flex; flex-direction: column; gap: 4px;
    }
    .he-label {
        display: block; font-size: var(--nt-text-xs); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-secondary); text-transform: uppercase; letter-spacing: 0.04em;
        margin-top: 14px;
    }
    .he-label:first-child { margin-top: 0; }

    .he-logo-preview {
        display: flex; align-items: center; gap: 12px;
        padding: 8px 12px; background: var(--nt-surface-subtle);
        border-radius: var(--nt-radius); margin-top: 6px;
    }
    .he-logo-remove {
        font-size: var(--nt-text-xs); color: var(--nt-error);
        background: none; border: none; cursor: pointer; font-weight: 500;
    }
    .he-logo-remove:hover { text-decoration: underline; }

    .he-upload-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px; margin-top: 6px;
        background: var(--nt-surface-subtle); border: 1px dashed var(--nt-border);
        border-radius: var(--nt-radius); cursor: pointer;
        font-size: var(--nt-text-sm); font-weight: 500; color: var(--nt-text-secondary);
        transition: border-color 150ms, background 150ms;
    }
    .he-upload-btn:hover { border-color: var(--nt-accent); background: var(--nt-accent-light); color: var(--nt-accent); }
    .he-upload-btn input[type="file"] { display: none; }

    .he-upload-status {
        font-size: var(--nt-text-xs); color: var(--nt-accent); font-weight: 500; margin-left: 8px;
    }

    /* ── Segmented Buttons ── */
    .he-seg {
        display: inline-flex; border: 1px solid var(--nt-border); border-radius: var(--nt-radius);
        overflow: hidden;
    }
    .he-seg-btn {
        padding: 6px 14px; border: none; border-right: 1px solid var(--nt-border);
        background: var(--nt-surface); color: var(--nt-text-secondary);
        font-size: var(--nt-text-xs); font-weight: var(--nt-weight-medium);
        cursor: pointer; transition: all var(--nt-duration-fast) var(--nt-ease);
    }
    .he-seg-btn:last-child { border-right: none; }
    .he-seg-btn.active {
        background: var(--nt-accent); color: #fff;
        font-weight: var(--nt-weight-semibold);
    }
    .he-seg-btn:hover:not(.active) { background: var(--nt-surface-subtle); }

    /* ── Color Inputs ── */
    .he-color-row {
        display: flex; gap: 8px; align-items: center;
    }
    .he-color-picker {
        width: 40px; height: 36px; padding: 2px; border: 1px solid var(--nt-border);
        border-radius: var(--nt-radius); cursor: pointer; background: var(--nt-surface);
    }
    .he-color-hex {
        flex: 1; padding: 8px 12px;
        border: 1px solid var(--nt-border); border-radius: var(--nt-radius);
        font-size: var(--nt-text-sm); font-family: var(--nt-font-mono);
        color: var(--nt-text-primary); background: var(--nt-surface);
        outline: none; transition: border-color var(--nt-duration-fast);
    }
    .he-color-hex:focus { border-color: var(--nt-accent); }

    /* ── Range ── */
    .he-range { width: 100%; accent-color: var(--nt-accent); cursor: pointer; }

    /* ── Switch Group ── */
    .he-switch-group {
        display: flex; flex-direction: column; gap: 10px; margin-top: 14px;
    }
    .he-switch-row {
        display: flex; align-items: center; gap: 10px; cursor: pointer;
    }
    .he-switch-row span {
        font-size: var(--nt-text-sm); color: var(--nt-text-primary);
    }

    /* ── Footer Links ── */
    .he-footer-link-row {
        display: flex; gap: 8px; align-items: center; margin-top: 6px;
    }

    /* ── Content Tab: Categories ── */
    .he-category {
        border: 1px solid var(--nt-border); border-radius: var(--nt-radius-md);
        overflow: hidden; margin-top: 8px;
    }
    .he-category:first-child { margin-top: 0; }
    .he-category-header {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 14px; background: var(--nt-surface-secondary);
        cursor: pointer; transition: background var(--nt-duration-fast);
    }
    .he-category-header:hover { background: var(--nt-surface-subtle); }
    .he-chevron {
        transition: transform var(--nt-duration-fast); flex-shrink: 0;
    }
    .he-chevron.expanded { transform: rotate(90deg); }
    .he-inline-edit {
        flex: 1; border: none; background: transparent;
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-primary); outline: none; padding: 2px 4px;
        border-radius: var(--nt-radius-sm);
    }
    .he-inline-edit:focus { background: var(--nt-surface); box-shadow: 0 0 0 2px var(--nt-accent); }
    .he-category-count {
        font-size: var(--nt-text-xs); color: var(--nt-text-muted);
        background: var(--nt-neutral-100); padding: 2px 8px;
        border-radius: 99px;
    }
    .he-category-body {
        padding: 10px 14px; display: flex; flex-direction: column; gap: 6px;
    }
    .he-item-row {
        display: flex; align-items: center; gap: 8px;
        padding: 8px 10px; border-radius: var(--nt-radius);
        background: var(--nt-surface); border: 1px solid var(--nt-border);
    }
    .he-drag-handle { color: var(--nt-text-muted); cursor: grab; flex-shrink: 0; }
    .he-item-name {
        flex: 1; font-size: var(--nt-text-sm); color: var(--nt-text-primary);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .he-item-type {
        font-size: var(--nt-text-xs); color: var(--nt-text-muted);
        background: var(--nt-neutral-100); padding: 2px 8px; border-radius: 99px;
    }
    .he-add-item-row {
        display: flex; gap: 8px; align-items: center; margin-top: 6px;
    }
    .he-btn-add-cat { margin-top: 12px; }

    /* ── Install Tab ── */
    .he-code-block {
        border: 1px solid var(--nt-border); border-radius: var(--nt-radius-md);
        overflow: hidden; margin-top: 4px;
    }
    .he-code-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 8px 14px; background: var(--nt-surface-secondary);
        border-bottom: 1px solid var(--nt-border);
        font-size: var(--nt-text-xs); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-secondary);
    }
    .he-btn-copy {
        padding: 4px 10px; border: 1px solid var(--nt-border); border-radius: var(--nt-radius);
        background: var(--nt-surface); color: var(--nt-text-secondary);
        font-size: var(--nt-text-xs); cursor: pointer;
        transition: all var(--nt-duration-fast);
    }
    .he-btn-copy:hover { border-color: var(--nt-accent); color: var(--nt-accent); }
    .he-code {
        margin: 0; padding: 14px; background: #1a1a2e;
        color: #e0e0e0; font-size: 12px; font-family: var(--nt-font-mono);
        overflow-x: auto; line-height: 1.6;
    }
    .he-offset-row {
        display: flex; gap: 12px; margin-top: 4px;
    }
    .he-offset-field { flex: 1; }
    .he-domain-input {
        display: flex; gap: 8px; align-items: center; margin-top: 4px;
    }
    .he-domain-list {
        display: flex; flex-wrap: wrap; gap: 6px; margin-top: 8px;
    }
    .he-domain-tag {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 4px 10px; border-radius: 99px;
        background: var(--nt-accent-light); color: var(--nt-accent);
        font-size: var(--nt-text-xs); font-weight: var(--nt-weight-medium);
    }
    .he-domain-remove {
        border: none; background: none; cursor: pointer; color: inherit;
        font-size: 14px; line-height: 1; padding: 0 2px; opacity: 0.7;
    }
    .he-domain-remove:hover { opacity: 1; }

    /* ── Analytics ── */
    .he-analytics-header {
        display: flex; align-items: center; justify-content: space-between;
        margin-bottom: 20px;
    }
    .he-analytics-title {
        margin: 0; font-size: var(--nt-text-lg); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-primary);
    }
    .he-analytics-range {
        font-size: var(--nt-text-xs); color: var(--nt-text-muted);
        background: var(--nt-surface-subtle); padding: 4px 10px;
        border-radius: 99px; border: 1px solid var(--nt-border);
    }
    .he-analytics-loading {
        display: flex; align-items: center; gap: 10px;
        padding: 32px 0; color: var(--nt-text-muted); font-size: var(--nt-text-sm);
    }
    .he-analytics-kpis {
        display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px;
        margin-bottom: 24px;
    }
    .he-analytics-section {
        margin-bottom: 24px;
    }
    .he-analytics-section-title {
        margin: 0 0 10px; font-size: var(--nt-text-sm); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-primary);
    }
    .he-analytics-list {
        display: flex; flex-direction: column; gap: 4px;
        border: 1px solid var(--nt-border); border-radius: var(--nt-radius);
        overflow: hidden;
    }
    .he-analytics-row {
        display: flex; align-items: center; justify-content: space-between;
        padding: 8px 12px; background: var(--nt-surface);
        font-size: var(--nt-text-sm);
    }
    .he-analytics-row:not(:last-child) {
        border-bottom: 1px solid var(--nt-border);
    }
    .he-analytics-row-label { color: var(--nt-text-primary); }
    .he-analytics-row-count {
        font-weight: var(--nt-weight-semibold); color: var(--nt-text-muted);
        font-size: var(--nt-text-xs);
    }
    .he-analytics-empty {
        margin: 0; font-size: var(--nt-text-sm); color: var(--nt-text-muted);
        padding: 16px 0;
    }
