@code {
    [Parameter] public Guid? HubId { get; set; }

    private HubResponse? hub;
    private List<HubResponse> hubs = [];
    private List<DemoListItemResponse> allDemos = [];
    private List<DemoListItemResponse> availableDemos = [];
    private bool loading = true;
    private bool saving;
    private bool logoUploading;
    private bool isPublished;
    private string activeTab = "appearance";

    // Editable settings
    private HubAppearanceSettings appearance = new();
    private HubBehaviorSettings behavior = new();
    private HubInstallSettings install = new();
    private List<HubCategoryResponse> categories = [];

    // UI state
    private HashSet<Guid> expandedCategories = [];
    private Guid? selectedDemoId;
    private string newDomain = "";

    // Analytics
    private HubAnalyticsResponse? hubAnalytics;
    private bool analyticsLoading;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.TryRestoreAsync();
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

        hubs = await HubApi.GetAllAsync();
        allDemos = await DemoApi.GetDemosAsync();
        availableDemos = allDemos.Where(d => d.Status == DemoStatus.Published).ToList();

        if (HubId.HasValue)
        {
            hub = await HubApi.GetByIdAsync(HubId.Value);
            if (hub != null) LoadSettings(hub);
        }
        else if (hubs.Count == 1)
        {
            hub = hubs[0];
            LoadSettings(hub);
        }

        loading = false;
        StateHasChanged();
    }

    private void LoadSettings(HubResponse h)
    {
        appearance = h.Appearance;
        behavior = h.Behavior;
        install = h.Install;
        categories = h.Categories.ToList();
        isPublished = h.IsPublished;
        expandedCategories = categories.Select(c => c.Id).ToHashSet();
    }

    private void SelectHub(HubResponse h)
    {
        hub = h;
        LoadSettings(h);
    }

    private void BackToList()
    {
        hub = null;
        hubAnalytics = null;
    }

    private async Task SelectAnalyticsTab()
    {
        activeTab = "analytics";
        if (hub != null && hubAnalytics == null && !analyticsLoading)
        {
            analyticsLoading = true;
            StateHasChanged();
            try
            {
                hubAnalytics = await Http.GetFromJsonAsync<HubAnalyticsResponse>($"api/v1/hubs/{hub.Id}/analytics");
            }
            catch { /* no data — leave null */ }
            finally
            {
                analyticsLoading = false;
                StateHasChanged();
            }
        }
    }

    private async Task HandleLogoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        logoUploading = true;
        StateHasChanged();
        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(5 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", file.Name);
            var response = await Http.PostAsync("api/v1/uploads/image", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<UploadResult>();
                if (result?.Url != null) appearance.LogoUrl = result.Url;
            }
        }
        catch { }
        logoUploading = false;
        StateHasChanged();
    }

    private record UploadResult(string? Url);

    private bool showShareMenu;
    private bool linkCopied;

    private string GetHubUrl() => hub?.Slug != null ? $"{Nav.BaseUri.TrimEnd('/')}/hub/{hub.Slug}" : "";

    private string GetFacebookShareUrl() => $"https://www.facebook.com/sharer/sharer.php?u={Uri.EscapeDataString(GetHubUrl())}";
    private string GetTwitterShareUrl() => $"https://twitter.com/intent/tweet?url={Uri.EscapeDataString(GetHubUrl())}&text={Uri.EscapeDataString($"Check out our interactive demos: {hub?.Name ?? "Demo Hub"}")}";
    private string GetWhatsAppShareUrl() => $"https://wa.me/?text={Uri.EscapeDataString($"{hub?.Name ?? "Demo Hub"} — {GetHubUrl()}")}";
    private string GetLinkedInShareUrl() => $"https://www.linkedin.com/sharing/share-offsite/?url={Uri.EscapeDataString(GetHubUrl())}";
    private string GetEmailShareUrl() => $"mailto:?subject={Uri.EscapeDataString(hub?.Name ?? "Demo Hub")}&body={Uri.EscapeDataString($"Check out our interactive demos: {GetHubUrl()}")}";

    private async Task CopyHubUrl()
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", GetHubUrl()); linkCopied = true; StateHasChanged(); await Task.Delay(2000); linkCopied = false; StateHasChanged(); } catch { }
    }

    private async Task SaveHub()
    {
        if (hub == null) return;
        saving = true;
        StateHasChanged();

        var result = await HubApi.UpdateAsync(hub.Id, new UpdateHubRequest(
            null, null, isPublished, appearance, behavior, install));
        if (result != null)
        {
            hub = result;
            var idx = hubs.FindIndex(h => h.Id == result.Id);
            if (idx >= 0) hubs[idx] = result;
        }

        saving = false;
        StateHasChanged();
    }

    private async Task CreateHub()
    {
        var result = await HubApi.CreateAsync(new CreateHubRequest("New Hub"));
        if (result != null)
        {
            hubs.Add(result);
            hub = result;
            LoadSettings(result);
        }
    }

    private async Task OnPublishToggle()
    {
        // publish state is saved with the next Save
        await Task.CompletedTask;
    }

    // ── Header background helper ──
    private string GetHeaderBackground() => appearance.BackgroundType switch
    {
        "gradient" => $"linear-gradient(135deg, {appearance.BackgroundColor1}, {appearance.BackgroundColor2 ?? appearance.BackgroundColor1})",
        "image" when !string.IsNullOrEmpty(appearance.BackgroundImageUrl) =>
            $"url('{appearance.BackgroundImageUrl}') center/cover no-repeat",
        _ => appearance.BackgroundColor1
    };

    // ── Category management ──
    private void ToggleCategory(Guid categoryId)
    {
        if (!expandedCategories.Remove(categoryId))
            expandedCategories.Add(categoryId);
    }

    private async Task AddCategory()
    {
        if (hub == null) return;
        var result = await HubApi.AddCategoryAsync(new CreateCategoryRequest(
            hub.Id, $"Category {categories.Count + 1}", null, null));
        if (result != null)
        {
            categories.Add(result);
            expandedCategories.Add(result.Id);
        }
    }

    private void RenameCategoryLocal(HubCategoryResponse cat, string? newName)
    {
        if (string.IsNullOrWhiteSpace(newName)) return;
        // Update locally; persisted via UpdateCategoryAsync on blur/save
        var idx = categories.FindIndex(c => c.Id == cat.Id);
        if (idx >= 0)
        {
            var old = categories[idx];
            categories[idx] = new HubCategoryResponse(old.Id, newName, old.Icon, old.Description, old.SortOrder, old.IsDefault, old.Items);
            _ = HubApi.UpdateCategoryAsync(cat.Id, new UpdateCategoryRequest(newName, null, null, null, null));
        }
    }

    private async Task DeleteCategory(HubCategoryResponse cat)
    {
        if (await HubApi.DeleteCategoryAsync(cat.Id))
        {
            categories.RemoveAll(c => c.Id == cat.Id);
            expandedCategories.Remove(cat.Id);
        }
    }

    // ── Item management ──
    private async Task AddItemToCategory(HubCategoryResponse cat)
    {
        if (selectedDemoId == null) return;
        var result = await HubApi.AddItemAsync(new AddItemRequest(
            cat.Id, "demo", selectedDemoId, null, null, null));
        if (result != null)
        {
            var idx = categories.FindIndex(c => c.Id == cat.Id);
            if (idx >= 0)
            {
                var old = categories[idx];
                var newItems = old.Items.ToList();
                newItems.Add(result);
                categories[idx] = new HubCategoryResponse(old.Id, old.Name, old.Icon, old.Description, old.SortOrder, old.IsDefault, newItems);
            }
            selectedDemoId = null;
        }
    }

    private async Task DeleteItem(HubCategoryResponse cat, HubItemResponse item)
    {
        if (await HubApi.DeleteItemAsync(item.Id))
        {
            var idx = categories.FindIndex(c => c.Id == cat.Id);
            if (idx >= 0)
            {
                var old = categories[idx];
                var newItems = old.Items.Where(i => i.Id != item.Id).ToList();
                categories[idx] = new HubCategoryResponse(old.Id, old.Name, old.Icon, old.Description, old.SortOrder, old.IsDefault, newItems);
            }
        }
    }

    // ── Install helpers ──
    private async Task CopyScript()
    {
        // JS interop for clipboard would go here
        await Task.CompletedTask;
    }

    private void AddDomain()
    {
        if (string.IsNullOrWhiteSpace(newDomain)) return;
        var domain = newDomain.Trim().ToLowerInvariant();
        if (!install.AllowedDomains.Contains(domain))
            install.AllowedDomains.Add(domain);
        newDomain = "";
    }
}
