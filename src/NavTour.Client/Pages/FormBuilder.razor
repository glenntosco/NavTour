    }

    .fb-submit-preview {
        margin-top: 20px;
        width: 100%;
        padding: 10px 20px;
        background: #4361ee;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        cursor: default;
    }

    /* Right Config */
    .fb-config {
        width: 320px;
        flex-shrink: 0;
        background: #fff;
        border-left: 1px solid #e5e7eb;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .fb-config-header {
        padding: 14px 16px;
        font-weight: 600;
        font-size: 14px;
        color: #333;
        border-bottom: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .fb-config-close {
        background: none;
        border: none;
        cursor: pointer;
        color: #999;
        padding: 2px;
        border-radius: 4px;
        display: flex;
    }

    .fb-config-close:hover {
        background: #f0f0f0;
        color: #555;
    }

    .fb-config-close .material-symbols-outlined {
        font-size: 18px;
    }

    .fb-config-body {
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
