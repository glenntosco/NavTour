@code {
    [Parameter] public Guid? FormId { get; set; }

    private bool isEditMode => FormId.HasValue;
    private FormResponse? existingForm;
    private bool saving;

    // Form data
    private string formName = "Untitled Form";
    private string? formDescription;
    private List<FieldModel> fields = [];
    private int selectedIndex = -1;

    // Settings
    private string? settingsTitle;
    private string? settingsSubtitle;
    private string submitButtonText = "Submit";
    private bool showConfirmation = true;
    private RepeatVisitorBehavior repeatBehavior = RepeatVisitorBehavior.AlwaysShow;
    private bool isStandalone;

    private int fieldCounter;

    private List<object> repeatOptions =
    [
        new { Text = "Always show", Value = RepeatVisitorBehavior.AlwaysShow },
        new { Text = "Skip if submitted", Value = RepeatVisitorBehavior.SkipIfSubmitted },
        new { Text = "Pre-fill values", Value = RepeatVisitorBehavior.PreFill }
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.TryRestoreAsync();
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

        if (isEditMode)
        {
            existingForm = await FormApi.GetFormAsync(FormId!.Value);
            if (existingForm == null)
            {
                Notification.Notify(NotificationSeverity.Error, "Form not found");
                Nav.NavigateTo("/forms");
                return;
            }
            LoadForm(existingForm);
        }

        StateHasChanged();
    }

    private void LoadForm(FormResponse form)
    {
        formName = form.Name;
        formDescription = form.Description;
        isStandalone = form.IsStandalone;

        fields = form.Fields.Select(f => new FieldModel
        {
            Key = f.Key,
            FieldType = f.FieldType,
            Label = f.Label,
            Placeholder = f.Placeholder,
            Description = f.Description,
            IsRequired = f.IsRequired,
            SortOrder = f.SortOrder,
            Options = f.Options != null ? new List<string>(f.Options) : null
        }).OrderBy(f => f.SortOrder).ToList();

        fieldCounter = fields.Count;

        if (form.Settings != null)
        {
            settingsTitle = form.Settings.Title;
            settingsSubtitle = form.Settings.Subtitle;
            submitButtonText = form.Settings.SubmitButtonText ?? "Submit";
            showConfirmation = form.Settings.ShowConfirmation;
            repeatBehavior = form.Settings.RepeatBehavior;
        }
    }

    // --- Add Fields ---

    private void AddDefaultField(string key, FormFieldType type, string label, string placeholder)
    {
        // Prevent duplicate default keys
        if (fields.Any(f => f.Key == key))
        {
            Notification.Notify(NotificationSeverity.Warning, $"{label} field already added");
            return;
        }

        var field = new FieldModel
        {
            Key = key,
            FieldType = type,
            Label = label,
            Placeholder = placeholder,
            IsRequired = type == FormFieldType.Email,
            SortOrder = fields.Count,
            Options = null
        };
        fields.Add(field);
        selectedIndex = fields.Count - 1;
    }

    private void AddCustomField(FormFieldType type)
    {
        fieldCounter++;
        var label = type switch
        {
            FormFieldType.Text => "Text Field",
            FormFieldType.TextArea => "Text Area",
            FormFieldType.Email => "Email",
            FormFieldType.Phone => "Phone",
            FormFieldType.Checkbox => "Checkbox",
            FormFieldType.Multiselect => "Multiselect",
            FormFieldType.Select => "Dropdown",
            FormFieldType.Url => "URL",
            _ => "Field"
        };

        var needsOptions = type == FormFieldType.Select || type == FormFieldType.Multiselect;

        var field = new FieldModel
        {
            Key = $"custom_{fieldCounter}",
            FieldType = type,
            Label = label,
            Placeholder = null,
            IsRequired = false,
            SortOrder = fields.Count,
            Options = needsOptions ? new List<string> { "Option 1", "Option 2" } : null
        };
        fields.Add(field);
        selectedIndex = fields.Count - 1;
    }

    // --- Field Operations ---

    private void SelectField(int index)
    {
        selectedIndex = index;
    }

    // Drag-and-drop state
    private int? dragIndex;
    private int? dragOverIndex;

    private void OnDragStart(int index)
    {
        dragIndex = index;
    }

    private void OnDragEnter(int index)
    {
        if (dragIndex == null || dragIndex == index) return;
        dragOverIndex = index;

        var item = fields[dragIndex.Value];
        fields.RemoveAt(dragIndex.Value);
        fields.Insert(index, item);

        if (selectedIndex == dragIndex) selectedIndex = index;
        else if (selectedIndex == index) selectedIndex = dragIndex.Value;

        dragIndex = index;
    }

    private void OnDragEnd()
    {
        dragIndex = null;
        dragOverIndex = null;
    }

    private void MoveField(int index, int direction)
    {
        var newIndex = index + direction;
        if (newIndex < 0 || newIndex >= fields.Count) return;

        (fields[index], fields[newIndex]) = (fields[newIndex], fields[index]);

        if (selectedIndex == index) selectedIndex = newIndex;
        else if (selectedIndex == newIndex) selectedIndex = index;
    }

    private void RemoveField(int index)
    {
        fields.RemoveAt(index);
        if (selectedIndex == index) selectedIndex = -1;
        else if (selectedIndex > index) selectedIndex--;
    }

    // --- Options Management ---

    private void AddOption(int fieldIndex)
    {
        if (fieldIndex >= 0 && fieldIndex < fields.Count)
        {
            var f = fields[fieldIndex];
            f.Options ??= [];
            f.Options.Add($"Option {f.Options.Count + 1}");
        }
    }

    private void UpdateOption(int fieldIndex, int optIndex, string value)
    {
        if (fieldIndex >= 0 && fieldIndex < fields.Count)
        {
            var f = fields[fieldIndex];
            if (f.Options != null && optIndex >= 0 && optIndex < f.Options.Count)
            {
                f.Options[optIndex] = value;
            }
        }
    }

    private void RemoveOption(int fieldIndex, int optIndex)
    {
        if (fieldIndex >= 0 && fieldIndex < fields.Count)
        {
            var f = fields[fieldIndex];
            if (f.Options != null && optIndex >= 0 && optIndex < f.Options.Count)
            {
                f.Options.RemoveAt(optIndex);
            }
        }
    }

    // --- Save ---

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(formName))
        {
            Notification.Notify(NotificationSeverity.Warning, "Please enter a form name");
            return;
        }

        saving = true;

        try
        {
            var fieldDefs = fields.Select((f, i) => new FormFieldDefinition(
                f.Key,
                f.FieldType,
                f.Label,
                f.Placeholder,
                f.Description,
                f.IsRequired,
                i,
                f.Options
            )).ToList();

            var settings = new FormSettingsDto(
                settingsTitle,
                settingsSubtitle,
                submitButtonText,
                true,
                showConfirmation,
                repeatBehavior
            );

            if (isEditMode)
            {
                var success = await FormApi.UpdateFormAsync(FormId!.Value, new UpdateFormRequest(
                    formName,
                    formDescription,
                    fieldDefs,
                    settings,
                    isStandalone
                ));

                if (success)
                {
                    existingForm = await FormApi.GetFormAsync(FormId!.Value);
                    Notification.Notify(NotificationSeverity.Success, "Form saved");
                }
                else
                {
                    Notification.Notify(NotificationSeverity.Error, "Failed to save form");
                }
            }
            else
            {
                var result = await FormApi.CreateFormAsync(new CreateFormRequest(
                    formName,
                    formDescription,
                    fieldDefs,
                    settings,
                    isStandalone
                ));

                if (result != null)
                {
                    Notification.Notify(NotificationSeverity.Success, "Form created");
                    Nav.NavigateTo($"/forms/{result.Id}/edit", replace: true);
                }
                else
                {
                    Notification.Notify(NotificationSeverity.Error, "Failed to create form");
                }
            }
        }
        finally
        {
            saving = false;
        }
    }

    // --- Mutable field model for editing ---
    private class FieldModel
    {
        public string Key { get; set; } = "";
        public FormFieldType FieldType { get; set; }
        public string Label { get; set; } = "";
        public string? Placeholder { get; set; }
        public string? Description { get; set; }
        public bool IsRequired { get; set; }
        public int SortOrder { get; set; }
        public List<string>? Options { get; set; }
    }
}
