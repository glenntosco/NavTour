@page "/forms/new"
@page "/forms/{FormId:guid}/edit"
@rendermode InteractiveServer
@inject FormApiService FormApi
@inject AuthService Auth
@inject NavigationManager Nav
@inject NotificationService Notification
@inject IJSRuntime JS

<div class="fb-layout">
    @* LEFT PANEL: Field Palette *@
    <div class="fb-palette">
        <div class="fb-palette-header">Add Fields</div>

        <div class="fb-palette-section">Default Fields</div>
        <button class="fb-palette-item" @onclick='() => AddDefaultField("email", FormFieldType.Email, "Email", "name@company.com")'>
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
            <span>Email</span>
        </button>
        <button class="fb-palette-item" @onclick='() => AddDefaultField("first_name", FormFieldType.Text, "First Name", "John")'>
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            <span>First Name</span>
        </button>
        <button class="fb-palette-item" @onclick='() => AddDefaultField("last_name", FormFieldType.Text, "Last Name", "Doe")'>
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            <span>Last Name</span>
        </button>
        <button class="fb-palette-item" @onclick='() => AddDefaultField("full_name", FormFieldType.Text, "Full Name", "John Doe")'>
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm-8 2.75c1.24 0 2.25 1.01 2.25 2.25S13.24 11.25 12 11.25 9.75 10.24 9.75 9 10.76 6.75 12 6.75zM17 17H7v-1.5c0-1.67 3.33-2.5 5-2.5s5 .83 5 2.5V17z"/></svg>
            <span>Full Name</span>
        </button>
        <button class="fb-palette-item" @onclick='() => AddDefaultField("phone", FormFieldType.Phone, "Phone", "+1 (555) 000-0000")'>
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
            <span>Phone</span>
        </button>
        <button class="fb-palette-item" @onclick='() => AddDefaultField("company", FormFieldType.Text, "Company Name", "Acme Inc.")'>
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"/></svg>
            <span>Company Name</span>
        </button>
        <button class="fb-palette-item" @onclick='() => AddDefaultField("job_title", FormFieldType.Text, "Job Title", "Product Manager")'>
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"/></svg>
            <span>Job Title</span>
        </button>

        <div class="fb-palette-section">Custom Fields</div>
        <button class="fb-palette-item" @onclick="() => AddCustomField(FormFieldType.Text)">
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M2.5 4v3h5v12h3V7h5V4h-13zm19 5h-9v3h3v7h3v-7h3V9z"/></svg>
            <span>Text</span>
        </button>
        <button class="fb-palette-item" @onclick="() => AddCustomField(FormFieldType.TextArea)">
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M3 18h12v-2H3v2zM3 6v2h18V6H3zm0 7h18v-2H3v2z"/></svg>
            <span>Text Area</span>
        </button>
        <button class="fb-palette-item" @onclick="() => AddCustomField(FormFieldType.Email)">
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M12.72 2.03C6.63 1.6 1.6 6.63 2.03 12.72 2.39 17.84 6.55 22 11.67 22H16v-2h-4.33c-3.68 0-6.97-2.53-7.67-6.13-.92-4.73 2.44-8.87 7-9.78V6.5l4 3-4 3V10c-2.83.47-4.89 3.17-4.37 6.12.4 2.29 2.28 4.07 4.59 4.37 3.17.41 5.92-1.81 6.23-4.78.09-.86-.04-1.69-.34-2.44l1.65-1.22c.52 1.1.8 2.34.7 3.64-.29 3.75-3.4 6.78-7.16 7.01C6.23 23.15 2 19.08 2 14c0-4.76 3.57-8.69 8.18-9.28C14.08 4.18 17.5 6.46 19 9.78l-1.84 1.37c-.86-2.1-2.82-3.6-5.12-3.87-.58-.07-1.15-.05-1.7.05C7.89 7.73 6.11 9.63 5.77 12.1c-.47 3.44 2.07 6.4 5.44 6.4 2.33 0 4.36-1.46 5.15-3.52l1.83 1.36C17.01 19.1 14.68 20.5 12 20.5c-4.69 0-8.5-3.81-8.5-8.5C3.5 7.52 7.02 3.77 11.46 3.52c.42-.02.84-.02 1.26.01z"/></svg>
            <span>Email</span>
        </button>
        <button class="fb-palette-item" @onclick="() => AddCustomField(FormFieldType.Phone)">
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56-.35-.12-.74-.03-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/></svg>
            <span>Phone</span>
        </button>
        <button class="fb-palette-item" @onclick="() => AddCustomField(FormFieldType.Checkbox)">
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            <span>Checkbox</span>
        </button>
        <button class="fb-palette-item" @onclick="() => AddCustomField(FormFieldType.Multiselect)">
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7zm-4 6h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2z"/></svg>
            <span>Multiselect</span>
        </button>
        <button class="fb-palette-item" @onclick="() => AddCustomField(FormFieldType.Select)">
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M7 10l5 5 5-5z"/></svg>
            <span>Select</span>
        </button>
        <button class="fb-palette-item" @onclick="() => AddCustomField(FormFieldType.Url)">
            <svg class="fb-icon" viewBox="0 0 24 24"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg>
            <span>URL</span>
        </button>
    </div>

    @* CENTER: Live Preview *@
    <div class="fb-center">
        <div class="fb-center-toolbar">
            <input class="fb-name-input" @bind="formName" @bind:event="oninput" placeholder="Untitled Form" />
            <RadzenButton Text="Save" Icon="save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                          Click="Save" IsBusy="saving" />
            <RadzenButton Icon="arrow_back" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                          Click='() => Nav.NavigateTo("/forms")' title="Back to forms" />
        </div>

        <div class="fb-preview-scroll">
            <div class="fb-preview-card">
                @if (!string.IsNullOrWhiteSpace(settingsTitle))
                {
                    <div class="fb-preview-title">@settingsTitle</div>
                }
                @if (!string.IsNullOrWhiteSpace(settingsSubtitle))
                {
                    <div class="fb-preview-subtitle">@settingsSubtitle</div>
                }

                @if (!fields.Any())
                {
                    <div class="fb-empty-state">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="#ccc"><path d="M9 11.24V7.5C9 6.12 10.12 5 11.5 5S14 6.12 14 7.5v3.74c1.21-.81 2-2.18 2-3.74C16 5.01 13.99 3 11.5 3S7 5.01 7 7.5c0 1.56.79 2.93 2 3.74zm9.84 4.63l-4.54-2.26c-.17-.07-.35-.11-.54-.11H13v-6c0-.83-.67-1.5-1.5-1.5S10 6.67 10 7.5v10.74l-3.43-.72c-.08-.01-.15-.03-.24-.03-.31 0-.59.13-.79.33l-.79.8 4.94 4.94c.27.27.65.44 1.06.44h6.79c.75 0 1.33-.55 1.44-1.28l.75-5.27c.01-.07.02-.14.02-.2 0-.62-.38-1.16-.91-1.38z"/></svg>
                        <p style="color:#999;margin:8px 0 0">Click fields from the left panel to add them</p>
                    </div>
                }
                else
                {
                    @for (int i = 0; i < fields.Count; i++)
                    {
                        var index = i;
                        var field = fields[index];
                        var isSelected = selectedIndex == index;

                        <div class="fb-field-row @(isSelected ? "selected" : "") @(dragOverIndex == index ? "drag-over" : "") @(dragIndex == index ? "dragging" : "")"
                             draggable="true"
                             @ondragstart="() => OnDragStart(index)"
                             @ondragenter="() => OnDragEnter(index)"
                             @ondragover:preventDefault
                             @ondragend="OnDragEnd"
                             @onclick="() => SelectField(index)">
                            <div class="fb-drag-handle" title="Drag to reorder">
                                <svg width="8" height="14" viewBox="0 0 8 14" fill="currentColor" opacity="0.3">
                                    <circle cx="2" cy="2" r="1.5"/><circle cx="6" cy="2" r="1.5"/>
                                    <circle cx="2" cy="7" r="1.5"/><circle cx="6" cy="7" r="1.5"/>
                                    <circle cx="2" cy="12" r="1.5"/><circle cx="6" cy="12" r="1.5"/>
                                </svg>
                            </div>
                            <div class="fb-field-content">
                                <label class="fb-field-label">
                                    @field.Label
                                    @if (field.IsRequired)
                                    {
                                        <span class="fb-required">*</span>
                                    }
                                </label>
                                @if (!string.IsNullOrWhiteSpace(field.Description))
                                {
                                    <div class="fb-field-desc">@field.Description</div>
                                }

                                @switch (field.FieldType)
                                {
                                    case FormFieldType.Text:
                                    case FormFieldType.Email:
                                    case FormFieldType.Phone:
                                    case FormFieldType.Url:
                                        <input type="text" class="fb-input" placeholder="@(field.Placeholder ?? "")" disabled />
                                        break;
                                    case FormFieldType.TextArea:
                                        <textarea class="fb-textarea" placeholder="@(field.Placeholder ?? "")" rows="3" disabled></textarea>
                                        break;
                                    case FormFieldType.Checkbox:
                                        <label class="fb-checkbox-label">
                                            <input type="checkbox" disabled />
                                            <span>@(field.Placeholder ?? field.Label)</span>
                                        </label>
                                        break;
                                    case FormFieldType.Select:
                                        <select class="fb-select" disabled>
                                            <option>@(field.Placeholder ?? "Select...")</option>
                                            @if (field.Options != null)
                                            {
                                                @foreach (var opt in field.Options)
                                                {
                                                    <option>@opt</option>
                                                }
                                            }
                                        </select>
                                        break;
                                    case FormFieldType.Multiselect:
                                        <div class="fb-multiselect-preview">
                                            @if (field.Options != null && field.Options.Any())
                                            {
                                                @foreach (var opt in field.Options)
                                                {
                                                    <label class="fb-checkbox-label">
                                                        <input type="checkbox" disabled />
                                                        <span>@opt</span>
                                                    </label>
                                                }
                                            }
                                            else
                                            {
                                                <span style="color:#aaa;font-size:13px">Add options in the right panel</span>
                                            }
                                        </div>
                                        break;
                                }
                            </div>
                            <div class="fb-field-actions">
                                <button class="fb-action-btn delete" title="Remove field" @onclick="() => RemoveField(index)" @onclick:stopPropagation="true">
                                    &times;
                                </button>
                            </div>
                        </div>
                    }
                }

                <button class="fb-submit-preview" disabled>
                    @(string.IsNullOrWhiteSpace(submitButtonText) ? "Submit" : submitButtonText)
                </button>
            </div>
        </div>
    </div>

    @* RIGHT PANEL: Config *@
    <div class="fb-config">
        @if (selectedIndex >= 0 && selectedIndex < fields.Count)
        {
            var sf = fields[selectedIndex];
            <div class="fb-config-header">
                Field Settings
                <button class="fb-config-close" @onclick="() => selectedIndex = -1">
                    &times;
                </button>
            </div>

            <div class="fb-config-body">
                <RadzenFormField Text="Label" Style="width:100%">
                    <RadzenTextBox Value="@sf.Label" Change="@(v => { sf.Label = v; StateHasChanged(); })" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Placeholder" Style="width:100%">
                    <RadzenTextBox Value="@sf.Placeholder" Change="@(v => { sf.Placeholder = v; StateHasChanged(); })" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Description" Style="width:100%">
                    <RadzenTextBox Value="@sf.Description" Change="@(v => { sf.Description = v; StateHasChanged(); })" Style="width:100%" />
                </RadzenFormField>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" Style="margin-top:4px">
                    <RadzenSwitch Value="@sf.IsRequired" Change="@((bool v) => { sf.IsRequired = v; StateHasChanged(); })" />
                    <RadzenText Style="font-size:13px">Required</RadzenText>
                </RadzenStack>

                @if (sf.FieldType == FormFieldType.Select || sf.FieldType == FormFieldType.Multiselect)
                {
                    <div style="margin-top:12px">
                        <RadzenText TextStyle="TextStyle.Subtitle2">Options</RadzenText>
                        @if (sf.Options != null)
                        {
                            @for (int oi = 0; oi < sf.Options.Count; oi++)
                            {
                                var optIndex = oi;
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="4px" Style="margin-top:4px">
                                    <RadzenTextBox Value="@sf.Options[optIndex]" Style="flex:1"
                                                   Change="@(v => UpdateOption(selectedIndex, optIndex, v))" />
                                    <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text"
                                                  Size="ButtonSize.ExtraSmall" Click="@(() => RemoveOption(selectedIndex, optIndex))" />
                                </RadzenStack>
                            }
                        }
                        <RadzenButton Text="Add Option" Icon="add" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.ExtraSmall"
                                      Style="margin-top:6px" Click="@(() => AddOption(selectedIndex))" />
                    </div>
                }
            </div>
        }
        else
        {
            <div class="fb-config-header">Form Settings</div>
            <div class="fb-config-body">
                <RadzenFormField Text="Title" Style="width:100%">
                    <RadzenTextBox @bind-Value="settingsTitle" Style="width:100%" Placeholder="Optional form title" />
                </RadzenFormField>
                <RadzenFormField Text="Subtitle" Style="width:100%">
                    <RadzenTextBox @bind-Value="settingsSubtitle" Style="width:100%" Placeholder="Optional subtitle" />
                </RadzenFormField>
                <RadzenFormField Text="Submit Button Text" Style="width:100%">
                    <RadzenTextBox @bind-Value="submitButtonText" Style="width:100%" Placeholder="Submit" />
                </RadzenFormField>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" Style="margin-top:4px">
                    <RadzenSwitch @bind-Value="showConfirmation" />
                    <RadzenText Style="font-size:13px">Show confirmation after submit</RadzenText>
                </RadzenStack>
                <RadzenFormField Text="Repeat Visitor Behavior" Style="width:100%;margin-top:8px">
                    <RadzenDropDown @bind-Value="repeatBehavior" Data="@repeatOptions" TextProperty="Text" ValueProperty="Value" Style="width:100%" />
                </RadzenFormField>
                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" Style="margin-top:12px">
                    <RadzenSwitch @bind-Value="isStandalone" />
                    <RadzenText Style="font-size:13px">Standalone form page</RadzenText>
                </RadzenStack>
                @if (isStandalone && existingForm != null)
                {
                    <div class="fb-slug-display">
                        <span style="color:#888;font-size:12px">URL:</span>
                        <code style="font-size:12px;word-break:break-all">/form/@existingForm.Slug</code>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
    /* Layout */
    .fb-layout {
        display: flex;
        height: 100%;
        overflow: hidden;
        background: #f5f6fa;
    }

    /* Left Palette */
    .fb-palette {
        width: 250px;
        flex-shrink: 0;
        background: #fff;
        border-right: 1px solid #e5e7eb;
        overflow-y: auto;
        padding-bottom: 16px;
    }

    .fb-palette-header {
        padding: 14px 16px;
        font-weight: 600;
        font-size: 14px;
        color: #333;
        border-bottom: 1px solid #e5e7eb;
    }

    .fb-palette-section {
        padding: 14px 16px 6px;
        font-size: 10px;
        font-weight: 700;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .fb-palette-item {
        display: flex;
        align-items: center;
        gap: 8px;
        width: calc(100% - 16px);
        margin: 1px 8px;
        padding: 7px 10px;
        background: none;
        border: 1px solid transparent;
        border-radius: 6px;
        font-size: 13px;
        color: #444;
        cursor: pointer;
        text-align: left;
        transition: background 0.15s;
    }

    .fb-palette-item:hover {
        background: #f0f1ff;
        border-color: #d0d4ff;
    }

    .fb-icon {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
        fill: #94a3b8;
    }
    .fb-palette-item:hover .fb-icon { fill: #4361ee; }

    /* Center Preview */
    .fb-center {
        flex: 1;
        display: flex;
        flex-direction: column;
        min-width: 0;
    }

    .fb-center-toolbar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: #fff;
        border-bottom: 1px solid #e5e7eb;
    }

    .fb-name-input {
        flex: 1;
        border: none;
        outline: none;
        font-size: 16px;
        font-weight: 600;
        color: #222;
        background: transparent;
        padding: 6px 0;
    }

    .fb-name-input::placeholder {
        color: #bbb;
    }

    .fb-preview-scroll {
        flex: 1;
        overflow-y: auto;
        padding: 32px 24px;
        display: flex;
        justify-content: center;
    }

    .fb-preview-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e5e7eb;
        padding: 32px;
        width: 100%;
        max-width: 520px;
        min-height: 200px;
    }

    .fb-preview-title {
        font-size: 20px;
        font-weight: 700;
        color: #222;
        margin-bottom: 4px;
    }

    .fb-preview-subtitle {
        font-size: 14px;
        color: #777;
        margin-bottom: 20px;
    }

    .fb-empty-state {
        text-align: center;
        padding: 48px 0;
    }

    /* Field Row */
    .fb-drag-handle {
        display: flex;
        align-items: center;
        padding: 4px 2px;
        cursor: grab;
        color: #cbd5e1;
        flex-shrink: 0;
    }
    .fb-drag-handle:active { cursor: grabbing; }

    .fb-field-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 12px;
        margin: 0 -12px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        border: 2px solid transparent;
    }

    .fb-field-row:hover {
        background: #fafbff;
    }

    .fb-field-row.selected {
        background: #f0f2ff;
        border-color: #4361ee;
    }
    .fb-field-row.dragging {
        opacity: 0.5;
    }
    .fb-field-row.drag-over {
        border-top: 2px solid #4361ee;
    }

    .fb-field-content {
        flex: 1;
        min-width: 0;
    }

    .fb-field-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #333;
        margin-bottom: 4px;
    }

    .fb-required {
        color: #e53e3e;
        margin-left: 2px;
    }

    .fb-field-desc {
        font-size: 12px;
        color: #888;
        margin-bottom: 4px;
    }

    .fb-input, .fb-textarea, .fb-select {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        font-size: 13px;
        color: #666;
        background: #fafafa;
    }

    .fb-textarea {
        resize: none;
    }

    .fb-select {
        appearance: auto;
    }

