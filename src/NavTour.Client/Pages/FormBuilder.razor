    .fb-field-row {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 12px;
        margin: 0 -12px;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        border: 2px solid transparent;
    }

    .fb-field-row:hover {
        background: #fafbff;
    }

    .fb-field-row.selected {
        background: #f0f2ff;
        border-color: #4361ee;
    }
    .fb-field-row.dragging {
        opacity: 0.5;
    }
    .fb-field-row.drag-over {
        border-top: 2px solid #4361ee;
    }

    .fb-field-content {
        flex: 1;
        min-width: 0;
    }

    .fb-field-label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #333;
        margin-bottom: 4px;
    }

    .fb-required {
        color: #e53e3e;
        margin-left: 2px;
    }

    .fb-field-desc {
        font-size: 12px;
        color: #888;
        margin-bottom: 4px;
    }

    .fb-input, .fb-textarea, .fb-select {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid #d1d5db;
