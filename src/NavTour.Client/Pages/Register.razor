@page "/register"
@layout Layout.AuthLayout
@rendermode InteractiveServer
@inject AuthService Auth
@inject NavigationManager Nav

<RadzenStack Gap="16px" Style="max-width:400px;margin:60px auto">
    <img src="navtour-logo.png" alt="NavTour" style="height:120px;width:auto;align-self:center" />
    <RadzenText TextStyle="TextStyle.H4">Create Your NavTour Account</RadzenText>

    @if (errorMessage != null)
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" ShowIcon="true">@errorMessage</RadzenAlert>
    }

    <RadzenTextBox @bind-Value="fullName" Placeholder="Full Name" Style="width:100%" />
    <RadzenTextBox @bind-Value="companyName" Placeholder="Company Name" Style="width:100%" />
    <RadzenTextBox @bind-Value="email" Placeholder="Email" Style="width:100%" />
    <RadzenPassword @bind-Value="password" Placeholder="Password (min 8 chars)" Style="width:100%" />
    <label style="display:flex;gap:10px;align-items:flex-start;font-size:14px;line-height:1.5;color:var(--nt-neutral-600)">
        <input type="checkbox" @bind="acceptedTerms" style="margin-top:4px" />
        <span>
            I agree to the <a href="/terms-of-use" target="_blank" rel="noopener noreferrer">Terms of Use</a>
            and <a href="/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a>.
        </span>
    </label>
    <RadzenButton Text="Create Account" ButtonStyle="ButtonStyle.Primary" Style="width:100%" Click="HandleRegister" IsBusy="loading" />

    <RadzenText>
        Already have an account? <RadzenLink Path="/login">Sign In</RadzenLink>
    </RadzenText>
</RadzenStack>

@code {
    private string fullName = "";
    private string companyName = "";
    private string email = "";
    private string password = "";
    private string? errorMessage;
    private bool loading;
    private bool acceptedTerms;

    private async Task HandleRegister()
    {
        if (!acceptedTerms)
        {
            errorMessage = "You must agree to the Terms of Use and Privacy Policy to create an account.";
            return;
        }

        loading = true;
        errorMessage = null;
        var (success, error) = await Auth.RegisterAsync(email, password, companyName, fullName, acceptedTerms);
        if (success)
            Nav.NavigateTo("/get-started");
        else
            errorMessage = error ?? "Registration failed";
        loading = false;
    }
}
