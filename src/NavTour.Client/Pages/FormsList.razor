@page "/forms"
@rendermode InteractiveServer
@inject FormApiService FormApi
@inject AuthService Auth
@inject NavigationManager Nav
@inject NotificationService Notification
@inject IJSRuntime JS

<RadzenStack Gap="24px">
    <div class="nt-page-header">
        <div>
            <h1 class="nt-page-title">Forms</h1>
            <p class="nt-page-subtitle">@(loading ? "" : $"{forms.Count} form{(forms.Count != 1 ? "s" : "")} in your workspace")</p>
        </div>
        <RadzenButton Text="New Form" Icon="add" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small"
                      Click="@(() => Nav.NavigateTo("/forms/new"))" />
    </div>

    @if (loading)
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height:200px">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        </RadzenStack>
    }
    else if (!forms.Any())
    {
        <div class="nt-empty">
            <div class="nt-empty-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
                </svg>
            </div>
            <h3>No forms yet</h3>
            <p>Create a form to capture leads from your product demos.</p>
            <RadzenButton Text="Create Your First Form" Icon="add" ButtonStyle="ButtonStyle.Primary"
                          Click="@(() => Nav.NavigateTo("/forms/new"))" />
        </div>
    }
    else
    {
        <div class="nt-card" style="padding:0;overflow:hidden">
        <RadzenDataGrid Data="@forms" TItem="FormListItemResponse" AllowSorting="true" AllowPaging="true" PageSize="25">
            <Columns>
                <RadzenDataGridColumn TItem="FormListItemResponse" Title="Name" Width="200px">
                    <Template Context="form">
                        <a href="/forms/@form.Id/edit" style="color:var(--nt-action);text-decoration:none;font-weight:600">@form.Name</a>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FormListItemResponse" Property="FieldCount" Title="Fields" Width="80px" TextAlign="TextAlign.Center" />
                <RadzenDataGridColumn TItem="FormListItemResponse" Property="SubmissionCount" Title="Submissions" Width="110px" TextAlign="TextAlign.Center" />
                <RadzenDataGridColumn TItem="FormListItemResponse" Property="ViewCount" Title="Views" Width="80px" TextAlign="TextAlign.Center" />
                <RadzenDataGridColumn TItem="FormListItemResponse" Title="Conversion" Width="100px" TextAlign="TextAlign.Center">
                    <Template Context="form">
                        @form.ConversionRate.ToString("0.0")%
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="FormListItemResponse" Property="AssignedDemoCount" Title="Demos" Width="80px" TextAlign="TextAlign.Center" />
                <RadzenDataGridColumn TItem="FormListItemResponse" Property="CreatedAt" Title="Created" Width="140px" FormatString="{0:MMM d, yyyy}" />
                <RadzenDataGridColumn TItem="FormListItemResponse" Title="" Width="160px" Sortable="false" TextAlign="TextAlign.Center">
                    <Template Context="form">
                        <RadzenButton Icon="share" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                                      Size="ButtonSize.Small" title="Copy share URL"
                                      Click="@(() => CopyUrl(form))" />
                        <RadzenButton Icon="code" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                                      Size="ButtonSize.Small" title="Copy embed code"
                                      Click="@(() => CopyEmbed(form))" />
                        <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text"
                                      Size="ButtonSize.Small" title="Edit form"
                                      Click="@(() => Nav.NavigateTo($"/forms/{form.Id}/edit"))" />
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text"
                                      Size="ButtonSize.Small" title="Delete form"
                                      Click="@(() => ConfirmDelete(form))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
        </div>
    }
</RadzenStack>

@code {
    private List<FormListItemResponse> forms = [];
    private bool loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.TryRestoreAsync();
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        forms = await FormApi.GetFormsAsync();
        loading = false;
        StateHasChanged();
    }

    private string GetFormUrl(FormListItemResponse form)
    {
        var uri = new Uri(Nav.BaseUri);
        var baseUrl = uri.Port is 80 or 443 ? $"{uri.Scheme}://{uri.Host}" : $"{uri.Scheme}://{uri.Host}:{uri.Port}";
        return $"{baseUrl}/form/{form.Slug}";
    }

    private async Task CopyUrl(FormListItemResponse form)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", GetFormUrl(form));
        Notification.Notify(NotificationSeverity.Success, "Share URL copied");
    }

    private async Task CopyEmbed(FormListItemResponse form)
    {
        var url = GetFormUrl(form);
        var embed = $"<iframe src=\"{url}\" width=\"100%\" height=\"600\" frameborder=\"0\" style=\"border:none;border-radius:8px\"></iframe>";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", embed);
        Notification.Notify(NotificationSeverity.Success, "Embed code copied");
    }

    private async Task ConfirmDelete(FormListItemResponse form)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete form \"{form.Name}\"? This action cannot be undone.");
        if (confirmed)
        {
            var success = await FormApi.DeleteFormAsync(form.Id);
            if (success)
            {
                forms.Remove(form);
                Notification.Notify(NotificationSeverity.Success, "Form deleted");
                StateHasChanged();
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Failed to delete form");
            }
        }
    }
}
