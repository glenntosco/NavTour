@page "/analytics"
@rendermode InteractiveServer
@using NavTour.Client.Services
@using NavTour.Shared.DTOs.Analytics
@using NavTour.Shared.DTOs.Demos
@using NavTour.Shared.DTOs.Leads
@inject AnalyticsApiService AnalyticsApi
@inject DemoApiService DemoApi
@inject HttpClient Http
@inject AuthService Auth
@inject NavigationManager Nav

<RadzenStack Gap="24px">
    <div class="nt-page-header">
        <div>
            <h1 class="nt-page-title">Analytics</h1>
            <p class="nt-page-subtitle">Performance across all demos — last 30 days</p>
        </div>
    </div>

    @if (loading)
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height:300px">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        </RadzenStack>
    }
    else if (summary != null)
    {
        @* KPI stat cards *@
        <div class="analytics-kpi-grid">
            <RadzenCard class="analytics-kpi-card">
                <div class="kpi-icon-wrap kpi-icon-blue">
                    <RadzenIcon Icon="visibility" />
                </div>
                <div class="kpi-content">
                    <span class="kpi-value">@summary.TotalViews.ToString("N0")</span>
                    <span class="kpi-label">Total Views</span>
                </div>
            </RadzenCard>

            <RadzenCard class="analytics-kpi-card">
                <div class="kpi-icon-wrap kpi-icon-green">
                    <RadzenIcon Icon="check_circle" />
                </div>
                <div class="kpi-content">
                    <span class="kpi-value">@summary.Completions.ToString("N0")</span>
                    <span class="kpi-label">Completions</span>
                </div>
            </RadzenCard>

            <RadzenCard class="analytics-kpi-card">
                <div class="kpi-icon-wrap kpi-icon-amber">
                    <RadzenIcon Icon="percent" />
                </div>
                <div class="kpi-content">
                    <span class="kpi-value">@(summary.CompletionRate.ToString("F1"))%</span>
                    <span class="kpi-label">Completion Rate</span>
                </div>
            </RadzenCard>

            <RadzenCard class="analytics-kpi-card">
                <div class="kpi-icon-wrap kpi-icon-neutral">
                    <RadzenIcon Icon="schedule" />
                </div>
                <div class="kpi-content">
                    <span class="kpi-value">@TimeSpan.FromSeconds(summary.AvgTimeSeconds).ToString(@"m\:ss")</span>
                    <span class="kpi-label">Avg Time</span>
                </div>
            </RadzenCard>
        </div>

        @* Views over time chart *@
        <div class="analytics-card">
            <h3 class="analytics-card-title">Views Over Time</h3>
            <div class="analytics-source-filters">
                <button class="analytics-source-pill @(sourceFilter == null ? "active" : "")" @onclick="() => sourceFilter = null">All</button>
                <button class="analytics-source-pill @(sourceFilter == "embed" ? "active" : "")" @onclick='() => sourceFilter = "embed"'>Embed</button>
                <button class="analytics-source-pill @(sourceFilter == "link" ? "active" : "")" @onclick='() => sourceFilter = "link"'>Share Link</button>
                <button class="analytics-source-pill @(sourceFilter == "social" ? "active" : "")" @onclick='() => sourceFilter = "social"'>Social</button>
            </div>
            @if (summary.ViewsOverTime.Count > 0)
            {
                <RadzenChart Style="height:280px">
                    <RadzenAreaSeries Data="@summary.ViewsOverTime" CategoryProperty="Date" ValueProperty="Count"
                        Stroke="rgba(67, 97, 238, 1)" Fill="rgba(67, 97, 238, 0.08)" StrokeWidth="2" />
                    <RadzenCategoryAxis FormatString="{0:MMM dd}" />
                    <RadzenValueAxis />
                </RadzenChart>
            }
            else
            {
                <div class="analytics-empty">No view data yet</div>
            }
        </div>

        @* Step drop-off funnel *@
        @if (summary.Funnel.Count > 0)
        {
            <div class="analytics-card">
                <h3 class="analytics-card-title">Step Drop-off</h3>
                <div class="funnel-chart">
                    @{ var maxViews = summary.Funnel.Max(f => f.ViewCount); }
                    @foreach (var step in summary.Funnel)
                    {
                        var widthPct = maxViews > 0 ? (double)step.ViewCount / maxViews * 100 : 0;
                        var completionPct = step.ViewCount > 0 ? (double)step.CompletionCount / step.ViewCount * 100 : 0;
                        <div class="funnel-row">
                            <span class="funnel-label">Step @step.StepNumber</span>
                            <div class="funnel-bar-track">
                                <div class="funnel-bar" style="width:@(widthPct.ToString("F1"))%"
                                     title="@step.ViewCount views, @step.CompletionCount completions, @(completionPct.ToString("F0"))% completion"></div>
                            </div>
                            <span class="funnel-value">@step.ViewCount</span>
                            <span class="funnel-pct">@(completionPct.ToString("F0"))%</span>
                        </div>
                    }
                </div>
                @if (summary.Funnel.Count > 1)
                {
                    var maxDrop = summary.Funnel.Skip(1)
                        .Select((f, i) => new { Step = f.StepNumber, Drop = summary.Funnel[i].ViewCount - f.ViewCount })
                        .OrderByDescending(x => x.Drop)
                        .FirstOrDefault();
                    @if (maxDrop != null && maxDrop.Drop > 0)
                    {
                        <div class="analytics-insight">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                            <span>Highest drop-off: Step @maxDrop.Step (lost @maxDrop.Drop viewers)</span>
                        </div>
                    }
                }
            </div>
        }

        <RadzenRow Gap="16px">
            @* Per-demo breakdown *@
            <RadzenColumn SizeMD="7" Size="12">
                <div class="analytics-card">
                    <h3 class="analytics-card-title">Demo Performance</h3>
                    @if (demos.Count > 0)
                    {
                        <RadzenDataGrid Data="@demos" TItem="DemoListItemResponse" AllowSorting="true">
                            <Columns>
                                <RadzenDataGridColumn TItem="DemoListItemResponse" Property="Name" Title="Demo">
                                    <Template Context="d">
                                        <RadzenLink Path="@($"/demos/{d.Id}/analytics")" Style="font-weight:600;color:var(--nt-accent)">@d.Name</RadzenLink>
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="DemoListItemResponse" Property="Status" Title="Status" Width="90px">
                                    <Template Context="d">
                                        <RadzenBadge Text="@d.Status.ToString()"
                                            BadgeStyle="@(d.Status == NavTour.Shared.Enums.DemoStatus.Published ? BadgeStyle.Success : BadgeStyle.Light)"
                                            Style="font-size:0.6875rem" />
                                    </Template>
                                </RadzenDataGridColumn>
                                <RadzenDataGridColumn TItem="DemoListItemResponse" Property="ViewCount" Title="Views" Width="80px" TextAlign="TextAlign.Right" />
                                <RadzenDataGridColumn TItem="DemoListItemResponse" Property="FrameCount" Title="Frames" Width="80px" TextAlign="TextAlign.Right" />
                                <RadzenDataGridColumn TItem="DemoListItemResponse" Property="StepCount" Title="Steps" Width="80px" TextAlign="TextAlign.Right" />
                            </Columns>
                        </RadzenDataGrid>
                    }
                    else
                    {
                        <div class="analytics-empty">No demos yet</div>
                    }
                </div>
            </RadzenColumn>

            @* Top sources *@
            <RadzenColumn SizeMD="5" Size="12">
                <div class="analytics-card">
                    <h3 class="analytics-card-title">Top Sources</h3>
                    @if (summary.TopSources.Count > 0)
                    {
                        <RadzenDataGrid Data="@summary.TopSources" TItem="SourceEntry">
                            <Columns>
                                <RadzenDataGridColumn TItem="SourceEntry" Property="Source" Title="Source" />
                                <RadzenDataGridColumn TItem="SourceEntry" Property="Count" Title="Views" Width="80px" TextAlign="TextAlign.Right" />
                            </Columns>
                        </RadzenDataGrid>
                    }
                    else
                    {
                        <div class="analytics-empty">No source data yet</div>
                    }
                </div>
            </RadzenColumn>
        </RadzenRow>

        @* Leads summary *@
        <div class="analytics-card">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
                <RadzenStack Gap="2px">
                    <h3 class="analytics-card-title" style="margin:0">Leads Captured</h3>
                    <span style="font-size:2rem;font-weight:700;color:var(--nt-text-primary)">@leadCount</span>
                </RadzenStack>
                <RadzenButton Text="View All Leads" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                    Click='() => Nav.NavigateTo("/leads")' />
            </RadzenStack>
        </div>

        @* Recent sessions *@
        <div class="analytics-card">
            <h3 class="analytics-card-title">Recent Sessions</h3>
            <RadzenDataGrid Data="@sessions" TItem="SessionListResponse" AllowPaging="true" PageSize="10" AllowSorting="true">
                <Columns>
                    <RadzenDataGridColumn TItem="SessionListResponse" Property="StartedAt" Title="Started" FormatString="{0:g}" Width="160px" />
                    <RadzenDataGridColumn TItem="SessionListResponse" Property="StepsViewed" Title="Steps Viewed" Width="120px" TextAlign="TextAlign.Center" />
                    <RadzenDataGridColumn TItem="SessionListResponse" Property="TotalSteps" Title="Total Steps" Width="110px" TextAlign="TextAlign.Center" />
                    <RadzenDataGridColumn TItem="SessionListResponse" Property="Completed" Title="Status" Width="100px">
                        <Template Context="session">
                            <RadzenBadge Text="@(session.Completed ? "Completed" : "Dropped")"
                                BadgeStyle="@(session.Completed ? BadgeStyle.Success : BadgeStyle.Light)"
                                Style="font-size:0.6875rem" />
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="SessionListResponse" Property="Source" Title="Source" />
                </Columns>
            </RadzenDataGrid>
        </div>
    }
</RadzenStack>

<style>
    .analytics-kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    .analytics-kpi-card {
        display: flex !important;
        align-items: center;
        gap: 16px;
        padding: 20px 24px !important;
        border-radius: var(--nt-radius-md) !important;
        border: 1px solid var(--nt-border) !important;
        box-shadow: var(--nt-shadow-sm) !important;
        background: var(--nt-surface) !important;
        transition: box-shadow 200ms, transform 200ms;
    }

    .analytics-kpi-card:hover {
        box-shadow: var(--nt-shadow-md) !important;
        transform: translateY(-1px);
    }

    .kpi-icon-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 48px; height: 48px;
        border-radius: var(--nt-radius-md);
        font-size: 24px;
        flex-shrink: 0;
    }

    .kpi-icon-blue {
        background: var(--nt-accent-light);
        color: var(--nt-accent);
    }

    .kpi-icon-green {
        background: var(--nt-success-light, #E8F5E9);
        color: var(--nt-success);
    }

    .kpi-icon-amber {
        background: var(--nt-warning-light, #FFF4E5);
        color: var(--nt-warning, #F59E0B);
    }

    .kpi-icon-neutral {
        background: var(--nt-surface-subtle);
        color: var(--nt-neutral-600);
    }

    .kpi-content {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .kpi-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--nt-text-primary);
        line-height: 1.2;
        letter-spacing: -0.02em;
    }

    .kpi-label {
        font-size: var(--nt-text-sm);
        font-weight: 500;
        color: var(--nt-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    @@media (max-width: 768px) {
        .analytics-kpi-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .analytics-card {
        background: var(--nt-surface);
        border: 1px solid var(--nt-border);
        border-radius: var(--nt-radius);
        padding: 24px;
        box-shadow: var(--nt-shadow-sm);
    }

    .analytics-card-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--nt-text-primary);
        margin: 0 0 16px;
    }

    .analytics-empty {
        text-align: center; padding: 40px 16px;
        color: var(--nt-text-muted); font-size: 0.875rem;
    }

    .funnel-chart {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .funnel-row {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .funnel-label {
        font-size: var(--nt-text-sm);
        color: var(--nt-text-secondary);
        font-weight: 500;
        width: 60px;
        flex-shrink: 0;
    }

    .funnel-bar-track {
        flex: 1;
        height: 28px;
        background: var(--nt-surface-subtle);
        border-radius: var(--nt-radius-sm);
        overflow: hidden;
    }

    .funnel-bar {
        height: 100%;
        background: linear-gradient(90deg, var(--nt-accent), rgba(67, 97, 238, 0.6));
        border-radius: var(--nt-radius-sm);
        min-width: 4px;
        transition: width 600ms cubic-bezier(0.1, 0.9, 0.2, 1);
    }

    .funnel-value {
        font-size: var(--nt-text-sm);
        font-weight: 600;
        color: var(--nt-text-primary);
        width: 48px;
        text-align: right;
        flex-shrink: 0;
    }

    .funnel-pct {
        font-size: var(--nt-text-xs);
        color: var(--nt-text-muted);
        width: 36px;
        text-align: right;
        flex-shrink: 0;
    }

    .analytics-source-filters { display: flex; gap: 6px; margin-bottom: 16px; }
    .analytics-source-pill { padding: 4px 12px; border: 1px solid var(--nt-border); border-radius: 16px; background: var(--nt-surface); color: var(--nt-text-secondary); font-size: 12px; font-weight: 500; cursor: pointer; font-family: var(--nt-font); transition: all 150ms; }
    .analytics-source-pill.active { background: var(--nt-accent); color: #fff; border-color: var(--nt-accent); }
    .analytics-source-pill:hover:not(.active) { border-color: var(--nt-border-hover); }

    .analytics-insight { display: flex; align-items: center; gap: 8px; padding: 12px 16px; background: var(--nt-warning-light, #FFF4E5); border-radius: var(--nt-radius); color: var(--nt-warning, #F59E0B); font-size: 13px; font-weight: 500; margin-top: 12px; }
</style>

@code {
    private AnalyticsSummaryResponse? summary;
    private List<DemoListItemResponse> demos = [];
    private List<SessionListResponse> sessions = [];
    private int leadCount;
    private bool loading = true;
    private string? sourceFilter;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.TryRestoreAsync();
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

        var summaryTask = AnalyticsApi.GetGlobalSummaryAsync();
        var demosTask = DemoApi.GetDemosAsync();
        var sessionsTask = AnalyticsApi.GetSessionsAsync();
        var leadsTask = Http.GetFromJsonAsync<List<LeadResponse>>("api/v1/leads");

        await Task.WhenAll(summaryTask, demosTask, sessionsTask, leadsTask);

        summary = summaryTask.Result;
        demos = demosTask.Result ?? [];
        sessions = sessionsTask.Result ?? [];
        leadCount = leadsTask.Result?.Count ?? 0;

        loading = false;
        StateHasChanged();
    }
}
