@page "/login"
@layout Layout.AuthLayout
@rendermode InteractiveServer
@inject AuthService Auth
@inject NavigationManager Nav

<div class="login-form">
    <div class="login-header">
        <h1 class="login-title">Welcome back</h1>
        <p class="login-subtitle">Sign in to continue to NavTour</p>
    </div>

    @if (errorMessage != null)
    {
        <div class="login-error">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink:0;margin-top:1px">
                <circle cx="8" cy="8" r="7" stroke="#C62828" stroke-width="1.5"/>
                <path d="M8 4.5v4M8 10.5v.5" stroke="#C62828" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
            <span>@errorMessage</span>
        </div>
    }

    <div class="login-fields">
        <div class="login-field">
            <label for="email">Email address</label>
            <RadzenTextBox @bind-Value="email" Placeholder="you@company.com" Style="width:100%" Name="email" />
        </div>

        <div class="login-field">
            <label for="password">Password</label>
            <RadzenPassword @bind-Value="password" Placeholder="Enter your password" Style="width:100%" Name="password" />
        </div>
    </div>

    <RadzenButton Text="Sign In" ButtonStyle="ButtonStyle.Primary"
        Style="width:100%;height:44px;font-size:0.9375rem;font-weight:600;border-radius:8px"
        Click="HandleLogin" IsBusy="loading" />

    <p class="login-footer-text">
        Don't have an account? <RadzenLink Path="/register" Style="font-weight:600">Create one</RadzenLink>
    </p>
</div>

<style>
    .login-form {
        width: 100%;
        max-width: 340px;
    }

    .login-header {
        margin-bottom: 32px;
    }

    .login-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #0B1929;
        margin: 0 0 6px;
        line-height: 1.15;
        letter-spacing: -0.02em;
    }

    .login-subtitle {
        font-size: 0.9375rem;
        color: #64748B;
        margin: 0;
        line-height: 1.5;
    }

    .login-error {
        display: flex;
        align-items: flex-start;
        gap: 8px;
        padding: 10px 14px;
        background: #FEF2F2;
        border: 1px solid #FECACA;
        border-radius: 8px;
        font-size: 0.8125rem;
        color: #991B1B;
        margin-bottom: 20px;
        line-height: 1.4;
    }

    .login-fields {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin-bottom: 24px;
    }

    .login-field {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .login-field label {
        font-size: 0.8125rem;
        font-weight: 600;
        color: #1E3A5F;
        letter-spacing: 0.01em;
    }

    /* Override Radzen input styling for premium feel */
    .login-field .rz-textbox,
    .login-field input.rz-textbox {
        height: 44px;
        border-radius: 8px;
        font-size: 0.9375rem;
        border: 1px solid #CBD5E1;
        transition: border-color 150ms, box-shadow 150ms;
    }

    .login-field .rz-textbox:hover,
    .login-field input.rz-textbox:hover {
        border-color: #94A3B8;
    }

    .login-field .rz-textbox:focus,
    .login-field input.rz-textbox:focus {
        border-color: #0A5FAD;
        box-shadow: 0 0 0 3px rgba(10, 95, 173, 0.1);
    }

    .login-footer-text {
        margin-top: 24px;
        font-size: 0.875rem;
        color: #64748B;
        text-align: center;
    }
</style>

@code {
    private string email = "";
    private string password = "";
    private string? errorMessage;
    private bool loading;

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task HandleLogin()
    {
        loading = true;
        errorMessage = null;

        try
        {
            var result = await JS.InvokeAsync<LoginResult>("authLogin.login", email, password);
            if (result != null)
                Nav.NavigateTo(result.HasCompletedOnboarding ? "/dashboard" : "/get-started", forceLoad: true);
            else
                errorMessage = "Invalid email or password";
        }
        catch
        {
            errorMessage = "Login failed. Please try again.";
        }

        loading = false;
    }

    private record LoginResult(bool HasCompletedOnboarding);
}
