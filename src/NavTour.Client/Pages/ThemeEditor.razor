@page "/themes"
@rendermode InteractiveServer
@inject ThemeApiService ThemeApi
@inject AuthService Auth
@inject NavigationManager Nav
@inject HttpClient Http

<PageTitle>Themes — NavTour</PageTitle>

@if (loading)
{
    <div class="te-loading">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Medium" />
    </div>
}
else
{
    <div class="te-shell">
        @* ── Left: Theme List ── *@
        <aside class="te-list">
            <div class="te-list-header">
                <span class="te-list-title">Themes</span>
                <button class="te-btn-create" @onclick="CreateTheme" title="Create theme">+ New</button>
            </div>
            <div class="te-list-items">
                @foreach (var theme in themes)
                {
                    <div class="te-card @(selectedTheme?.Id == theme.Id ? "selected" : "")"
                         @onclick="() => SelectTheme(theme)">
                        <span class="te-card-swatch" style="background:@theme.BrandColor"></span>
                        <span class="te-card-name">@theme.Name</span>
                        <button class="te-card-delete" @onclick="() => DeleteThemeById(theme.Id)" @onclick:stopPropagation="true" title="Delete">
                            <svg viewBox="0 0 24 24" width="14" height="14"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z" fill="currentColor"/></svg>
                        </button>
                    </div>
                }
                @if (themes.Count == 0)
                {
                    <div class="te-empty-list">No themes yet</div>
                }
            </div>
        </aside>

        @* ── Center + Right: Editor & Preview ── *@
        @if (selectedTheme != null)
        {
            <section class="te-editor">
                @* ── Tab Bar ── *@
                <div class="te-tabs">
                    <button class="te-tab active">Theme Settings</button>
                </div>

                @* ── Tab 1: Tooltip Style ── *@
                @if (activeThemeTab == "tooltip")
                {
                    <div class="te-form">
                        <label class="te-label">Theme Name</label>
                        <input type="text" class="te-input" @bind="editName" @bind:event="oninput" />

                        <label class="te-label">Brand Color</label>
                        <div class="te-color-row">
                            <input type="color" class="te-color-picker" @bind="editBrandColor" />
                            <input type="text" class="te-color-hex" @bind="editBrandColor" @bind:event="oninput" />
                        </div>

                        <label class="te-label">Text Color</label>
                        <div class="te-color-row">
                            <input type="color" class="te-color-picker" @bind="editTextColor" />
                            <input type="text" class="te-color-hex" @bind="editTextColor" @bind:event="oninput" />
                        </div>

                        <label class="te-label">Background Color</label>
                        <div class="te-color-row">
                            <input type="color" class="te-color-picker" @bind="editBackgroundColor" />
                            <input type="text" class="te-color-hex" @bind="editBackgroundColor" @bind:event="oninput" />
                        </div>

                        <label class="te-label">Font Family</label>
                        <RadzenDropDown TValue="string" @bind-Value="editFontFamily"
                            Data="fontFamilies" Style="width:100%;" />

                        <label class="te-label">Border Radius — @(editBorderRadius)px</label>
                        <input type="range" class="te-range" min="0" max="20" @bind="editBorderRadius" @bind:event="oninput" />

                        <label class="te-label">Button Style</label>
                        <RadzenDropDown TValue="string" @bind-Value="editButtonStyle"
                            Data="buttonStyles" Style="width:100%;" />

                        <label class="te-label">Shadow Level</label>
                        <RadzenDropDown TValue="string" @bind-Value="editShadowLevel"
                            Data="shadowLevels" Style="width:100%;" />

                        <label class="te-label">Company Logo</label>
                        @if (!string.IsNullOrEmpty(editLogoUrl))
                        {
                            <div style="display:flex;align-items:center;gap:12px;padding:8px 12px;background:var(--nt-surface-subtle);border-radius:var(--nt-radius);margin-top:6px">
                                <img src="@editLogoUrl" alt="Logo" style="max-height:40px;max-width:200px" />
                                <button style="font-size:0.75rem;color:var(--nt-error);background:none;border:none;cursor:pointer" @onclick='() => editLogoUrl = null'>Remove</button>
                            </div>
                        }
                        <label style="display:inline-flex;align-items:center;gap:6px;padding:8px 16px;margin-top:6px;background:var(--nt-surface-subtle);border:1px dashed var(--nt-border);border-radius:var(--nt-radius);cursor:pointer;font-size:0.8125rem;color:var(--nt-text-secondary)">
                            <InputFile OnChange="HandleThemeLogoUpload" accept=".png,.jpg,.jpeg,.svg,.webp,.gif" style="display:none" />
                            <span>@(string.IsNullOrEmpty(editLogoUrl) ? "Upload Logo" : "Replace")</span>
                        </label>
                        @if (themeLogoUploading) { <span style="font-size:0.75rem;color:var(--nt-accent)">Uploading...</span> }
                    </div>
                }

                @* Cover/Closing slides are per-demo, configured in the Demo Editor *@

                <div class="te-actions">
                    <button class="te-btn-save" @onclick="SaveTheme" disabled="@saving">@(saving ? "Saving..." : "Save Theme")</button>
                    <button class="te-btn-delete" @onclick="DeleteTheme">Delete</button>
                </div>
            </section>

            <aside class="te-preview">
                <h3 class="te-section-title">Live Preview</h3>

                @* ── Tooltip Preview ── *@
                @{
                    <div class="te-preview-stage">
                        <div class="theme-preview" style="
                            --preview-brand: @editBrandColor;
                            --preview-text: @editTextColor;
                            --preview-bg: @editBackgroundColor;
                            --preview-font: @editFontFamily;
                            --preview-radius: @(editBorderRadius)px;
                            --preview-shadow: @GetShadow();
                        ">
                            <div class="preview-backdrop"></div>
                            <div class="preview-tooltip">
                                <div class="preview-badge">1</div>
                                <h4>Welcome to the demo</h4>
                                <p>This is a preview of how your tooltips will look with the current theme.</p>
                                <div class="preview-footer">
                                    <span class="preview-step">1 of 5</span>
                                    <button class="preview-btn @editButtonStyle">Next</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @* Cover/Closing previews removed — per-demo settings *@
            </aside>
        }
        else
        {
            <div class="te-placeholder">
                <svg viewBox="0 0 24 24" width="48" height="48" fill="var(--nt-text-muted)"><path d="M12 22C6.49 22 2 17.51 2 12S6.49 2 12 2s10 4.04 10 9c0 3.31-2.69 6-6 6h-1.77c-.28 0-.5.22-.5.5 0 .12.05.23.13.33.41.47.64 1.06.64 1.67A2.5 2.5 0 0 1 12 22zm0-18c-4.41 0-8 3.59-8 8s3.59 8 8 8c.28 0 .5-.22.5-.5a.54.54 0 0 0-.14-.35c-.41-.46-.63-1.05-.63-1.65a2.5 2.5 0 0 1 2.5-2.5H16c2.21 0 4-1.79 4-4 0-3.86-3.59-7-8-7z"/><circle cx="6.5" cy="11.5" r="1.5"/><circle cx="9.5" cy="7.5" r="1.5"/><circle cx="14.5" cy="7.5" r="1.5"/><circle cx="17.5" cy="11.5" r="1.5"/></svg>
                <p>Select a theme or create a new one</p>
            </div>
        }
    </div>
}

<style>
    /* ── Shell ── */
    .te-loading {
        display: flex; align-items: center; justify-content: center;
        height: 100%; min-height: 400px;
    }
    .te-shell {
        display: flex; height: 100%; min-height: 0;
    }

    /* ── Theme List (left) ── */
    .te-list {
        width: 240px; flex-shrink: 0;
        border-right: 1px solid var(--nt-border);
        display: flex; flex-direction: column;
        background: var(--nt-surface-secondary);
    }
    .te-list-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px; border-bottom: 1px solid var(--nt-border);
    }
    .te-list-title {
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-primary);
    }
    .te-btn-create {
        padding: 4px 10px; border: none; border-radius: var(--nt-radius);
        background: var(--nt-accent); color: #fff;
        font-size: var(--nt-text-xs); font-weight: var(--nt-weight-semibold);
        cursor: pointer; transition: background var(--nt-duration-fast) var(--nt-ease);
    }
    .te-btn-create:hover { background: var(--nt-accent-hover); }

    .te-list-items {
        flex: 1; overflow-y: auto; padding: 8px;
    }

    .te-card {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 12px; border-radius: var(--nt-radius-md);
        cursor: pointer; position: relative;
        transition: background var(--nt-duration-fast) var(--nt-ease);
    }
    .te-card:hover { background: var(--nt-surface-subtle); }
    .te-card.selected {
        background: var(--nt-accent-light);
        outline: 2px solid var(--nt-accent); outline-offset: -2px;
    }
    .te-card-swatch {
        width: 14px; height: 14px; border-radius: 50%; flex-shrink: 0;
        border: 1px solid var(--nt-border);
    }
    .te-card-name {
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-medium);
        color: var(--nt-text-primary); flex: 1;
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .te-card-delete {
        opacity: 0; border: none; background: none; cursor: pointer;
        color: var(--nt-text-muted); padding: 2px;
        border-radius: var(--nt-radius-sm);
        transition: opacity var(--nt-duration-fast), color var(--nt-duration-fast);
    }
    .te-card:hover .te-card-delete { opacity: 1; }
    .te-card-delete:hover { color: var(--nt-error); }

    .te-empty-list {
        padding: 24px 12px; text-align: center;
        font-size: var(--nt-text-sm); color: var(--nt-text-muted);
    }

    /* ── Tabs ── */
    .te-tabs {
        display: flex; gap: 0; margin-bottom: 20px;
        border-bottom: 1px solid var(--nt-border);
    }
    .te-tab {
        padding: 10px 16px; border: none; background: none;
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-medium);
        color: var(--nt-text-secondary); cursor: pointer;
        border-bottom: 2px solid transparent;
        transition: color var(--nt-duration-fast) var(--nt-ease), border-color var(--nt-duration-fast) var(--nt-ease);
    }
    .te-tab:hover { color: var(--nt-text-primary); }
    .te-tab.active {
        color: var(--nt-accent); border-bottom-color: var(--nt-accent);
        font-weight: var(--nt-weight-semibold);
    }

    /* ── Editor (center) ── */
    .te-editor {
        flex: 1; padding: 24px; overflow-y: auto;
        min-width: 280px;
    }
    .te-section-title {
        font-size: var(--nt-text-lg); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-primary); margin: 0 0 20px;
    }
    .te-form {
        display: flex; flex-direction: column;
    }
    .te-label {
        display: block; font-size: var(--nt-text-xs); font-weight: var(--nt-weight-semibold);
        color: var(--nt-text-secondary); text-transform: uppercase; letter-spacing: 0.04em;
        margin: 16px 0 6px;
    }
    .te-label:first-of-type { margin-top: 0; }

    .te-input {
        width: 100%; padding: 8px 12px;
        border: 1px solid var(--nt-border); border-radius: var(--nt-radius);
        font-size: var(--nt-text-sm); font-family: var(--nt-font);
        color: var(--nt-text-primary); background: var(--nt-surface);
        outline: none; transition: border-color var(--nt-duration-fast);
        box-sizing: border-box;
    }
    .te-input:focus { border-color: var(--nt-accent); }

    .te-color-row {
        display: flex; gap: 8px; align-items: center;
    }
    .te-color-picker {
        width: 40px; height: 36px; padding: 2px; border: 1px solid var(--nt-border);
        border-radius: var(--nt-radius); cursor: pointer; background: var(--nt-surface);
    }
    .te-color-hex {
        flex: 1; padding: 8px 12px;
        border: 1px solid var(--nt-border); border-radius: var(--nt-radius);
        font-size: var(--nt-text-sm); font-family: var(--nt-font-mono);
        color: var(--nt-text-primary); background: var(--nt-surface);
        outline: none; transition: border-color var(--nt-duration-fast);
    }
    .te-color-hex:focus { border-color: var(--nt-accent); }

    .te-range {
        width: 100%; accent-color: var(--nt-accent); cursor: pointer;
    }

    /* ── Segmented Buttons ── */
    .te-seg {
        display: flex; gap: 0;
        border: 1px solid var(--nt-border); border-radius: var(--nt-radius);
        overflow: hidden;
    }
    .te-seg-btn {
        flex: 1; padding: 7px 12px; border: none;
        background: var(--nt-surface); color: var(--nt-text-secondary);
        font-size: var(--nt-text-xs); font-weight: var(--nt-weight-medium);
        cursor: pointer; transition: background var(--nt-duration-fast), color var(--nt-duration-fast);
    }
    .te-seg-btn:not(:last-child) {
        border-right: 1px solid var(--nt-border);
    }
    .te-seg-btn:hover { background: var(--nt-surface-subtle); }
    .te-seg-btn.active {
        background: var(--nt-accent); color: #fff;
    }

    .te-actions {
        display: flex; gap: 10px; margin-top: 28px; padding-top: 20px;
        border-top: 1px solid var(--nt-border);
    }
    .te-btn-save {
        padding: 8px 20px; border: none; border-radius: var(--nt-radius);
        background: var(--nt-accent); color: #fff;
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-semibold);
        cursor: pointer; transition: background var(--nt-duration-fast);
    }
    .te-btn-save:hover { background: var(--nt-accent-hover); }
    .te-btn-save:disabled { opacity: 0.6; cursor: not-allowed; }

    .te-btn-delete {
        padding: 8px 16px; border: 1px solid var(--nt-error); border-radius: var(--nt-radius);
        background: transparent; color: var(--nt-error);
        font-size: var(--nt-text-sm); font-weight: var(--nt-weight-medium);
        cursor: pointer; transition: background var(--nt-duration-fast), color var(--nt-duration-fast);
    }
    .te-btn-delete:hover { background: var(--nt-error-light); }

    /* ── Preview (right) ── */
    .te-preview {
        width: 360px; flex-shrink: 0; padding: 24px;
        border-left: 1px solid var(--nt-border);
        background: var(--nt-surface-secondary);
        overflow-y: auto;
    }
    .te-preview-stage {
        margin-top: 8px; border-radius: var(--nt-radius-lg);
        background:
            linear-gradient(45deg, var(--nt-neutral-100) 25%, transparent 25%),
            linear-gradient(-45deg, var(--nt-neutral-100) 25%, transparent 25%),
            linear-gradient(45deg, transparent 75%, var(--nt-neutral-100) 75%),
            linear-gradient(-45deg, transparent 75%, var(--nt-neutral-100) 75%);
        background-size: 16px 16px;
        background-position: 0 0, 0 8px, 8px -8px, -8px 0px;
        padding: 32px 24px;
    }

    /* ── Theme Preview Component (Tooltip) ── */
    .theme-preview {
        position: relative;
    }
    .preview-backdrop {
        position: absolute; inset: 0;
        background: rgba(0,0,0,0.35); border-radius: var(--nt-radius-md);
    }
    .preview-tooltip {
        position: relative;
        background: var(--preview-bg);
        color: var(--preview-text);
        border-radius: var(--preview-radius);
        font-family: var(--preview-font), system-ui, sans-serif;
        padding: 20px;
        box-shadow: var(--preview-shadow);
        max-width: 300px;
        margin: 0 auto;
    }
    .preview-badge {
        position: absolute; top: -10px; left: -10px;
        width: 28px; height: 28px; border-radius: 50%;
        background: var(--preview-brand); color: #fff;
        font-size: 0.75rem; font-weight: 700;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    }
    .preview-tooltip h4 {
        margin: 0 0 8px; font-size: 0.9375rem; font-weight: 600;
        color: var(--preview-text);
    }
    .preview-tooltip p {
        margin: 0 0 16px; font-size: 0.8125rem; line-height: 1.5;
        opacity: 0.85;
    }
    .preview-footer {
        display: flex; align-items: center; justify-content: space-between;
    }
    .preview-step {
        font-size: 0.6875rem; opacity: 0.6;
    }
    .preview-btn {
        padding: 6px 16px; border: none; border-radius: var(--preview-radius);
        font-size: 0.8125rem; font-weight: 600; cursor: pointer;
        font-family: var(--preview-font), system-ui, sans-serif;
        transition: opacity 150ms;
    }
    .preview-btn.filled {
        background: var(--preview-brand); color: #fff;
    }
    .preview-btn.outline {
        background: transparent; color: var(--preview-brand);
        border: 1.5px solid var(--preview-brand);
    }
    .preview-btn.ghost {
        background: transparent; color: var(--preview-brand);
        border: none;
    }
    .preview-btn:hover { opacity: 0.85; }

    /* ── Slide Preview ── */
    .te-slide-preview {
        border-radius: var(--nt-radius-md);
        padding: 24px;
        text-align: center;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        min-height: 180px;
    }

    /* ── Placeholder ── */
    .te-placeholder {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; justify-content: center; gap: 12px;
    }
    .te-placeholder p {
        font-size: var(--nt-text-sm); color: var(--nt-text-muted); margin: 0;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .te-shell { flex-direction: column; height: auto; }
        .te-list {
            width: 100%;
            border-right: none;
            border-bottom: 1px solid var(--nt-border);
            max-height: 200px;
        }
        .te-list-items { max-height: 140px; }
        .te-editor { padding: 16px; }
        .te-preview {
            width: 100%;
            border-left: none;
            border-top: 1px solid var(--nt-border);
        }
    }
</style>

@code {
    private List<ThemeResponse> themes = [];
    private ThemeResponse? selectedTheme;
    private bool loading = true;
    private bool saving;
    private string activeThemeTab = "tooltip";

    // Editable fields — Tooltip Style
    private string editName = "";
    private string editBrandColor = "#4361ee";
    private string editTextColor = "#ffffff";
    private string editBackgroundColor = "#1a1a2e";
    private string editFontFamily = "Segoe UI";
    private int editBorderRadius = 8;
    private string editButtonStyle = "filled";
    private string editShadowLevel = "medium";
    private string? editLogoUrl;
    private bool themeLogoUploading;

    // Slide settings
    private ThemeSlideSettings editCoverSlide = new();
    private ThemeSlideSettings editClosingSlide = new() { Title = "Enjoyed the demo?", Description = "Learn more about our features", CtaText = "Learn More" };

    // Dropdown data
    private static readonly List<string> fontFamilies = ["Segoe UI", "Inter", "Arial", "Georgia", "Cascadia Code"];
    private static readonly List<string> buttonStyles = ["filled", "outline", "ghost"];
    private static readonly List<string> shadowLevels = ["none", "light", "medium", "heavy"];
    private static readonly List<string> ctaActions = ["next", "url"];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.TryRestoreAsync();
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        themes = await ThemeApi.GetAllAsync();
        if (themes.Count > 0) SelectTheme(themes[0]);
        loading = false;
        StateHasChanged();
    }

    private void SelectTheme(ThemeResponse theme)
    {
        selectedTheme = theme;
        editName = theme.Name;
        editBrandColor = theme.BrandColor;
        editTextColor = theme.TextColor;
        editBackgroundColor = theme.BackgroundColor;
        editFontFamily = theme.FontFamily;
        editBorderRadius = theme.BorderRadius;
        editButtonStyle = theme.ButtonStyle;
        editShadowLevel = theme.ShadowLevel;
        editLogoUrl = theme.LogoUrl;
        editCoverSlide = theme.CoverSlide ?? new ThemeSlideSettings();
        editClosingSlide = theme.ClosingSlide ?? new ThemeSlideSettings { Title = "Enjoyed the demo?", Description = "Learn more about our features", CtaText = "Learn More" };
        activeThemeTab = "tooltip";
    }

    private async Task CreateTheme()
    {
        var result = await ThemeApi.CreateAsync(new CreateThemeRequest(
            "New Theme", "#4361ee", "#ffffff", "#1a1a2e", "Segoe UI", 8, "filled", "medium",
            null, new ThemeSlideSettings(), new ThemeSlideSettings { Title = "Enjoyed the demo?", Description = "Learn more about our features", CtaText = "Learn More" }));
        if (result != null)
        {
            themes.Add(result);
            SelectTheme(result);
        }
    }

    private async Task SaveTheme()
    {
        if (selectedTheme == null) return;
        saving = true;
        var result = await ThemeApi.UpdateAsync(selectedTheme.Id, new UpdateThemeRequest(
            editName, editBrandColor, editTextColor, editBackgroundColor,
            editFontFamily, editBorderRadius, editButtonStyle, editShadowLevel,
            editLogoUrl, editCoverSlide, editClosingSlide));
        if (result != null)
        {
            var idx = themes.FindIndex(t => t.Id == result.Id);
            if (idx >= 0) themes[idx] = result;
            selectedTheme = result;
        }
        saving = false;
    }

    private async Task HandleThemeLogoUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;
        themeLogoUploading = true;
        StateHasChanged();
        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(2 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", file.Name);
            var response = await Http.PostAsync("api/v1/uploads/image", content);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LogoUploadResult>();
                if (result?.Url != null) editLogoUrl = result.Url;
            }
        }
        catch { }
        themeLogoUploading = false;
        StateHasChanged();
    }

    private record LogoUploadResult(string? Url);

    private async Task DeleteTheme()
    {
        if (selectedTheme == null) return;
        await DeleteThemeById(selectedTheme.Id);
    }

    private async Task DeleteThemeById(Guid id)
    {
        if (await ThemeApi.DeleteAsync(id))
        {
            themes.RemoveAll(t => t.Id == id);
            if (selectedTheme?.Id == id)
            {
                selectedTheme = themes.Count > 0 ? themes[0] : null;
                if (selectedTheme != null) SelectTheme(selectedTheme);
                else ResetEditFields();
            }
        }
    }

    private void ResetEditFields()
    {
        editName = "";
        editBrandColor = "#4361ee";
        editTextColor = "#ffffff";
        editBackgroundColor = "#1a1a2e";
        editFontFamily = "Segoe UI";
        editBorderRadius = 8;
        editButtonStyle = "filled";
        editShadowLevel = "medium";
        editLogoUrl = null;
        editCoverSlide = new ThemeSlideSettings();
        editClosingSlide = new ThemeSlideSettings { Title = "Enjoyed the demo?", Description = "Learn more about our features", CtaText = "Learn More" };
    }

    private string GetShadow() => editShadowLevel switch
    {
        "none" => "none",
        "light" => "0 2px 8px rgba(0,0,0,0.08)",
        "medium" => "0 4px 16px rgba(0,0,0,0.14)",
        "heavy" => "0 8px 32px rgba(0,0,0,0.22)",
        _ => "0 4px 16px rgba(0,0,0,0.14)"
    };

    // ── Reusable Slide Settings Form ──
    RenderFragment SlideSettingsForm(ThemeSlideSettings settings) => @<div class="te-form">
        <label class="te-label">Layout</label>
        <div class="te-seg">
            <button class="te-seg-btn @(settings.Layout == "left" ? "active" : "")" @onclick='() => settings.Layout = "left"'>Left</button>
            <button class="te-seg-btn @(settings.Layout == "center" ? "active" : "")" @onclick='() => settings.Layout = "center"'>Center</button>
            <button class="te-seg-btn @(settings.Layout == "right" ? "active" : "")" @onclick='() => settings.Layout = "right"'>Right</button>
        </div>

        <label class="te-label">Theme</label>
        <div class="te-seg">
            <button class="te-seg-btn @(settings.Theme == "dark" ? "active" : "")" @onclick='() => settings.Theme = "dark"'>Dark</button>
            <button class="te-seg-btn @(settings.Theme == "light" ? "active" : "")" @onclick='() => settings.Theme = "light"'>Light</button>
        </div>

        <label class="te-label">Title</label>
        <RadzenTextBox @bind-Value="settings.Title" Placeholder="Welcome to..." Style="width:100%" />

        <label class="te-label">Description</label>
        <RadzenTextArea @bind-Value="settings.Description" Rows="2" Style="width:100%" />

        <label class="te-label">CTA Button Text</label>
        <RadzenTextBox @bind-Value="settings.CtaText" Style="width:100%" />

        <label class="te-label">CTA Action</label>
        <RadzenDropDown TValue="string" @bind-Value="settings.CtaAction"
            Data="ctaActions" Style="width:100%" />

        @if (settings.CtaAction == "url")
        {
            <label class="te-label">CTA URL</label>
            <RadzenTextBox @bind-Value="settings.CtaUrl" Placeholder="https://..." Style="width:100%" />
        }

        <label class="te-label">Show Logo</label>
        <RadzenSwitch @bind-Value="settings.ShowLogo" />

        <label class="te-label">Background</label>
        <div class="te-seg">
            <button class="te-seg-btn @(settings.BackgroundType == "none" ? "active" : "")" @onclick='() => settings.BackgroundType = "none"'>None</button>
            <button class="te-seg-btn @(settings.BackgroundType == "frame" ? "active" : "")" @onclick='() => settings.BackgroundType = "frame"'>First Frame</button>
            <button class="te-seg-btn @(settings.BackgroundType == "custom" ? "active" : "")" @onclick='() => settings.BackgroundType = "custom"'>Custom</button>
        </div>

        @if (settings.BackgroundType == "custom")
        {
            <label class="te-label">Background Image URL</label>
            <RadzenTextBox @bind-Value="settings.BackgroundUrl" Placeholder="https://..." Style="width:100%" />
        }

        <label class="te-label">Backdrop Opacity — @(settings.BackdropOpacity)%</label>
        <input type="range" min="0" max="100" @bind="settings.BackdropOpacity" @bind:event="oninput" style="width:100%" />
    </div>;

    // ── Reusable Slide Preview ──
    RenderFragment SlidePreview(ThemeSlideSettings settings, string defaultCta) => @<div class="te-slide-preview" style="background:@(settings.Theme == "dark" ? "#0A0A0A" : "#FAFAFA")">
        @if (settings.ShowLogo && !string.IsNullOrEmpty(editLogoUrl))
        {
            <img src="@editLogoUrl" alt="Logo" style="max-height:24px;margin-bottom:8px" />
        }
        <h4 style="color:@(settings.Theme == "dark" ? "#fff" : "#0A0A0A");margin:0 0 4px;font-size:14px;font-weight:700">@(settings.Title ?? "Title")</h4>
        <p style="color:@(settings.Theme == "dark" ? "rgba(255,255,255,0.7)" : "#737373");margin:0 0 12px;font-size:11px">@(settings.Description ?? "Description")</p>
        <button style="padding:6px 16px;border:none;border-radius:6px;font-size:11px;font-weight:600;background:@editBrandColor;color:#fff;cursor:default">@(settings.CtaText ?? defaultCta)</button>
    </div>;
}
