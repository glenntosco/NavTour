@page "/integrations"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject AuthService Auth
@inject NavigationManager Nav

<div class="int-page">
    <div class="int-header">
        <h1 class="nt-page-title">Integrations</h1>
        <p class="nt-page-subtitle">Connect NavTour with your favorite tools to automate workflows and track engagement.</p>
    </div>

    <div class="int-grid">
        @foreach (var item in _integrations)
        {
            <div class="int-card">
                <div class="int-card-icon" style="background:@item.IconBg">
                    @((MarkupString)item.IconSvg)
                </div>
                <div class="int-card-name">@item.Name</div>
                <div class="int-card-desc">@item.Description</div>
                <button class="int-card-btn" disabled title="Coming soon">Connect</button>
            </div>
        }
    </div>
</div>

<style>
    .int-page {
        max-width: 960px;
    }

    .int-header {
        margin-bottom: 32px;
    }

    .int-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
    }

    @@media (max-width: 900px) {
        .int-grid { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 500px) {
        .int-grid { grid-template-columns: 1fr; }
    }

    .int-card {
        background: var(--nt-surface);
        border: 1px solid var(--nt-border);
        border-radius: var(--nt-radius-md);
        padding: 24px 20px 20px;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 8px;
        box-shadow: var(--nt-shadow-sm);
        transition: box-shadow 150ms, border-color 150ms;
    }

    .int-card:hover {
        box-shadow: var(--nt-shadow-md);
        border-color: var(--nt-border-hover);
    }

    .int-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 4px;
        flex-shrink: 0;
    }

    .int-card-icon svg {
        width: 28px;
        height: 28px;
    }

    .int-card-name {
        font-size: var(--nt-text-base);
        font-weight: 600;
        color: var(--nt-text-primary);
    }

    .int-card-desc {
        font-size: var(--nt-text-sm);
        color: var(--nt-text-muted);
        line-height: 1.5;
        flex: 1;
    }

    .int-card-btn {
        margin-top: 8px;
        padding: 7px 18px;
        border: 1px solid var(--nt-border);
        border-radius: var(--nt-radius);
        background: var(--nt-surface-subtle);
        color: var(--nt-text-muted);
        font-size: var(--nt-text-sm);
        font-weight: 500;
        cursor: not-allowed;
        font-family: var(--nt-font);
        opacity: 0.7;
    }
</style>

@code {
