    private async Task AiWriteContent()
    {
        if (selectedStepId == null) return;
        var step = steps.FirstOrDefault(s => s.Id == selectedStepId);
        if (step == null) return;

        aiWriting = true;
        StateHasChanged();

        try
        {
            var title = step.Annotations.FirstOrDefault()?.Title ?? "Step " + step.StepNumber;
            var context = step.Annotations.FirstOrDefault()?.Content ?? "";
            var result = await AiApi.WriteContentAsync(title, context);
            if (result != null)
            {
                // Update the first annotation's title and content
                var ann = step.Annotations.FirstOrDefault();
                if (ann != null)
                {
                    var request = new CreateAnnotationRequest(
                        ann.Type, result.Title, result.Content,
                        ann.PositionX, ann.PositionY, ann.Width, ann.Height, ann.Style,
                        ann.TargetSelector, ann.ArrowDirection, ann.BadgeNumber);
                    await DemoApi.UpdateAnnotationAsync(step.Id, ann.Id, request);

                    // Update voiceover on the step
                    var stepDto = MapStepToDto(step) with { VoiceoverText = result.VoiceoverText };
                    var allSteps = steps.Select(s => s.Id == step.Id ? stepDto : MapStepToDto(s)).ToList();
                    await DemoApi.UpdateStepsAsync(DemoId, new UpdateStepsRequest(allSteps));

                    await RefreshAnnotations();
                    Notification.Notify(NotificationSeverity.Success, "AI Write", "Step content updated by AI.");
                }
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "AI Write", "Failed to generate content.");
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally
        {
            aiWriting = false;
            StateHasChanged();
        }
    }

    private async Task TranslateSteps(string language)
    {
        if (steps.Count == 0) return;

        aiTranslating = true;
        StateHasChanged();

        try
        {
            var translatableSteps = steps.Select(s =>
            {
                var ann = s.Annotations.FirstOrDefault();
                return new TranslatableStep(s.StepNumber, ann?.Title ?? "", ann?.Content ?? "", s.VoiceoverText ?? "");
            }).ToList();

            var result = await AiApi.TranslateAsync(translatableSteps, language);
            if (result != null)
            {
                // Apply translations to each step's annotation
                foreach (var translated in result)
                {
                    var step = steps.FirstOrDefault(s => s.StepNumber == translated.StepNumber);
                    var ann = step?.Annotations.FirstOrDefault();
                    if (step != null && ann != null)
                    {
                        var request = new CreateAnnotationRequest(
                            ann.Type, translated.Title, translated.Content,
                            ann.PositionX, ann.PositionY, ann.Width, ann.Height, ann.Style,
                            ann.TargetSelector, ann.ArrowDirection, ann.BadgeNumber);
                        await DemoApi.UpdateAnnotationAsync(step.Id, ann.Id, request);
                    }
                }

                // Update voiceover text on steps
                var stepDtos = steps.Select(s =>
                {
                    var translated = result.FirstOrDefault(t => t.StepNumber == s.StepNumber);
                    var dto = MapStepToDto(s);
                    return translated != null ? dto with { VoiceoverText = translated.VoiceoverText } : dto;
                }).ToList();
                await DemoApi.UpdateStepsAsync(DemoId, new UpdateStepsRequest(stepDtos));

                await RefreshAnnotations();
                Notification.Notify(NotificationSeverity.Success, "Translated", $"Steps translated to {language}.");
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Translation", "Failed to translate steps.");
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally
        {
            aiTranslating = false;
            StateHasChanged();
        }
    }

    private async Task ScoreQuality()
    {
        if (steps.Count == 0) return;

        aiScoring = true;
        StateHasChanged();

        try
        {
            var summaries = steps.Select(s =>
            {
                var ann = s.Annotations.FirstOrDefault();
                return new StepSummary(s.StepNumber, ann?.Title, ann?.Content, s.VoiceoverText);
            }).ToList();

            qualityScore = await AiApi.ScoreAsync(summaries, frames?.Count ?? 0);
            if (qualityScore != null)
            {
                showQualityScore = true;
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Quality Score", "Failed to score demo.");
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally
        {
            aiScoring = false;
            StateHasChanged();
        }
    }

    private static string ScoreColor(int score) => score > 70 ? "#22c55e" : score >= 50 ? "#eab308" : "#ef4444";

    private static StepDto MapStepToDto(StepResponse s) => new StepDto(
        s.Id, s.FrameId, s.StepNumber, s.ClickTargetSelector,
        s.NavigationAction, s.NavigationTarget,
        s.Annotations.Select(a => new AnnotationDto(
            a.Id, a.Type, a.Title, a.Content,
            a.PositionX, a.PositionY, a.Width, a.Height, a.Style,
            a.TargetSelector, a.ArrowDirection, a.BadgeNumber)).ToList(),
        s.TriggerType, s.TriggerDurationMs, s.BackdropLevel, s.VoiceoverText, s.VoiceId,
        s.Type, s.ChapterSettings);

    private static NavTour.Shared.DTOs.ChapterSettings ParseChapterSettings(string? json)
    {
        if (string.IsNullOrEmpty(json)) return new NavTour.Shared.DTOs.ChapterSettings();
        try { return System.Text.Json.JsonSerializer.Deserialize<NavTour.Shared.DTOs.ChapterSettings>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new(); }
        catch { return new NavTour.Shared.DTOs.ChapterSettings(); }
    }
