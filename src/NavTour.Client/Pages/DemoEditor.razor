@page "/demos/{DemoId:guid}/edit"
@rendermode InteractiveServer
@inject DemoApiService DemoApi
@inject NavigationManager Nav
@inject NotificationService Notification
@inject AuthService Auth
@inject IJSRuntime JS

<RadzenStack Gap="0" Style="height:calc(100vh - 80px)">
    @* Toolbar *@
    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px"
        class="editor-toolbar"
        Style="padding:8px 12px;border-bottom:1px solid var(--rz-border-color)">
        <RadzenText TextStyle="TextStyle.H6" class="rz-m-0">@(demo?.Name ?? "Loading...")</RadzenText>
        <div style="flex:1"></div>
        <RadzenButton Text="Find & Replace" Icon="find_replace" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="() => showFindReplace = !showFindReplace" title="Search and replace text across the current frame" />
        <RadzenButton Text="Save Edits" Icon="save_alt" ButtonStyle="ButtonStyle.Warning" Size="ButtonSize.Small" Click="SaveFrameEdits" Visible="@(frameEditor?.HasUnsavedEdits == true)" title="Save changes to the current frame's HTML" />
        <RadzenButton Text="AI Generate" Icon="auto_awesome" ButtonStyle="ButtonStyle.Success" Size="ButtonSize.Small" Click="GenerateTour" IsBusy="generating" Disabled="@(frames == null || frames.Count == 0)" title="AI generates steps, annotations, and voiceover for all frames" />
        <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Size="ButtonSize.Small" Click="SaveSteps" IsBusy="saving" title="Save all step configurations and annotations" />
        <RadzenButton Text="Preview" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="OpenPreview" class="preview-btn" title="Open demo player in a new tab" />
        @if (demo?.Status == DemoStatus.Published)
        {
            <button @onclick="UnpublishDemo" style="border-radius:8px;padding:6px 16px;font-weight:600;cursor:pointer;background:var(--nt-success);color:white;border:none;font-size:13px;line-height:1.4" title="Published — click to unpublish">Published</button>
        }
        else
        {
            <button @onclick="PublishDemo" style="border-radius:8px;padding:6px 16px;font-weight:600;cursor:pointer;background:var(--nt-surface-subtle);color:var(--nt-text-secondary);border:1px solid var(--nt-border);font-size:13px;line-height:1.4" title="Draft — click to publish">Draft</button>
        }
        <RadzenButton Text="Share" Icon="share" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="() => showSharePopover = !showSharePopover" Style="position:relative" title="Copy share link, WhatsApp, or embed code" />
        <RadzenButton Text="Settings" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click='() => Nav.NavigateTo($"/demos/{DemoId}/settings")' title="Demo name, slug, lead capture, personalization" />
        <RadzenButton Text="Tour" Icon="help_outline" ButtonStyle="ButtonStyle.Light" Variant="Variant.Outlined"
            Size="ButtonSize.Small" Click="() => showTour = true" title="Replay the guided tour of the demo builder" />
        <div class="drawer-toggles">
            <button class="drawer-toggle @(activeDrawer == "steps" ? "active" : "")" @onclick='() => ToggleDrawer("steps")'>
                <svg viewBox="0 0 24 24" width="14" height="14"><path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z" fill="currentColor"/></svg>
                Steps
            </button>
            <button class="drawer-toggle @(activeDrawer == "annotations" ? "active" : "")" @onclick='() => ToggleDrawer("annotations")'>
                <svg viewBox="0 0 24 24" width="14" height="14"><path d="M21.99 4c0-1.1-.89-2-1.99-2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4-.01-18zM18 14H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z" fill="currentColor"/></svg>
                Annotations
            </button>
        </div>
    </RadzenStack>

    @* Main workspace *@
    <div style="flex:1;display:flex;overflow:hidden;position:relative">
        <div style="overflow-y:auto;flex-shrink:0">
            <FrameStrip Frames="frames" SelectedFrameId="selectedFrameId"
                OnFrameSelected="SelectFrame" OnAddFrame="AddFrame"
                OnDeleteFrame="DeleteFrame" OnInsertFrame="InsertFrame"
                OnReorderFrame="ReorderFrame" OnRenameFrame="RenameFrame" />
        </div>

        <div class="frame-editor" style="flex:1;display:flex;overflow:hidden">
            @{ var selectedStep = selectedStepId.HasValue ? steps.FirstOrDefault(s => s.Id == selectedStepId) : null; }
            @if (selectedStep?.Type == StepType.CoverSlide || selectedStep?.Type == StepType.ClosingSlide)
            {
                var chapterSettings = ParseChapterSettings(selectedStep.ChapterSettings);
                <div style="width:1440px;height:900px;position:relative;background:var(--nt-neutral-950)">
                    <CoverSlideRenderer Settings="chapterSettings"
                        TotalSteps="@steps.Count"
                        IsClosing="@(selectedStep.Type == StepType.ClosingSlide)" />
                </div>
            }
            else
            {
                <FrameEditor @ref="frameEditor" DemoId="@DemoId" HtmlContent="@currentFrameHtml"
                    Annotations="@currentAnnotations"
                    ShowFindReplace="@showFindReplace"
                    ShowFindReplaceChanged="(v) => showFindReplace = v"
                    OnHtmlChanged="OnFrameHtmlSaved"
                    OnAnnotationMoved="HandleAnnotationMoved"
                    OnAnnotationResized="HandleAnnotationResized"
                    OnAnnotationDoubleClicked="HandleAnnotationDoubleClicked" />
            }
        </div>

        @* Drawer backdrop *@
        @if (activeDrawer != null)
        {
            <div class="drawer-backdrop" @onclick="CloseDrawer"></div>
        }

        @* Steps drawer *@
        <div class="editor-drawer @(activeDrawer == "steps" ? "open" : "")">
            <div class="drawer-header">
                <strong>Steps</strong>
                <button class="drawer-close" @onclick="CloseDrawer">&times;</button>
            </div>
            <StepPanel Steps="steps" Frames="frames" SelectedStepId="selectedStepId"
                OnStepSelected="SelectStep" OnAddStep="AddStep" OnDeleteStep="DeleteStep"
                OnReorderStep="ReorderStep" OnStepSettingsChanged="HandleStepSettingsChanged" />
        </div>

        @* Annotations drawer *@
        <div class="editor-drawer @(activeDrawer == "annotations" ? "open" : "")">
            <div class="drawer-header">
                <strong>Annotations</strong>
                <button class="drawer-close" @onclick="CloseDrawer">&times;</button>
            </div>
            <AnnotationEditor DemoId="@DemoId" StepId="@selectedStepId" Annotations="@currentAnnotations"
                OnAnnotationsChanged="RefreshAnnotations" />
        </div>

        @if (generating)
        {
            <div style="position:absolute;inset:0;z-index:100;background:rgba(255,255,255,0.9);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px">
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
                <span style="font-size:16px;font-weight:600;color:var(--nt-accent)">@generatingStatus</span>
                <span style="font-size:13px;color:var(--nt-text-secondary)">This may take 30-60 seconds</span>
            </div>
        }
    </div>

    <OnboardingTour @bind-Visible="showTour" />
</RadzenStack>

@if (showSharePopover)
{
    <div style="position:fixed;inset:0;z-index:999" @onclick="() => showSharePopover = false"></div>
    <div style="position:fixed;top:48px;right:180px;z-index:1000;background:white;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,0.18);padding:20px;width:420px;border:1px solid var(--nt-border)">
        <div style="display:flex;align-items:center;gap:8px;margin-bottom:12px">
            <RadzenIcon Icon="share" Style="color:var(--nt-accent)" />
            <RadzenText TextStyle="TextStyle.Subtitle1" class="rz-m-0" Style="font-weight:600">Share Demo</RadzenText>
            <div style="flex:1"></div>
            <button @onclick="() => showSharePopover = false"
                style="background:none;border:none;font-size:18px;cursor:pointer;color:var(--nt-text-muted);padding:0 4px">&times;</button>
        </div>

        @if (demo?.Status == DemoStatus.Published)
        {
            <div style="display:flex;gap:8px;margin-bottom:12px">
                <button @onclick="CopyShareLink"
                    style="flex:1;padding:10px 16px;background:var(--nt-accent);color:white;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px">
                    <RadzenIcon Icon="content_copy" Style="font-size:16px" /> @shareCopyLabel
                </button>
                <button @onclick="ShareWhatsApp"
                    style="flex:1;padding:10px 16px;background:#25D366;color:white;border:none;border-radius:8px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px">
                    WhatsApp
                </button>
            </div>

            <pre style="background:var(--nt-surface-subtle);border:1px solid var(--nt-border);border-radius:8px;padding:12px;font-size:0.8rem;white-space:pre-wrap;word-break:break-all;margin:0 0 12px;color:var(--nt-neutral-700)">@DemoUrl</pre>

            <details style="border:1px solid var(--nt-border);border-radius:8px;overflow:hidden">
                <summary style="padding:10px 14px;cursor:pointer;font-size:13px;font-weight:600;color:var(--nt-neutral-700);background:#f8fafc;user-select:none">Embed Code (iframe)</summary>
                <div style="padding:12px">
                    <div style="display:flex;gap:8px;margin-bottom:8px">
                        <RadzenFormField Text="Width" Style="flex:1">
                            <RadzenTextBox @bind-Value="embedWidth" Style="width:100%" />
                        </RadzenFormField>
                        <RadzenFormField Text="Height" Style="flex:1">
                            <RadzenTextBox @bind-Value="embedHeight" Style="width:100%" />
                        </RadzenFormField>
                    </div>
                    <pre style="background:var(--nt-surface-subtle);border:1px solid var(--nt-border);border-radius:8px;padding:12px;font-size:0.75rem;white-space:pre-wrap;word-break:break-all;margin:0 0 8px;color:var(--nt-neutral-700)">@EmbedIframeCode</pre>
                    <button @onclick="CopyShareIframe"
                        style="width:100%;padding:8px;background:var(--nt-surface-subtle);color:var(--nt-neutral-700);border:1px solid var(--nt-border);border-radius:8px;font-size:13px;font-weight:500;cursor:pointer">
                        @embedCopyLabel
                    </button>
                </div>
            </details>
        }
        else
        {
            <RadzenAlert AlertStyle="AlertStyle.Info" Shade="Shade.Lighter" AllowClose="false" Size="AlertSize.Small">
                Publish your demo first to get a share link.
            </RadzenAlert>
        }
    </div>
}

<InputFile id="frame-file-input" OnChange="HandleFileUpload" Accept=".html,.htm"
    style="display:none" />

@code {
    [Parameter] public Guid DemoId { get; set; }

    private DemoResponse? demo;
    private List<FrameResponse> frames = [];
    private List<StepResponse> steps = [];
    private Guid? selectedFrameId;
    private Guid? selectedStepId;
    private string? currentFrameHtml;
    private List<AnnotationResponse>? currentAnnotations;
    private bool saving;
    private bool generating;
    private string generatingStatus = "";
    private string? activeDrawer = "steps";

    private void ToggleDrawer(string drawer)
    {
        activeDrawer = activeDrawer == drawer ? null : drawer;
    }

    private void CloseDrawer() => activeDrawer = null;

    private void HandleAnnotationDoubleClicked(Guid annotationId)
    {
        activeDrawer = "annotations";
        StateHasChanged();
    }

    private bool showFindReplace;
    private bool showSharePopover;
    private bool showTour;
    private string embedWidth = "100%";
    private string embedHeight = "600";
    private string shareCopyLabel = "Copy Link";
    private string embedCopyLabel = "Copy Embed Code";
    private FrameEditor? frameEditor;

    private string DemoUrl
    {
        get
        {
            var uri = new Uri(Nav.BaseUri);
            return $"{uri.Scheme}://{uri.Authority}/demo/{demo?.Slug}";
        }
    }

    private string EmbedIframeCode =>
$@"<iframe
  src=""{DemoUrl}""
  width=""{embedWidth}""
  height=""{embedHeight}""
  frameborder=""0""
  allowfullscreen
  style=""border: 1px solid #e2e8f0; border-radius: 8px;"">
</iframe>";

    private bool _dataLoaded;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_dataLoaded) return;

        // Auth is handled by server middleware — just restore the Bearer token for API calls
        await Auth.TryRestoreAsync();

        demo = await DemoApi.GetDemoAsync(DemoId);
        if (demo == null) { Nav.NavigateTo("/dashboard"); return; }

        frames = await DemoApi.GetFramesAsync(DemoId);
        steps = await DemoApi.GetStepsAsync(DemoId);

        if (frames.Count > 0)
            await SelectFrame(frames[0].Id);
        _dataLoaded = true;
        StateHasChanged();
    }

    private async Task SelectFrame(Guid frameId)
    {
        // Save pending edits before switching frames
        if (frameEditor?.HasUnsavedEdits == true && selectedFrameId != null)
            await SaveFrameEdits();

        selectedFrameId = frameId;
        var detail = await DemoApi.GetFrameDetailAsync(frameId);
        currentFrameHtml = detail?.HtmlContent;

        var step = steps.FirstOrDefault(s => s.FrameId == frameId);
        currentAnnotations = step?.Annotations;
        selectedStepId = step?.Id;
    }

    private async Task HandleAnnotationMoved(AnnotationOverlay.AnnotationPositionChange change)
    {
        if (selectedStepId == null) return;
        var ann = currentAnnotations?.FirstOrDefault(a => a.Id == change.AnnotationId);
        if (ann == null) return;

        var request = new CreateAnnotationRequest(
            ann.Type, ann.Title, ann.Content,
            Math.Round(change.PositionX, 2), Math.Round(change.PositionY, 2),
            ann.Width, ann.Height, ann.Style,
            ann.TargetSelector, ann.ArrowDirection, ann.BadgeNumber);

        await DemoApi.UpdateAnnotationAsync(selectedStepId.Value, ann.Id, request);
        await RefreshAnnotations();
    }

    private async Task HandleAnnotationResized(AnnotationOverlay.AnnotationSizeChange change)
    {
        if (selectedStepId == null) return;
        var ann = currentAnnotations?.FirstOrDefault(a => a.Id == change.AnnotationId);
        if (ann == null) return;

        var request = new CreateAnnotationRequest(
            ann.Type, ann.Title, ann.Content,
            ann.PositionX, ann.PositionY,
            Math.Round(change.Width, 2), Math.Round(change.Height, 2), ann.Style,
            ann.TargetSelector, ann.ArrowDirection, ann.BadgeNumber);

        await DemoApi.UpdateAnnotationAsync(selectedStepId.Value, ann.Id, request);
        await RefreshAnnotations();
    }

    private async Task RefreshAnnotations()
    {
        // Reload steps to get fresh annotations
        steps = await DemoApi.GetStepsAsync(DemoId);
        if (selectedStepId != null)
        {
            var step = steps.FirstOrDefault(s => s.Id == selectedStepId);
            currentAnnotations = step?.Annotations;
        }
        StateHasChanged();
    }

    private void SelectStep(Guid stepId)
    {
        selectedStepId = stepId;
        var step = steps.FirstOrDefault(s => s.Id == stepId);
        if (step != null)
        {
            if (step.Type == StepType.CoverSlide || step.Type == StepType.ClosingSlide)
            {
                // Chapter steps don't have frames — just select and show cover preview
                currentAnnotations = step.Annotations;
                StateHasChanged();
            }
            else
            {
                selectedFrameId = step.FrameId;
                currentAnnotations = step.Annotations;
                if (step.FrameId.HasValue)
                    _ = SelectFrame(step.FrameId.Value);
            }
        }
    }

    private async Task SaveFrameEdits()
    {
        if (selectedFrameId == null || frameEditor == null) return;
        await frameEditor.RequestSerializedHtml();
        // OnFrameHtmlSaved will be called via the callback
    }

    private async Task OnFrameHtmlSaved(string html)
    {
        if (selectedFrameId == null) return;
        var success = await DemoApi.PatchFrameContentAsync(selectedFrameId.Value, html);
        if (success)
            Notification.Notify(NotificationSeverity.Success, "Saved", "Frame edits saved.");
        else
            Notification.Notify(NotificationSeverity.Error, "Error", "Failed to save frame edits.");
    }

    private async Task OpenPreview()
    {
        if (demo?.Slug != null)
            await JS.InvokeVoidAsync("open", $"/demo/{demo.Slug}", "_blank");
    }

    private async Task AddFrame()
    {
        await JS.InvokeVoidAsync("clickElement", "frame-file-input");
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var result = await DemoApi.UploadFrameAsync(DemoId, stream, file.Name);
            if (result != null)
            {
                frames = await DemoApi.GetFramesAsync(DemoId);

                // Auto-create a step with a default annotation for the new frame
                var stepNum = steps.Count + 1;
                var newStep = new StepDto(null, result.Id, stepNum, null, NavigationAction.NextStep, null,
                    [new AnnotationDto(null, AnnotationType.NumberedTooltip, "Step " + stepNum, "Click Next to continue",
                        20, 30, 20, 20, "{\"backgroundColor\":\"#ffffff\",\"textColor\":\"#334155\"}", null, "bottom", stepNum)]);
                var allSteps = steps.Select(s => MapStepToDto(s)).Append(newStep).ToList();
                await DemoApi.UpdateStepsAsync(DemoId, new UpdateStepsRequest(allSteps));
                steps = await DemoApi.GetStepsAsync(DemoId);

                await SelectFrame(result.Id);
                Notification.Notify(NotificationSeverity.Success, "Frame added", file.Name);
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Upload failed", "Could not upload frame.");
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Upload error", ex.Message);
        }
    }

    private async Task DeleteFrame(Guid frameId)
    {
        var success = await DemoApi.DeleteFrameAsync(frameId);
        if (!success)
        {
            Notification.Notify(NotificationSeverity.Error, "Error", "Failed to delete frame.");
            return;
        }

        frames = await DemoApi.GetFramesAsync(DemoId);

        if (selectedFrameId == frameId)
        {
            if (frames.Count > 0)
                await SelectFrame(frames[0].Id);
            else
            {
                selectedFrameId = null;
                currentFrameHtml = null;
                currentAnnotations = null;
                selectedStepId = null;
            }
        }

        Notification.Notify(NotificationSeverity.Success, "Frame deleted");
        StateHasChanged();
    }

    private async Task InsertFrame(int index)
    {
        await JS.InvokeVoidAsync("clickElement", "frame-file-input");
    }

    private async Task ReorderFrame((int OldIndex, int NewIndex) move)
    {
        if (move.OldIndex < 0 || move.NewIndex < 0 || move.OldIndex >= frames.Count || move.NewIndex >= frames.Count)
            return;

        var item = frames[move.OldIndex];
        frames.RemoveAt(move.OldIndex);
        frames.Insert(move.NewIndex, item);

        var frameIds = frames.Select(f => f.Id).ToList();
        await DemoApi.ReorderFramesAsync(DemoId, frameIds);
        frames = await DemoApi.GetFramesAsync(DemoId);
        StateHasChanged();
    }

    private async Task RenameFrame((Guid FrameId, string Name) rename)
    {
        await DemoApi.RenameFrameAsync(rename.FrameId, rename.Name);
        frames = await DemoApi.GetFramesAsync(DemoId);
        StateHasChanged();
    }

    private async Task AddStep()
    {
        if (selectedFrameId == null) return;

        var newStep = new StepDto(
            null, selectedFrameId.Value, steps.Count + 1,
            null, NavigationAction.NextStep, null, []);

        var allSteps = steps.Select(s => MapStepToDto(s)).Append(newStep).ToList();

        await DemoApi.UpdateStepsAsync(DemoId, new UpdateStepsRequest(allSteps));
        steps = await DemoApi.GetStepsAsync(DemoId);
        Notification.Notify(NotificationSeverity.Success, "Step added");
    }

    private async Task DeleteStep(Guid stepId)
    {
        var remaining = steps.Where(s => s.Id != stepId).ToList();

        var stepDtos = remaining.Select((s, i) =>
        {
            var dto = MapStepToDto(s);
            return dto with { StepNumber = i + 1 };
        }).ToList();

        await DemoApi.UpdateStepsAsync(DemoId, new UpdateStepsRequest(stepDtos));
        steps = await DemoApi.GetStepsAsync(DemoId);

        if (selectedStepId == stepId)
        {
            selectedStepId = null;
            currentAnnotations = null;
        }

        Notification.Notify(NotificationSeverity.Success, "Step deleted");
        StateHasChanged();
    }

    private async Task ReorderStep((Guid StepId, int Direction) args)
    {
        var ordered = steps.OrderBy(s => s.StepNumber).ToList();
        var idx = ordered.FindIndex(s => s.Id == args.StepId);
        if (idx < 0) return;

        var targetIdx = idx + args.Direction;
        if (targetIdx < 0 || targetIdx >= ordered.Count) return;

        // Swap step numbers
        var currentStep = ordered[idx];
        var adjacentStep = ordered[targetIdx];
        var tempNumber = currentStep.StepNumber;
        ordered[idx] = currentStep with { StepNumber = adjacentStep.StepNumber };
        ordered[targetIdx] = adjacentStep with { StepNumber = tempNumber };

        // Update local list
        steps = ordered;

        // Persist
        var stepDtos = steps.Select(s => MapStepToDto(s)).ToList();
        await DemoApi.UpdateStepsAsync(DemoId, new UpdateStepsRequest(stepDtos));
        steps = await DemoApi.GetStepsAsync(DemoId);
        StateHasChanged();
    }

    private async Task GenerateTour()
    {
        if (frames == null || frames.Count == 0)
        {
            Notification.Notify(NotificationSeverity.Warning, "No frames", "Capture pages first before generating a tour.");
            return;
        }

        generating = true;
        generatingStatus = "Analyzing frames...";
        StateHasChanged();

        try
        {
            await Task.Delay(500);
            generatingStatus = "AI is generating your tour...";
            StateHasChanged();

            var response = await DemoApi.GenerateTourAsync(DemoId, null);
            if (response)
            {
                generatingStatus = "Loading tour...";
                StateHasChanged();

                steps = await DemoApi.GetStepsAsync(DemoId);
                if (steps.Count > 0)
                {
                    SelectStep(steps[0].Id);
                }

                Notification.Notify(NotificationSeverity.Success, "Tour generated!", $"{steps.Count} steps created with AI.");
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Generation failed", "AI could not generate a tour. Please try again.");
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Error", ex.Message);
        }
        finally
        {
            generating = false;
            generatingStatus = "";
            StateHasChanged();
        }
    }

    private async Task SaveSteps()
    {
        saving = true;

        // Save frame edits first if any
        if (frameEditor?.HasUnsavedEdits == true)
            await SaveFrameEdits();

        var stepDtos = steps.Select(s => MapStepToDto(s)).ToList();

        await DemoApi.UpdateStepsAsync(DemoId, new UpdateStepsRequest(stepDtos));
        Notification.Notify(NotificationSeverity.Success, "Saved", "Steps saved successfully.");
        saving = false;
    }

    private async Task PublishDemo()
    {
        try
        {
            // Save steps before publishing
            var stepDtos = steps.Select(s => MapStepToDto(s)).ToList();
            await DemoApi.UpdateStepsAsync(DemoId, new UpdateStepsRequest(stepDtos));

            // Save frame edits if any
            if (frameEditor?.HasUnsavedEdits == true)
                await SaveFrameEdits();

            var success = await DemoApi.PublishDemoAsync(DemoId);
            if (success)
            {
                demo = await DemoApi.GetDemoAsync(DemoId);
                Notification.Notify(NotificationSeverity.Success, "Published", $"Demo is live at /demo/{demo?.Slug}");
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Publish failed", "Could not publish demo.");
            }
        }
        catch (Exception ex)
        {
            Notification.Notify(NotificationSeverity.Error, "Publish error", ex.Message);
        }
    }

    private void HandleStepSettingsChanged(StepResponse updatedStep)
    {
        var idx = steps.FindIndex(s => s.Id == updatedStep.Id);
        if (idx >= 0)
        {
            steps[idx] = updatedStep;
            StateHasChanged();
        }
    }

    private async Task UnpublishDemo()
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Unpublish this demo? It will no longer be accessible via the share link.");
        if (!confirmed) return;

        var success = await DemoApi.UnpublishDemoAsync(DemoId);
        if (success)
        {
            demo = await DemoApi.GetDemoAsync(DemoId);
            Notification.Notify(NotificationSeverity.Success, "Unpublished", "Demo is now a draft.");
        }
        else
        {
            Notification.Notify(NotificationSeverity.Error, "Error", "Could not unpublish demo.");
        }
    }

    private async Task ShareWhatsApp()
    {
        var encodedUrl = Uri.EscapeDataString(DemoUrl);
        await JS.InvokeVoidAsync("open", $"https://wa.me/?text={encodedUrl}", "_blank");
    }

    private async Task CopyShareLink()
    {
        await JS.InvokeVoidAsync("copyToClipboard", DemoUrl);
        shareCopyLabel = "Copied!";
        StateHasChanged();
        await Task.Delay(2000);
        shareCopyLabel = "Copy Link";
    }

    private async Task CopyShareIframe()
    {
        await JS.InvokeVoidAsync("copyToClipboard", EmbedIframeCode);
        embedCopyLabel = "Copied!";
        StateHasChanged();
        await Task.Delay(2000);
        embedCopyLabel = "Copy Embed Code";
    }

    private static StepDto MapStepToDto(StepResponse s) => new StepDto(
        s.Id, s.FrameId, s.StepNumber, s.ClickTargetSelector,
        s.NavigationAction, s.NavigationTarget,
        s.Annotations.Select(a => new AnnotationDto(
            a.Id, a.Type, a.Title, a.Content,
            a.PositionX, a.PositionY, a.Width, a.Height, a.Style,
            a.TargetSelector, a.ArrowDirection, a.BadgeNumber)).ToList(),
        s.TriggerType, s.TriggerDurationMs, s.BackdropLevel, s.VoiceoverText, s.VoiceId,
        s.Type, s.ChapterSettings);

    private static NavTour.Shared.DTOs.ChapterSettings ParseChapterSettings(string? json)
    {
        if (string.IsNullOrEmpty(json)) return new NavTour.Shared.DTOs.ChapterSettings();
        try { return System.Text.Json.JsonSerializer.Deserialize<NavTour.Shared.DTOs.ChapterSettings>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new(); }
        catch { return new NavTour.Shared.DTOs.ChapterSettings(); }
    }
}
