@page "/leads"
@rendermode InteractiveServer
@inject HttpClient Http
@inject AuthService Auth
@inject NavigationManager Nav
@inject DialogService DialogService
@inject NotificationService Notification

<RadzenDialog />
<RadzenNotification />

<RadzenStack Gap="16px">
    <RadzenRow AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
        <RadzenText TextStyle="TextStyle.H4">Captured Leads</RadzenText>
        <RadzenButton Text="Export to Excel" Icon="download" ButtonStyle="ButtonStyle.Light"
                      Click="@(() => Nav.NavigateTo("/api/v1/leads/export", forceLoad: true))" />
    </RadzenRow>

    @if (loading)
    {
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else
    {
        <RadzenDataGrid Data="@leads" TItem="LeadResponse" AllowSorting="true" AllowPaging="true" PageSize="25">
            <Columns>
                <RadzenDataGridColumn TItem="LeadResponse" Property="Email" Title="Email" />
                <RadzenDataGridColumn TItem="LeadResponse" Property="Name" Title="Name" />
                <RadzenDataGridColumn TItem="LeadResponse" Property="Company" Title="Company" />
                <RadzenDataGridColumn TItem="LeadResponse" Property="DemoName" Title="Demo" />
                <RadzenDataGridColumn TItem="LeadResponse" Property="CapturedAt" Title="Captured" FormatString="{0:g}" />
                <RadzenDataGridColumn TItem="LeadResponse" Title="" Width="50px" Sortable="false" TextAlign="TextAlign.Center">
                    <Template Context="lead">
                        <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Text"
                                      Size="ButtonSize.Small" Click="@(() => ConfirmDelete(lead))" />
                    </Template>
                </RadzenDataGridColumn>
            </Columns>
        </RadzenDataGrid>
    }
</RadzenStack>

@code {
    private List<LeadResponse> leads = [];
    private bool loading = true;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.TryRestoreAsync();
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        leads = await Http.GetFromJsonAsync<List<LeadResponse>>("api/v1/leads") ?? [];
        loading = false;
        StateHasChanged();
    }

    private async Task ConfirmDelete(LeadResponse lead)
    {
        var confirmed = await DialogService.Confirm(
            "Delete this lead? This action cannot be undone.",
            "Delete Lead",
            new ConfirmOptions { OkButtonText = "Delete", CancelButtonText = "Cancel" });

        if (confirmed == true)
        {
            var response = await Http.DeleteAsync($"api/v1/leads/{lead.Id}");
            if (response.IsSuccessStatusCode)
            {
                leads.Remove(lead);
                Notification.Notify(NotificationSeverity.Success, "Lead deleted");
                StateHasChanged();
            }
            else
            {
                Notification.Notify(NotificationSeverity.Error, "Failed to delete lead");
            }
        }
    }
}
