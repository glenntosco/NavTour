@page "/s/{Slug}"
@rendermode InteractiveServer
@layout PlayerLayout
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@using NavTour.Shared.DTOs.Screenshots
@inject ScreenshotApiService ScreenshotApi
@inject IJSRuntime JS
@implements IDisposable

@if (loading)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100vh">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
    </div>
}
else if (screenshot == null)
{
    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;gap:16px;color:#666">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
        <p>Screenshot not found or not published.</p>
    </div>
}
else
{
    <div class="sv-viewer">
        @* Header *@
        <div class="sv-header">
            <div class="sv-title">@screenshot.Name</div>
            <div class="sv-meta">@slides.Count slide@(slides.Count != 1 ? "s" : "") · @screenshot.ViewCount views</div>
        </div>

        @* Main canvas area *@
        <div class="sv-body">
            @if (currentSlide != null)
            {
                <div class="sv-canvas-wrap" id="sv-canvas-container">
                    <canvas id="sv-canvas"></canvas>
                </div>
            }

            @* Slide nav arrows *@
            @if (slides.Count > 1)
            {
                <button class="sv-arrow sv-arrow-prev" @onclick="PrevSlide" disabled="@(currentIndex == 0)">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                </button>
                <button class="sv-arrow sv-arrow-next" @onclick="NextSlide" disabled="@(currentIndex >= slides.Count - 1)">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </button>
            }
        </div>

        @* Slide strip *@
        @if (slides.Count > 1)
        {
            <div class="sv-strip">
                @for (int i = 0; i < slides.Count; i++)
                {
                    var slide = slides[i];
                    var idx = i;
                    <button class="sv-thumb @(currentIndex == idx ? "active" : "")" @onclick="() => GoToSlide(idx)">
                        @if (!string.IsNullOrEmpty(slide.ThumbnailUrl))
                        {
                            <img src="@slide.ThumbnailUrl" alt="Slide @(idx+1)" />
                        }
                        else
                        {
                            <span>@(idx + 1)</span>
                        }
                    </button>
                }
            </div>
        }
    </div>
}

<style>
.sv-viewer { display:flex; flex-direction:column; height:100vh; background:#1a1a2e; color:#fff; overflow:hidden; }
.sv-header { display:flex; align-items:center; gap:16px; padding:14px 24px; background:rgba(0,0,0,0.3); flex-shrink:0; backdrop-filter:blur(8px); border-bottom:1px solid rgba(255,255,255,0.08); }
.sv-title { font-size:1rem; font-weight:600; }
.sv-meta { font-size:0.75rem; color:rgba(255,255,255,0.5); }
.sv-body { flex:1; min-height:0; position:relative; display:flex; align-items:center; justify-content:center; }
.sv-canvas-wrap { position:relative; }
.sv-arrow { position:absolute; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:50%; background:rgba(255,255,255,0.12); border:1px solid rgba(255,255,255,0.15); color:#fff; display:flex; align-items:center; justify-content:center; cursor:pointer; transition:background 0.15s; z-index:10; }
.sv-arrow:hover:not(:disabled) { background:rgba(255,255,255,0.22); }
.sv-arrow:disabled { opacity:0.25; cursor:not-allowed; }
.sv-arrow-prev { left:16px; }
.sv-arrow-next { right:16px; }
.sv-strip { display:flex; gap:8px; padding:12px 16px; background:rgba(0,0,0,0.4); overflow-x:auto; flex-shrink:0; }
.sv-thumb { flex-shrink:0; width:96px; height:64px; border-radius:6px; border:2px solid transparent; background:rgba(255,255,255,0.1); cursor:pointer; overflow:hidden; display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,0.6); font-size:12px; font-weight:600; padding:0; transition:border-color 0.15s; }
.sv-thumb:hover { border-color:rgba(255,255,255,0.3); }
.sv-thumb.active { border-color:#4361ee; }
.sv-thumb img { width:100%; height:100%; object-fit:cover; }
</style>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private ScreenshotResponse? screenshot;
    private List<ScreenshotSlideResponse> slides = [];
    private ScreenshotSlideResponse? currentSlide;
    private int currentIndex;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        screenshot = await ScreenshotApi.GetPublicBySlugAsync(Slug);
        if (screenshot != null)
        {
            slides = await ScreenshotApi.GetPublicSlidesAsync(Slug);
            if (slides.Count > 0) currentSlide = slides[0];
        }
        loading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && currentSlide != null)
        {
            await LoadFabricAsync();
            await RenderSlideAsync();
        }
    }

    private async Task LoadFabricAsync()
    {
        await JS.InvokeVoidAsync("eval", @"
            if (!window.fabric) {
                var s = document.createElement('script');
                s.src = 'https://cdnjs.cloudflare.com/ajax/libs/fabric.js/5.3.0/fabric.min.js';
                document.head.appendChild(s);
                await new Promise(r => s.onload = r);
            }
        ");
        await Task.Delay(1200);
    }

    private async Task RenderSlideAsync()
    {
        if (currentSlide == null) return;
        try
        {
            await JS.InvokeVoidAsync("screenshotViewer.render",
                "sv-canvas", "sv-canvas-container",
                currentSlide.ImageData, currentSlide.AnnotationData);
        }
        catch { }
    }

    private async Task GoToSlide(int idx)
    {
        if (idx < 0 || idx >= slides.Count) return;
        currentIndex = idx;
        currentSlide = slides[idx];
        StateHasChanged();
        await Task.Delay(30);
        await RenderSlideAsync();
    }

    private Task PrevSlide() => GoToSlide(currentIndex - 1);
    private Task NextSlide() => GoToSlide(currentIndex + 1);

    public void Dispose()
    {
        _ = JS.InvokeVoidAsync("screenshotViewer.dispose");
    }
}
