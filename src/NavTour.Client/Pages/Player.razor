@page "/demo/{Slug}"
@rendermode InteractiveServer
@layout PlayerLayout
@inject PlayerApiService PlayerApi
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div @onkeydown="HandleKeyDown" tabindex="0" @ref="playerContainer" style="outline:none">
@if (loading)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100vh">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
    </div>
}
else if (manifest == null)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100vh;flex-direction:column;gap:16px">
        <RadzenText TextStyle="TextStyle.H4">Demo Not Found</RadzenText>
        <RadzenText>This demo may have been removed or is not yet published.</RadzenText>
    </div>
}
else
{
    @* Player chrome *@
    <div style="display:flex;flex-direction:column;height:100vh;background:#f5f5f5">
        @* Header bar *@
        <div style="display:flex;align-items:center;padding:8px 16px;background:white;border-bottom:1px solid #e0e0e0;gap:12px">
            <img src="navtour-logo.png" alt="NavTour" style="height:24px;width:auto" />
            <span style="font-size:14px;font-weight:500">@manifest.DemoName</span>
            <div style="flex:1"></div>
            <span style="font-size:13px;color:#999">@(currentStepIndex + 1) / @manifest.Steps.Count</span>
            <button onclick="var m=voiceover.toggleMute();this.textContent=m?'🔇':'🔊'" class="voice-btn" title="Toggle audio">🔊</button>
        </div>

        @* Frame content with overlays *@
        <div @ref="frameContainer" class="player-frame-container" style="flex:1;position:relative;overflow:hidden;background:#f5f5f5">
            <div id="player-scale-wrapper" style="width:1440px;height:900px;position:absolute;top:0;left:0;transform-origin:top left">
                @if (currentStep?.Type == StepType.CoverSlide || currentStep?.Type == StepType.ClosingSlide)
                {
                    var chapterSettings = ParseChapterSettings(currentStep.ChapterSettings);
                    var firstContentFrame = manifest?.Steps.FirstOrDefault(s => s.Type == StepType.Content && s.FrameId.HasValue);
                    var bgFrameId = firstContentFrame?.FrameId ?? manifest?.Frames.FirstOrDefault()?.Id;
                    var bgUrl = bgFrameId != null ? $"/api/v1/player/frames/{bgFrameId}/html" : null;
                    <CoverSlideRenderer Settings="chapterSettings"
                        BackgroundImageUrl="@bgUrl"
                        TotalSteps="@(manifest?.Steps.Count ?? 0)"
                        IsClosing="@(currentStep.Type == StepType.ClosingSlide)"
                        OnCtaClick="HandleCoverCtaClick"
                        OnButtonClick="HandleCoverButtonClick" />
                }
                else
                {
                    @if (currentFrame != null)
                    {
                        <iframe @ref="iframeRef" id="@_playerIframeId"
                            src="/api/v1/player/frames/@currentFrame.Id/html"
                            sandbox="allow-same-origin"
                            style="width:1440px;height:900px;border:none"></iframe>
                    }

                    @* Spotlight overlay is managed by JS (playerSpotlight) *@

                    @if (currentStep != null)
                    {
                        <PlayerOverlay Annotations="currentStep.Annotations" OnClickZone="HandleClickZone"
                            StepIndex="currentStepIndex" TotalSteps="@(manifest?.Steps.Count ?? 0)"
                            OnNavigate="HandleAnnotationNavigate" />
                    }
                }
            </div>

            @* Timer progress indicator *@
            @if (currentStep?.TriggerType == TriggerType.Timer && currentStep.TriggerDurationMs > 0)
            {
                <div style="position:absolute;bottom:0;left:0;right:0;height:3px;z-index:150">
                    <div class="timer-progress" style="animation-duration:@(currentStep.TriggerDurationMs)ms"></div>
                </div>
            }
        </div>

        @* Trigger hint (shown above frame when non-button trigger) *@
        @if (currentStep != null && currentStep.TriggerType != TriggerType.ButtonClick)
        {
            <div style="position:absolute;bottom:12px;left:50%;transform:translateX(-50%);z-index:200">
                <span class="trigger-hint-pulse" style="font-size:12px;color:#4361ee;font-weight:500;background:white;padding:6px 14px;border-radius:20px;box-shadow:0 2px 8px rgba(0,0,0,0.1)">@GetTriggerHint(currentStep)</span>
            </div>
        }
    </div>

    @* Escape View overlay *@
    @if (showEscapeView)
    {
        <div style="position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center"
            @onclick="DismissEscapeView" @onclick:stopPropagation="true">
            <div style="background:white;border-radius:16px;padding:32px 40px;max-width:400px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.3)"
                @onclick:stopPropagation="true">
                <h2 style="margin:0 0 8px;font-size:20px;font-weight:600;color:#1a1a2e">Exit this demo?</h2>
                <p style="margin:0 0 24px;color:#666;font-size:14px">You're @Math.Round(progressPercent)% through. Want to keep going?</p>
                <div style="display:flex;gap:12px;justify-content:center">
                    <button @onclick="DismissEscapeView"
                        style="padding:10px 24px;background:#4361ee;color:white;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer">
                        Continue Demo
                    </button>
                    <button @onclick="ExitDemo"
                        style="padding:10px 24px;background:#f1f3f5;color:#666;border:none;border-radius:8px;font-size:14px;cursor:pointer">
                        Exit
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showLeadForm)
    {
        @if (manifest?.FormFields is { Count: > 0 })
        {
            <DynamicFormRenderer Fields="manifest.FormFields" Settings="manifest.FormSettings"
                OnSubmit="SubmitDynamicForm" OnSkip="SkipLead" />
        }
        else
        {
            <LeadCaptureForm OnSubmit="SubmitLead" OnSkip="SkipLead" />
        }
    }
}
</div>

<style>
    .voice-btn {
        background: none; border: none; cursor: pointer; font-size: 18px;
        padding: 4px 8px; border-radius: 4px; opacity: 0.6;
    }
    .voice-btn:hover { opacity: 1; background: #f0f0f0; }

    .timer-progress {
        height: 100%;
        background: linear-gradient(90deg, #4361ee, #818cf8);
        animation: timer-fill linear forwards;
        transform-origin: left;
    }
    @@keyframes timer-fill {
        from { width: 0%; }
        to { width: 100%; }
    }
</style>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private PlayerManifestResponse? manifest;
    private bool loading = true;
    private int currentStepIndex;
    private bool _navigating;
    private Guid? sessionId;
    private bool showLeadForm;
    private bool showEscapeView;
    private DateTime stepStartTime = DateTime.UtcNow;
    private List<SessionEventDto> eventBuffer = [];
    private System.Threading.Timer? flushTimer;
    private ElementReference playerContainer;
    private ElementReference iframeRef;
    private ElementReference frameContainer;
    private DotNetObjectReference<Player>? dotnetRef;
    private string _playerIframeId = "navtour-player-" + Guid.NewGuid().ToString("N")[..8];
    private Guid? _lastRenderedFrameId;

    private PlayerStepDto? currentStep => manifest?.Steps.ElementAtOrDefault(currentStepIndex);
    private PlayerFrameDto? currentFrame => currentStep != null
        ? manifest?.Frames.FirstOrDefault(f => f.Id == currentStep.FrameId)
        : null;
    private double progressPercent => manifest?.Steps.Count > 0
        ? (double)(currentStepIndex + 1) / manifest.Steps.Count * 100
        : 0;

    protected override async Task OnInitializedAsync()
    {
        manifest = await PlayerApi.GetManifestAsync(Slug);
        loading = false;

        if (manifest != null)
        {
            dotnetRef = DotNetObjectReference.Create(this);
            BufferEvent(EventType.DemoStarted, null, null);
            BufferEvent(EventType.StepViewed, 1, null);
            stepStartTime = DateTime.UtcNow;
            flushTimer = new System.Threading.Timer(async _ => await FlushEvents(), null, 5000, 5000);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("playerInterop.focusElement", playerContainer);
        }

        // Load frame HTML via server URL when frame changes (content steps only)
        if (currentStep?.Type == StepType.Content && currentFrame != null && currentFrame.Id != _lastRenderedFrameId)
        {
            var isFirstFrame = _lastRenderedFrameId == null;
            _lastRenderedFrameId = currentFrame.Id;
            // Set iframe src to server-rendered HTML (resources load from /api/v1/resources/{hash})
            await JS.InvokeVoidAsync("navtourSetFrameSrc", _playerIframeId, $"/api/v1/player/frames/{currentFrame.Id}/html");
            await Task.Delay(300); // Wait for stylesheets/resources to load

            // Init scaling after the first frame renders (wrapper exists now)
            if (isFirstFrame)
            {
                await JS.InvokeVoidAsync("playerInterop.initScaling", frameContainer);
            }
        }

        // Set up trigger for current step after render (content steps only)
        if (currentStep?.Type == StepType.Content && manifest != null && currentStep != null && dotnetRef != null)
        {
            await SetupCurrentStepTrigger();
        }

        // Voiceover for the first step on initial render
        if (firstRender && manifest != null && currentStep?.VoiceoverAudioUrl != null)
            try { await JS.InvokeVoidAsync("voiceover.play", currentStep.VoiceoverAudioUrl); } catch { }

        // Update spotlight for current step (content steps only)
        if (currentStep?.Type == StepType.Content && manifest != null && currentStep != null)
        {
            await UpdateSpotlight();
        }
    }

    private async Task SetupCurrentStepTrigger()
    {
        if (currentStep == null || dotnetRef == null) return;

        try
        {
            var loaded = await JS.InvokeAsync<bool>("playerInterop.waitForIframeLoad", "iframe");
            if (loaded)
                await SetupTriggerForStep(currentStep);
        }
        catch
        {
            // Iframe may not be available during dispose
        }
    }

    private async Task SetupTriggerForStep(PlayerStepDto step)
    {
        await JS.InvokeVoidAsync("playerInterop.clearTrigger");

        if (step.TriggerType == TriggerType.ButtonClick) return;

        try
        {
            await JS.InvokeAsync<bool>(
                "playerInterop.setupTrigger",
                dotnetRef,
                "iframe",
                step.TriggerType.ToString(),
                step.ClickTargetSelector,
                step.TriggerDurationMs ?? 0);
        }
        catch
        {
            // Selector not found — graceful fallback
        }
    }

    [JSInvokable]
    public async Task OnTriggerFired()
    {
        if (_navigating) return;
        await InvokeAsync(async () =>
        {
            await NextStep();
            StateHasChanged();
        });
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (showEscapeView)
        {
            if (e.Key == "Escape") DismissEscapeView();
            return;
        }

        if (e.Key == "Escape")
        {
            showEscapeView = true;
            BufferEvent(EventType.StepCompleted, currentStepIndex + 1, "{\"action\":\"escape_view\"}");
            return;
        }

        if (e.Key == "ArrowRight" || e.Key == "Right") _ = NextStep();
        else if (e.Key == "ArrowLeft" || e.Key == "Left") _ = PreviousStep();
    }

    private async Task NextStep()
    {
        if (manifest == null || _navigating) return;
        _navigating = true;
        try
        {

        var step = currentStep;
        var timeOnStep = (int)(DateTime.UtcNow - stepStartTime).TotalMilliseconds;
        BufferEvent(EventType.StepCompleted, currentStepIndex + 1, $"{{\"timeOnStepMs\":{timeOnStep}}}");

        // Clear any active trigger
        try { await JS.InvokeVoidAsync("playerInterop.clearTrigger"); } catch { }

        // Handle NavigationAction
        if (step != null)
        {
            switch (step.NavigationAction)
            {
                case NavigationAction.NextStep:
                    if (currentStepIndex >= manifest.Steps.Count - 1)
                    {
                        BufferEvent(EventType.DemoCompleted, null, null);
                        await FlushEvents();
                        showLeadForm = true;
                        return;
                    }
                    currentStepIndex++;
                    break;

                case NavigationAction.GoToStep:
                    if (int.TryParse(step.NavigationTarget, out var targetStep))
                        currentStepIndex = manifest.Steps.FindIndex(s => s.StepNumber == targetStep);
                    break;

                case NavigationAction.PreviousStep:
                    if (currentStepIndex > 0) currentStepIndex--;
                    break;

                case NavigationAction.EndDemo:
                    BufferEvent(EventType.DemoCompleted, null, null);
                    await FlushEvents();
                    showLeadForm = true;
                    return;

                case NavigationAction.OpenUrl:
                    if (step.NavigationTarget != null)
                        Nav.NavigateTo(step.NavigationTarget, true);
                    return;

                case NavigationAction.MarkConverted:
                    BufferEvent(EventType.DemoCompleted, null, "{\"converted\":true}");
                    await FlushEvents();
                    // Continue to next step if available
                    if (currentStepIndex < manifest.Steps.Count - 1)
                        currentStepIndex++;
                    else
                    {
                        showLeadForm = true;
                        return;
                    }
                    break;

                case NavigationAction.StartFlow:
                    if (step.NavigationTarget != null)
                    {
                        BufferEvent(EventType.DemoCompleted, null, $"{{\"nextFlow\":\"{step.NavigationTarget}\"}}");
                        await FlushEvents();
                        Nav.NavigateTo($"/demo/{step.NavigationTarget}", true);
                        return;
                    }
                    break;
            }
        }

        stepStartTime = DateTime.UtcNow;
        BufferEvent(EventType.StepViewed, currentStepIndex + 1, null);
        StateHasChanged();

        if (currentStep?.VoiceoverAudioUrl != null)
            try { await JS.InvokeVoidAsync("voiceover.play", currentStep.VoiceoverAudioUrl); } catch { }

        } finally { _navigating = false; }
    }

    private async Task PreviousStep()
    {
        if (currentStepIndex <= 0 || _navigating) return;
        _navigating = true;
        try
        {
            try { await JS.InvokeVoidAsync("playerInterop.clearTrigger"); } catch { }
            currentStepIndex--;
            stepStartTime = DateTime.UtcNow;
            BufferEvent(EventType.StepViewed, currentStepIndex + 1, null);
            StateHasChanged();

            if (currentStep?.VoiceoverAudioUrl != null)
                try { await JS.InvokeVoidAsync("voiceover.play", currentStep.VoiceoverAudioUrl); } catch { }
        }
        finally { _navigating = false; }
    }

    private async Task HandleClickZone(PlayerAnnotationDto annotation)
    {
        await NextStep();
    }

    private async Task HandleAnnotationNavigate(string direction)
    {
        if (direction == "next") await NextStep();
        else if (direction == "previous") await PreviousStep();
    }

    private void DismissEscapeView()
    {
        showEscapeView = false;
    }

    private void ExitDemo()
    {
        showEscapeView = false;
        BufferEvent(EventType.DemoCompleted, null, "{\"earlyExit\":true}");
        _ = FlushEvents();
        showLeadForm = true;
    }

    private async Task UpdateSpotlight()
    {
        if (currentStep == null) return;
        try
        {
            var backdrop = currentStep.BackdropLevel;
            if (string.IsNullOrEmpty(backdrop) || backdrop == "none")
            {
                await JS.InvokeVoidAsync("playerSpotlight.hide");
                return;
            }

            double opacity = backdrop switch
            {
                "light" => 0.15,
                "medium" => 0.35,
                "heavy" => 0.55,
                _ => 0.35
            };

            // Find the primary spotlight target annotation
            var target = GetSpotlightTarget(currentStep);
            if (target != null)
            {
                // Pad the spotlight around the annotation (2% padding)
                var pad = 2.0;
                var x = Math.Max(0, target.PositionX - pad);
                var y = Math.Max(0, target.PositionY - pad);
                var w = Math.Min(100 - x, target.Width + pad * 2);
                var h = Math.Min(100 - y, target.Height + pad * 2);
                await JS.InvokeVoidAsync("playerSpotlight.show", x, y, w, h, opacity);
            }
            else
            {
                // No spotlight target — use flat backdrop
                await JS.InvokeVoidAsync("playerSpotlight.showFlat", opacity);
            }
        }
        catch { /* Component may be disposing */ }
    }

    private static PlayerAnnotationDto? GetSpotlightTarget(PlayerStepDto step)
    {
        // Priority: NumberedTooltip > Tooltip > Hotspot > Beacon > Modal
        var annotations = step.Annotations;
        return annotations.FirstOrDefault(a => a.Type == AnnotationType.NumberedTooltip)
            ?? annotations.FirstOrDefault(a => a.Type == AnnotationType.Tooltip)
            ?? annotations.FirstOrDefault(a => a.Type == AnnotationType.Hotspot)
            ?? annotations.FirstOrDefault(a => a.Type == AnnotationType.Beacon)
            ?? annotations.FirstOrDefault(a => a.Type == AnnotationType.Modal);
    }

    private static string GetTriggerHint(PlayerStepDto step) => step.TriggerType switch
    {
        TriggerType.ElementClick => "Click the highlighted element to continue",
        TriggerType.TextInput => "Type in the highlighted field to continue",
        TriggerType.Timer => $"Auto-advancing in {(step.TriggerDurationMs ?? 0) / 1000}s...",
        _ => ""
    };

    private void BufferEvent(EventType type, int? stepNumber, string? data)
    {
        eventBuffer.Add(new SessionEventDto(type, stepNumber, data, DateTime.UtcNow));
    }

    private async Task FlushEvents()
    {
        if (eventBuffer.Count == 0) return;
        var batch = new EventBatchRequest(sessionId, null, [.. eventBuffer]);
        eventBuffer.Clear();
        var result = await PlayerApi.SendEventsAsync(Slug, batch);
        if (result.HasValue) sessionId = result.Value;
    }

    private async Task SubmitLead(LeadCaptureRequest request)
    {
        BufferEvent(EventType.LeadSubmitted, null, null);
        await FlushEvents();
        await PlayerApi.CaptureLead(Slug, request, sessionId);
        showLeadForm = false;
    }

    private async Task SubmitDynamicForm(FormSubmissionRequest request)
    {
        BufferEvent(EventType.LeadSubmitted, null, null);
        await FlushEvents();
        await PlayerApi.SubmitFormAsync(Slug, request, sessionId);
        showLeadForm = false;
    }

    private void SkipLead()
    {
        showLeadForm = false;
    }

    private NavTour.Shared.DTOs.ChapterSettings ParseChapterSettings(string? json)
    {
        if (string.IsNullOrEmpty(json)) return new NavTour.Shared.DTOs.ChapterSettings();
        try { return System.Text.Json.JsonSerializer.Deserialize<NavTour.Shared.DTOs.ChapterSettings>(json, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true }) ?? new(); }
        catch { return new NavTour.Shared.DTOs.ChapterSettings(); }
    }

    private async Task HandleCoverCtaClick()
    {
        var settings = currentStep != null ? ParseChapterSettings(currentStep.ChapterSettings) : new NavTour.Shared.DTOs.ChapterSettings();
        if (settings.CtaAction == "url" && !string.IsNullOrEmpty(settings.CtaUrl))
            Nav.NavigateTo(settings.CtaUrl, true);
        else
            await NextStep();
    }

    private async Task HandleCoverButtonClick(NavTour.Shared.DTOs.ChapterButton btn)
    {
        if (btn.ActionType == "url" && !string.IsNullOrEmpty(btn.ActionUrl))
            Nav.NavigateTo(btn.ActionUrl, true);
        else if (btn.ActionType == "step" && btn.ActionStepNumber.HasValue)
        {
            currentStepIndex = Math.Min(btn.ActionStepNumber.Value - 1, (manifest?.Steps.Count ?? 1) - 1);
            currentStepIndex = Math.Max(0, currentStepIndex);
            stepStartTime = DateTime.UtcNow;
            BufferEvent(EventType.StepViewed, currentStepIndex + 1, null);
            StateHasChanged();
        }
        else
            await NextStep();
    }

    public void Dispose()
    {
        flushTimer?.Dispose();
        dotnetRef?.Dispose();
        _ = FlushEvents();
        try { _ = JS.InvokeVoidAsync("playerSpotlight.hide"); } catch { }
        try { _ = JS.InvokeVoidAsync("voiceover.stop"); } catch { }
        try { _ = JS.InvokeVoidAsync("playerInterop.disposeScaling"); } catch { }
    }
}
