@page "/demo/{Slug}"
@rendermode InteractiveServer
@layout PlayerLayout
@inject PlayerApiService PlayerApi
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable

<div @onkeydown="HandleKeyDown" tabindex="0" @ref="playerContainer" style="outline:none">
@if (loading)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100vh">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Size="ProgressBarCircularSize.Large" />
    </div>
}
else if (manifest == null)
{
    <div style="display:flex;align-items:center;justify-content:center;height:100vh;flex-direction:column;gap:16px">
        <RadzenText TextStyle="TextStyle.H4">Demo Not Found</RadzenText>
        <RadzenText>This demo may have been removed or is not yet published.</RadzenText>
    </div>
}
else
{
    @* Player chrome *@
    <div style="display:flex;flex-direction:column;height:100vh;background:#f5f5f5">
        @* Header bar *@
        <div style="display:flex;align-items:center;padding:8px 16px;background:white;border-bottom:1px solid #e0e0e0;gap:12px">
            <img src="favicon.svg" alt="NavTour" style="height:24px;width:auto" />
            <span style="font-size:14px;font-weight:500">@manifest.DemoName</span>
            <div style="flex:1"></div>
            <span style="font-size:13px;color:#999">@(currentStepIndex + 1) / @manifest.Steps.Count</span>
        </div>

        @* Frame content with overlays *@
        <div style="flex:1;position:relative;overflow:hidden">
            @if (currentFrame != null)
            {
                <iframe @ref="iframeRef" sandbox="allow-same-origin" style="width:100%;height:100%;border:none"
                    srcdoc="@currentFrame.HtmlContent"></iframe>
            }

            @* Backdrop overlay (after iframe so it renders on top) *@
            @if (currentStep != null && !string.IsNullOrEmpty(currentStep.BackdropLevel) && currentStep.BackdropLevel != "none")
            {
                <div style="position:absolute;inset:0;z-index:5;pointer-events:none;@GetBackdropStyle(currentStep.BackdropLevel)"></div>
            }

            @if (currentStep != null)
            {
                <PlayerOverlay Annotations="currentStep.Annotations" OnClickZone="HandleClickZone"
                    StepIndex="currentStepIndex" TotalSteps="@(manifest?.Steps.Count ?? 0)"
                    OnNavigate="HandleAnnotationNavigate" />
            }

            @* Timer progress indicator *@
            @if (currentStep?.TriggerType == TriggerType.Timer && currentStep.TriggerDurationMs > 0)
            {
                <div style="position:absolute;bottom:0;left:0;right:0;height:3px;z-index:20">
                    <div class="timer-progress" style="animation-duration:@(currentStep.TriggerDurationMs)ms"></div>
                </div>
            }
        </div>

        @* Navigation is handled via annotation card Back/Next buttons *@
    </div>

    @* Escape View overlay *@
    @if (showEscapeView)
    {
        <div style="position:fixed;inset:0;z-index:1000;background:rgba(0,0,0,0.6);display:flex;align-items:center;justify-content:center"
            @onclick="DismissEscapeView" @onclick:stopPropagation="true">
            <div style="background:white;border-radius:16px;padding:32px 40px;max-width:400px;text-align:center;box-shadow:0 20px 60px rgba(0,0,0,0.3)"
                @onclick:stopPropagation="true">
                <h2 style="margin:0 0 8px;font-size:20px;font-weight:600;color:#1a1a2e">Exit this demo?</h2>
                <p style="margin:0 0 24px;color:#666;font-size:14px">You're @Math.Round(progressPercent)% through. Want to keep going?</p>
                <div style="display:flex;gap:12px;justify-content:center">
                    <button @onclick="DismissEscapeView"
                        style="padding:10px 24px;background:#4361ee;color:white;border:none;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer">
                        Continue Demo
                    </button>
                    <button @onclick="ExitDemo"
                        style="padding:10px 24px;background:#f1f3f5;color:#666;border:none;border-radius:8px;font-size:14px;cursor:pointer">
                        Exit
                    </button>
                </div>
            </div>
        </div>
    }

    @if (showLeadForm)
    {
        <LeadCaptureForm OnSubmit="SubmitLead" OnSkip="SkipLead" />
    }
}
</div>

<style>
    .timer-progress {
        height: 100%;
        background: linear-gradient(90deg, #4361ee, #818cf8);
        animation: timer-fill linear forwards;
        transform-origin: left;
    }
    @@keyframes timer-fill {
        from { width: 0%; }
        to { width: 100%; }
    }
</style>

@code {
    [Parameter] public string Slug { get; set; } = "";

    private PlayerManifestResponse? manifest;
    private bool loading = true;
    private int currentStepIndex;
    private Guid? sessionId;
    private bool showLeadForm;
    private bool showEscapeView;
    private DateTime stepStartTime = DateTime.UtcNow;
    private List<SessionEventDto> eventBuffer = [];
    private System.Threading.Timer? flushTimer;
    private ElementReference playerContainer;
    private ElementReference iframeRef;
    private DotNetObjectReference<Player>? dotnetRef;

    private PlayerStepDto? currentStep => manifest?.Steps.ElementAtOrDefault(currentStepIndex);
    private PlayerFrameDto? currentFrame => currentStep != null
        ? manifest?.Frames.FirstOrDefault(f => f.Id == currentStep.FrameId)
        : null;
    private double progressPercent => manifest?.Steps.Count > 0
        ? (double)(currentStepIndex + 1) / manifest.Steps.Count * 100
        : 0;

    protected override async Task OnInitializedAsync()
    {
        manifest = await PlayerApi.GetManifestAsync(Slug);
        loading = false;

        if (manifest != null)
        {
            dotnetRef = DotNetObjectReference.Create(this);
            BufferEvent(EventType.DemoStarted, null, null);
            BufferEvent(EventType.StepViewed, 1, null);
            stepStartTime = DateTime.UtcNow;
            flushTimer = new System.Threading.Timer(async _ => await FlushEvents(), null, 5000, 5000);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("playerInterop.focusElement", playerContainer);
        }

        // Set up trigger for current step after render
        if (manifest != null && currentStep != null && dotnetRef != null)
        {
            await SetupTriggerForStep(currentStep);
        }
    }

    private async Task SetupTriggerForStep(PlayerStepDto step)
    {
        await JS.InvokeVoidAsync("playerInterop.clearTrigger");

        if (step.TriggerType == TriggerType.ButtonClick) return;

        try
        {
            await JS.InvokeAsync<bool>(
                "playerInterop.setupTrigger",
                dotnetRef,
                "iframe",
                step.TriggerType.ToString(),
                step.ClickTargetSelector,
                step.TriggerDurationMs ?? 0);
        }
        catch
        {
            // Iframe may not be ready yet, or selector not found — graceful fallback
        }
    }

    [JSInvokable]
    public async Task OnTriggerFired()
    {
        await InvokeAsync(async () =>
        {
            await NextStep();
            StateHasChanged();
        });
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (showEscapeView)
        {
            if (e.Key == "Escape") DismissEscapeView();
            return;
        }

        if (e.Key == "Escape")
        {
            showEscapeView = true;
            BufferEvent(EventType.StepCompleted, currentStepIndex + 1, "{\"action\":\"escape_view\"}");
            return;
        }

        if (e.Key == "ArrowRight" || e.Key == "Right") _ = NextStep();
        else if (e.Key == "ArrowLeft" || e.Key == "Left") _ = PreviousStep();
    }

    private async Task NextStep()
    {
        if (manifest == null) return;

        var step = currentStep;
        var timeOnStep = (int)(DateTime.UtcNow - stepStartTime).TotalMilliseconds;
        BufferEvent(EventType.StepCompleted, currentStepIndex + 1, $"{{\"timeOnStepMs\":{timeOnStep}}}");

        // Clear any active trigger
        try { await JS.InvokeVoidAsync("playerInterop.clearTrigger"); } catch { }

        // Handle NavigationAction
        if (step != null)
        {
            switch (step.NavigationAction)
            {
                case NavigationAction.NextStep:
                    if (currentStepIndex >= manifest.Steps.Count - 1)
                    {
                        BufferEvent(EventType.DemoCompleted, null, null);
                        await FlushEvents();
                        showLeadForm = true;
                        return;
                    }
                    currentStepIndex++;
                    break;

                case NavigationAction.GoToStep:
                    if (int.TryParse(step.NavigationTarget, out var targetStep))
                        currentStepIndex = manifest.Steps.FindIndex(s => s.StepNumber == targetStep);
                    break;

                case NavigationAction.PreviousStep:
                    if (currentStepIndex > 0) currentStepIndex--;
                    break;

                case NavigationAction.EndDemo:
                    BufferEvent(EventType.DemoCompleted, null, null);
                    await FlushEvents();
                    showLeadForm = true;
                    return;

                case NavigationAction.OpenUrl:
                    if (step.NavigationTarget != null)
                        Nav.NavigateTo(step.NavigationTarget, true);
                    return;

                case NavigationAction.MarkConverted:
                    BufferEvent(EventType.DemoCompleted, null, "{\"converted\":true}");
                    await FlushEvents();
                    // Continue to next step if available
                    if (currentStepIndex < manifest.Steps.Count - 1)
                        currentStepIndex++;
                    else
                    {
                        showLeadForm = true;
                        return;
                    }
                    break;

                case NavigationAction.StartFlow:
                    if (step.NavigationTarget != null)
                    {
                        BufferEvent(EventType.DemoCompleted, null, $"{{\"nextFlow\":\"{step.NavigationTarget}\"}}");
                        await FlushEvents();
                        Nav.NavigateTo($"/demo/{step.NavigationTarget}", true);
                        return;
                    }
                    break;
            }
        }

        stepStartTime = DateTime.UtcNow;
        BufferEvent(EventType.StepViewed, currentStepIndex + 1, null);
        StateHasChanged();
    }

    private async Task PreviousStep()
    {
        if (currentStepIndex > 0)
        {
            try { await JS.InvokeVoidAsync("playerInterop.clearTrigger"); } catch { }
            currentStepIndex--;
            stepStartTime = DateTime.UtcNow;
            BufferEvent(EventType.StepViewed, currentStepIndex + 1, null);
            StateHasChanged();
        }
    }

    private async Task HandleClickZone(PlayerAnnotationDto annotation)
    {
        await NextStep();
    }

    private async Task HandleAnnotationNavigate(string direction)
    {
        if (direction == "next") await NextStep();
        else if (direction == "previous") await PreviousStep();
    }

    private void DismissEscapeView()
    {
        showEscapeView = false;
    }

    private void ExitDemo()
    {
        showEscapeView = false;
        BufferEvent(EventType.DemoCompleted, null, "{\"earlyExit\":true}");
        _ = FlushEvents();
        showLeadForm = true;
    }

    private static string GetBackdropStyle(string? level) => level switch
    {
        "light" => "background:rgba(0,0,0,0.15);",
        "medium" => "background:rgba(0,0,0,0.35);",
        "heavy" => "background:rgba(0,0,0,0.55);",
        _ => ""
    };

    private static string GetTriggerHint(PlayerStepDto step) => step.TriggerType switch
    {
        TriggerType.ElementClick => "Click the highlighted element to continue",
        TriggerType.TextInput => "Type in the highlighted field to continue",
        TriggerType.Timer => $"Auto-advancing in {(step.TriggerDurationMs ?? 0) / 1000}s...",
        _ => ""
    };

    private void BufferEvent(EventType type, int? stepNumber, string? data)
    {
        eventBuffer.Add(new SessionEventDto(type, stepNumber, data, DateTime.UtcNow));
    }

    private async Task FlushEvents()
    {
        if (eventBuffer.Count == 0) return;
        var batch = new EventBatchRequest(sessionId, null, [.. eventBuffer]);
        eventBuffer.Clear();
        var result = await PlayerApi.SendEventsAsync(Slug, batch);
        if (result.HasValue) sessionId = result.Value;
    }

    private async Task SubmitLead(LeadCaptureRequest request)
    {
        BufferEvent(EventType.LeadSubmitted, null, null);
        await FlushEvents();
        await PlayerApi.CaptureLead(Slug, request, sessionId);
        showLeadForm = false;
    }

    private void SkipLead()
    {
        showLeadForm = false;
    }

    public void Dispose()
    {
        flushTimer?.Dispose();
        dotnetRef?.Dispose();
        _ = FlushEvents();
    }
}
