@page "/settings"
@rendermode InteractiveServer
@inject HttpClient Http
@inject AuthService Auth
@inject NavigationManager Nav
@inject NotificationService Notification

<RadzenStack Gap="24px" Style="max-width:640px">
    <div>
        <h1 class="nt-page-title">Settings</h1>
        <p class="nt-page-subtitle">Manage your workspace and account</p>
    </div>

    @if (loading)
    {
        <RadzenStack AlignItems="AlignItems.Center" JustifyContent="JustifyContent.Center" Style="min-height:200px">
            <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
        </RadzenStack>
    }
    else
    {
        @* Workspace *@
        <div class="settings-card">
            <h3 class="settings-card-title">Workspace</h3>
            <RadzenStack Gap="16px">
                <RadzenFormField Text="Company Name" Style="width:100%">
                    <RadzenTextBox @bind-Value="companyName" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Workspace URL" Style="width:100%">
                    <RadzenTextBox Value="@workspaceSlug" Disabled="true" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Plan" Style="width:100%">
                    <RadzenTextBox Value="@plan" Disabled="true" Style="width:100%" />
                </RadzenFormField>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
                    <RadzenButton Text="Save Changes" ButtonStyle="ButtonStyle.Primary" Click="SaveWorkspace" IsBusy="saving" />
                </RadzenStack>
            </RadzenStack>
        </div>

        @* Account *@
        <div class="settings-card">
            <h3 class="settings-card-title">Account</h3>
            <RadzenStack Gap="16px">
                <RadzenFormField Text="Email" Style="width:100%">
                    <RadzenTextBox Value="@email" Disabled="true" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Full Name" Style="width:100%">
                    <RadzenTextBox @bind-Value="fullName" Style="width:100%" />
                </RadzenFormField>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="8px">
                    <RadzenButton Text="Update Profile" ButtonStyle="ButtonStyle.Primary" Click="SaveProfile" IsBusy="savingProfile" />
                </RadzenStack>
            </RadzenStack>
        </div>

        @* Lead Email *@
        <div class="settings-card">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" Style="margin-bottom:16px">
                <h3 class="settings-card-title" style="margin:0">Lead Notification Email</h3>
                <RadzenSwitch @bind-Value="leadEmailEnabled" Style="margin:0" />
            </RadzenStack>
            <p style="font-size:0.8125rem;color:var(--nt-text-secondary);margin:0 0 16px">
                Automatically send an email to leads after they submit their info at the end of a demo.
                Use <code>@("{{name}}")</code>, <code>@("{{email}}")</code>, <code>@("{{demo_name}}")</code> as variables.
            </p>
            <RadzenStack Gap="16px">
                <RadzenFormField Text="Subject" Style="width:100%">
                    <RadzenTextBox @bind-Value="leadEmailSubject" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Heading" Style="width:100%">
                    <RadzenTextBox @bind-Value="leadEmailHeading" Style="width:100%" />
                </RadzenFormField>
                <RadzenFormField Text="Body" Style="width:100%">
                    <RadzenTextArea @bind-Value="leadEmailBody" Rows="4" Style="width:100%" />
                </RadzenFormField>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="12px">
                    <RadzenFormField Text="CTA Button Text" Style="flex:1">
                        <RadzenTextBox @bind-Value="leadEmailCtaText" Style="width:100%" />
                    </RadzenFormField>
                    <RadzenFormField Text="CTA URL" Style="flex:1">
                        <RadzenTextBox @bind-Value="leadEmailCtaUrl" Placeholder="https://yoursite.com" Style="width:100%" />
                    </RadzenFormField>
                </RadzenStack>
                <RadzenFormField Text="Accent Color" Style="width:160px">
                    <RadzenColorPicker @bind-Value="leadEmailAccentColor" ShowHSV="false" ShowRGBA="false" ShowButton="false" Style="width:100%" />
                </RadzenFormField>
                <RadzenStack Orientation="Orientation.Horizontal" Gap="8px" AlignItems="AlignItems.Center">
                    <RadzenButton Text="Save" ButtonStyle="ButtonStyle.Primary" Click="SaveLeadEmail" IsBusy="savingLeadEmail" />
                    <RadzenButton Text="Send Test Email" ButtonStyle="ButtonStyle.Light" Click="SendTestLeadEmail" IsBusy="sendingTest" />
                    <RadzenButton Text="Preview" ButtonStyle="ButtonStyle.Info" Variant="Variant.Text" Click="@(() => showEmailPreview = !showEmailPreview)" />
                </RadzenStack>
            </RadzenStack>

            @if (showEmailPreview)
            {
                <div class="email-preview-container">
                    <div class="email-preview-label">Preview</div>
                    <div style="background:var(--nt-surface-subtle);padding:24px;border-radius:8px">
                        <div style="max-width:560px;margin:0 auto;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 4px 6px -1px rgba(0,0,0,0.07)">
                            <div style="height:4px;background:@leadEmailAccentColor"></div>
                            <div style="padding:32px 28px;text-align:center">
                                <div style="display:inline-block;width:40px;height:40px;background:@leadEmailAccentColor;border-radius:10px;line-height:40px;margin-bottom:20px">
                                    <span style="color:#fff;font-size:18px;font-weight:700">N</span>
                                </div>
                                <h2 style="color:var(--nt-text-primary);font-size:20px;font-weight:700;margin:0 0 12px">@ResolvePreview(leadEmailHeading)</h2>
                                <p style="color:var(--nt-neutral-600);font-size:14px;line-height:1.6;margin:0 0 8px;white-space:pre-line">@ResolvePreview(leadEmailBody)</p>
                                @if (!string.IsNullOrWhiteSpace(leadEmailCtaUrl))
                                {
                                    <div style="margin:24px 0 8px">
                                        <span style="display:inline-block;background:@leadEmailAccentColor;color:#fff;padding:12px 28px;border-radius:6px;font-size:14px;font-weight:600">@ResolvePreview(leadEmailCtaText)</span>
                                    </div>
                                }
                            </div>
                            <div style="background:#F8FAFC;padding:16px 28px;border-top:1px solid var(--nt-border)">
                                <p style="color:var(--nt-text-muted);font-size:11px;text-align:center;margin:0">You received this email because you explored a demo.</p>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        @* Danger Zone *@
        <div class="settings-card settings-danger">
            <h3 class="settings-card-title" style="color:#C62828">Danger Zone</h3>
            <p style="font-size:0.875rem;color:var(--nt-text-secondary);margin:0 0 12px">Permanently delete your workspace and all associated data. This action cannot be undone.</p>
            <RadzenButton Text="Delete Workspace" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Outlined" Size="ButtonSize.Small" />
        </div>
    }
</RadzenStack>

<style>
    .settings-card {
        background: var(--nt-surface);
        border: 1px solid var(--nt-border);
        border-radius: var(--nt-radius);
        padding: 24px;
        box-shadow: var(--nt-shadow-sm);
    }

    .settings-card-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--nt-text-primary);
        margin: 0 0 16px;
    }

    .settings-danger {
        border-color: #FECACA;
    }

    .email-preview-container {
        margin-top: 20px;
        border-top: 1px solid var(--nt-border);
        padding-top: 16px;
    }

    .email-preview-label {
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--nt-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 8px;
    }
</style>

@code {
    private string companyName = "";
    private string workspaceSlug = "";
    private string plan = "";
    private string email = "";
    private string fullName = "";
    private bool loading = true;
    private bool saving;
    private bool savingProfile;

    // Lead email template
    private string leadEmailSubject = "";
    private string leadEmailHeading = "";
    private string leadEmailBody = "";
    private string leadEmailCtaText = "";
    private string? leadEmailCtaUrl;
    private string leadEmailAccentColor = "#4361ee";
    private bool leadEmailEnabled = true;
    private bool savingLeadEmail;
    private bool sendingTest;
    private bool showEmailPreview;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await Auth.TryRestoreAsync();
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }

        try
        {
            var settings = await Http.GetFromJsonAsync<WorkspaceSettings>("api/v1/settings");
            if (settings != null)
            {
                companyName = settings.CompanyName;
                workspaceSlug = settings.Slug;
                plan = settings.Plan;
                email = settings.Email;
                fullName = settings.FullName;
            }
        }
        catch
        {
            // Settings endpoint may not exist yet — show empty state
        }

        try
        {
            var leadTemplate = await Http.GetFromJsonAsync<LeadEmailTemplateDto>("api/v1/settings/lead-email");
            if (leadTemplate != null)
            {
                leadEmailSubject = leadTemplate.Subject;
                leadEmailHeading = leadTemplate.Heading;
                leadEmailBody = leadTemplate.Body;
                leadEmailCtaText = leadTemplate.CtaText;
                leadEmailCtaUrl = leadTemplate.CtaUrl;
                leadEmailAccentColor = leadTemplate.AccentColor;
                leadEmailEnabled = leadTemplate.IsEnabled;
            }
        }
        catch { }

        loading = false;
        StateHasChanged();
    }

    private async Task SaveWorkspace()
    {
        saving = true;
        try
        {
            await Http.PutAsJsonAsync("api/v1/settings/workspace", new { Name = companyName });
            Notification.Notify(NotificationSeverity.Success, "Workspace updated");
        }
        catch
        {
            Notification.Notify(NotificationSeverity.Error, "Failed to save");
        }
        saving = false;
    }

    private async Task SaveProfile()
    {
        savingProfile = true;
        try
        {
            await Http.PutAsJsonAsync("api/v1/settings/profile", new { FullName = fullName });
            Notification.Notify(NotificationSeverity.Success, "Profile updated");
        }
        catch
        {
            Notification.Notify(NotificationSeverity.Error, "Failed to save");
        }
        savingProfile = false;
    }

    private async Task SaveLeadEmail()
    {
        savingLeadEmail = true;
        try
        {
            await Http.PutAsJsonAsync("api/v1/settings/lead-email", new
            {
                Subject = leadEmailSubject,
                Heading = leadEmailHeading,
                Body = leadEmailBody,
                CtaText = leadEmailCtaText,
                CtaUrl = leadEmailCtaUrl,
                AccentColor = leadEmailAccentColor,
                IsEnabled = leadEmailEnabled
            });
            Notification.Notify(NotificationSeverity.Success, "Lead email template saved");
        }
        catch
        {
            Notification.Notify(NotificationSeverity.Error, "Failed to save template");
        }
        savingLeadEmail = false;
    }

    private async Task SendTestLeadEmail()
    {
        sendingTest = true;
        try
        {
            // Save first so the test uses latest values
            await Http.PutAsJsonAsync("api/v1/settings/lead-email", new
            {
                Subject = leadEmailSubject,
                Heading = leadEmailHeading,
                Body = leadEmailBody,
                CtaText = leadEmailCtaText,
                CtaUrl = leadEmailCtaUrl,
                AccentColor = leadEmailAccentColor,
                IsEnabled = leadEmailEnabled
            });
            var response = await Http.PostAsync("api/v1/settings/lead-email/test", null);
            if (response.IsSuccessStatusCode)
                Notification.Notify(NotificationSeverity.Success, "Test email sent", $"Check {email}");
            else
                Notification.Notify(NotificationSeverity.Error, "Failed to send test email");
        }
        catch
        {
            Notification.Notify(NotificationSeverity.Error, "Failed to send test email");
        }
        sendingTest = false;
    }

    private string ResolvePreview(string text) => text
        .Replace("{{name}}", "Jane")
        .Replace("{{email}}", "jane@example.com")
        .Replace("{{demo_name}}", "Product Tour")
        .Replace("{{company}}", "Acme Inc");

    private record WorkspaceSettings(string CompanyName, string Slug, string Plan, string Email, string FullName);
    private record LeadEmailTemplateDto(string Subject, string Heading, string Body, string CtaText, string? CtaUrl, string AccentColor, bool IsEnabled);
}
