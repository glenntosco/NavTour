@page "/get-started"
@rendermode InteractiveServer
@layout Layout.OnboardingLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject HttpClient Http

<div class="gs-container">
    <h1 class="gs-title">Get started with NavTour</h1>
    <p class="gs-subtitle">Create your first interactive demo in minutes</p>

    <div class="gs-cards">
        @* Card 1 — Get extension (FEATURED) *@
        <div class="gs-card gs-card-featured gs-card-anim" style="animation-delay: 0ms;">
            <span class="gs-badge">1</span>
            <div class="gs-card-icon">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="4" y="8" width="40" height="28" rx="4" fill="#EEF1FF" stroke="#4361ee" stroke-width="2"/>
                    <path d="M24 36V42" stroke="#4361ee" stroke-width="2" stroke-linecap="round"/>
                    <path d="M18 42H30" stroke="#4361ee" stroke-width="2" stroke-linecap="round"/>
                    <path d="M20 18L18 22H22L20 26" stroke="#4361ee" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    <rect x="26" y="17" width="8" height="8" rx="2" fill="#EEF1FF" stroke="#4361ee" stroke-width="1.5"/>
                    <circle cx="30" cy="21" r="1.5" fill="#4361ee"/>
                </svg>
            </div>
            <h3 class="gs-card-title">Get extension</h3>
            <p class="gs-card-desc">We recommend the Chrome extension. Capture any web page with one click.</p>
            <a href="https://chromewebstore.google.com/detail/navtour-capture/opgaokkionehglmipncajghhlmohanoi"
               target="_blank"
               rel="noopener noreferrer"
               class="gs-btn gs-btn-primary">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.5"/>
                    <path d="M7 4V10M4 7H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
                Add to Chrome
            </a>
        </div>

        @* Card 2 — Create a demo *@
        <div class="gs-card gs-card-anim" style="animation-delay: 80ms;">
            <span class="gs-badge">2</span>
            <div class="gs-card-icon">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="6" y="8" width="36" height="28" rx="4" fill="#EEF1FF" stroke="#4361ee" stroke-width="2"/>
                    <path d="M6 16H42" stroke="#4361ee" stroke-width="2"/>
                    <circle cx="12" cy="12" r="1.5" fill="#4361ee"/>
                    <circle cx="17" cy="12" r="1.5" fill="#4361ee"/>
                    <circle cx="22" cy="12" r="1.5" fill="#4361ee"/>
                    <rect x="12" y="22" width="10" height="2" rx="1" fill="#4361ee" opacity="0.5"/>
                    <rect x="12" y="27" width="16" height="2" rx="1" fill="#4361ee" opacity="0.3"/>
                    <path d="M34 22L30 26L34 30" stroke="#4361ee" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M24 40L30 44L36 40" stroke="#4361ee" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <h3 class="gs-card-title">Create a demo</h3>
            <p class="gs-card-desc">Capture pages from your product, then build guided tours in the editor.</p>
            <a href="/dashboard"
               class="gs-btn gs-btn-secondary"
               @onclick="CompleteOnboarding"
               @onclick:preventDefault="false">
                Open editor
            </a>
        </div>

        @* Card 3 — Share your demo *@
        <div class="gs-card gs-card-anim" style="animation-delay: 160ms;">
            <span class="gs-badge">3</span>
            <div class="gs-card-icon">
                <svg width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="16" cy="24" r="5" fill="#EEF1FF" stroke="#4361ee" stroke-width="2"/>
                    <circle cx="36" cy="14" r="5" fill="#EEF1FF" stroke="#4361ee" stroke-width="2"/>
                    <circle cx="36" cy="34" r="5" fill="#EEF1FF" stroke="#4361ee" stroke-width="2"/>
                    <path d="M20.5 21.5L31.5 16.5" stroke="#4361ee" stroke-width="2" stroke-linecap="round"/>
                    <path d="M20.5 26.5L31.5 31.5" stroke="#4361ee" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
            <h3 class="gs-card-title">Share your demo</h3>
            <p class="gs-card-desc">Share via link or embed anywhere — with built-in tracking and insights.</p>
            <a href="/dashboard"
               class="gs-btn gs-btn-secondary"
               @onclick="CompleteOnboarding"
               @onclick:preventDefault="false">
                Learn more
            </a>
        </div>
    </div>
</div>

@code {
    private async Task CompleteOnboarding()
    {
        try { await Http.PostAsync("api/v1/auth/complete-onboarding", null); } catch { }
    }
}

<style>
    .gs-container {
        text-align: center;
        width: 100%;
        max-width: 960px;
    }

    .gs-title {
        font-size: 2rem;
        font-weight: 700;
        color: #0B1929;
        margin: 0 0 12px;
        line-height: 1.2;
        letter-spacing: -0.02em;
    }

    .gs-subtitle {
        font-size: 1.0625rem;
        color: #64748B;
        font-weight: 400;
        line-height: 1.6;
        margin: 0 0 48px;
    }

    /* Cards grid */
    .gs-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .gs-card {
        position: relative;
        background: #fff;
        border: 1px solid #E2E8F0;
        border-radius: 12px;
        padding: 32px 24px 28px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        transition: transform 250ms ease, box-shadow 250ms ease;
        box-shadow: 0 1px 3px rgba(11, 25, 41, 0.08), 0 1px 2px rgba(11, 25, 41, 0.04);
    }

    .gs-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(11, 25, 41, 0.10), 0 2px 4px rgba(11, 25, 41, 0.06);
    }

    /* Featured card */
    .gs-card-featured {
        border-color: #A5B4FC;
        box-shadow: 0 0 0 1px rgba(67, 97, 238, 0.12), 0 4px 16px rgba(67, 97, 238, 0.10);
    }

    .gs-card-featured:hover {
        box-shadow: 0 0 0 1px rgba(67, 97, 238, 0.18), 0 8px 24px rgba(67, 97, 238, 0.14);
    }

    /* Badge */
    .gs-badge {
        position: absolute;
        top: -12px;
        left: -12px;
        width: 28px;
        height: 28px;
        background: #4361ee;
        color: #fff;
        font-size: 0.8125rem;
        font-weight: 700;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(67, 97, 238, 0.3);
        line-height: 1;
    }

    /* Icon */
    .gs-card-icon {
        margin-bottom: 20px;
    }

    /* Card title */
    .gs-card-title {
        font-size: 1.125rem;
        font-weight: 600;
        color: #0B1929;
        margin: 0 0 8px;
        line-height: 1.3;
    }

    /* Card description */
    .gs-card-desc {
        font-size: 0.875rem;
        color: #64748B;
        line-height: 1.6;
        margin: 0 0 24px;
        flex: 1;
    }

    /* Buttons */
    .gs-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 24px;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: background 200ms ease, box-shadow 200ms ease, transform 150ms ease;
    }

    .gs-btn-primary {
        background: #4361ee;
        color: #fff;
    }

    .gs-btn-primary:hover {
        background: #3451d1;
        box-shadow: 0 2px 8px rgba(67, 97, 238, 0.3);
    }

    .gs-btn-secondary {
        background: #F1F5F9;
        color: #334155;
    }

    .gs-btn-secondary:hover {
        background: #E2E8F0;
        box-shadow: 0 1px 4px rgba(11, 25, 41, 0.08);
    }

    /* Entrance animation */
    .gs-card-anim {
        animation: gs-fade-up 500ms cubic-bezier(0.1, 0.9, 0.2, 1) both;
    }

    @@keyframes gs-fade-up {
        from {
            opacity: 0;
            transform: translateY(16px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Responsive: tablet */
    @@media (max-width: 1024px) and (min-width: 769px) {
        .gs-cards {
            gap: 16px;
        }

        .gs-card {
            padding: 28px 20px 24px;
        }
    }

    /* Responsive: mobile */
    @@media (max-width: 768px) {
        .gs-title {
            font-size: 1.5rem;
        }

        .gs-subtitle {
            margin-bottom: 36px;
        }

        .gs-cards {
            grid-template-columns: 1fr;
            max-width: 360px;
            margin: 0 auto;
        }
    }

    /* Reduced motion */
    @@media (prefers-reduced-motion: reduce) {
        .gs-card-anim {
            animation: none;
            opacity: 1;
            transform: none;
        }

        .gs-card {
            transition: none;
        }
    }
</style>
