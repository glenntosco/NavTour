@page "/dashboard"
@rendermode InteractiveServer
@inject AuthService Auth
@inject DemoApiService DemoApi
@inject NavigationManager Nav
@inject DialogService Dialog

@if (loading)
{
    <RadzenStack AlignItems="AlignItems.Center" Style="margin:100px auto">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else if (!Auth.IsAuthenticated)
{
    <RadzenStack Gap="24px" Style="max-width:600px;margin:60px auto;text-align:center">
        <img src="favicon.svg" alt="NavTour" style="height:48px;width:auto" />
        <RadzenText TextStyle="TextStyle.H6" Style="color:var(--rz-text-secondary-color)">
            Create interactive product demos that convert prospects into customers.
        </RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="12px" JustifyContent="JustifyContent.Center">
            <RadzenButton Text="Sign In" ButtonStyle="ButtonStyle.Primary" Click='() => Nav.NavigateTo("/login")' />
            <RadzenButton Text="Get Started Free" ButtonStyle="ButtonStyle.Secondary" Click='() => Nav.NavigateTo("/register")' />
        </RadzenStack>
    </RadzenStack>
}
else
{
    <div class="dash">
        @* Header *@
        <div class="nt-page-header">
            <div>
                <h1 class="nt-page-title">Product Demos</h1>
                <p class="nt-page-subtitle">@demos.Count demo@(demos.Count != 1 ? "s" : "") in your workspace</p>
            </div>
            <button class="nt-btn-primary" @onclick="CreateNewDemo">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Create Demo
            </button>
        </div>

        @* Search *@
        <div class="dash-search">
            <svg class="dash-search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <RadzenTextBox Placeholder="Search demos..." @bind-Value="searchText" Change="@OnSearchChanged" Style="flex:1;border:none;box-shadow:none;background:transparent;font-size:0.875rem" />
        </div>

        @if (filteredDemos.Count == 0 && demos.Count > 0)
        {
            <div class="dash-empty">
                <p>No demos match "<strong>@searchText</strong>"</p>
            </div>
        }
        else if (demos.Count == 0)
        {
            <div class="nt-empty">
                <div class="nt-empty-icon">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                    </svg>
                </div>
                <h3>No demos yet</h3>
                <p>Create your first interactive demo to start converting prospects.</p>
                <button class="nt-btn-primary" @onclick="CreateNewDemo">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Create Demo
                </button>
            </div>
        }
        else
        {
            <div class="dash-grid">
                @foreach (var demo in filteredDemos)
                {
                    <div class="dash-card" @onclick='() => Nav.NavigateTo($"/demos/{demo.Id}/edit")'>
                        <div class="dash-card-preview">
                            <div class="dash-card-preview-inner">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
                                </svg>
                                <span>@demo.FrameCount frames</span>
                            </div>
                        </div>
                        <div class="dash-card-info">
                            <div class="dash-card-row">
                                <span class="dash-card-name">@demo.Name</span>
                                <span class="nt-badge @(demo.Status == DemoStatus.Published ? "nt-badge-live" : "nt-badge-draft")">
                                    @(demo.Status == DemoStatus.Published ? "Live" : "Draft")
                                </span>
                            </div>
                            <div class="dash-card-meta">
                                <span>@demo.FrameCount frames</span>
                                <span class="dash-dot"></span>
                                <span>@demo.ViewCount views</span>
                                <span class="dash-dot"></span>
                                <span>@demo.StepCount steps</span>
                            </div>
                            <div class="dash-card-actions" @onclick:stopPropagation="true">
                                <button class="dash-action-btn" @onclick='() => Nav.NavigateTo($"/demos/{demo.Id}/edit")'>Edit</button>
                                <button class="dash-action-btn dash-action-secondary" @onclick='() => Nav.NavigateTo($"/demos/{demo.Id}/analytics")'>Analytics</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @* Tips card *@
        @if (demos.Count < 5)
        {
            <div class="dash-tips">
                <div class="dash-tips-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
                    </svg>
                </div>
                <div>
                    <strong>Getting started</strong>
                    <p>Install the Chrome extension to capture pages from your product, then build guided tours in the editor.</p>
                </div>
            </div>
        }
    </div>
}

<style>
    .dash {
        max-width: 960px;
        margin: 0 auto;
        padding: 4px 0 32px;
    }

    /* Search */
    .dash-search {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0 14px;
        background: var(--nt-surface);
        border: 1px solid var(--nt-border);
        border-radius: var(--nt-radius);
        margin-bottom: 24px;
        transition: border-color 150ms, box-shadow 150ms;
    }

    .dash-search:focus-within {
        border-color: var(--nt-action);
        box-shadow: 0 0 0 3px var(--nt-action-light);
    }

    .dash-search-icon { color: var(--nt-text-faint); flex-shrink: 0; }

    /* Grid */
    .dash-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
    }

    /* Card */
    .dash-card {
        background: var(--nt-surface);
        border: 1px solid var(--nt-border);
        border-radius: 10px;
        overflow: hidden;
        cursor: pointer;
        transition: border-color var(--nt-transition), box-shadow var(--nt-transition),
                    transform var(--nt-transition);
    }

    .dash-card:hover {
        border-color: var(--nt-border-hover);
        box-shadow: var(--nt-shadow-lg);
        transform: translateY(-3px);
    }

    .dash-card-preview {
        height: 160px;
        background: linear-gradient(145deg, var(--nt-surface-subtle) 0%, #EEF2F7 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        border-bottom: 1px solid var(--nt-surface-muted);
    }

    .dash-card-preview-inner {
        display: flex; flex-direction: column; align-items: center;
        gap: 8px; color: var(--nt-text-faint);
    }

    .dash-card-preview-inner span {
        font-size: 0.75rem; font-weight: 500; letter-spacing: 0.02em;
    }

    .dash-card-info { padding: 16px 20px 20px; }

    .dash-card-row {
        display: flex; align-items: center; gap: 10px; margin-bottom: 6px;
    }

    .dash-card-name {
        font-size: 0.9375rem; font-weight: 600;
        color: var(--nt-text-primary); letter-spacing: -0.01em;
    }

    .dash-card-meta {
        display: flex; align-items: center; gap: 6px;
        font-size: 0.75rem; color: var(--nt-text-faint); margin-bottom: 14px;
    }

    .dash-dot {
        width: 3px; height: 3px; border-radius: 50%; background: var(--nt-border-hover);
    }

    .dash-card-actions { display: flex; gap: 8px; }

    .dash-action-btn {
        padding: 6px 16px; font-size: 0.75rem; font-weight: 600;
        border-radius: 6px; cursor: pointer; font-family: inherit;
        transition: background 150ms;
        background: var(--nt-surface-muted); color: var(--nt-navy); border: none;
    }
    .dash-action-btn:hover { background: var(--nt-border); }

    .dash-action-secondary { background: transparent; color: var(--nt-action); }
    .dash-action-secondary:hover { background: var(--nt-accent-light); }

    /* No-match empty */
    .dash-empty {
        text-align: center; padding: 48px 24px;
        color: var(--nt-text-muted); font-size: 0.875rem;
    }

    /* Tips card */
    .dash-tips {
        display: flex; gap: 14px; align-items: flex-start;
        margin-top: 28px; padding: 16px 20px;
        background: var(--nt-surface-subtle);
        border: 1px solid var(--nt-border); border-radius: 10px;
    }

    .dash-tips-icon { flex-shrink: 0; color: var(--nt-action); margin-top: 1px; }

    .dash-tips strong {
        display: block; font-size: 0.8125rem; font-weight: 600;
        color: var(--nt-text-primary); margin-bottom: 2px;
    }

    .dash-tips p {
        font-size: 0.8125rem; color: var(--nt-text-muted);
        margin: 0; line-height: 1.5;
    }
</style>

@code {
    private List<DemoListItemResponse> demos = [];
    private List<DemoListItemResponse> filteredDemos = [];
    private bool loading = true;
    private string searchText = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.TryRestoreAsync();
            if (Auth.IsAuthenticated)
            {
                demos = await DemoApi.GetDemosAsync();
                filteredDemos = demos;
            }
            loading = false;
            StateHasChanged();
        }
    }

    private void OnSearchChanged()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredDemos = demos;
        }
        else
        {
            filteredDemos = demos.Where(d => d.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private async Task CreateNewDemo()
    {
        var result = await Dialog.OpenAsync<CreateDemoDialog>("New Demo Name");
        if (result is string demoName && !string.IsNullOrWhiteSpace(demoName))
        {
            var demo = await DemoApi.CreateDemoAsync(new CreateDemoRequest(demoName, null));
            if (demo != null)
                Nav.NavigateTo($"/demos/{demo.Id}/edit");
        }
    }
}
