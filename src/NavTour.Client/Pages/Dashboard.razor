@page "/dashboard"
@rendermode InteractiveServer
@inject AuthService Auth
@inject DemoApiService DemoApi
@inject NavigationManager Nav
@inject DialogService Dialog

@if (loading)
{
    <RadzenStack AlignItems="AlignItems.Center" Style="margin:100px auto">
        <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    </RadzenStack>
}
else if (!Auth.IsAuthenticated)
{
    <RadzenStack Gap="24px" Style="max-width:600px;margin:60px auto;text-align:center">
        <img src="favicon.svg" alt="NavTour" style="height:48px;width:auto" />
        <RadzenText TextStyle="TextStyle.H6" Style="color:var(--rz-text-secondary-color)">
            Create interactive product demos that convert prospects into customers.
        </RadzenText>
        <RadzenStack Orientation="Orientation.Horizontal" Gap="12px" JustifyContent="JustifyContent.Center">
            <RadzenButton Text="Sign In" ButtonStyle="ButtonStyle.Primary" Click='() => Nav.NavigateTo("/login")' />
            <RadzenButton Text="Get Started Free" ButtonStyle="ButtonStyle.Secondary" Click='() => Nav.NavigateTo("/register")' />
        </RadzenStack>
    </RadzenStack>
}
else
{
    <RadzenStack Gap="24px">
        @* Header: Title + Create button *@
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
            <RadzenText TextStyle="TextStyle.H4" Style="margin:0;font-weight:700">
                Product Demos <span style="font-weight:400;color:var(--rz-text-secondary-color)">(@demos.Count)</span>
            </RadzenText>
            <RadzenButton Text="+ Create Demo" ButtonStyle="ButtonStyle.Secondary" Click="CreateNewDemo" />
        </RadzenStack>

        @* Search bar *@
        <div class="demo-search-bar">
            <RadzenIcon Icon="search" Style="color:var(--rz-text-secondary-color)" />
            <RadzenTextBox Placeholder="Search demos..." @bind-Value="searchText" Change="@OnSearchChanged" Style="flex:1;max-width:400px" />
        </div>

        @if (filteredDemos.Count == 0 && demos.Count > 0)
        {
            <RadzenCard Style="text-align:center;padding:40px">
                <RadzenText TextStyle="TextStyle.H6" Style="color:var(--rz-text-secondary-color)">No demos match your search</RadzenText>
            </RadzenCard>
        }
        else if (demos.Count == 0)
        {
            <RadzenCard Style="text-align:center;padding:60px">
                <RadzenIcon Icon="apps" Style="font-size:3rem;color:var(--rz-text-secondary-color);margin-bottom:16px" />
                <RadzenText TextStyle="TextStyle.H5" Style="margin-bottom:8px">No demos yet</RadzenText>
                <RadzenText Style="color:var(--rz-text-secondary-color);margin-bottom:24px">Create your first interactive demo to get started.</RadzenText>
                <RadzenButton Text="+ Create Demo" ButtonStyle="ButtonStyle.Secondary" Click="CreateNewDemo" />
            </RadzenCard>
        }
        else
        {
            @* Demo cards grid *@
            <div class="demo-cards-grid">
                @foreach (var demo in filteredDemos)
                {
                    <div class="demo-card" @onclick='() => Nav.NavigateTo($"/demos/{demo.Id}/edit")'>
                        <div class="demo-card-thumbnail">
                            <span>Demo Preview</span>
                        </div>
                        <div class="demo-card-body">
                            <div style="display:flex;align-items:center;gap:8px;margin-bottom:8px">
                                <span class="demo-card-name">@demo.Name</span>
                                <span class="demo-status-badge @(demo.Status == DemoStatus.Published ? "demo-status-published" : "demo-status-draft")">
                                    @demo.Status.ToString()
                                </span>
                            </div>
                            <div class="demo-card-meta">
                                <span>@demo.FrameCount frames</span>
                                <span>&middot;</span>
                                <span>@demo.ViewCount views</span>
                            </div>
                            <div class="demo-card-actions">
                                <RadzenButton Text="Edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small"
                                    Click='() => Nav.NavigateTo($"/demos/{demo.Id}/edit")' />
                                <RadzenButton Text="Analytics" ButtonStyle="ButtonStyle.Info" Variant="Variant.Text" Size="ButtonSize.Small"
                                    Click='() => Nav.NavigateTo($"/demos/{demo.Id}/analytics")' />
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        @* Get started section for new users *@
        @if (demos.Count < 3)
        {
            <RadzenCard Style="background:linear-gradient(135deg, #F8FAFC 0%, #EEF2F7 100%);border:1px solid #E2E8F0;margin-top:8px">
                <RadzenStack Gap="8px">
                    <RadzenText TextStyle="TextStyle.H6" Style="margin:0;font-weight:600">Get started with NavTour</RadzenText>
                    <RadzenText Style="color:var(--rz-text-secondary-color);margin:0">
                        Best practices for creating interactive demos that convert prospects into customers.
                    </RadzenText>
                    <RadzenLink Path="https://navtour.com/docs" Text="Explore docs" Style="font-weight:500" />
                </RadzenStack>
            </RadzenCard>
        }
    </RadzenStack>
}

@code {
    private List<DemoListItemResponse> demos = [];
    private List<DemoListItemResponse> filteredDemos = [];
    private bool loading = true;
    private string searchText = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Auth.TryRestoreAsync();
            if (Auth.IsAuthenticated)
            {
                demos = await DemoApi.GetDemosAsync();
                filteredDemos = demos;
            }
            loading = false;
            StateHasChanged();
        }
    }

    private void OnSearchChanged()
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            filteredDemos = demos;
        }
        else
        {
            filteredDemos = demos.Where(d => d.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private async Task CreateNewDemo()
    {
        var result = await Dialog.OpenAsync<CreateDemoDialog>("New Demo Name");
        if (result is string demoName && !string.IsNullOrWhiteSpace(demoName))
        {
            var demo = await DemoApi.CreateDemoAsync(new CreateDemoRequest(demoName, null));
            if (demo != null)
                Nav.NavigateTo($"/demos/{demo.Id}/edit");
        }
    }
}
