@inherits LayoutComponentBase
@using Syncfusion.Blazor.Navigations
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<div id="wrapper">
    <SfSidebar @ref="sidebarObj" Width="250px" DockSize="72px" EnableDock="true"
               @bind-IsOpen="sidebarExpanded" MediaQuery="(min-width: 600px)">
        <ChildContent>
            <div class="sidebar-header">
                <a href="/dashboard" class="sidebar-logo-link">
                    @if (sidebarExpanded)
                    {
                        <img src="images/NavTourNoTag.webp" alt="NavTour" class="sidebar-logo" />
                    }
                    else
                    {
                        <img src="favicon.svg" alt="N" style="height:28px;width:28px" />
                    }
                </a>
            </div>
            <nav class="sidebar-nav">
                <a href="/dashboard" class="nav-link @ActiveClass("/dashboard")">
                    <span class="material-icons nav-icon">apps</span>
                    <span class="nav-label">Product Demos</span>
                </a>
                <div class="nav-divider">Analyze</div>
                <a href="/analytics" class="nav-link @ActiveClass("/analytics")">
                    <span class="material-icons nav-icon">bar_chart</span>
                    <span class="nav-label">Analytics</span>
                </a>
                <div class="nav-divider">Leads</div>
                <a href="/leads" class="nav-link @ActiveClass("/leads")">
                    <span class="material-icons nav-icon">people</span>
                    <span class="nav-label">Leads</span>
                </a>
                <div class="nav-divider">Manage</div>
                <a href="/team" class="nav-link @ActiveClass("/team")">
                    <span class="material-icons nav-icon">group</span>
                    <span class="nav-label">Team</span>
                </a>
                <a href="/settings" class="nav-link @ActiveClass("/settings")">
                    <span class="material-icons nav-icon">settings</span>
                    <span class="nav-label">Settings</span>
                </a>
            </nav>
            @if (Auth.IsAuthenticated)
            {
                <div class="sidebar-footer">
                    <a @onclick="Logout" @onclick:preventDefault href="#" class="nav-link">
                        <span class="material-icons nav-icon">logout</span>
                        <span class="nav-label">Logout</span>
                    </a>
                    @if (sidebarExpanded)
                    {
                        <div class="sidebar-version">v@(AppVersion)</div>
                    }
                </div>
            }
        </ChildContent>
    </SfSidebar>

    <div class="main-content-area">
        <div class="app-toolbar">
            <button class="toolbar-toggle" @onclick="ToggleSidebar">
                <span class="e-icons e-menu"></span>
            </button>
            <span class="toolbar-breadcrumb">@GetBreadcrumb()</span>
        </div>
        <div class="page-content @(IsEditorPage ? "" : "padded")">
            @Body
        </div>
    </div>
</div>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

<style>
    #wrapper {
        display: flex;
        height: 100vh;
        overflow: hidden;
    }

    /* Sidebar */
    .e-sidebar {
        display: flex !important;
        flex-direction: column !important;
    }

    .sidebar-header {
        padding: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 56px;
    }
    .sidebar-logo-link { display: flex; align-items: center; text-decoration: none; }
    .sidebar-logo { height: 28px; width: auto; }

    .sidebar-nav {
        flex: 1;
        overflow-y: auto;
        padding: 4px 0;
    }

    .nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 20px;
        color: #424242;
        text-decoration: none;
        font-size: 14px;
        font-weight: 500;
        border-radius: 8px;
        margin: 2px 12px;
        white-space: nowrap;
        overflow: hidden;
        transition: background 0.15s, color 0.15s;
    }
    .nav-link:hover { background: #f5f5f5; color: #1a1a1a; }
    .nav-link.active { background: #e8eafd; color: #4361ee; font-weight: 600; }
    .nav-icon { font-size: 20px; flex-shrink: 0; color: #616161; }
    .nav-link.active .nav-icon { color: #4361ee; }

    .nav-divider {
        padding: 16px 20px 6px;
        font-size: 11px;
        font-weight: 700;
        color: #9e9e9e;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
        overflow: hidden;
    }

    /* Docked (icon-only) mode */
    .e-dock.e-close .nav-label { display: none; }
    .e-dock.e-close .nav-link {
        justify-content: center;
        padding: 12px;
        margin: 2px 8px;
        gap: 0;
    }
    .e-dock.e-close .nav-divider { display: none; }

    .sidebar-footer {
        border-top: 1px solid #e0e0e0;
        padding: 8px 0 12px;
    }
    .sidebar-version {
        text-align: center;
        font-size: 11px;
        color: #9e9e9e;
        padding-top: 4px;
    }

    /* Main content */
    .main-content-area {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        min-width: 0;
    }

    .app-toolbar {
        border-bottom: 1px solid #e5e7eb;
        background: #fff;
        height: 48px;
        display: flex;
        align-items: center;
        padding: 0 12px;
        gap: 8px;
        flex-shrink: 0;
    }
    .toolbar-toggle {
        background: none;
        border: none;
        cursor: pointer;
        padding: 8px;
        border-radius: 6px;
        color: #424242;
        display: flex;
        align-items: center;
    }
    .toolbar-toggle:hover { background: #f5f5f5; }
    .toolbar-breadcrumb {
        font-size: 0.875rem;
        color: #64748B;
        font-weight: 500;
    }

    .page-content {
        flex: 1;
        overflow-y: auto;
    }
    .page-content.padded { padding: 16px; }
</style>

@code {
    private SfSidebar? sidebarObj;
    private bool sidebarExpanded = true;
    private bool _restored;

    private static string AppVersion =>
        typeof(MainLayout).Assembly.GetName().Version?.ToString(3) ?? "0.0.0";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_restored)
        {
            _restored = true;
            await Auth.TryRestoreAsync();
            StateHasChanged();
        }
    }

    private async Task ToggleSidebar()
    {
        sidebarExpanded = !sidebarExpanded;
        await JS.InvokeVoidAsync("sidebarToggle.toggle", sidebarExpanded);
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    private string ActiveClass(string path) =>
        Nav.Uri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    private bool IsEditorPage => Nav.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

    private string GetBreadcrumb()
    {
        var uri = Nav.Uri;
        if (uri.Contains("/dashboard", StringComparison.OrdinalIgnoreCase)) return "Product Demos";
        if (uri.Contains("/analytics", StringComparison.OrdinalIgnoreCase)) return "Analytics";
        if (uri.Contains("/leads", StringComparison.OrdinalIgnoreCase)) return "Leads";
        if (uri.Contains("/team", StringComparison.OrdinalIgnoreCase)) return "Team";
        if (uri.Contains("/settings", StringComparison.OrdinalIgnoreCase)) return "Settings";
        if (uri.Contains("/demos/", StringComparison.OrdinalIgnoreCase) && uri.Contains("/edit", StringComparison.OrdinalIgnoreCase)) return "Product Demos / Edit Demo";
        if (uri.Contains("/demos/", StringComparison.OrdinalIgnoreCase) && uri.Contains("/analytics", StringComparison.OrdinalIgnoreCase)) return "Product Demos / Analytics";
        return "NavTour";
    }
}
