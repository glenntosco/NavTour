@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav

<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>

<div class="app-shell">
    <aside class="sidebar">
        <div class="sidebar-logo">
            <a href="/dashboard">
                <img src="favicon.svg" alt="NavTour" />
                <span class="sidebar-wordmark">NavTour</span>
            </a>
        </div>
        <nav class="sidebar-nav">
            <a href="/dashboard" class="nav-item @ActiveClass("/dashboard")">
                <svg class="nav-icon" viewBox="0 0 24 24"><path d="M4 8h4V4H4v4zm6 12h4v-4h-4v4zm-6 0h4v-4H4v4zm0-6h4v-4H4v4zm6 0h4v-4h-4v4zm6-10v4h4V4h-4zm-6 4h4V4h-4v4zm6 6h4v-4h-4v4zm0 6h4v-4h-4v4z"/></svg>
                <span>Product Demos</span>
            </a>
            <div class="nav-group">Analyze</div>
            <a href="/analytics" class="nav-item @ActiveClass("/analytics")">
                <svg class="nav-icon" viewBox="0 0 24 24"><path d="M5 9.2h3V19H5zM10.6 5h2.8v14h-2.8zm5.6 8H19v6h-2.8z"/></svg>
                <span>Analytics</span>
            </a>
            <div class="nav-group">Capture</div>
            <a href="/leads" class="nav-item @ActiveClass("/leads")">
                <svg class="nav-icon" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
                <span>Leads</span>
            </a>
            <a href="/forms" class="nav-item @ActiveClass("/forms")">
                <svg class="nav-icon" viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm-1 7V3.5L18.5 9H13zM7 17h5v-2H7v2zm10-4H7v-2h10v2z"/></svg>
                <span>Forms</span>
            </a>
            <div class="nav-group">Manage</div>
            <a href="/team" class="nav-item @ActiveClass("/team")">
                <svg class="nav-icon" viewBox="0 0 24 24"><path d="M12 12.75c1.63 0 3.07.39 4.24.9 1.08.48 1.76 1.56 1.76 2.73V18H6v-1.61c0-1.18.68-2.26 1.76-2.73 1.17-.52 2.61-.91 4.24-.91zM4 13c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm1.13 1.1c-.37-.06-.74-.1-1.13-.1-.99 0-1.93.21-2.78.58C.48 14.9 0 15.62 0 16.43V18h4.5v-1.61c0-.83.23-1.61.63-2.29zM20 13c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm4 3.43c0-.81-.48-1.53-1.22-1.85-.85-.37-1.79-.58-2.78-.58-.39 0-.76.04-1.13.1.4.68.63 1.46.63 2.29V18H24v-1.57zM12 6c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3z"/></svg>
                <span>Team</span>
            </a>
            <a href="/settings" class="nav-item @ActiveClass("/settings")">
                <svg class="nav-icon" viewBox="0 0 24 24"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/></svg>
                <span>Settings</span>
            </a>
        </nav>
        <div class="sidebar-bottom">
            @if (Auth.IsAuthenticated)
            {
                <div class="sidebar-user">
                    <div class="sidebar-avatar">@(Auth.UserEmail?.Substring(0, 1).ToUpper())</div>
                    <span class="sidebar-email" title="@Auth.UserEmail">@Auth.UserEmail</span>
                </div>
                <a href="/login" onclick="document.cookie='navtour_auth=;path=/;expires=Thu, 01 Jan 1970 00:00:00 GMT'" class="nav-item">
                    <svg class="nav-icon" viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>
                    <span>Sign out</span>
                </a>
            }
            <div class="sidebar-ver">v@(AppVersion)</div>
        </div>
    </aside>
    <main class="main-area">
        <header class="top-bar">
            <span class="breadcrumb">@GetBreadcrumb()</span>
        </header>
        <div class="content @(IsEditorPage ? "" : "padded")">
            @Body
        </div>
    </main>
</div>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

<style>
    .app-shell { display:flex; height:100vh; overflow:hidden; }

    .sidebar {
        width:232px; flex-shrink:0; background:var(--nt-surface-secondary);
        border-right:1px solid var(--nt-border); display:flex; flex-direction:column;
    }

    .sidebar-logo { padding:16px 20px; border-bottom:1px solid var(--nt-border); }
    .sidebar-logo a {
        display:flex; align-items:center; gap:10px; text-decoration:none;
    }
    .sidebar-logo img { height:28px; width:28px; }
    .sidebar-wordmark {
        font-size:1.0625rem; font-weight:700; color:var(--nt-navy);
        letter-spacing:-0.03em;
    }

    .sidebar-nav { flex:1; overflow-y:auto; padding:16px 0 8px; }

    .nav-item {
        display:flex; align-items:center; gap:10px; padding:8px 14px;
        color:var(--nt-text-secondary); text-decoration:none;
        font-size:0.8125rem; font-weight:500;
        border-radius:6px; margin:1px 10px;
        transition:background 150ms, color 150ms;
    }
    .nav-item:hover { background:var(--nt-surface-muted); color:var(--nt-text-primary); }
    .nav-item:hover .nav-icon { fill:var(--nt-text-secondary); }
    .nav-item.active {
        background:var(--nt-action-light); color:var(--nt-action);
        font-weight:600;
    }
    .nav-item.active .nav-icon { fill:var(--nt-action); }

    .nav-icon { width:18px; height:18px; flex-shrink:0; fill:var(--nt-text-muted); transition:fill 150ms; }

    .nav-group {
        padding:20px 14px 6px; margin:0 10px; font-size:0.625rem; font-weight:700;
        color:var(--nt-text-faint); text-transform:uppercase; letter-spacing:0.08em;
    }

    .sidebar-bottom { border-top:1px solid var(--nt-border); padding:12px 10px 8px; }

    .sidebar-user {
        display:flex; align-items:center; gap:10px;
        padding:8px 10px; margin-bottom:4px;
    }
    .sidebar-avatar {
        width:28px; height:28px; border-radius:50%;
        background:var(--nt-navy); color:#fff;
        font-size:0.6875rem; font-weight:700;
        display:flex; align-items:center; justify-content:center;
        flex-shrink:0;
    }
    .sidebar-email {
        font-size:0.75rem; color:var(--nt-text-muted);
        overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
    }

    .sidebar-ver { text-align:center; font-size:0.625rem; color:var(--nt-border-hover); padding:4px 0; }

    .main-area { flex:1; display:flex; flex-direction:column; overflow:hidden; min-width:0; }

    .top-bar {
        height:48px; display:flex; align-items:center; padding:0 24px;
        border-bottom:1px solid var(--nt-border); background:var(--nt-surface); flex-shrink:0;
    }
    .breadcrumb {
        font-size:0.8125rem; color:var(--nt-text-muted); font-weight:500;
    }

    .content { flex:1; overflow-y:auto; }
    .content.padded { padding:24px; }
</style>

@code {
    private bool _restored;

    private static string AppVersion =>
        typeof(MainLayout).Assembly.GetName().Version?.ToString(3) ?? "0.0.0";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_restored)
        {
            _restored = true;
            await Auth.TryRestoreAsync();
            StateHasChanged();
        }
    }

    private string ActiveClass(string path) =>
        Nav.Uri.Contains(path, StringComparison.OrdinalIgnoreCase) ? "active" : "";

    private bool IsEditorPage => Nav.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

    private string GetBreadcrumb()
    {
        var uri = Nav.Uri;
        if (uri.Contains("/dashboard", StringComparison.OrdinalIgnoreCase)) return "Product Demos";
        if (uri.Contains("/analytics", StringComparison.OrdinalIgnoreCase)) return "Analytics";
        if (uri.Contains("/leads", StringComparison.OrdinalIgnoreCase)) return "Leads";
        if (uri.Contains("/forms", StringComparison.OrdinalIgnoreCase)) return "Forms";
        if (uri.Contains("/team", StringComparison.OrdinalIgnoreCase)) return "Team";
        if (uri.Contains("/settings", StringComparison.OrdinalIgnoreCase)) return "Settings";
        if (uri.Contains("/demos/", StringComparison.OrdinalIgnoreCase) && uri.Contains("/edit", StringComparison.OrdinalIgnoreCase)) return "Product Demos / Edit Demo";
        if (uri.Contains("/demos/", StringComparison.OrdinalIgnoreCase) && uri.Contains("/analytics", StringComparison.OrdinalIgnoreCase)) return "Product Demos / Analytics";
        return "NavTour";
    }
}
