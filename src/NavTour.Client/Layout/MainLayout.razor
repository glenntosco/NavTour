@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<RadzenLayout>
    <RadzenSidebar Responsive="false" class="@(sidebarExpanded ? "sidebar-open" : "sidebar-closed")" Style="background:var(--rz-primary-darker);overflow:hidden">
        <div style="padding:16px 12px 12px;display:flex;align-items:center;justify-content:center;overflow:hidden">
            <a href="/dashboard" style="display:flex;align-items:center;text-decoration:none">
                @if (sidebarExpanded)
                {
                    <img src="images/NavTourNoTag.webp" alt="NavTour" style="height:28px;width:auto;filter:brightness(0) invert(1)" />
                }
                else
                {
                    <RadzenIcon Icon="apps" Style="color:white;font-size:24px" />
                }
            </a>
        </div>

        <div style="flex:1;overflow-y:auto;padding-top:8px">
            <RadzenPanelMenu DisplayStyle="@SidebarDisplayStyle" ShowArrow="false" Style="width:100%">
                <RadzenPanelMenuItem Text="Product Demos" Icon="apps" Path="dashboard" Style="@NavItemStyle("/dashboard")" />
            </RadzenPanelMenu>

            @if (sidebarExpanded) { <div class="sidebar-category">Analyze</div> }
            <RadzenPanelMenu DisplayStyle="@SidebarDisplayStyle" ShowArrow="false" Style="width:100%">
                <RadzenPanelMenuItem Text="Analytics" Icon="bar_chart" Path="analytics" Style="@NavItemStyle("/analytics")" />
            </RadzenPanelMenu>

            @if (sidebarExpanded) { <div class="sidebar-category">Leads</div> }
            <RadzenPanelMenu DisplayStyle="@SidebarDisplayStyle" ShowArrow="false" Style="width:100%">
                <RadzenPanelMenuItem Text="Leads" Icon="people" Path="leads" Style="@NavItemStyle("/leads")" />
            </RadzenPanelMenu>

            @if (sidebarExpanded) { <div class="sidebar-category">Manage</div> }
            <RadzenPanelMenu DisplayStyle="@SidebarDisplayStyle" ShowArrow="false" Style="width:100%">
                <RadzenPanelMenuItem Text="Team" Icon="group" Path="team" Style="@NavItemStyle("/team")" />
                <RadzenPanelMenuItem Text="Settings" Icon="settings" Path="settings" Style="@NavItemStyle("/settings")" />
            </RadzenPanelMenu>
        </div>

        @if (Auth.IsAuthenticated)
        {
            <div style="padding:8px;border-top:1px solid rgba(255,255,255,0.1)">
                <RadzenButton Icon="logout" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Click="Logout"
                    Style="@($"width:100%;justify-content:{(sidebarExpanded ? "flex-start" : "center")};color:rgba(255,255,255,0.6)")"
                    Text="@(sidebarExpanded ? "Logout" : "")" />
            </div>
        }
        @if (sidebarExpanded)
        {
            <div style="padding:8px 20px 12px;text-align:center">
                <span style="font-size:11px;color:rgba(255,255,255,0.25)">v@(AppVersion)</span>
            </div>
        }
    </RadzenSidebar>
    <RadzenHeader Style="background:#fff;border-bottom:1px solid #E2E8F0">
        <RadzenStack Orientation="Radzen.Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="8px" Style="padding:0 16px;width:100%">
            <RadzenButton Icon="menu" Click="ToggleSidebar"
                ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Size="ButtonSize.Medium" Style="color:#1E3A5F" />
            <span style="font-size:0.875rem;color:#64748B">@GetBreadcrumb()</span>
        </RadzenStack>
    </RadzenHeader>
    <RadzenBody>
        <div class="@BodyCssClass">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

@code {
    private bool sidebarExpanded = true;
    private bool _restored;

    private MenuItemDisplayStyle SidebarDisplayStyle =>
        sidebarExpanded ? MenuItemDisplayStyle.IconAndText : MenuItemDisplayStyle.Icon;

    private static string AppVersion =>
        typeof(MainLayout).Assembly.GetName().Version?.ToString(3) ?? "0.0.0";

    private async Task ToggleSidebar()
    {
        sidebarExpanded = !sidebarExpanded;
        await JS.InvokeVoidAsync("sidebarToggle.toggle", sidebarExpanded);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_restored)
        {
            _restored = true;
            await Auth.TryRestoreAsync();
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    private string NavItemStyle(string path)
    {
        var isActive = Nav.Uri.Contains(path, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "color:white;background:rgba(255,255,255,0.12);border-radius:6px;margin:2px 12px;font-weight:600"
            : "color:rgba(255,255,255,0.7);border-radius:6px;margin:2px 12px";
    }

    private bool IsEditorPage => Nav.Uri.Contains("/edit", StringComparison.OrdinalIgnoreCase);

    private string BodyCssClass => IsEditorPage ? "" : "rz-p-4";

    private string GetBreadcrumb()
    {
        var uri = Nav.Uri;
        if (uri.Contains("/dashboard", StringComparison.OrdinalIgnoreCase)) return "Product Demos";
        if (uri.Contains("/analytics", StringComparison.OrdinalIgnoreCase)) return "Analytics";
        if (uri.Contains("/leads", StringComparison.OrdinalIgnoreCase)) return "Leads";
        if (uri.Contains("/team", StringComparison.OrdinalIgnoreCase)) return "Team";
        if (uri.Contains("/settings", StringComparison.OrdinalIgnoreCase)) return "Settings";
        if (uri.Contains("/demos/", StringComparison.OrdinalIgnoreCase) && uri.Contains("/edit", StringComparison.OrdinalIgnoreCase)) return "Product Demos / Edit Demo";
        if (uri.Contains("/demos/", StringComparison.OrdinalIgnoreCase) && uri.Contains("/analytics", StringComparison.OrdinalIgnoreCase)) return "Product Demos / Analytics";
        return "NavTour";
    }
}
