@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav

<RadzenLayout>
    <RadzenSidebar @bind-Expanded="@sidebarExpanded" Style="width:240px;background:var(--rz-primary-darker)">
        <div style="padding:20px;display:flex;align-items:center;gap:12px">
            <a href="/dashboard" style="display:flex;align-items:center;text-decoration:none">
                <img src="images/NavTourNoTag.webp" alt="NavTour" style="height:28px;width:auto;filter:brightness(0) invert(1)" />
            </a>
        </div>
        <RadzenPanelMenu Style="width:100%">
            <RadzenPanelMenuItem Text="Dashboard" Icon="dashboard" Path="dashboard" Style="@NavItemStyle("/dashboard")" />
            <RadzenPanelMenuItem Text="Leads" Icon="people" Path="leads" Style="@NavItemStyle("/leads")" />
        </RadzenPanelMenu>
        @if (Auth.IsAuthenticated)
        {
            <div style="position:absolute;bottom:0;left:0;right:0;padding:16px 20px;border-top:1px solid rgba(255,255,255,0.1)">
                <RadzenButton Text="Logout" Icon="logout" ButtonStyle="ButtonStyle.Light" Variant="Variant.Text" Click="Logout" Style="width:100%;justify-content:flex-start;color:rgba(255,255,255,0.6)" />
            </div>
        }
    </RadzenSidebar>
    <RadzenHeader>
        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0" Style="padding:0 16px">
            <RadzenSidebarToggle Click="@(() => sidebarExpanded = !sidebarExpanded)" />
        </RadzenStack>
    </RadzenHeader>
    <RadzenBody>
        <div class="rz-p-4" style="max-width:1200px">
            @Body
        </div>
    </RadzenBody>
</RadzenLayout>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />
<RadzenContextMenu />

@code {
    private bool sidebarExpanded = true;
    private bool _restored;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_restored)
        {
            _restored = true;
            await Auth.TryRestoreAsync();
            StateHasChanged();
        }
    }

    private async Task Logout()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }

    private string NavItemStyle(string path)
    {
        var isActive = Nav.Uri.Contains(path, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "color:white;background:rgba(255,255,255,0.1);border-radius:6px;margin:2px 8px"
            : "color:rgba(255,255,255,0.7);border-radius:6px;margin:2px 8px";
    }
}
