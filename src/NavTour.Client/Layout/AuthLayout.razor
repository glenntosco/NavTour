@inherits LayoutComponentBase

<div class="auth-page">
    <div class="auth-form-side">
        @Body
    </div>
    <div class="auth-brand-side">
        <div class="auth-brand-content">
            <img src="images/NavTourNoTag.webp" alt="NavTour" class="auth-brand-logo" />
            <p class="auth-brand-tagline">Interactive product demos that close deals faster</p>
        </div>
    </div>
</div>

<RadzenDialog />
<RadzenNotification />
<RadzenTooltip />

<style>
    .auth-page {
        min-height: 100vh;
        display: flex;
    }

    .auth-form-side {
        flex: 0 0 480px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 40px;
        background: #fff;
    }

    .auth-brand-side {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0B1929 0%, #1E3A5F 50%, #0A5FAD 100%);
        position: relative;
        overflow: hidden;
    }

    .auth-brand-side::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 30% 70%, rgba(67, 97, 238, 0.12) 0%, transparent 50%),
                    radial-gradient(circle at 70% 30%, rgba(255, 255, 255, 0.04) 0%, transparent 50%);
        pointer-events: none;
    }

    .auth-brand-content {
        position: relative;
        z-index: 1;
        text-align: center;
        padding: 48px;
    }

    .auth-brand-logo {
        width: 280px;
        height: auto;
        filter: brightness(0) invert(1);
        margin-bottom: 24px;
    }

    .auth-brand-tagline {
        color: rgba(255, 255, 255, 0.6);
        font-size: 1.125rem;
        font-weight: 400;
        line-height: 1.6;
        max-width: 320px;
        margin: 0 auto;
    }

    @@media (max-width: 900px) {
        .auth-page {
            flex-direction: column;
        }
        .auth-brand-side {
            display: none;
        }
        .auth-form-side {
            flex: 1;
            min-height: 100vh;
            background: #F4F8FC;
        }
    }
</style>
