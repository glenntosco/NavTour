{
  "manifest_version": 3,
  "name": "NavTour Capture",
  "version": "0.2.0",
  "description": "Capture web pages as static HTML snapshots for NavTour demos",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "http://localhost:5017/*",
    "http://127.0.0.1:5017/*",
    "https://localhost:7048/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
