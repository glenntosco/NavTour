{
  "manifest_version": 3,
  "name": "NavTour Capture",
  "version": "1.2.1",
  "description": "Capture your application and build interactive product demos in NavTour, we make interactive demo easy.",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "cookies"],
  "optional_host_permissions": [
    "https://navtour.cloud/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
